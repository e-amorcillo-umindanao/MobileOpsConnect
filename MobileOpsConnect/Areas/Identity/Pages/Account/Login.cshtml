@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    ViewData["HideLayout"] = true;
}

<div class="flex min-h-screen bg-white dark:bg-neutral-900 relative">
  <!-- Absolute Theme Toggle for Login Gateway -->
  <div class="absolute top-4 right-4 sm:top-6 sm:right-8 z-50">
      <button type="button" class="hs-dark-mode-active:hidden block hs-dark-mode p-2 inline-flex justify-center items-center gap-x-2 rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 transition-colors" data-hs-theme-click-value="dark" aria-label="Enable Dark Mode">
          <svg class="shrink-0 size-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
      </button>
      <button type="button" class="hs-dark-mode-active:block hidden hs-dark-mode p-2 inline-flex justify-center items-center gap-x-2 rounded-lg border border-transparent bg-neutral-800 text-amber-400 hover:bg-neutral-700 focus:outline-none focus:bg-neutral-700 transition-colors" data-hs-theme-click-value="light" aria-label="Enable Light Mode">
          <svg class="shrink-0 size-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
      </button>
  </div>

  <!-- Left Side: Branding & Marketing (Hidden on mobile) -->
  <div class="hidden lg:flex flex-col justify-between w-1/2 p-12 bg-gray-50 border-e border-gray-100 dark:bg-neutral-800 dark:border-neutral-700">
    <div>
      <div class="flex items-center gap-x-3">
        <img src="~/images/mobileops-logo.jpg" alt="MobileOps Connect" class="size-10 rounded-lg object-contain" />
        <span class="text-xl font-bold text-gray-800 dark:text-white">MobileOps</span>
      </div>
    </div>

    <div class="max-w-md">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
        Streamline your operations.
      </h1>
      <p class="text-lg text-gray-500 dark:text-neutral-400 leading-relaxed">
        MobileOps provides the tools you need to manage your fleet, track maintenance, and ensure compliance—all in one place.
      </p>
    </div>

    <div>
      <p class="text-sm text-gray-400 dark:text-neutral-500">
        &copy; 2026 MobileOps Inc. All rights reserved.
      </p>
    </div>
  </div>

  <!-- Right Side: Login Form -->
  <div class="flex-1 flex flex-col items-center justify-center p-6 sm:p-12">
    <div class="w-full max-w-[360px] mx-auto">
      <div class="mb-10 lg:hidden text-center">
         <div class="flex items-center justify-center gap-x-2 mb-8">
            <img src="~/images/mobileops-logo.jpg" alt="MobileOps Connect" class="size-8 rounded-lg object-contain" />
            <span class="text-lg font-bold text-gray-800 dark:text-white">MobileOps</span>
         </div>
      </div>

      <div class="mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">Log in to your account</h2>
        <p class="mt-2 text-sm text-gray-500 dark:text-neutral-400">
          Enter your email and password to access your dashboard.
        </p>
      </div>

      <form id="account" method="post" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-xs text-red-600 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

        <!-- Email -->
        <div>
          <label asp-for="Input.Email" class="block text-sm font-medium mb-2 dark:text-white">Email address</label>
          <input asp-for="Input.Email" class="py-2.5 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-gray-900 focus:ring-gray-900 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" required placeholder="you@example.com">
          <span asp-validation-for="Input.Email" class="text-xs text-red-600 mt-2 block"></span>
        </div>

        <!-- Password -->
        <div>
          <div class="mb-2">
            <label asp-for="Input.Password" class="block text-sm font-medium dark:text-white">Password</label>
          </div>
          <div class="relative">
            <input asp-for="Input.Password" type="password" id="loginPasswordField" class="py-2.5 px-4 pe-11 block w-full border-gray-200 rounded-lg text-sm focus:border-gray-900 focus:ring-gray-900 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" required placeholder="••••••••">
            <button type="button" id="toggleLoginPassword" class="absolute inset-y-0 end-0 flex items-center z-20 px-3 cursor-pointer text-gray-400 rounded-e-md hover:text-gray-900 dark:hover:text-white transition-colors">
              <i class="bi bi-eye" id="toggleLoginIcon"></i>
            </button>
          </div>
          <span asp-validation-for="Input.Password" class="text-xs text-red-600 mt-2 block"></span>
        </div>

        <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-gray-900 text-white hover:bg-gray-800 focus:outline-none focus:bg-gray-800 disabled:opacity-50 disabled:pointer-events-none transition-all shadow-sm">
          Continue with Email <i class="bi bi-chevron-right text-xs"></i>
        </button>
      </form>


    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        const toggle = document.getElementById('toggleLoginPassword');
        const field  = document.getElementById('loginPasswordField');
        const icon   = document.getElementById('toggleLoginIcon');
        if (!toggle || !field || !icon) return;
        toggle.addEventListener('click', function () {
            const isPassword = field.type === 'password';
            field.type = isPassword ? 'text' : 'password';
            icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
    })();
    </script>
}