@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    ViewData["HideLayout"] = true;
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-neutral-900">
  <main class="w-full max-w-md mx-auto p-6">
    <div class="mt-7 bg-white border border-gray-200 rounded-xl shadow-sm dark:bg-neutral-900 dark:border-neutral-700">
      <div class="p-4 sm:p-7">
        <div class="text-center">
          <img src="~/images/mobileops-logo.jpg" alt="MobileOps Connect Logo" class="mx-auto h-16 w-auto mb-4 rounded-lg object-contain" />
          <h1 class="block text-2xl font-bold text-gray-800 dark:text-white">Log in to MobileOps</h1>
          <p class="mt-2 text-sm text-gray-600 dark:text-neutral-400">
            Don't have an account?
            <a class="text-blue-600 decoration-2 hover:underline font-medium dark:text-blue-500" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
              Sign up here
            </a>
          </p>
        </div>

        <div class="mt-5">
          <!-- Form -->
          <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mt-2 mb-4 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

            <div class="grid gap-y-4">
              <!-- Form Group -->
              <div>
                <label asp-for="Input.Email" class="block text-sm mb-2 dark:text-white">Email address</label>
                <div class="relative">
                  <input asp-for="Input.Email" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" required aria-describedby="email-error" placeholder="you@example.com">
                </div>
                <span asp-validation-for="Input.Email" class="text-xs text-red-600 mt-2 block" id="email-error"></span>
              </div>
              <!-- End Form Group -->

              <!-- Form Group -->
              <div>
                <div class="flex justify-between items-center">
                  <label asp-for="Input.Password" class="block text-sm mb-2 dark:text-white">Password</label>
                  <a class="text-sm text-blue-600 decoration-2 hover:underline font-medium dark:text-blue-500" asp-page="./ForgotPassword">Forgot password?</a>
                </div>
                <div class="relative">
                  <input asp-for="Input.Password" type="password" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" required aria-describedby="password-error" placeholder="••••••••">
                </div>
                <span asp-validation-for="Input.Password" class="text-xs text-red-600 mt-2 block" id="password-error"></span>
              </div>
              <!-- End Form Group -->

              <!-- Checkbox -->
              <div class="flex items-center">
                <div class="flex">
                  <input asp-for="Input.RememberMe" id="remember-me" class="shrink-0 mt-0.5 border-gray-200 rounded text-blue-600 focus:ring-blue-500 dark:bg-neutral-800 dark:border-neutral-700 dark:checked:bg-blue-500 dark:checked:border-blue-500 dark:focus:ring-offset-gray-800">
                </div>
                <div class="ms-3">
                  <label for="remember-me" class="text-sm dark:text-white">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                </div>
              </div>
              <!-- End Checkbox -->

              <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 disabled:pointer-events-none">
                Continue with Email
              </button>
            </div>
          </form>
          <!-- End Form -->
        </div>
      </div>
    </div>
  </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}