@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200 flex items-center gap-x-2"><i class="bi bi-trash3-fill text-red-500"></i> Delete Personal Data</h2>
    <div class="grow border-t border-gray-100 dark:border-neutral-800"></div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
    <div class="p-6">
        <div class="text-center mb-6">
            <span class="inline-flex justify-center items-center size-[64px] rounded-2xl bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400 mx-auto mb-4 tracking-tight"><i class="bi bi-exclamation-triangle text-2xl"></i></span>
            <h3 class="text-xl font-bold text-red-600 dark:text-red-500 mb-2">Permanently Delete Account</h3>
            <p class="text-sm text-gray-500 dark:text-neutral-500 max-w-sm mx-auto">This action is <strong>irreversible</strong>. Your account and all associated operational data will be permanently purged.</p>
        </div>

        <!-- Warning -->
        <div class="bg-red-50 border border-red-100 rounded-xl p-4 mb-6 flex items-start gap-4 dark:bg-red-900/10 dark:border-red-900/20">
            <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-400 shrink-0 shadow-sm"><i class="bi bi-exclamation-triangle-fill"></i></span>
            <div>
                <p class="text-sm font-bold text-gray-800 dark:text-neutral-200 mb-1">Final Warning</p>
                <p class="text-[11px] text-gray-500 dark:text-neutral-500 leading-relaxed font-bold uppercase tracking-wider">Account closure will remove all data and cannot be undone.</p>
            </div>
        </div>

        <form id="delete-user" method="post">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mt-2 mb-4 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

            @if (Model.RequirePassword)
            {
                <div class="flex items-center gap-x-3 mb-3">
                    <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400"><i class="bi bi-lock-fill"></i></span>
                    <div><h3 class="text-sm font-bold text-gray-800 dark:text-neutral-200 mb-0">Confirm Password</h3><span class="text-xs text-gray-500 dark:text-neutral-500">Enter your password to authorize deletion</span></div>
                </div>
                <div class="mb-6">
                    <div class="flex">
                        <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-gray-50 text-sm text-gray-400 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-500"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="Input.Password" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-red-500 focus:ring-red-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300 dark:placeholder-neutral-500" autocomplete="current-password" placeholder="Enter your password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-xs text-red-600 mt-2 block"></span>
                </div>
            }

            <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700 transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                <i class="bi bi-trash3"></i> Delete My Account &amp; Data
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
