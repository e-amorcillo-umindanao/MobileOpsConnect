@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-trash3-fill text-red-500"></i> Delete Personal Data</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="flex flex-col bg-white border shadow-sm rounded-xl">
    <div class="p-6">
        <div class="text-center mb-5">
            <span class="inline-flex justify-center items-center size-[64px] rounded-xl bg-red-100 text-red-800 mx-auto mb-4"><i class="bi bi-exclamation-triangle text-2xl"></i></span>
            <h3 class="text-lg font-bold text-red-600 mb-2">Permanently Delete Account</h3>
            <p class="text-sm text-gray-500 mb-0">This action is <strong>irreversible</strong>. Your account and all associated data will be permanently deleted.</p>
        </div>

        <!-- Warning -->
        <div class="bg-red-50 border border-red-100 rounded-lg p-4 mb-5 flex items-start gap-3">
            <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800 shrink-0"><i class="bi bi-exclamation-triangle-fill"></i></span>
            <div>
                <p class="text-sm font-semibold text-gray-800 mb-1">Warning</p>
                <p class="text-xs text-gray-500 mb-0">Deleting your data will permanently remove your account and cannot be undone. Make sure to download your data first if needed.</p>
            </div>
        </div>

        <form id="delete-user" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4" role="alert"></div>

            @if (Model.RequirePassword)
            {
                <div class="flex items-center gap-x-3 mb-3">
                    <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-lock-fill"></i></span>
                    <div><h3 class="text-sm font-bold text-gray-800 mb-0">Confirm Password</h3><span class="text-xs text-gray-500">Enter your password to confirm deletion</span></div>
                </div>
                <div class="mb-5">
                    <div class="flex">
                        <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-red-50 text-sm text-gray-500"><i class="bi bi-key-fill text-red-600"></i></span>
                        <input asp-for="Input.Password" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-blue-500 focus:ring-blue-500" autocomplete="current-password" placeholder="Enter your password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs"></span>
                </div>
            }

            <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700">
                <i class="bi bi-trash3"></i> Delete Account & Data
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
