@page
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-shield-lock-fill text-green-500"></i> Two-Factor Authentication</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="flex flex-col bg-white border shadow-sm rounded-xl">
    <div class="p-6">
        <div class="text-center p-6">
            <span class="inline-flex justify-center items-center size-[64px] rounded-xl bg-green-100 text-green-800 mx-auto mb-4"><i class="bi bi-shield-lock text-2xl"></i></span>
            <h3 class="text-lg font-bold text-gray-800 mb-2">Two-Factor Authentication</h3>
            <p class="text-sm text-gray-500 mb-5">
                Two-factor authentication adds an extra layer of security to your account.
                This feature requires an authenticator app to generate verification codes.
            </p>

            @if (Model.Is2faEnabled)
            {
                <div class="inline-flex items-center gap-2 py-2 px-4 rounded-lg bg-green-50 border border-green-200 mb-5">
                    <i class="bi bi-check-circle-fill text-green-600"></i>
                    <span class="text-sm font-semibold text-green-700">2FA is currently enabled</span>
                </div>
            }
            else
            {
                <div class="inline-flex items-center gap-2 py-2 px-4 rounded-lg bg-amber-50 border border-amber-200 mb-5">
                    <i class="bi bi-exclamation-triangle-fill text-amber-600"></i>
                    <span class="text-sm font-semibold text-amber-700">2FA is not yet configured</span>
                </div>
            }
        </div>

        <!-- Info Notice -->
        <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-4 flex items-start gap-3">
            <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800 shrink-0"><i class="bi bi-info-circle"></i></span>
            <div>
                <p class="text-sm font-semibold text-gray-800 mb-1">Note</p>
                <p class="text-xs text-gray-500 mb-0">
                    Two-factor authentication configuration is managed by your system administrator.
                    Contact your admin if you need to enable or disable this feature.
                </p>
            </div>
        </div>
    </div>
</div>
