@model string

@if (!String.IsNullOrEmpty(Model))
{
    var isError = Model.StartsWith("Error");
    <div class="@(isError ? "bg-red-50 border border-red-200 shadow-sm" : "bg-green-50 border border-green-200 shadow-sm") rounded-xl p-4 flex items-center gap-3 mb-6 animate-in fade-in slide-in-from-top-2 duration-300" role="alert">
        <i class="bi @(isError ? "bi-exclamation-circle-fill text-red-600" : "bi-check-circle-fill text-green-600") text-lg"></i>
        <span class="text-sm font-semibold @(isError ? "text-red-800" : "text-green-800")">@Model</span>
        <button type="button" class="ms-auto inline-flex justify-center items-center size-8 rounded-lg text-gray-400 hover:bg-gray-200/50 hover:text-gray-600 focus:outline-none transition-all" onclick="this.closest('[role=alert]').remove()" aria-label="Close">
            <i class="bi bi-x-lg text-xs"></i>
        </button>
    </div>
}
