@model string

@if (!String.IsNullOrEmpty(Model))
{
    var isError = Model.StartsWith("Error");
    <div class="@(isError ? "bg-red-50 border border-red-200" : "bg-green-50 border border-green-200") rounded-lg p-4 flex items-center gap-2 mb-6" role="alert">
        <i class="bi @(isError ? "bi-exclamation-circle-fill text-red-600" : "bi-check-circle-fill text-green-600")"></i>
        <span class="text-sm font-semibold @(isError ? "text-red-800" : "text-green-800")">@Model</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close" style="font-size:0.65rem;"></button>
    </div>
}
