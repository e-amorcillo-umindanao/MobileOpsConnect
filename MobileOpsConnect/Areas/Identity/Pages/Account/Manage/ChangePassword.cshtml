@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200 flex items-center gap-x-2"><i class="bi bi-key-fill text-amber-500"></i> Change Password</h2>
    <div class="grow border-t border-gray-100 dark:border-neutral-800"></div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
    <div class="p-6">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mt-2 mb-4 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

            <!-- Current Password -->
            <div class="flex items-center gap-x-3 mb-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400"><i class="bi bi-lock-fill"></i></span>
                <div><h3 class="text-sm font-bold text-gray-800 dark:text-neutral-200 mb-0">Current Password</h3><span class="text-xs text-gray-500 dark:text-neutral-500">Verify your current identity</span></div>
            </div>
            <div class="mb-5">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-gray-50 text-sm text-gray-400 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-500"><i class="bi bi-shield-lock"></i></span>
                    <input asp-for="Input.OldPassword" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-gray-500 focus:ring-gray-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300 dark:placeholder-neutral-500" autocomplete="current-password" placeholder="Enter current password" />
                </div>
                <span asp-validation-for="Input.OldPassword" class="text-xs text-red-600 mt-2 block"></span>
            </div>

            <hr class="my-6 border-gray-100 dark:border-neutral-800" />

            <!-- New Password -->
            <div class="flex items-center gap-x-3 mb-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-green-50 text-green-600 dark:bg-green-900/30 dark:text-green-400"><i class="bi bi-key-fill"></i></span>
                <div><h3 class="text-sm font-bold text-gray-800 dark:text-neutral-200 mb-0">New Password</h3><span class="text-xs text-gray-500 dark:text-neutral-500">Choose a strong, unique password</span></div>
            </div>
            <div class="mb-5">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-gray-50 text-sm text-gray-400 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-500"><i class="bi bi-key"></i></span>
                    <input asp-for="Input.NewPassword" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-gray-500 focus:ring-gray-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300 dark:placeholder-neutral-500" autocomplete="new-password" placeholder="Enter new password" />
                </div>
                <span asp-validation-for="Input.NewPassword" class="text-xs text-red-600 mt-2 block"></span>
            </div>

            <!-- Confirm Password -->
            <div class="mb-6">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-gray-50 text-sm text-gray-400 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-500"><i class="bi bi-check2-circle"></i></span>
                    <input asp-for="Input.ConfirmPassword" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-gray-500 focus:ring-gray-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300 dark:placeholder-neutral-500" autocomplete="new-password" placeholder="Confirm new password" />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-600 mt-2 block"></span>
            </div>

            <!-- Policy Notice -->
            <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4 mb-6 flex items-start gap-3 dark:bg-indigo-900/10 dark:border-indigo-900/30">
                <span class="inline-flex justify-center items-center size-[36px] rounded-lg bg-indigo-100 text-indigo-600 dark:bg-indigo-900/40 dark:text-indigo-400 shrink-0"><i class="bi bi-shield-check"></i></span>
                <div>
                    <p class="text-sm font-bold text-gray-800 dark:text-neutral-200 mb-0.5">Password Requirements</p>
                    <p class="text-[11px] text-gray-500 dark:text-neutral-500 leading-relaxed uppercase tracking-wider font-bold">Min. 6 chars &bull; Upper &bull; Lower &bull; Digit &bull; Symbol</p>
                </div>
            </div>

            <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900">
                <i class="bi bi-shield-lock"></i> Update Account Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
