@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="moc-section-header">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-key-fill text-amber mr-1"></i> Change Password
    </h5>
    <hr />
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm">
    <div class="p-6 p-6 p-md-5">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-6" role="alert"></div>

            <!-- Current Password -->
            <div class="flex items-center mb-6">
                <div class="moc-icon-box bg-red-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                    <i class="bi bi-lock-fill text-red"></i>
                </div>
                <div>
                    <h6 class="font-bold mb-0 letter-tight">Current Password</h6>
                    <span class="text-moc-text-muted text-xs">Verify your identity</span>
                </div>
            </div>
            <div class="mb-6">
                <div class="flex w-full items-stretch">
                    <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0" style="background:rgba(239,68,68,0.06);">
                        <i class="bi bi-shield-lock text-red"></i>
                    </span>
                    <input asp-for="Input.OldPassword" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                           autocomplete="current-password" placeholder="Enter current password"
                           style="padding:0.875rem 1rem;font-size:1rem;" />
                </div>
                <span asp-validation-for="Input.OldPassword" class="text-red-500 text-xs"></span>
            </div>

            <hr class="my-6 opacity-10" />

            <!-- New Password -->
            <div class="flex items-center mb-6">
                <div class="moc-icon-box bg-green-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                    <i class="bi bi-key-fill text-green"></i>
                </div>
                <div>
                    <h6 class="font-bold mb-0 letter-tight">New Password</h6>
                    <span class="text-moc-text-muted text-xs">Choose a strong password</span>
                </div>
            </div>
            <div class="mb-6">
                <div class="flex w-full items-stretch">
                    <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0" style="background:rgba(34,197,94,0.06);">
                        <i class="bi bi-key text-green"></i>
                    </span>
                    <input asp-for="Input.NewPassword" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                           autocomplete="new-password" placeholder="Enter new password"
                           style="padding:0.875rem 1rem;font-size:1rem;" />
                </div>
                <span asp-validation-for="Input.NewPassword" class="text-red-500 text-xs"></span>
            </div>

            <!-- Confirm Password -->
            <div class="mb-6">
                <div class="flex w-full items-stretch">
                    <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0" style="background:rgba(34,197,94,0.06);">
                        <i class="bi bi-check2-circle text-green"></i>
                    </span>
                    <input asp-for="Input.ConfirmPassword" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                           autocomplete="new-password" placeholder="Confirm new password"
                           style="padding:0.875rem 1rem;font-size:1rem;" />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs"></span>
            </div>

            <!-- Policy Notice -->
            <div class="rounded-3 p-6 mb-6 flex items-start gap-6"
                 style="background:rgba(99,102,241,0.04);border:1px solid rgba(99,102,241,0.1);">
                <div class="moc-icon-box bg-indigo-50 rounded-3" style="width:40px;height:40px;min-width:40px;">
                    <i class="bi bi-shield-check text-indigo"></i>
                </div>
                <div>
                    <p class="font-semibold text-sm mb-1 letter-tight">Password Requirements</p>
                    <p class="text-moc-text-muted text-xs mb-0">
                        Passwords must be at least 6 characters long and contain at least one uppercase letter,
                        one lowercase letter, one digit, and one special character.
                    </p>
                </div>
            </div>

            <div class="grid">
                <button type="submit" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-4 py-2 text-base py-6">
                    <i class="bi bi-check-circle mr-1"></i> Update Password
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


