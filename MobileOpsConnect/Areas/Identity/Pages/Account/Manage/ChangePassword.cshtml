@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-key-fill text-amber-500"></i> Change Password</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="flex flex-col bg-white border shadow-sm rounded-xl">
    <div class="p-6">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4" role="alert"></div>

            <!-- Current Password -->
            <div class="flex items-center gap-x-3 mb-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-lock-fill"></i></span>
                <div><h3 class="text-sm font-bold text-gray-800 mb-0">Current Password</h3><span class="text-xs text-gray-500">Verify your identity</span></div>
            </div>
            <div class="mb-5">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-red-50 text-sm text-gray-500"><i class="bi bi-shield-lock text-red-600"></i></span>
                    <input asp-for="Input.OldPassword" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-blue-500 focus:ring-blue-500" autocomplete="current-password" placeholder="Enter current password" />
                </div>
                <span asp-validation-for="Input.OldPassword" class="text-red-500 text-xs"></span>
            </div>

            <hr class="my-5 border-gray-100" />

            <!-- New Password -->
            <div class="flex items-center gap-x-3 mb-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-green-100 text-green-800"><i class="bi bi-key-fill"></i></span>
                <div><h3 class="text-sm font-bold text-gray-800 mb-0">New Password</h3><span class="text-xs text-gray-500">Choose a strong password</span></div>
            </div>
            <div class="mb-5">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-green-50 text-sm text-gray-500"><i class="bi bi-key text-green-600"></i></span>
                    <input asp-for="Input.NewPassword" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-blue-500 focus:ring-blue-500" autocomplete="new-password" placeholder="Enter new password" />
                </div>
                <span asp-validation-for="Input.NewPassword" class="text-red-500 text-xs"></span>
            </div>

            <!-- Confirm Password -->
            <div class="mb-5">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-green-50 text-sm text-gray-500"><i class="bi bi-check2-circle text-green-600"></i></span>
                    <input asp-for="Input.ConfirmPassword" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-blue-500 focus:ring-blue-500" autocomplete="new-password" placeholder="Confirm new password" />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs"></span>
            </div>

            <!-- Policy Notice -->
            <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-4 mb-5 flex items-start gap-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800 shrink-0"><i class="bi bi-shield-check"></i></span>
                <div>
                    <p class="text-sm font-semibold text-gray-800 mb-1">Password Requirements</p>
                    <p class="text-xs text-gray-500 mb-0">Passwords must be at least 6 characters long and contain at least one uppercase letter, one lowercase letter, one digit, and one special character.</p>
                </div>
            </div>

            <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                <i class="bi bi-check-circle"></i> Update Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
