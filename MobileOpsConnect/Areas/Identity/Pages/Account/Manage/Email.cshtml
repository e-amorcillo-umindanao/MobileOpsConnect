@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<div class="moc-section-header">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-envelope-fill text-cyan mr-1"></i> Manage Email
    </h5>
    <hr />
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm">
    <div class="p-6 p-6 p-md-5">
        <form id="email-form" method="post">
            <div asp-validation-summary="All" class="text-red-500 mb-6" role="alert"></div>

            <!-- Current Email -->
            <div class="flex items-center mb-6">
                <div class="moc-icon-box bg-cyan-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                    <i class="bi bi-envelope-check-fill text-cyan"></i>
                </div>
                <div>
                    <h6 class="font-bold mb-0 letter-tight">Current Email</h6>
                    <span class="text-moc-text-muted text-xs">Your registered email address</span>
                </div>
            </div>
            <div class="mb-6 flex items-center gap-2">
                <input asp-for="Email" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 form-control-lg rounded-3" disabled
                       style="padding:0.875rem 1rem;font-size:1rem;background:var(--moc-surface);" />
                @if (Model.IsEmailConfirmed)
                {
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green rounded-pill px-6 py-2">
                        <i class="bi bi-check-circle-fill mr-1"></i> Verified
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber rounded-pill px-6 py-2">
                        <i class="bi bi-exclamation-circle-fill mr-1"></i> Unverified
                    </span>
                }
            </div>

            <hr class="my-6 opacity-10" />

            <!-- New Email -->
            <div class="flex items-center mb-6">
                <div class="moc-icon-box bg-indigo-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                    <i class="bi bi-pencil-fill text-indigo"></i>
                </div>
                <div>
                    <h6 class="font-bold mb-0 letter-tight">New Email</h6>
                    <span class="text-moc-text-muted text-xs">Enter a new email address to update</span>
                </div>
            </div>
            <div class="mb-6">
                <div class="input-group input-group-lg">
                    <span class="input-group-text rounded-start-3 border-end-0" style="background:rgba(99,102,241,0.06);">
                        <i class="bi bi-at text-indigo"></i>
                    </span>
                    <input asp-for="Input.NewEmail" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                           placeholder="Enter new email address"
                           style="padding:0.875rem 1rem;font-size:1rem;" />
                </div>
                <span asp-validation-for="Input.NewEmail" class="text-red-500 text-xs"></span>
            </div>

            <div class="d-grid">
                <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-4 py-2 text-base py-6">
                    <i class="bi bi-check-circle mr-1"></i> Change Email
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

