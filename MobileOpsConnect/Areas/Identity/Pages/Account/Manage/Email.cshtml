@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-envelope-fill text-cyan-500"></i> Manage Email</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="flex flex-col bg-white border shadow-sm rounded-xl">
    <div class="p-6">
        <form id="email-form" method="post">
            <div asp-validation-summary="All" class="text-red-500 mb-4" role="alert"></div>

            <!-- Current Email -->
            <div class="flex items-center gap-x-3 mb-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-cyan-100 text-cyan-800"><i class="bi bi-envelope-check-fill"></i></span>
                <div><h3 class="text-sm font-bold text-gray-800 mb-0">Current Email</h3><span class="text-xs text-gray-500">Your registered email address</span></div>
            </div>
            <div class="mb-5 flex items-center gap-2">
                <input asp-for="Email" class="py-3 px-4 block w-full bg-gray-100 border-gray-200 rounded-lg text-sm" disabled />
                @if (Model.IsEmailConfirmed)
                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><i class="bi bi-check-circle-fill"></i> Verified</span> }
                else
                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800"><i class="bi bi-exclamation-circle-fill"></i> Unverified</span> }
            </div>

            <hr class="my-5 border-gray-100" />

            <!-- New Email -->
            <div class="flex items-center gap-x-3 mb-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-pencil-fill"></i></span>
                <div><h3 class="text-sm font-bold text-gray-800 mb-0">New Email</h3><span class="text-xs text-gray-500">Enter a new email address to update</span></div>
            </div>
            <div class="mb-5">
                <div class="flex">
                    <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-indigo-50 text-sm text-gray-500"><i class="bi bi-at text-indigo-600"></i></span>
                    <input asp-for="Input.NewEmail" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Enter new email address" />
                </div>
                <span asp-validation-for="Input.NewEmail" class="text-red-500 text-xs"></span>
            </div>

            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                <i class="bi bi-check-circle"></i> Change Email
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
