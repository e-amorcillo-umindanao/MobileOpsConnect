@page
@model DownloadPersonalDataModel
@{
    ViewData["Title"] = "Download Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="moc-section-header">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-download text-indigo mr-1"></i> Download Your Data
    </h5>
    <hr />
</div>

<div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm">
    <div class="p-6 p-6 p-md-5 text-center">
        <div class="moc-icon-box-lg bg-indigo-50 rounded-3 mx-auto mb-6" style="width:64px;height:64px;">
            <i class="bi bi-file-earmark-arrow-down text-indigo fs-2"></i>
        </div>
        <h5 class="font-bold mb-2 letter-tight">Your Data is Ready</h5>
        <p class="text-moc-text-muted text-sm mb-6">
            Click the button below to download a JSON file containing your personal data.
        </p>

        <form method="post">
            <button class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-4 py-2 text-base px-8 py-6" type="submit">
                <i class="bi bi-cloud-download mr-2"></i> Download Data
            </button>
        </form>
    </div>
</div>

