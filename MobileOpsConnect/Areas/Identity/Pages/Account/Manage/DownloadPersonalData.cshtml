@page
@model DownloadPersonalDataModel
@{
    ViewData["Title"] = "Download Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-download text-indigo-500"></i> Download Your Data</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<div class="flex flex-col bg-white border shadow-sm rounded-xl">
    <div class="p-6 text-center">
        <span class="inline-flex justify-center items-center size-[64px] rounded-xl bg-indigo-100 text-indigo-800 mx-auto mb-4"><i class="bi bi-file-earmark-arrow-down text-2xl"></i></span>
        <h3 class="text-lg font-bold text-gray-800 mb-2">Your Data is Ready</h3>
        <p class="text-sm text-gray-500 mb-5">Click the button below to download a JSON file containing your personal data.</p>
        <form method="post">
            <button class="py-3 px-6 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700" type="submit">
                <i class="bi bi-cloud-download"></i> Download Data
            </button>
        </form>
    </div>
</div>
