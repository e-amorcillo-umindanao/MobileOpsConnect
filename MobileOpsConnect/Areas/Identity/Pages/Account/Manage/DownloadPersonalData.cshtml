@page
@model DownloadPersonalDataModel
@{
    ViewData["Title"] = "Download Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200 flex items-center gap-x-2"><i class="bi bi-download text-indigo-500"></i> Download Your Data</h2>
    <div class="grow border-t border-gray-100 dark:border-neutral-800"></div>
</div>

<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
    <div class="p-6 text-center">
        <span class="inline-flex justify-center items-center size-[64px] rounded-2xl bg-indigo-50 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400 mx-auto mb-4 animate-bounce tracking-tight"><i class="bi bi-file-earmark-arrow-down text-2xl"></i></span>
        <h3 class="text-xl font-bold text-gray-800 dark:text-neutral-200 mb-2">Your Data is Ready</h3>
        <p class="text-sm text-gray-500 dark:text-neutral-500 max-w-sm mx-auto mb-6">Click the button below to generate and download a secure JSON file containing all personal data associated with your account.</p>
        <form method="post">
            <button class="w-full py-3 px-6 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900" type="submit">
                <i class="bi bi-cloud-download"></i> Start Secure Download
            </button>
        </form>
    </div>
</div>
