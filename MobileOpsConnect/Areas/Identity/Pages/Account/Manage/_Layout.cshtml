@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout is string parentLayoutStr)
    {
        Layout = parentLayoutStr;
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> Account Settings
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-person-gear"></i> Profile Management
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Manage Account</h1>
        <p class="text-blue-100 text-lg">Update your profile, security settings &amp; personal information</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-person-gear text-9xl text-white"></i>
    </div>
</div>

<div class="grid md:grid-cols-3 gap-6">
    <div>
        <partial name="_ManageNav" />
    </div>
    <div class="md:col-span-2">
        @RenderBody()
    </div>
</div>

@if (IsSectionDefined("Scripts"))
{
    @RenderSection("Scripts")
}
