@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout is string parentLayoutStr)
    {
        Layout = parentLayoutStr;
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-circle-fill text-green-500 mr-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                Account Settings
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-person-gear mr-1"></i> Profile Management
            </span>
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">Manage Account</h1>
        <p class="lead mb-0 opacity-75">
            Update your profile, security settings &amp; personal information
        </p>
    </div>
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-person-gear"></i>
    </div>
</div>

<div class="flex flex-wrap -mx-3 g-4">
    <div class="w-full md:w-1/3 px-6 col-lg-3 anim-fade-in">
        <partial name="_ManageNav" />
    </div>
    <div class="w-full md:w-2/3 px-6 col-lg-9 anim-fade-in anim-delay-1">
        @RenderBody()
    </div>
</div>

@if (IsSectionDefined("Scripts"))
{
    @RenderSection("Scripts")
}

