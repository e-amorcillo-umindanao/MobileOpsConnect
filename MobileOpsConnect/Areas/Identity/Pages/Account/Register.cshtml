@page
@model RegisterModel

@{
    ViewData["Title"] = "Sign up";
    ViewData["HideLayout"] = true;
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-neutral-900">
  <main class="w-full max-w-md mx-auto p-6">
    <div class="mt-7 bg-white border border-gray-200 rounded-xl shadow-sm dark:bg-neutral-900 dark:border-neutral-700">
      <div class="p-4 sm:p-7">
        <div class="text-center">
          <img src="~/images/mobileops-logo.jpg" alt="MobileOps Connect Logo" class="mx-auto h-16 w-auto mb-4 rounded-lg object-contain" />
          <h1 class="block text-2xl font-bold text-gray-800 dark:text-white">Create your account</h1>
          <p class="mt-2 text-sm text-gray-600 dark:text-neutral-400">
            Already have an account?
            <a class="text-blue-600 decoration-2 hover:underline font-medium dark:text-blue-500" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">
              Sign in here
            </a>
          </p>
        </div>

        <div class="mt-5">
          <!-- Form -->
          <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mt-2 mb-4 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

            <div class="grid gap-y-4">
              <!-- Email -->
              <div>
                <label asp-for="Input.Email" class="block text-sm mb-2 dark:text-white">Email address</label>
                <div class="relative">
                  <input asp-for="Input.Email"
                         class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600"
                         autocomplete="username"
                         required
                         aria-required="true"
                         aria-describedby="email-error"
                         placeholder="you@example.com">
                </div>
                <span asp-validation-for="Input.Email" class="text-xs text-red-600 mt-2 block" id="email-error"></span>
              </div>
              <!-- End Email -->

              <!-- Password -->
              <div>
                <label asp-for="Input.Password" class="block text-sm mb-2 dark:text-white">Password</label>
                <div class="relative">
                  <input asp-for="Input.Password"
                         class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600"
                         autocomplete="new-password"
                         required
                         aria-required="true"
                         aria-describedby="password-error"
                         placeholder="••••••••">
                </div>
                <span asp-validation-for="Input.Password" class="text-xs text-red-600 mt-2 block" id="password-error"></span>
              </div>
              <!-- End Password -->

              <!-- Confirm Password -->
              <div>
                <label asp-for="Input.ConfirmPassword" class="block text-sm mb-2 dark:text-white">Confirm password</label>
                <div class="relative">
                  <input asp-for="Input.ConfirmPassword"
                         class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600"
                         autocomplete="new-password"
                         required
                         aria-required="true"
                         aria-describedby="confirm-password-error"
                         placeholder="••••••••">
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-600 mt-2 block" id="confirm-password-error"></span>
              </div>
              <!-- End Confirm Password -->

              <!-- Password Requirements -->
              <div class="bg-blue-50 border border-blue-100 rounded-lg p-3 dark:bg-blue-800/10 dark:border-blue-900">
                <p class="text-xs font-medium text-gray-600 dark:text-neutral-400 mb-1.5">Password requirements</p>
                <ul class="space-y-1 text-xs text-gray-500 dark:text-neutral-500 list-disc list-inside">
                  <li>At least 6 characters long</li>
                  <li>At least one uppercase letter (A–Z)</li>
                  <li>At least one lowercase letter (a–z)</li>
                  <li>At least one digit (0–9)</li>
                  <li>At least one special character (!@@#$%^&*)</li>
                </ul>
              </div>
              <!-- End Password Requirements -->

              <button id="registerSubmit" type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 disabled:pointer-events-none">
                Create Account
              </button>
            </div>
          </form>
          <!-- End Form -->

          <!-- External Logins -->
          @if ((Model.ExternalLogins?.Count ?? 0) > 0)
          {
            <div class="py-3 flex items-center text-xs text-gray-400 uppercase before:flex-1 before:border-t before:border-gray-200 before:me-6 after:flex-1 after:border-t after:border-gray-200 after:ms-6 dark:text-neutral-500 dark:before:border-neutral-700 dark:after:border-neutral-700">
              Or sign up with
            </div>

            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
              <div class="grid gap-2">
                @foreach (var provider in Model.ExternalLogins!)
                {
                  <button type="submit"
                          class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800"
                          name="provider" value="@provider.Name"
                          title="Sign up using your @provider.DisplayName account">
                    @provider.DisplayName
                  </button>
                }
              </div>
            </form>
          }
        </div>
      </div>
    </div>
  </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}