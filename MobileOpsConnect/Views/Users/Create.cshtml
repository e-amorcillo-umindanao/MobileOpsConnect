@{
    ViewData["Title"] = "Create New User";
    bool isSuperAdmin = ViewBag.IsSuperAdmin ?? false;
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> New Account
            </span>
            @if (isSuperAdmin)
            {
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-500/30 text-white">
                    <i class="bi bi-shield-lock-fill"></i> Alpha Privilege
                </span>
            }
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Create New User</h1>
        <p class="text-blue-100 text-lg">@(isSuperAdmin ? "Register a new System Administrator (Beta) account." : "Add a new team member to the system with the appropriate role and permissions.")</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-person-plus-fill text-9xl text-white"></i>
    </div>
</div>

<!-- Action Bar -->
<div class="flex justify-start mb-6">
    <a asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
        <i class="bi bi-arrow-left"></i> Back to Users
    </a>
</div>

<!-- Form Card -->
<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
        <div class="px-6 py-4 border-b border-gray-200">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-person-vcard text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800">Account Details</h3>
                    <span class="text-xs text-gray-500">Fill in all required fields to create a new user</span>
                </div>
            </div>
        </div>
        <div class="p-6">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 rounded-lg p-3 text-sm text-red-800 mb-4" role="alert"></div>

                <!-- Email -->
                <div class="mb-5">
                    <label class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-envelope me-1 text-indigo-500"></i> Email Address</label>
                    <input name="email" type="email" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" required placeholder="user@company.com" />
                </div>

                <!-- Password -->
                <div class="mb-5">
                    <label class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-key me-1 text-amber-500"></i> Password</label>
                    <div class="relative">
                        <input name="password" type="password" id="passwordField" class="py-3 px-4 pe-11 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" required placeholder="Enter a strong password" />
                        <button type="button" id="togglePassword" class="absolute inset-y-0 end-0 flex items-center z-20 px-3 cursor-pointer text-gray-400 rounded-e-md hover:text-blue-600">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                    <div class="mt-2 flex flex-wrap gap-1">
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-50 text-indigo-800 text-xs font-medium"><i class="bi bi-check2"></i> Uppercase</span>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-50 text-indigo-800 text-xs font-medium"><i class="bi bi-check2"></i> Number</span>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-50 text-indigo-800 text-xs font-medium"><i class="bi bi-check2"></i> Special Character</span>
                    </div>
                </div>

                <!-- Role -->
                <div class="mb-5">
                    <label class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-shield-check me-1 text-green-500"></i> Assign Role</label>
                    <select name="role" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500">
                        @if (isSuperAdmin)
                        {
                            <option value="SystemAdmin">System Admin (Beta)</option>
                        }
                        else
                        {
                            <option value="DepartmentManager">Department Manager (Charlie)</option>
                            <option value="WarehouseStaff">Warehouse Staff (Delta)</option>
                            <option value="Employee">Employee (Echo)</option>
                        }
                    </select>
                    <div class="mt-2">
                        @if (isSuperAdmin)
                        {
                            <div class="bg-red-50 rounded-lg p-3 flex items-center gap-2">
                                <i class="bi bi-info-circle text-red-500"></i>
                                <span class="text-xs text-gray-500">System Admins have elevated privileges. Assign with caution.</span>
                            </div>
                        }
                        else
                        {
                            <div class="bg-indigo-50 rounded-lg p-3 flex items-center gap-2">
                                <i class="bi bi-info-circle text-indigo-500"></i>
                                <span class="text-xs text-gray-500">The selected role determines the user's access level and permissions.</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex gap-2">
                    <button type="submit" class="flex-grow py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                        <i class="bi bi-person-plus"></i> Create Account
                    </button>
                    <a asp-action="Index" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toggle Password Script -->
<script>
(function () {
    const toggle = document.getElementById('togglePassword');
    const field = document.getElementById('passwordField');
    const icon = document.getElementById('toggleIcon');
    if (!toggle || !field || !icon) return;
    toggle.addEventListener('click', function () {
        const isPassword = field.type === 'password';
        field.type = isPassword ? 'text' : 'password';
        icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
    });
})();
</script>
