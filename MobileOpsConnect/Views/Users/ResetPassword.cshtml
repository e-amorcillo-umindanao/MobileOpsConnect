@model MobileOpsConnect.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-amber-50 text-amber-600 border border-amber-100 dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-400 tracking-wide uppercase">
            <i class="bi bi-key"></i> Security Action
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Reset Password</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Resetting password for <strong>@Model.Email</strong></p>
</div>

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl mb-6 dark:bg-neutral-900 dark:border-neutral-800">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-50 text-amber-500 dark:bg-amber-900/20 dark:text-amber-400"><i class="bi bi-key text-lg"></i></span>
                <div><h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Set New Password</h3><span class="text-xs text-gray-500 dark:text-neutral-500">Enter a new password for this account</span></div>
            </div>
        </div>
        <div class="p-6">
            <form asp-action="ResetPassword">
                <input type="hidden" asp-for="Id" />
                <div class="mb-5">
                    <label asp-for="NewPassword" class="block text-sm font-medium mb-2"><i class="bi bi-lock-fill me-1 text-amber-500"></i> New Password</label>
                    <input asp-for="NewPassword" type="password" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" required />
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="flex-grow py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">Reset Password</button>
                    <a asp-action="Index" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-colors dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
