@model MobileOpsConnect.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Users
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Reset Password</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Resetting password for <strong>@Model.Email</strong></p>
</div>

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl mb-6 dark:bg-neutral-900 dark:border-neutral-800">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-50 text-amber-500 dark:bg-amber-900/20 dark:text-amber-400"><i class="bi bi-key text-lg"></i></span>
                <div><h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Set New Password</h3><span class="text-xs text-gray-500 dark:text-neutral-500">Enter a new password for this account</span></div>
            </div>
        </div>
        <div class="p-6">
            <form asp-action="ResetPassword">
                <input type="hidden" asp-for="Id" />
                <div class="mb-6">
                    <label asp-for="NewPassword" class="block text-sm font-medium mb-2"><i class="bi bi-lock-fill me-1 text-amber-500"></i> New Password</label>
                    <div class="relative">
                        <input asp-for="NewPassword" type="password" id="resetPasswordField" class="py-3 px-4 pe-11 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" required placeholder="Enter new password" />
                        <button type="button" id="toggleResetPassword" class="absolute inset-y-0 end-0 flex items-center z-20 px-3 cursor-pointer text-gray-400 rounded-e-md hover:text-blue-600">
                            <i class="bi bi-eye" id="toggleResetIcon"></i>
                        </button>
                    </div>
                    <div class="mt-3 flex flex-wrap gap-1">
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-50 text-indigo-800 text-xs font-medium"><i class="bi bi-check2"></i> Uppercase</span>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-50 text-indigo-800 text-xs font-medium"><i class="bi bi-check2"></i> Number</span>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-50 text-indigo-800 text-xs font-medium"><i class="bi bi-check2"></i> Special</span>
                    </div>
                </div>

                <div class="bg-blue-50/50 rounded-lg p-4 mb-6 border border-blue-100">
                    <div class="flex items-start gap-3">
                        <i class="bi bi-info-circle-fill text-blue-500 text-lg mt-0.5"></i>
                        <p class="text-xs text-blue-800 leading-relaxed">The user will be required to use this new password for their next login attempt. Make sure to communicate the new credentials securely.</p>
                    </div>
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="btn-moc-primary flex-grow inline-flex justify-center items-center gap-x-2 text-sm font-semibold">
                        <i class="bi bi-check2-circle"></i> Reset Password
                    </button>
                    <a asp-action="Index" class="py-3 px-6 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-colors dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
(function () {
    const toggle = document.getElementById('toggleResetPassword');
    const field = document.getElementById('resetPasswordField');
    const icon = document.getElementById('toggleResetIcon');
    if (!toggle || !field || !icon) return;
    toggle.addEventListener('click', function () {
        const isPassword = field.type === 'password';
        field.type = isPassword ? 'text' : 'password';
        icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
    });
})();
</script>
