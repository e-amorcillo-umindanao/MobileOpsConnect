@model MobileOpsConnect.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-key-fill"></i> Security Action
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Reset Password</h1>
        <p class="text-blue-100 text-lg">Resetting password for <strong>@Model.Email</strong></p>
    </div>
</div>

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
        <div class="px-6 py-4 border-b border-gray-200">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-100 text-amber-800"><i class="bi bi-key-fill text-lg"></i></span>
                <div><h3 class="text-sm font-semibold text-gray-800">Set New Password</h3><span class="text-xs text-gray-500">Enter a new password for this account</span></div>
            </div>
        </div>
        <div class="p-6">
            <form asp-action="ResetPassword">
                <input type="hidden" asp-for="Id" />
                <div class="mb-5">
                    <label asp-for="NewPassword" class="block text-sm font-medium mb-2"><i class="bi bi-lock-fill me-1 text-amber-500"></i> New Password</label>
                    <input asp-for="NewPassword" type="password" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" required />
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="flex-grow py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 shadow-sm">Reset Password</button>
                    <a asp-action="Index" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
