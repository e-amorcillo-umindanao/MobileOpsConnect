@model MobileOpsConnect.Models.EditUserViewModel

@{
    ViewData["Title"] = Model.IsOwnAccount ? "My Account" : "Edit User Role";
    bool isAlpha = ViewBag.IsAlpha ?? false;
    bool isOwnAccount = Model.IsOwnAccount;
}

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <a asp-action="Index" class="inline-flex items-center gap-x-1 text-sm font-medium text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors mb-5">
        <i class="bi bi-chevron-left text-xs"></i> Back to Users
    </a>
    <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
        <div class="flex items-center gap-2">
            <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
                <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span> @(isOwnAccount ? "Your Account" : "User Management")
            </span>
            <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
                @if (Model.CurrentRole == "SuperAdmin")
                {
                    <i class="bi bi-shield-lock"></i> <text>Alpha</text>
                }
                else if (Model.CurrentRole == "SystemAdmin")
                {
                    <i class="bi bi-gear"></i> <text>Beta</text>
                }
                else
                {
                    <i class="bi bi-person-badge"></i> @Model.CurrentRole
                }
            </span>
        </div>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">@(isOwnAccount ? "My Account" : "Edit User")</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">@(isOwnAccount ? "Manage your SuperAdmin (Alpha) account settings" : $"Editing account: {Model.Email}")</p>
</div>

<!-- Error Alerts -->
@if (TempData["DeleteError"] != null)
{
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6" role="alert">
        <div class="flex items-center gap-3">
            <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-x-circle-fill text-lg"></i></span>
            <div><span class="font-semibold text-red-800">Error!</span> <span class="text-sm text-red-800 ms-1">@TempData["DeleteError"]</span></div>
        </div>
    </div>
}

@if (isOwnAccount && isAlpha)
{
    <!-- Account Status -->
    <div class="flex items-center gap-x-2 mb-4">
        <i class="bi bi-shield-lock text-gray-400"></i>
        <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Account Status</h2>
    </div>

    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl mb-6 dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-6">
            <div class="flex items-center gap-4 mb-6">
                <span class="inline-flex justify-center items-center size-[56px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill text-2xl"></i></span>
                <div><h3 class="text-lg font-bold text-gray-800 mb-0">SuperAdmin &bull; Alpha</h3><p class="text-sm text-gray-500 mb-0">You hold the highest role in the system</p></div>
            </div>
            <div class="grid sm:grid-cols-2 gap-4 mb-6">
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Email</p>
                    <h3 class="text-sm font-bold text-gray-800 mb-1 break-all">@Model.Email</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Verified</span>
                </div>
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Role</p>
                    <h3 class="text-sm font-bold text-gray-800 mb-1">SuperAdmin (Alpha)</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-lock-fill"></i> Immutable</span>
                </div>
            </div>
            <div class="bg-indigo-50 rounded-lg p-4 flex items-center gap-3">
                <i class="bi bi-info-circle-fill text-indigo-500 text-lg"></i>
                <div class="text-sm text-indigo-800"><strong>No role changes available.</strong> You already hold the highest role. This role cannot be demoted or promoted.</div>
            </div>
        </div>
    </div>

    <!-- Danger Zone -->
    <div class="flex items-center gap-x-2 mb-4">
        <i class="bi bi-exclamation-triangle text-gray-400"></i>
        <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Danger Zone</h2>
    </div>

    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl mb-6 dark:bg-neutral-900 dark:border-neutral-800" style="border-left: 4px solid #ef4444 !important;">
        <div class="p-6">
            <div class="flex items-start gap-4 mb-4">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-trash3-fill text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-bold text-red-600 mb-1">Delete My Account</h3>
                    <p class="text-xs text-gray-500 mb-0">Permanently remove your SuperAdmin account. This action is <strong>irreversible</strong> and you will lose all administrative privileges immediately.</p>
                </div>
            </div>
            <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700" data-hs-overlay="#deleteAccountModal">
                <i class="bi bi-trash3"></i> Delete My Account
            </button>
        </div>
    </div>

    <!-- Delete Account Modal (Preline UI) -->
    <div id="deleteAccountModal" class="hs-overlay hidden size-full fixed top-0 start-0 z-[80] overflow-x-hidden overflow-y-auto pointer-events-none" role="dialog" tabindex="-1" aria-labelledby="deleteAccountModalLabel">
        <div class="hs-overlay-animation-target hs-overlay-open:scale-100 hs-overlay-open:opacity-100 scale-95 opacity-0 ease-in-out transition-all duration-200 sm:max-w-lg sm:w-full m-3 sm:mx-auto min-h-[calc(100%-3.5rem)] flex items-center">
            <div class="w-full flex flex-col bg-white border border-gray-200 shadow-lg rounded-2xl pointer-events-auto shadow-[0_10px_40px_10px_rgba(0,0,0,0.08)]">
                <div class="flex justify-between items-center py-3 px-6 border-b border-gray-100" style="background: rgba(239,68,68,0.04);">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex justify-center items-center size-[32px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-exclamation-triangle-fill"></i></span>
                        <h5 class="font-bold text-gray-800" id="deleteAccountModalLabel">Confirm Account Deletion</h5>
                    </div>
                    <button type="button" class="size-8 inline-flex justify-center items-center gap-x-2 rounded-full border border-transparent bg-white text-gray-800 hover:bg-gray-100 disabled:opacity-50 disabled:pointer-events-none" data-hs-overlay="#deleteAccountModal" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="p-6">
                    <div class="bg-red-50 rounded-xl p-4 mb-5 border border-red-100">
                        <div class="flex items-start gap-3">
                            <i class="bi bi-shield-exclamation text-red-600 text-xl mt-0.5"></i>
                            <div class="text-sm text-red-800 leading-relaxed"><strong>Warning:</strong> You are about to permanently delete your SuperAdmin account (<strong>@Model.Email</strong>). This cannot be undone.</div>
                        </div>
                    </div>
                    
                    <form asp-action="DeleteSelf" method="post" id="deleteAccountForm">
                        @Html.AntiForgeryToken()
                        <div>
                            <label for="confirmPassword" class="block text-sm font-semibold text-gray-800 mb-2"><i class="bi bi-lock-fill text-red-500 me-1"></i> Verify Password</label>
                            <input type="password" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-red-500 focus:ring-red-500 bg-gray-50 focus:bg-white transition-colors" id="confirmPassword" name="password" required placeholder="Enter your current password to confirm" autocomplete="current-password" />
                            <p class="text-xs text-gray-500 mt-2 text-right">Required for final deletion.</p>
                        </div>
                    </form>
                </div>
                <div class="flex justify-end items-center gap-x-3 py-4 px-6 border-t border-gray-100 bg-gray-50 rounded-b-2xl">
                    <button type="button" class="py-2.5 px-4 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 transition-colors" data-hs-overlay="#deleteAccountModal">
                        Cancel
                    </button>
                    <button type="submit" form="deleteAccountForm" class="py-2.5 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700 shadow-sm shadow-red-500/30 transition-all disabled:opacity-50 disabled:pointer-events-none disabled:shadow-none" id="confirmDeleteBtn" disabled>
                        <i class="bi bi-trash3"></i> Permanently Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var pwd = document.getElementById('confirmPassword');
            var btn = document.getElementById('confirmDeleteBtn');
            pwd.addEventListener('input', function () {
                btn.disabled = pwd.value.trim().length < 1;
            });
        });
    </script>
}
else
{
    <!-- Standard Edit View -->
    <div class="flex items-center gap-x-2 mb-4">
        <i class="bi bi-pencil-square text-gray-400"></i>
        <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Role Assignment</h2>
    </div>

    <div class="max-w-5xl mx-auto">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>

            <div class="grid md:grid-cols-12 gap-6 lg:gap-8 lg:items-start mb-6">
                
                <!-- Left Column: Current Role Card -->
                <div class="md:col-span-5 flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
                    <div class="p-5">
                        <h3 class="text-sm font-semibold text-gray-800 mb-4 flex items-center gap-2"><i class="bi bi-person-badge text-indigo-500"></i> Current Status</h3>
                        <div class="flex items-center gap-4">
                            @if (Model.CurrentRole == "SuperAdmin")
                            {
                                <span class="shrink-0 inline-flex justify-center items-center size-[48px] rounded-full bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill text-xl"></i></span>
                            }
                            else if (Model.CurrentRole == "SystemAdmin")
                            {
                                <span class="shrink-0 inline-flex justify-center items-center size-[48px] rounded-full bg-amber-100 text-amber-800"><i class="bi bi-gear-fill text-xl"></i></span>
                            }
                            else
                            {
                                <span class="shrink-0 inline-flex justify-center items-center size-[48px] rounded-full bg-indigo-100 text-indigo-800"><i class="bi bi-person-fill text-xl"></i></span>
                            }
                            <div>
                                <p class="text-xs uppercase tracking-wide text-gray-500 font-medium mb-0.5">Role Name</p>
                                <h4 class="text-base font-bold text-gray-800 mb-0">@Model.CurrentRole</h4>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: New Role Form -->
                <div class="md:col-span-7 flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
                    <div class="p-6">
                        <div class="mb-5">
                            <label asp-for="NewRole" class="block text-sm font-medium mb-2"><i class="bi bi-arrow-repeat me-1 text-indigo-500"></i> Assign New Role</label>
                            <select asp-for="NewRole" asp-items="ViewBag.Roles" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 bg-gray-50 focus:bg-white transition-colors"></select>
                            
                            <div class="mt-4 bg-indigo-50/50 rounded-lg p-3">
                                <p class="text-xs text-indigo-800 flex items-start gap-1.5">
                                    <i class="bi bi-info-circle-fill text-indigo-500 mt-0.5"></i>
                                    <span>
                                        @if (isAlpha)
                                        {
                                            <text>Select </text><strong>SuperAdmin</strong><text> to promote this user to Alpha.</text>
                                        }
                                        else
                                        {
                                            <text>Changing the role will update this user's permissions immediately.</text>
                                        }
                                    </span>
                                </p>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex gap-3 pt-2 border-t border-gray-100 mt-6">
                            <button type="submit" class="flex-1 py-2.5 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                                <i class="bi bi-check2-circle"></i> Save Changes
                            </button>
                            <a asp-action="Index" class="flex-1 py-2.5 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-colors dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </form>
    </div>
}

