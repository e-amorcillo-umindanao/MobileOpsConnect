@model MobileOpsConnect.Models.EditUserViewModel

@{
    ViewData["Title"] = Model.IsOwnAccount ? "My Account" : "Edit User Role";
    bool isAlpha = ViewBag.IsAlpha ?? false;
    bool isOwnAccount = Model.IsOwnAccount;
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> @(isOwnAccount ? "Your Account" : "User Management")
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                @if (Model.CurrentRole == "SuperAdmin")
                {
                    <i class="bi bi-shield-lock-fill"></i> <text>Alpha</text>
                }
                else if (Model.CurrentRole == "SystemAdmin")
                {
                    <i class="bi bi-gear-fill"></i> <text>Beta</text>
                }
                else
                {
                    <i class="bi bi-person-badge"></i> @Model.CurrentRole
                }
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">@(isOwnAccount ? "My Account" : "Edit User")</h1>
        <p class="text-blue-100 text-lg">@(isOwnAccount ? "Manage your SuperAdmin (Alpha) account settings" : $"Editing account: {Model.Email}")</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-@(isOwnAccount ? "shield-lock-fill" : "pencil-square") text-9xl text-white"></i>
    </div>
</div>

<!-- Error Alerts -->
@if (TempData["DeleteError"] != null)
{
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6" role="alert">
        <div class="flex items-center gap-3">
            <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-x-circle-fill text-lg"></i></span>
            <div><span class="font-semibold text-red-800">Error!</span> <span class="text-sm text-red-800 ms-1">@TempData["DeleteError"]</span></div>
        </div>
    </div>
}

@if (isOwnAccount && isAlpha)
{
    <!-- Account Status -->
    <div class="flex items-center gap-x-3 mb-4">
        <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-shield-lock-fill text-red-500"></i> Account Status</h2>
        <div class="grow border-t border-gray-200"></div>
    </div>

    <div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
        <div class="p-6">
            <div class="flex items-center gap-4 mb-6">
                <span class="inline-flex justify-center items-center size-[56px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill text-2xl"></i></span>
                <div><h3 class="text-lg font-bold text-gray-800 mb-0">SuperAdmin &bull; Alpha</h3><p class="text-sm text-gray-500 mb-0">You hold the highest role in the system</p></div>
            </div>
            <div class="grid sm:grid-cols-2 gap-4 mb-6">
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Email</p>
                    <h3 class="text-sm font-bold text-gray-800 mb-1 break-all">@Model.Email</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Verified</span>
                </div>
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Role</p>
                    <h3 class="text-sm font-bold text-gray-800 mb-1">SuperAdmin (Alpha)</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-lock-fill"></i> Immutable</span>
                </div>
            </div>
            <div class="bg-indigo-50 rounded-lg p-4 flex items-center gap-3">
                <i class="bi bi-info-circle-fill text-indigo-500 text-lg"></i>
                <div class="text-sm text-indigo-800"><strong>No role changes available.</strong> You already hold the highest role. This role cannot be demoted or promoted.</div>
            </div>
        </div>
    </div>

    <!-- Danger Zone -->
    <div class="flex items-center gap-x-3 mb-4">
        <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-exclamation-triangle-fill text-red-500"></i> Danger Zone</h2>
        <div class="grow border-t border-gray-200"></div>
    </div>

    <div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6" style="border-left: 4px solid #ef4444 !important;">
        <div class="p-6">
            <div class="flex items-start gap-4 mb-4">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-trash3-fill text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-bold text-red-600 mb-1">Delete My Account</h3>
                    <p class="text-xs text-gray-500 mb-0">Permanently remove your SuperAdmin account. This action is <strong>irreversible</strong> and you will lose all administrative privileges immediately.</p>
                </div>
            </div>
            <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                <i class="bi bi-trash3"></i> Delete My Account
            </button>
        </div>
    </div>

    <!-- Delete Account Modal -->
    <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
                <div class="modal-header border-0 pb-0" style="background: rgba(239,68,68,0.04);">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-exclamation-triangle-fill text-lg"></i></span>
                        <h5 class="modal-title font-bold" id="deleteAccountModalLabel">Confirm Account Deletion</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-6 py-6">
                    <div class="bg-red-50 rounded-lg p-4 mb-4">
                        <div class="flex items-start gap-2">
                            <i class="bi bi-shield-exclamation text-red-600 text-lg mt-1"></i>
                            <div class="text-sm text-red-800"><strong>Warning:</strong> You are about to permanently delete your SuperAdmin account (<strong>@Model.Email</strong>). This cannot be undone.</div>
                        </div>
                    </div>
                    <p class="text-sm text-gray-500 mb-4">To confirm this action, please enter your current password:</p>
                    <form asp-action="DeleteSelf" method="post" id="deleteAccountForm">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label for="confirmPassword" class="block text-sm font-medium mb-2"><i class="bi bi-lock-fill text-red-500 me-1"></i> Your Password</label>
                            <input type="password" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" id="confirmPassword" name="password" required placeholder="Enter your password to confirm" autocomplete="current-password" />
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 px-6 pb-4">
                    <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancel</button>
                    <button type="submit" form="deleteAccountForm" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700" id="confirmDeleteBtn" disabled><i class="bi bi-trash3"></i> Permanently Delete</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var pwd = document.getElementById('confirmPassword');
            var btn = document.getElementById('confirmDeleteBtn');
            pwd.addEventListener('input', function () {
                btn.disabled = pwd.value.trim().length < 1;
            });
        });
    </script>
}
else
{
    <!-- Standard Edit View -->
    <div class="flex items-center gap-x-3 mb-4">
        <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-pencil-square text-indigo-500"></i> Role Assignment</h2>
        <div class="grow border-t border-gray-200"></div>
    </div>

    <div class="max-w-xl mx-auto">
        <div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
            <div class="p-6">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>

                    <!-- Current Role -->
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 mb-5 flex items-center gap-4">
                        @if (Model.CurrentRole == "SuperAdmin")
                        {
                            <span class="inline-flex justify-center items-center size-[40px] rounded-full bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill"></i></span>
                        }
                        else if (Model.CurrentRole == "SystemAdmin")
                        {
                            <span class="inline-flex justify-center items-center size-[40px] rounded-full bg-amber-100 text-amber-800"><i class="bi bi-gear-fill"></i></span>
                        }
                        else
                        {
                            <span class="inline-flex justify-center items-center size-[40px] rounded-full bg-indigo-100 text-indigo-800"><i class="bi bi-person-fill"></i></span>
                        }
                        <div><p class="text-xs uppercase text-gray-500 font-medium mb-0">Current Role</p><h3 class="text-sm font-bold text-gray-800 mb-0">@Model.CurrentRole</h3></div>
                    </div>

                    <!-- New Role -->
                    <div class="mb-5">
                        <label asp-for="NewRole" class="block text-sm font-medium mb-2"><i class="bi bi-arrow-repeat me-1 text-indigo-500"></i> Assign New Role</label>
                        <select asp-for="NewRole" asp-items="ViewBag.Roles" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500"></select>
                        <p class="text-xs text-gray-500 mt-2 flex items-center gap-1">
                            <i class="bi bi-info-circle text-indigo-500"></i>
                            @if (isAlpha)
                            {
                                <text>Select </text><strong>SuperAdmin</strong><text> to promote this user to Alpha.</text>
                            }
                            else
                            {
                                <text>Changing the role will update this user's permissions immediately.</text>
                            }
                        </p>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex gap-2">
                        <button type="submit" class="flex-1 py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                            <i class="bi bi-check2-circle"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="flex-1 py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Back to Directory -->
<div class="flex justify-start mb-6">
    <a asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
        <i class="bi bi-arrow-left"></i> Back to User Directory
    </a>
</div>
