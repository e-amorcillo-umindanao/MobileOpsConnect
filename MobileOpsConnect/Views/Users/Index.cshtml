@model IEnumerable<MobileOpsConnect.Models.UserViewModel>

@{
    ViewData["Title"] = "User Management";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    int totalUsers = Model.Count();
    int superAdminCount = Model.Count(u => u.Role == "SuperAdmin");
    int systemAdminCount = Model.Count(u => u.Role == "SystemAdmin");
    int otherCount = totalUsers - superAdminCount - systemAdminCount;
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> Directory Online
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-people-fill"></i> @totalUsers Registered Account@(totalUsers != 1 ? "s" : "")
            </span>
        </div>
        @if (isSuperAdmin)
        {
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">System Admin Management</h1>
            <p class="text-blue-100 text-lg">Create &amp; manage Beta-level System Administrator accounts</p>
        }
        else
        {
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">User Management</h1>
            <p class="text-blue-100 text-lg">Manage staff accounts, roles &amp; access permissions</p>
        }
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-people-fill text-9xl text-white"></i>
    </div>
</div>

<!-- Account Overview -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg"><i class="bi bi-person-lines-fill text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Total Users</p><h3 class="text-xl font-medium text-gray-800 mt-1">@totalUsers</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium"><i class="bi bi-people-fill"></i> All Roles</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg"><i class="bi bi-shield-lock-fill text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Super Admins</p><h3 class="text-xl font-medium text-gray-800 mt-1">@superAdminCount</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-shield-lock-fill"></i> Alpha</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-amber-100 text-amber-800 rounded-lg"><i class="bi bi-gear-wide-connected text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Sys Admins</p><h3 class="text-xl font-medium text-gray-800 mt-1">@systemAdminCount</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-gear-fill"></i> Beta</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-cyan-100 text-cyan-800 rounded-lg"><i class="bi bi-person-workspace text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Staff &amp; Others</p><h3 class="text-xl font-medium text-gray-800 mt-1">@otherCount</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium"><i class="bi bi-person-badge"></i> Standard</span></div></div></div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-3 mb-6">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-green-100 text-green-800"><i class="bi bi-person-plus-fill text-lg"></i></span>
        <div><p class="text-sm font-semibold text-gray-800 mb-0">Add New Account</p><span class="text-xs text-gray-500">Register a new user to the system</span></div>
    </div>
    <a asp-action="Create" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
        <i class="bi bi-plus-circle"></i> Create New User
    </a>
</div>

<!-- User Table -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
    <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-table text-lg"></i></span>
                <div><h3 class="text-sm font-semibold text-gray-800">All Accounts</h3><span class="text-xs text-gray-500">@totalUsers user@(totalUsers != 1 ? "s" : "") registered</span></div>
            </div>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"><i class="bi bi-filter"></i> Showing All</span>
        </div>
    </div>
    <div class="p-6">
        <!-- Desktop Table -->
        <div class="overflow-x-auto hidden md:block">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50"><tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-person me-1"></i> User</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-shield me-1"></i> Role</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase"><i class="bi bi-lightning me-1"></i> Actions</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-x-3">
                                    @if (item.Role == "SuperAdmin")
                                    { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill"></i></span> }
                                    else if (item.Role == "SystemAdmin")
                                    { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-amber-100 text-amber-800"><i class="bi bi-gear-fill"></i></span> }
                                    else
                                    { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-indigo-100 text-indigo-800"><i class="bi bi-person-fill"></i></span> }
                                    <div><span class="text-sm font-semibold text-gray-800">@item.Email</span><br/><span class="text-xs text-gray-500">ID: @item.Id.Substring(0, Math.Min(8, item.Id.Length))…</span></div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                @if (item.Role == "SuperAdmin")
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill"></i> Super Admin</span> }
                                else if (item.Role == "SystemAdmin")
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800"><i class="bi bi-gear-fill"></i> System Admin</span> }
                                else
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800"><i class="bi bi-person-badge"></i> @item.Role</span> }
                            </td>
                            <td class="px-6 py-4 text-end">
                                <div class="flex justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50" title="Edit Role"><i class="bi bi-pencil-square"></i> Edit</a>
                                    <a asp-action="ResetPassword" asp-route-id="@item.Id" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100" title="Reset Password"><i class="bi bi-key-fill"></i> Reset</a>
                                    @if (isSuperAdmin && item.Role == "SystemAdmin")
                                    {
                                        <button type="button" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100" title="Remove User" aria-haspopup="dialog" aria-expanded="false" aria-controls="deleteUserModal" data-hs-overlay="#deleteUserModal" onclick="setDeleteTarget('@item.Id', '@item.Email')"><i class="bi bi-trash3"></i> Remove</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Cards -->
        <div class="md:hidden space-y-4">
            @foreach (var item in Model)
            {
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <div class="flex items-center gap-3 mb-3">
                        @if (item.Role == "SuperAdmin")
                        { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill"></i></span> }
                        else if (item.Role == "SystemAdmin")
                        { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-amber-100 text-amber-800"><i class="bi bi-gear-fill"></i></span> }
                        else
                        { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-indigo-100 text-indigo-800"><i class="bi bi-person-fill"></i></span> }
                        <div class="grow min-w-0">
                            <p class="text-sm font-semibold text-gray-800 mb-0 truncate">@item.Email</p>
                            <span class="text-xs text-gray-500">ID: @item.Id.Substring(0, Math.Min(8, item.Id.Length))…</span>
                        </div>
                        @if (item.Role == "SuperAdmin")
                        { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-shield-lock-fill"></i> Alpha</span> }
                        else if (item.Role == "SystemAdmin")
                        { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-gear-fill"></i> Beta</span> }
                        else
                        { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-cyan-100 text-cyan-800 text-xs font-medium" style="max-width:7.5rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><i class="bi bi-person-badge"></i> @(item.Role == "DepartmentManager" ? "Dept Mgr" : item.Role)</span> }
                    </div>
                    <div class="flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="flex-1 py-2 px-3 inline-flex justify-center items-center gap-x-1 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50"><i class="bi bi-pencil-square"></i> Edit Role</a>
                        <a asp-action="ResetPassword" asp-route-id="@item.Id" class="flex-1 py-2 px-3 inline-flex justify-center items-center gap-x-1 text-xs font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100"><i class="bi bi-key-fill"></i> Reset PW</a>
                        @if (isSuperAdmin && item.Role == "SystemAdmin")
                        {
                            <button type="button" class="py-2 px-3 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100" aria-haspopup="dialog" aria-expanded="false" aria-controls="deleteUserModal" data-hs-overlay="#deleteUserModal" onclick="setDeleteTarget('@item.Id', '@item.Email')"><i class="bi bi-trash3"></i></button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-gray-200">
        <div class="flex flex-wrap justify-between items-center gap-2">
            <span class="text-xs text-gray-500"><i class="bi bi-info-circle me-1"></i> Showing all @totalUsers account@(totalUsers != 1 ? "s" : "")</span>
            <div class="flex gap-1">
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-red-100 text-red-800 text-xs">@superAdminCount Alpha</span>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-amber-100 text-amber-800 text-xs">@systemAdminCount Beta</span>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-cyan-100 text-cyan-800 text-xs">@otherCount Staff</span>
            </div>
        </div>
    </div>
</div>



@if (isSuperAdmin)
{
    <!-- Delete User Confirmation Modal -->
    <div id="deleteUserModal" class="hs-overlay hidden size-full fixed top-0 start-0 z-[80] overflow-x-hidden overflow-y-auto pointer-events-none" role="dialog" tabindex="-1" aria-labelledby="deleteUserModalLabel">
        <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all sm:max-w-lg sm:w-full m-3 sm:mx-auto min-h-[calc(100%-3.5rem)] flex items-center">
            <div class="w-full flex flex-col bg-white border shadow-sm rounded-xl pointer-events-auto">
                <div class="flex justify-between items-center py-3 px-4 border-b" style="background: rgba(239,68,68,0.04);">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-exclamation-triangle-fill text-lg"></i></span>
                        <h3 id="deleteUserModalLabel" class="font-bold text-gray-800">Remove System Admin</h3>
                    </div>
                    <button type="button" class="size-8 inline-flex justify-center items-center gap-x-2 rounded-full border border-transparent bg-gray-100 text-gray-800 hover:bg-gray-200" aria-label="Close" data-hs-overlay="#deleteUserModal">
                        <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                    </button>
                </div>
                <div class="p-6">
                    <p class="text-gray-800 mb-2">Are you sure you want to permanently remove this System Admin?</p>
                    <p class="font-semibold text-red-500 mb-0" id="deleteTargetEmail"></p>
                </div>
                <div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t">
                    <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50" data-hs-overlay="#deleteUserModal"><i class="bi bi-x-lg"></i> Cancel</button>
                    <form id="deleteUserForm" asp-action="Delete" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteUserIdInput" />
                        <button type="submit" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700"><i class="bi bi-trash3"></i> Remove Permanently</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function setDeleteTarget(userId, userEmail) {
            document.getElementById('deleteUserIdInput').value = userId;
            document.getElementById('deleteTargetEmail').textContent = userEmail;
        }
    </script>
}
