@model IEnumerable<MobileOpsConnect.Models.UserViewModel>

@{
    ViewData["Title"] = "User Management";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    int totalUsers = Model.Count();
    var roleDisplayNames = (Dictionary<string, string>)ViewBag.RoleDisplayNames;
    int superAdminCount = Model.Count(u => u.Role == "SuperAdmin");
    int systemAdminCount = Model.Count(u => u.Role == "SystemAdmin");
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            Directory Online
        </span>
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
            <i class="bi bi-people"></i> @totalUsers Registered Account@(totalUsers != 1 ? "s" : "")
        </span>
    </div>
    @if (isSuperAdmin)
    {
        <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">System Admin Management</h1>
        <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Create & manage System Administrator accounts</p>
    }
    else
    {
        <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">User Management</h1>
        <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Manage staff accounts, roles & access permissions</p>
    }
</div>

<!-- Account Overview -->
<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-10">
    <!-- Total Users -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-[#f4f2ff] text-[#5e4dcd] rounded-2xl dark:bg-indigo-900/20 dark:text-indigo-400">
                <i class="bi bi-people text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Total Users</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@totalUsers</h3>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-[#f4f2ff] text-[#5e4dcd] text-[10px] font-bold uppercase tracking-wide dark:bg-indigo-900/20 dark:text-indigo-400 mb-1">
                <i class="bi bi-layers"></i> All Roles
            </span>
        </div>
    </div>

    <!-- Super Admins -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-rose-50 text-rose-500 rounded-2xl dark:bg-rose-900/20 dark:text-rose-400">
                <i class="bi bi-shield text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Super Admins</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@superAdminCount</h3>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-rose-50 text-rose-600 text-[10px] font-bold uppercase tracking-wide dark:bg-rose-900/20 dark:text-rose-400 mb-1">
                <i class="bi bi-shield-check"></i> Super Admin
            </span>
        </div>
    </div>

    <!-- Sys Admins -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-amber-50 text-amber-500 rounded-2xl dark:bg-amber-900/20 dark:text-amber-400">
                <i class="bi bi-gear text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Sys Admins</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@systemAdminCount</h3>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-amber-50 text-amber-600 text-[10px] font-bold uppercase tracking-wide dark:bg-amber-900/20 dark:text-amber-400 mb-1">
                <i class="bi bi-gear-wide"></i> System Admin
            </span>
        </div>
    </div>

</div>

<!-- Action Bar -->
<div class="flex flex-col sm:flex-row sm:justify-between sm:items-center p-6 bg-white border border-gray-100 shadow-sm rounded-[1.25rem] gap-4 mb-8 dark:bg-neutral-900 dark:border-neutral-800">
    <div class="flex items-center gap-x-4">
        <span class="inline-flex justify-center items-center size-[42px] rounded-xl bg-emerald-50 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
            <i class="bi bi-person-plus text-xl"></i>
        </span>
        <div>
            <p class="text-[15px] font-bold text-gray-900 dark:text-white mb-0">Add New Account</p>
            <span class="text-[13px] font-medium text-gray-500 dark:text-neutral-400">Register a new user to the system</span>
        </div>
    </div>
    <a asp-action="Create" class="py-2.5 px-5 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] focus:outline-none focus:bg-[#1a1a1a] transition-colors w-full sm:w-auto">
        <i class="bi bi-plus text-lg leading-none"></i> Create New User
    </a>
</div>

<!-- User Table -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] mb-6 relative overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3 w-full sm:w-auto">
                <div class="relative inline-block w-full sm:w-48">
                    <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none text-gray-400">
                        <i class="bi bi-funnel"></i>
                    </div>
                    <select id="roleFilter" class="py-1.5 ps-9 pe-8 block w-full bg-gray-50 border-gray-200 rounded-lg text-xs font-bold uppercase tracking-wide focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-indigo-400 transition-all cursor-pointer">
                        <option value="">All Roles</option>
                        @foreach (string roleName in (List<string>)ViewBag.AllRoles)
                        {
                            string displayName = roleDisplayNames.GetValueOrDefault(roleName, roleName);
                            <option value="@roleName" selected="@(ViewBag.SelectedRole == roleName)">@displayName</option>
                        }
                    </select>
                </div>

                <!-- Search Input -->
                <div class="relative inline-block w-full sm:w-64">
                    <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none text-gray-400">
                        <i class="bi bi-search text-xs"></i>
                    </div>
                    <input type="text" id="userSearchInput" class="py-1.5 ps-9 pe-4 block w-full bg-gray-50 border-gray-200 rounded-lg text-xs font-medium focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 transition-all" placeholder="Search by email or role...">
                </div>
            </div>
        </div>
    </div>
    <div class="p-6">
        <!-- Desktop Table -->
        <div class="overflow-x-auto hidden md:block">
            <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                <thead><tr>
                    <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-person me-2"></i> User</th>
                    <th class="px-4 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-shield-check me-2"></i> Role</th>
                    <th class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-gear me-2"></i> Actions</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                    @foreach (var item in Model)
                    {
                        <tr class="user-row hover:bg-gray-50 transition-colors" data-search="@(item.Email.ToLower())|@(item.Role.ToLower())">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-x-4">
                                    @if (item.Role == "SuperAdmin")
                                    { <span class="inline-flex justify-center items-center size-[42px] rounded-2xl bg-rose-50 text-rose-500 dark:bg-rose-900/20 dark:text-rose-400"><i class="bi bi-shield-lock"></i></span> }
                                    else if (item.Role == "SystemAdmin")
                                    { <span class="inline-flex justify-center items-center size-[42px] rounded-2xl bg-amber-50 text-amber-500 dark:bg-amber-900/20 dark:text-amber-400"><i class="bi bi-gear-wide"></i></span> }
                                    else
                                    { <span class="inline-flex justify-center items-center size-[42px] rounded-2xl bg-cyan-50 text-cyan-600 dark:bg-cyan-900/20 dark:text-cyan-400"><i class="bi bi-person-bounding-box"></i></span> }
                                    <div><span class="text-[14px] font-bold text-gray-900 dark:text-white">@item.Email</span><br/><span class="text-xs text-gray-500 font-medium tracking-wide dark:text-neutral-500">ID: @item.Id.Substring(0, Math.Min(8, item.Id.Length))…</span></div>
                                </div>
                            </td>
                            <td class="px-4 py-5 text-center">
                                @if (item.Role == "SuperAdmin")
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-[10px] uppercase tracking-wide font-bold bg-rose-50 text-rose-600 dark:bg-rose-900/20 dark:text-rose-400"><i class="bi bi-shield-check"></i> Super Admin</span> }
                                else if (item.Role == "SystemAdmin")
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-[10px] uppercase tracking-wide font-bold bg-amber-50 text-amber-600 dark:bg-amber-900/20 dark:text-amber-400"><i class="bi bi-gear-wide"></i> System Admin</span> }
                                else
                                { 
                                    string displayName = roleDisplayNames.GetValueOrDefault(item.Role, item.Role);
                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-[10px] uppercase tracking-wide font-bold bg-cyan-50 text-cyan-700 dark:bg-cyan-900/20 dark:text-cyan-400"><i class="bi bi-person-bounding-box"></i> @displayName</span> 
                                }
                            </td>
                            <td class="px-6 py-4 text-end">
                                <div class="hs-dropdown [--placement:bottom-right] relative inline-block">
                                    <button id="hs-user-dropdown-@item.Id.Substring(0, 8)" type="button" class="hs-dropdown-toggle py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800" aria-haspopup="menu" aria-expanded="false" aria-label="Dropdown">
                                        Options
                                        <i class="bi bi-chevron-down hs-dropdown-open:rotate-180 transition-transform duration-200"></i>
                                    </button>
                                    <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden min-w-40 bg-white shadow-md rounded-lg p-2 mt-2 z-10 border border-gray-200 dark:bg-neutral-900 dark:border-neutral-700" role="menu" aria-orientation="vertical" aria-labelledby="hs-user-dropdown-@item.Id.Substring(0, 8)">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-gray-800 hover:bg-gray-100 dark:text-neutral-400 dark:hover:bg-neutral-800">
                                            <i class="bi bi-pencil-square"></i> Edit Role
                                        </a>
                                        <a asp-action="ResetPassword" asp-route-id="@item.Id" class="flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-amber-700 hover:bg-gray-100 dark:text-amber-400 dark:hover:bg-neutral-800">
                                            <i class="bi bi-key-fill"></i> Reset Password
                                        </a>
                                        @if (isSuperAdmin && item.Role == "SystemAdmin")
                                        {
                                            <div class="my-1 border-t border-gray-200 dark:border-neutral-700"></div>
                                            <button type="button" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-red-600 hover:bg-gray-100 dark:text-red-400 dark:hover:bg-neutral-800" aria-haspopup="dialog" aria-expanded="false" aria-controls="deleteUserModal" data-hs-overlay="#deleteUserModal" onclick="setDeleteTarget('@item.Id', '@item.Email')">
                                                <i class="bi bi-trash3"></i> Remove User
                                            </button>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Cards -->
        <div class="md:hidden space-y-4">
            @foreach (var item in Model)
            {
                <div class="user-card bg-gray-50 rounded-xl p-4 border border-gray-100" data-search="@(item.Email.ToLower())|@(item.Role.ToLower())">
                    <div class="flex items-center gap-3 mb-3">
                        @if (item.Role == "SuperAdmin")
                        { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-red-100 text-red-800"><i class="bi bi-shield-lock-fill"></i></span> }
                        else if (item.Role == "SystemAdmin")
                        { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-amber-100 text-amber-800"><i class="bi bi-gear-fill"></i></span> }
                        else
                        { <span class="inline-flex justify-center items-center size-[38px] rounded-full bg-indigo-100 text-indigo-800"><i class="bi bi-person-fill"></i></span> }
                        <div class="grow min-w-0">
                            <p class="text-sm font-semibold text-gray-800 mb-0 truncate">@item.Email</p>
                            <span class="text-xs text-gray-500">ID: @item.Id.Substring(0, Math.Min(8, item.Id.Length))…</span>
                        </div>
                        @if (item.Role == "SuperAdmin")
                        { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-shield-lock-fill"></i> Super Admin</span> }
                        else if (item.Role == "SystemAdmin")
                        { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-gear-fill"></i> System Admin</span> }
                        else
                        { 
                            string displayName = roleDisplayNames.GetValueOrDefault(item.Role, item.Role);
                            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-cyan-100 text-cyan-800 text-xs font-medium" style="max-width:7.5rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><i class="bi bi-person-badge"></i> @displayName</span> 
                        }
                    </div>
                    <div class="flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="flex-1 py-2 px-3 inline-flex justify-center items-center gap-x-1 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50"><i class="bi bi-pencil-square"></i> Edit Role</a>
                        <a asp-action="ResetPassword" asp-route-id="@item.Id" class="flex-1 py-2 px-3 inline-flex justify-center items-center gap-x-1 text-xs font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100"><i class="bi bi-key-fill"></i> Reset PW</a>
                        @if (isSuperAdmin && item.Role == "SystemAdmin")
                        {
                            <button type="button" class="py-2 px-3 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100" aria-haspopup="dialog" aria-expanded="false" aria-controls="deleteUserModal" data-hs-overlay="#deleteUserModal" onclick="setDeleteTarget('@item.Id', '@item.Email')"><i class="bi bi-trash3"></i></button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-gray-100 dark:border-neutral-800">
        <div class="flex flex-wrap justify-between items-center gap-2">
            <span class="text-[11px] text-gray-500 dark:text-neutral-500 font-medium tracking-wide"><i class="bi bi-info-circle me-1"></i> Showing all @totalUsers account@(totalUsers != 1 ? "s" : "")</span>
            <div class="flex gap-2">
                <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-rose-50 text-rose-600 text-[10px] uppercase tracking-wide font-bold dark:bg-rose-900/20 dark:text-rose-400">@superAdminCount Super Admin</span>
                <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-amber-50 text-amber-600 text-[10px] uppercase tracking-wide font-bold dark:bg-amber-900/20 dark:text-amber-400">@systemAdminCount System Admin</span>
            </div>
        </div>
    </div>
</div>



@if (isSuperAdmin)
{
    <!-- Delete User Confirmation Modal -->
    <div id="deleteUserModal" class="hs-overlay hidden size-full fixed top-0 start-0 z-[80] overflow-x-hidden overflow-y-auto pointer-events-none" role="dialog" tabindex="-1" aria-labelledby="deleteUserModalLabel">
        <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all sm:max-w-lg sm:w-full m-3 sm:mx-auto min-h-[calc(100%-3.5rem)] flex items-center">
            <div class="w-full flex flex-col bg-white border shadow-sm rounded-xl pointer-events-auto">
                <div class="flex justify-between items-center py-3 px-4 border-b" style="background: rgba(239,68,68,0.04);">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-exclamation-triangle-fill text-lg"></i></span>
                        <h3 id="deleteUserModalLabel" class="font-bold text-gray-800">Remove System Admin</h3>
                    </div>
                    <button type="button" class="size-8 inline-flex justify-center items-center gap-x-2 rounded-full border border-transparent bg-gray-100 text-gray-800 hover:bg-gray-200" aria-label="Close" data-hs-overlay="#deleteUserModal">
                        <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                    </button>
                </div>
                <div class="p-6">
                    <p class="text-gray-800 mb-2">Are you sure you want to permanently remove this System Admin?</p>
                    <p class="font-semibold text-red-500 mb-0" id="deleteTargetEmail"></p>
                </div>
                <div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t">
                    <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50" data-hs-overlay="#deleteUserModal"><i class="bi bi-x-lg"></i> Cancel</button>
                    <form id="deleteUserForm" asp-action="Delete" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteUserIdInput" />
                        <button type="submit" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700"><i class="bi bi-trash3"></i> Remove Permanently</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function setDeleteTarget(userId, userEmail) {
            document.getElementById('deleteUserIdInput').value = userId;
            document.getElementById('deleteTargetEmail').textContent = userEmail;
        }
    </script>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const roleFilter = document.getElementById('roleFilter');
        
        roleFilter.addEventListener('change', function() {
            const role = roleFilter.value;
            let url = '@Url.Action("Index", "Users")';
            if (role) {
                url += `?role=${encodeURIComponent(role)}`;
            }
            window.location.href = url;
        });

        // ── Instant Search Logic ──
        const userSearchInput = document.getElementById('userSearchInput');
        const userRows = document.querySelectorAll('.user-row');
        const userCards = document.querySelectorAll('.user-card');

        userSearchInput.addEventListener('input', function() {
            const query = this.value.toLowerCase().trim();
            
            // Filter Desktop Table
            userRows.forEach(row => {
                const searchContent = row.dataset.search;
                row.style.display = !query || searchContent.includes(query) ? '' : 'none';
            });

            // Filter Mobile Cards
            userCards.forEach(card => {
                const searchContent = card.dataset.search;
                card.style.display = !query || searchContent.includes(query) ? 'block' : 'none';
            });
        });
    });
</script>
}
