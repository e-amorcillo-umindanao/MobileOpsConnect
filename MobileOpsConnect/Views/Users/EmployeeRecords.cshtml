@model List<MobileOpsConnect.Models.EmployeeRecordViewModel>
@{
    ViewData["Title"] = "Employee Records";
}

<div class="flex justify-between items-center mb-6">
    <h2>👥 Employee Records</h2>
    <a asp-controller="Home" asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline">Back to Dashboard</a>
</div>

<div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm">
    <div class="px-6 py-4 border-b border-moc-border bg-gray-50 bg-transparent border-0 p-6 pb-0">
        <div class="flex items-center gap-2">
            <div class="moc-icon-box bg-indigo-50 rounded-3">
                <i class="bi bi-people-fill text-indigo fs-5"></i>
            </div>
            <div>
                <h6 class="font-bold mb-0 letter-tight">Staff Directory</h6>
                <span class="text-moc-text-muted text-xs">@Model.Count team members</span>
            </div>
        </div>
    </div>
    <div class="p-6 p-6 pt-3">
        @if (Model.Count == 0)
        {
            <div class="text-center py-8">
                <i class="bi bi-person-x text-moc-text-muted" style="font-size: 3rem;"></i>
                <p class="text-moc-text-muted mt-2">No employee records found.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="overflow-x-auto w-full hidden md:block">
                <table class="w-full text-left border-collapse align-middle mb-0">
                    <thead>
                        <tr style="border: none;">
                            <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 ps-3 py-6">
                                <i class="bi bi-person mr-1"></i> Email
                            </th>
                            <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 py-6">
                                <i class="bi bi-shield mr-1"></i> Role
                            </th>
                            <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 py-6">
                                <i class="bi bi-check-circle mr-1"></i> Approved Leaves
                            </th>
                            <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 py-6">
                                <i class="bi bi-clock mr-1"></i> Pending Leaves
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model)
                        {
                            <tr style="background: var(--moc-surface); border-radius: 0.75rem;">
                                <td class="border-0 ps-3 py-6">
                                    <div class="flex items-center gap-2">
                                        <div class="moc-icon-box bg-purple-50 rounded-full" style="width:32px;height:32px;min-width:32px;">
                                            <i class="bi bi-person-fill text-purple" style="font-size:0.75rem;"></i>
                                        </div>
                                        <span class="font-semibold text-sm">@emp.Email</span>
                                    </div>
                                </td>
                                <td class="border-0 py-6">
                                    @{
                                        var roleBadge = emp.Role switch
                                        {
                                            "DepartmentManager" => "bg-purple-50 text-purple",
                                            "WarehouseStaff" => "bg-cyan-50 text-cyan",
                                            _ => "bg-green-50 text-green"
                                        };
                                        var roleLabel = emp.Role switch
                                        {
                                            "DepartmentManager" => "Manager",
                                            "WarehouseStaff" => "Warehouse",
                                            _ => "Employee"
                                        };
                                    }
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill @roleBadge px-6 py-2 font-semibold text-xs">@roleLabel</span>
                                </td>
                                <td class="border-0 py-6">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill bg-green-50 text-green px-2 py-1 font-semibold text-xs">
                                        <i class="bi bi-check-circle-fill mr-1"></i> @emp.ApprovedLeaves
                                    </span>
                                </td>
                                <td class="border-0 py-6">
                                    @if (emp.PendingLeaves > 0)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill bg-amber-50 text-amber px-2 py-1 font-semibold text-xs">
                                            <i class="bi bi-clock-fill mr-1"></i> @emp.PendingLeaves
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-moc-text-muted text-xs">None</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden">
                @foreach (var emp in Model)
                {
                    <div class="moc-metric p-6 mb-6">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="moc-icon-box bg-purple-50 rounded-full" style="width:32px;height:32px;min-width:32px;">
                                <i class="bi bi-person-fill text-purple" style="font-size:0.75rem;"></i>
                            </div>
                            <div>
                                <span class="font-semibold text-sm">@emp.Email</span>
                                <span class="block text-moc-text-muted text-xs">@emp.Role</span>
                            </div>
                        </div>
                        <div class="flex flex-wrap -mx-3 gap-4">
                            <div class="w-full md:w-1/2 px-3">
                                <div class="rounded-3 p-2 text-center" style="background:rgba(34,197,94,0.05);">
                                    <p class="font-bold text-sm mb-0 text-green">@emp.ApprovedLeaves</p>
                                    <span class="text-moc-text-muted text-xs">Approved</span>
                                </div>
                            </div>
                            <div class="w-full md:w-1/2 px-3">
                                <div class="rounded-3 p-2 text-center" style="background:rgba(245,158,11,0.05);">
                                    <p class="font-bold text-sm mb-0 @(emp.PendingLeaves > 0 ?"text-amber" : "")">@emp.PendingLeaves</p>
                                    <span class="text-moc-text-muted text-xs">Pending</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>


