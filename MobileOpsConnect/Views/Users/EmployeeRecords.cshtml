@model PaginatedList<MobileOpsConnect.Models.EmployeeRecordViewModel>
@{
    ViewData["Title"] = "Employee Records";
    int totalCount = ViewBag.TotalCount ?? 0;
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Employee Records</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Staff directory and leave tracking overview</p>
</div>

<!-- Staff Directory Card -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-[#f4f2ff] text-[#5e4dcd] dark:bg-indigo-900/30 dark:text-indigo-400"><i class="bi bi-people text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Staff Directory</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500">@totalCount total team members</span>
                </div>
            </div>
            
            <!-- Search Form -->
            <form method="get" asp-action="EmployeeRecords" class="relative max-w-sm w-full">
                <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none text-gray-400">
                    <i class="bi bi-search text-xs"></i>
                </div>
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="py-2 ps-9 pe-16 block w-full bg-gray-50 border-gray-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400" placeholder="Search by email...">
                @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                {
                    <a asp-action="EmployeeRecords" class="absolute inset-y-0 end-10 flex items-center pe-3 text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-circle"></i>
                    </a>
                }
                <button type="submit" class="absolute inset-y-0 end-0 flex items-center pe-3 text-indigo-600 hover:text-indigo-700 font-semibold text-xs">
                    Find
                </button>
            </form>
        </div>
    </div>

    <div class="p-6">
        @if (!Model.Any())
        {
            <div class="text-center py-10">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-500 mx-auto mb-4"><i class="bi bi-person-x text-2xl"></i></span>
                <h3 class="text-lg font-semibold text-gray-800 mb-1">No Records Found</h3>
                <p class="text-sm text-gray-500">No employee records match your search or exist.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                    <thead>
                        <tr>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-person me-1"></i> Email</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-shield me-1"></i> Role</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-check-circle me-1"></i> Approved Leaves</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500"><i class="bi bi-clock me-1"></i> Pending Leaves</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                        @foreach (var emp in Model)
                        {
                            var roleBadge = emp.Role switch
                            {
                                "DepartmentManager" => "bg-purple-100 text-purple-800",
                                "WarehouseStaff" => "bg-cyan-100 text-cyan-800",
                                _ => "bg-green-100 text-green-800"
                            };
                            var roleLabel = emp.Role switch
                            {
                                "DepartmentManager" => "Manager",
                                "WarehouseStaff" => "Warehouse",
                                _ => "Employee"
                            };

                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                                <td class="whitespace-nowrap px-6 py-4">
                                    <div class="flex items-center gap-x-3">
                                        <span class="shrink-0 inline-flex justify-center items-center size-[32px] rounded-full bg-purple-100 text-purple-800"><i class="bi bi-person-fill text-sm"></i></span>
                                        <span class="text-sm font-semibold text-gray-800">@emp.Email</span>
                                    </div>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium @roleBadge">@roleLabel</span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> @emp.ApprovedLeaves</span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    @if (emp.PendingLeaves > 0)
                                    {
                                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-clock-fill"></i> @emp.PendingLeaves</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-gray-400">None</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden space-y-3">
                @foreach (var emp in Model)
                {
                    <div class="flex flex-col bg-white border shadow-sm rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800">
                        <div class="flex items-center gap-x-3 mb-3">
                            <span class="shrink-0 inline-flex justify-center items-center size-[32px] rounded-full bg-purple-100 text-purple-800"><i class="bi bi-person-fill text-sm"></i></span>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">@emp.Email</span>
                                <span class="block text-xs text-gray-500">@emp.Role</span>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div class="bg-green-50 rounded-lg p-2 text-center">
                                <p class="text-sm font-bold text-green-700 mb-0">@emp.ApprovedLeaves</p>
                                <span class="text-xs text-gray-500">Approved</span>
                            </div>
                            <div class="bg-amber-50 rounded-lg p-2 text-center">
                                <p class="text-sm font-bold mb-0 @(emp.PendingLeaves > 0 ? "text-amber-700" : "text-gray-400")">@emp.PendingLeaves</p>
                                <span class="text-xs text-gray-500">Pending</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Pagination Integration -->
    <div class="px-6 py-4 border-t border-gray-100 dark:border-neutral-800">
        <partial name="_Pagination" model="Model" />
    </div>

    @if (Model.Any())
    {
        <div class="px-6 py-3 bg-gray-50/50 dark:bg-neutral-800/50 border-t border-gray-100 dark:border-neutral-800">
            <p class="text-[11px] text-gray-500 dark:text-neutral-500 font-medium tracking-wide mb-0">
                <i class="bi bi-info-circle me-1"></i> 
                Showing @((Model.PageIndex - 1) * 10 + 1) to @(Math.Min(Model.PageIndex * 10, totalCount)) of @totalCount members
            </p>
        </div>
    }
</div>
