@model List<MobileOpsConnect.Models.EmployeeRecordViewModel>
@{
    ViewData["Title"] = "Employee Records";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> HR Module
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-people-fill"></i> @Model.Count Team Members
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Employee Records</h1>
        <p class="text-blue-100 text-lg">Staff directory and leave tracking overview</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-people-fill text-9xl text-white"></i>
    </div>
</div>

<!-- Staff Directory Card -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-people-fill text-lg"></i></span>
            <div>
                <h3 class="text-sm font-semibold text-gray-800">Staff Directory</h3>
                <span class="text-xs text-gray-500">@Model.Count team members</span>
            </div>
        </div>
    </div>

    <div class="p-6">
        @if (Model.Count == 0)
        {
            <div class="text-center py-10">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-500 mx-auto mb-4"><i class="bi bi-person-x text-2xl"></i></span>
                <h3 class="text-lg font-semibold text-gray-800 mb-1">No Records Found</h3>
                <p class="text-sm text-gray-500">No employee records found.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
                    <thead class="bg-gray-50 dark:bg-neutral-800">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-person me-1"></i> Email</th>
                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-shield me-1"></i> Role</th>
                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-check-circle me-1"></i> Approved Leaves</th>
                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-clock me-1"></i> Pending Leaves</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                        @foreach (var emp in Model)
                        {
                            var roleBadge = emp.Role switch
                            {
                                "DepartmentManager" => "bg-purple-100 text-purple-800",
                                "WarehouseStaff" => "bg-cyan-100 text-cyan-800",
                                _ => "bg-green-100 text-green-800"
                            };
                            var roleLabel = emp.Role switch
                            {
                                "DepartmentManager" => "Manager",
                                "WarehouseStaff" => "Warehouse",
                                _ => "Employee"
                            };

                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                                <td class="whitespace-nowrap px-6 py-4">
                                    <div class="flex items-center gap-x-3">
                                        <span class="shrink-0 inline-flex justify-center items-center size-[32px] rounded-full bg-purple-100 text-purple-800"><i class="bi bi-person-fill text-sm"></i></span>
                                        <span class="text-sm font-semibold text-gray-800">@emp.Email</span>
                                    </div>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium @roleBadge">@roleLabel</span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> @emp.ApprovedLeaves</span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    @if (emp.PendingLeaves > 0)
                                    {
                                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-clock-fill"></i> @emp.PendingLeaves</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-gray-400">None</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden space-y-3">
                @foreach (var emp in Model)
                {
                    <div class="flex flex-col bg-white border shadow-sm rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800">
                        <div class="flex items-center gap-x-3 mb-3">
                            <span class="shrink-0 inline-flex justify-center items-center size-[32px] rounded-full bg-purple-100 text-purple-800"><i class="bi bi-person-fill text-sm"></i></span>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">@emp.Email</span>
                                <span class="block text-xs text-gray-500">@emp.Role</span>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div class="bg-green-50 rounded-lg p-2 text-center">
                                <p class="text-sm font-bold text-green-700 mb-0">@emp.ApprovedLeaves</p>
                                <span class="text-xs text-gray-500">Approved</span>
                            </div>
                            <div class="bg-amber-50 rounded-lg p-2 text-center">
                                <p class="text-sm font-bold mb-0 @(emp.PendingLeaves > 0 ? "text-amber-700" : "text-gray-400")">@emp.PendingLeaves</p>
                                <span class="text-xs text-gray-500">Pending</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
