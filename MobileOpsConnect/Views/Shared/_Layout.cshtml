@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <title>@ViewData["Title"] - MobileOps Connect</title>
    <link rel="manifest" href="/manifest.json" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MobileOpsConnect.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

</head>
<body>

    @if (ViewData["HideLayout"] is not true)
    {
        <header class="bg-white border-b border-moc-border sticky top-0 z-50">
            <nav class="container mx-auto px-6 sm:px-6 lg:px-8 h-16 flex items-center justify-between" role="navigation" aria-label="Main navigation">
                <div class="flex items-center gap-8">
                    <a class="flex items-center gap-2 font-semibold text-lg text-moc-text hover:opacity-80 transition-opacity" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-shield-lock-fill text-moc-primary"></i>
                        <span>MobileOps<span class="font-normal text-moc-text-muted">Connect</span></span>
                    </a>
                    <div class="hidden lg:flex items-center gap-6">
                        @{
                            var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
                        }
                        <a class="text-sm font-medium transition-colors hover:text-moc-text @(currentController =="Home" && (currentAction == "Index" || currentAction == "ManagerDashboard" || currentAction == "EmployeeDashboard") ? "text-moc-text" : "text-moc-text-muted")" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2-fill mr-1.5"></i> Dashboard
                        </a>
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
                        {
                            <a class="text-sm font-medium transition-colors hover:text-moc-text @(currentController =="Accounting" ? "text-moc-text" : "text-moc-text-muted")" asp-area="" asp-controller="Accounting" asp-action="Index">
                                <i class="bi bi-journal-text mr-1.5"></i> Accounting
                            </a>
                        }
                        <a class="text-sm font-medium transition-colors hover:text-moc-text @(currentAction =="Privacy" ? "text-moc-text" : "text-moc-text-muted")" asp-area="" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-check mr-1.5"></i> Privacy
                        </a>
                    </div>
                </div>
                <div class="flex items-center gap-6">
                    <partial name="_LoginPartial" />
                </div>
            </nav>
        </header>
    }

    @if (ViewData["HideLayout"] is not true)
    {
        <div class="container mx-auto px-6 sm:px-6 lg:px-8 flex-grow flex flex-col">
            <main role="main" class="pb-8 pt-6 flex-grow flex flex-col">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main role="main" class="min-h-screen">
            @RenderBody()
        </main>
    }

    @if (ViewData["HideLayout"] is not true)
    {
        <footer class="bg-white border-t border-moc-border mt-auto py-6">
            <div class="container mx-auto px-6 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-moc-text-muted">
                    <span class="flex items-center gap-1.5">
                        <i class="bi bi-shield-lock-fill opacity-50"></i>
                        &copy; 2026 MobileOpsConnect &mdash; All rights reserved.
                    </span>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-moc-text hover:underline transition-all flex items-center gap-1.5">
                        <i class="bi bi-file-earmark-lock"></i> Privacy Policy
                    </a>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── SignalR Real-Time Updates ── *@
    <div id="signalrToastContainer" class="signalr-toast-container"></div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        // SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/inventory")
            .withAutomaticReconnect()
            .build();

        function showSignalRToast(icon, title, message) {
            const container = document.getElementById('signalrToastContainer');
            const toast = document.createElement('div');
            toast.className = 'signalr-toast';
            toast.innerHTML = `<div class="flex items-start gap-2">
                <span style="font-size:1.3rem;">${icon}</span>
                <div>
                    <strong class="block text-sm mb-1">${title}</strong>
                    <span class="text-moc-text-muted text-xs">${message}</span>
                </div>
            </div>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('toast-hide');
                setTimeout(() => toast.remove(), 350);
            }, 5000);
        }

        connection.on("StockUpdated", (productId, productName, newQty, action) => {
            showSignalRToast("📦", `${action}`, `${productName} — now at ${newQty} units`);
            setTimeout(() => location.reload(), 2000);
        });

        connection.on("LeaveStatusChanged", (leaveId, status, userId) => {
            const icon = status === "Approved" ? "✅" : status === "Rejected" ? "❌" : "📋";
            const label = status === "Pending" ? "New Leave Request" : `Leave ${status}`;
            const desc = status === "Pending"
                ? `A new leave request (#${leaveId}) has been submitted.`
                : `Leave request #${leaveId} has been ${status.toLowerCase()}.`;
            showSignalRToast(icon, label, desc);
            setTimeout(() => location.reload(), 2000);
        });

        connection.start().catch(err => console.error("SignalR Error:", err));
    </script>

    @* ── Firebase Cloud Messaging ── *@
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            // Injected from server-side config — not hardcoded in source
            window.__FIREBASE_CONFIG__ = {
                apiKey: "@Configuration["Firebase:ClientConfig:ApiKey"]",
                authDomain: "@Configuration["Firebase:ClientConfig:AuthDomain"]",
                projectId: "@Configuration["Firebase:ClientConfig:ProjectId"]",
                storageBucket: "@Configuration["Firebase:ClientConfig:StorageBucket"]",
                messagingSenderId: "@Configuration["Firebase:ClientConfig:MessagingSenderId"]",
                appId: "@Configuration["Firebase:ClientConfig:AppId"]"
            };
            window.__FIREBASE_VAPID_KEY__ = "@Configuration["Firebase:VapidKey"]";
        </script>
        <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
        <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-messaging-compat.js"></script>
        <script src="~/js/fcm-init.js" asp-append-version="true"></script>
    }

    @* ── PWA Service Worker ── *@
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .then(reg => console.log('[PWA] Service Worker registered:', reg.scope))
                .catch(err => console.error('[PWA] SW registration failed:', err));
        }
    </script>
</body>
</html>
