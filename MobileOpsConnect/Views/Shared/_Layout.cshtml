@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <title>@ViewData["Title"] - MobileOps Connect</title>
    <link rel="manifest" href="/manifest.json" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MobileOpsConnect.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

</head>
<body>

    @if (ViewData["HideLayout"] is not true)
    {
        <!-- ========== HEADER ========== -->
        <header class="flex flex-wrap sm:justify-start sm:flex-nowrap w-full bg-white text-sm py-3 dark:bg-neutral-800">
            <nav class="max-w-[85rem] w-full mx-auto px-4 sm:flex sm:items-center sm:justify-between" aria-label="Global">
                <div class="flex items-center justify-between">
                    <a class="flex-none text-xl font-semibold dark:text-white" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-shield-lock-fill text-blue-600"></i> MobileOps Connect
                    </a>
                    <div class="sm:hidden">
                        <button type="button" class="hs-collapse-toggle p-2 inline-flex justify-center items-center gap-x-2 rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none dark:bg-transparent dark:border-neutral-700 dark:text-white dark:hover:bg-white/10" data-hs-collapse="#navbar-alignment" aria-controls="navbar-alignment" aria-label="Toggle navigation">
                            <svg class="hs-collapse-open:hidden flex-shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
                            <svg class="hs-collapse-open:block hidden flex-shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </div>
                </div>
                <div id="navbar-alignment" class="hs-collapse hidden overflow-hidden transition-all duration-300 basis-full grow sm:block">
                    <div class="flex flex-col gap-5 mt-5 sm:flex-row sm:items-center sm:justify-end sm:mt-0 sm:ps-5">
                        @{
                            var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
                        }
                        <a class="font-medium text-gray-600 hover:text-gray-400 dark:text-neutral-400 dark:hover:text-neutral-500 @(currentController == "Home" && (currentAction == "Index" || currentAction == "ManagerDashboard" || currentAction == "EmployeeDashboard") ? "text-blue-500" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2-fill mr-1.5"></i> Dashboard
                        </a>
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
                        {
                            <a class="font-medium text-gray-600 hover:text-gray-400 dark:text-neutral-400 dark:hover:text-neutral-500 @(currentController == "Accounting" ? "text-blue-500" : "")" asp-area="" asp-controller="Accounting" asp-action="Index">
                                <i class="bi bi-journal-text mr-1.5"></i> Accounting
                            </a>
                        }
                        <a class="font-medium text-gray-600 hover:text-gray-400 dark:text-neutral-400 dark:hover:text-neutral-500 @(currentAction == "Privacy" ? "text-blue-500" : "")" asp-area="" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-check mr-1.5"></i> Privacy
                        </a>
                        
                        <!-- Login Partial -->
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>
        <!-- ========== END HEADER ========== -->
    }

    @if (ViewData["HideLayout"] is not true)
    {
        <div class="container mx-auto px-6 sm:px-6 lg:px-8 flex-grow flex flex-col">
            <main role="main" class="pb-8 pt-6 flex-grow flex flex-col">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main role="main" class="min-h-screen">
            @RenderBody()
        </main>
    }

    @if (ViewData["HideLayout"] is not true)
    {
        <footer class="bg-white border-t border-gray-200 mt-auto py-6">
            <div class="container mx-auto px-6 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500">
                    <span class="flex items-center gap-1.5">
                        <i class="bi bi-shield-lock-fill opacity-50"></i>
                        &copy; 2026 MobileOpsConnect &mdash; All rights reserved.
                    </span>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-gray-800 hover:underline transition-all flex items-center gap-1.5">
                        <i class="bi bi-file-earmark-lock"></i> Privacy Policy
                    </a>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/preline/preline.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── SignalR Real-Time Updates ── *@
    <div id="signalrToastContainer" class="signalr-toast-container"></div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        // SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/inventory")
            .withAutomaticReconnect()
            .build();

        function showSignalRToast(icon, title, message) {
            const container = document.getElementById('signalrToastContainer');
            const toast = document.createElement('div');
            toast.className = 'signalr-toast';
            toast.innerHTML = `<div class="flex items-start gap-2">
                <span style="font-size:1.3rem;">${icon}</span>
                <div>
                    <strong class="block text-sm mb-1">${title}</strong>
                    <span class="text-gray-500 text-xs">${message}</span>
                </div>
            </div>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('toast-hide');
                setTimeout(() => toast.remove(), 350);
            }, 5000);
        }

        connection.on("StockUpdated", (productId, productName, newQty, action) => {
            showSignalRToast("📦", `${action}`, `${productName} — now at ${newQty} units`);
            setTimeout(() => location.reload(), 2000);
        });

        connection.on("LeaveStatusChanged", (leaveId, status, userId) => {
            const icon = status === "Approved" ? "✅" : status === "Rejected" ? "❌" : "📋";
            const label = status === "Pending" ? "New Leave Request" : `Leave ${status}`;
            const desc = status === "Pending"
                ? `A new leave request (#${leaveId}) has been submitted.`
                : `Leave request #${leaveId} has been ${status.toLowerCase()}.`;
            showSignalRToast(icon, label, desc);
            setTimeout(() => location.reload(), 2000);
        });

        connection.start().catch(err => console.error("SignalR Error:", err));
    </script>

    @* ── Firebase Cloud Messaging ── *@
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            // Injected from server-side config — not hardcoded in source
            window.__FIREBASE_CONFIG__ = {
                apiKey: "@Configuration["Firebase:ClientConfig:ApiKey"]",
                authDomain: "@Configuration["Firebase:ClientConfig:AuthDomain"]",
                projectId: "@Configuration["Firebase:ClientConfig:ProjectId"]",
                storageBucket: "@Configuration["Firebase:ClientConfig:StorageBucket"]",
                messagingSenderId: "@Configuration["Firebase:ClientConfig:MessagingSenderId"]",
                appId: "@Configuration["Firebase:ClientConfig:AppId"]"
            };
            window.__FIREBASE_VAPID_KEY__ = "@Configuration["Firebase:VapidKey"]";
        </script>
        <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
        <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-messaging-compat.js"></script>
        <script src="~/js/fcm-init.js" asp-append-version="true"></script>
    }

    @* ── PWA Service Worker ── *@
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .then(reg => console.log('[PWA] Service Worker registered:', reg.scope))
                .catch(err => console.error('[PWA] SW registration failed:', err));
        }
    </script>
</body>
</html>
