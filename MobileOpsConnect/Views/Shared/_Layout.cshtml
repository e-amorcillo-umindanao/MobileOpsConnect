@inject IConfiguration Configuration
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using MobileOpsConnect.Models
@{
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="request-verification-token" content="@csrfToken" />
    <title>@ViewData["Title"] - MobileOps Connect</title>
    <link rel="manifest" href="/manifest.json" />
    <!-- iOS PWA support -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MobileOps" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <meta name="user-authenticated" content="true" />
    }
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MobileOpsConnect.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Theme Initialization Script -->
    <script>
        // Check local storage or OS preference to set initial theme BEFORE body loads
        const html = document.querySelector('html');
        const saved = localStorage.getItem('hs_theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'light');
        
        if (theme === 'dark') {
            html.classList.add('dark');
        } else {
            html.classList.remove('dark');
        }
    </script>
    <style>
        body{opacity:0}
        body.ready{opacity:1;transition:opacity .15s ease-in}
        html { background-color: #f9fafb; }
        html.dark { background-color: #171717; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-neutral-900 dark:text-neutral-300">

    @if (ViewData["HideLayout"] is not true)
    {
        <!-- ========== HEADER ========== -->
        <header class="flex flex-wrap sm:justify-start sm:flex-nowrap w-full bg-white text-sm py-3 dark:bg-neutral-800">
            <nav class="max-w-[85rem] w-full mx-auto px-4 sm:flex sm:items-center sm:justify-between" aria-label="Global">
                <div class="flex items-center justify-between gap-x-3">
                    <a class="flex-none flex items-center gap-x-2 text-lg font-bold text-gray-900 dark:text-white" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/mobileops-logo.jpg" alt="MobileOps Connect" class="size-8 rounded-lg object-contain" />
                        MobileOps
                    </a>
                <div class="flex items-center justify-between gap-x-2">
                    <!-- Theme Toggle -->
                    <button type="button" class="hs-dark-mode-active:hidden block hs-dark-mode p-2 inline-flex justify-center items-center gap-x-2 rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-700" data-hs-theme-click-value="dark">
                        <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
                        </svg>
                    </button>
                    <button type="button" class="hs-dark-mode-active:block hidden hs-dark-mode p-2 inline-flex justify-center items-center gap-x-2 rounded-lg border border-transparent bg-neutral-900/50 text-amber-400 hover:bg-neutral-900 focus:outline-none focus:bg-neutral-900" data-hs-theme-click-value="light">
                        <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="4"></circle>
                            <path d="M12 2v2"></path>
                            <path d="M12 20v2"></path>
                            <path d="m4.93 4.93 1.41 1.41"></path>
                            <path d="m17.66 17.66 1.41 1.41"></path>
                            <path d="M2 12h2"></path>
                            <path d="M20 12h2"></path>
                            <path d="m6.34 17.66-1.41 1.41"></path>
                            <path d="m19.07 4.93-1.41 1.41"></path>
                        </svg>
                    </button>
                    <!-- Notification Bell (Always visible, outside collapse) -->
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <partial name="_NotificationBell" />
                    }

                    <div class="sm:hidden">
                        <button type="button" class="hs-collapse-toggle p-2 inline-flex justify-center items-center gap-x-2 rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none dark:bg-transparent dark:border-neutral-700 dark:text-white dark:hover:bg-white/10" data-hs-collapse="#navbar-alignment" aria-controls="navbar-alignment" aria-label="Toggle navigation">
                            <svg class="hs-collapse-open:hidden flex-shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
                            <svg class="hs-collapse-open:block hidden flex-shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </div>
                </div>
                </div>
                <div id="navbar-alignment" class="hs-collapse hidden overflow-hidden transition-all duration-300 basis-full grow sm:block">
                    <div class="flex flex-col gap-5 mt-5 sm:flex-row sm:items-center sm:justify-end sm:mt-0 sm:ps-5">
                        @{
                            var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
                            string NavClass(bool isActive) =>
                                $"inline-flex items-center gap-1.5 font-medium text-gray-600 hover:text-gray-900 dark:text-neutral-400 dark:hover:text-white {(isActive ? "text-gray-900 font-bold dark:text-white" : string.Empty)}";
                        }
                        <a class="@NavClass(currentController == "Home" && (currentAction == "Index" || currentAction == "ManagerDashboard" || currentAction == "EmployeeDashboard"))" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <a class="@NavClass(currentController == "Products")" asp-area="" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-box-seam"></i> Products
                            </a>

                            @if (User.IsInRole("WarehouseStaff") || User.IsInRole("DepartmentManager") || User.IsInRole("SuperAdmin"))
                            {
                                <a class="@NavClass(currentController == "Orders")" asp-area="" asp-controller="Orders" asp-action="Index">
                                    <i class="bi bi-bag-check"></i> Orders
                                </a>
                            }

                            @if (User.IsInRole("WarehouseStaff"))
                            {
                                <a class="@NavClass(currentController == "Warehouse")" asp-area="" asp-controller="Warehouse" asp-action="Index">
                                    <i class="bi bi-building"></i> Warehouse
                                </a>
                            }

                            <a class="@NavClass(currentController == "LeaveRequests")" asp-area="" asp-controller="LeaveRequests" asp-action="Index" asp-route-view="my">
                                <i class="bi bi-calendar2-week"></i> Leave
                            </a>

                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin"))
                            {
                                <a class="@NavClass(currentController == "Users")" asp-area="" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-people"></i> Users
                                </a>

                                <a class="@NavClass(currentController == "Settings")" asp-area="" asp-controller="Settings" asp-action="Index">
                                    <i class="bi bi-sliders"></i> Settings
                                </a>
                            }

                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
                            {
                                <a class="@NavClass(currentController == "Home" && currentAction == "Analytics")" asp-area="" asp-controller="Home" asp-action="Analytics">
                                    <i class="bi bi-graph-up-arrow"></i> Analytics
                                </a>
                            }
                        }
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <a class="@NavClass(currentController == "Accounting")" asp-area="" asp-controller="Accounting" asp-action="Index">
                                <i class="bi bi-journal-text"></i> Accounting
                            </a>
                        }
                        <a class="@NavClass(currentAction == "Privacy")" asp-area="" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-check"></i> Privacy
                        </a>
                        


                        <!-- Login Partial -->
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>
        <!-- ========== END HEADER ========== -->
    }

    @if (ViewData["HideLayout"] is not true)
    {
        <div class="container mx-auto px-6 sm:px-6 lg:px-8 flex-grow flex flex-col">
            <main role="main" class="pb-8 pt-6 flex-grow flex flex-col">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main role="main" class="min-h-screen">
            @RenderBody()
        </main>
    }

    @if (ViewData["HideLayout"] is not true)
    {
        <footer class="bg-white border-t border-gray-100 mt-auto py-6 dark:bg-neutral-900 dark:border-neutral-800">
            <div class="container mx-auto px-6 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500">
                    <span class="flex items-center gap-1.5">
                        <i class="bi bi-shield-lock-fill opacity-50"></i>
                        &copy; 2026 MobileOpsConnect &mdash; All rights reserved.
                    </span>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-gray-800 hover:underline transition-all flex items-center gap-1.5">
                        <i class="bi bi-file-earmark-lock"></i> Privacy Policy
                    </a>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/preline/preline.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── SignalR Real-Time Updates ── *@
    <div id="signalrToastContainer" class="signalr-toast-container"></div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        // SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/inventory")
            .withAutomaticReconnect()
            .build();
        const LEAVE_PENDING = '@LeaveRequestStatus.Pending';
        const LEAVE_APPROVED = '@LeaveRequestStatus.Approved';
        const LEAVE_REJECTED = '@LeaveRequestStatus.Rejected';
        const ORDER_APPROVED = '@PurchaseOrderStatus.Approved';
        const ORDER_REJECTED = '@PurchaseOrderStatus.Rejected';

        function showSignalRToast(icon, title, message) {
            const container = document.getElementById('signalrToastContainer');
            const toast = document.createElement('div');
            toast.className = 'signalr-toast';
            toast.innerHTML = `<div class="flex items-start gap-2">
                <span style="font-size:1.3rem;">${icon}</span>
                <div>
                    <strong class="block text-sm mb-1">${title}</strong>
                    <span class="text-gray-500 text-xs">${message}</span>
                </div>
            </div>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('toast-hide');
                setTimeout(() => toast.remove(), 350);
            }, 5000);
        }

        function dispatchRealtimeUpdate(eventName, payload) {
            window.dispatchEvent(new CustomEvent(eventName, { detail: payload }));
        }

        connection.off("StockUpdated");
        connection.on("StockUpdated", (productId, productName, newQty, action) => {
            showSignalRToast("📦", `${action}`, `${productName} — now at ${newQty} units`);
            dispatchRealtimeUpdate('moc:stock-updated', { productId, productName, newQty, action });
        });

        connection.off("LeaveStatusChanged");
        connection.on("LeaveStatusChanged", (leaveId, status, userId, employeeName) => {
            const icon = status === LEAVE_APPROVED ? "✅" : status === LEAVE_REJECTED ? "❌" : "📋";
            const label = status === LEAVE_PENDING ? "New Leave Request" : `Leave ${status}`;
            const desc = status === LEAVE_PENDING
                ? `A new leave request from ${employeeName || 'an employee'} has been submitted.`
                : `Your leave request has been ${status.toLowerCase()}.`;
            showSignalRToast(icon, label, desc);
            dispatchRealtimeUpdate('moc:leave-status-changed', { leaveId, status, userId, employeeName });
        });

        connection.off("PurchaseOrderUpdated");
        connection.on("PurchaseOrderUpdated", (orderId, productName, quantity, action, byUser) => {
            const icon = action.includes(ORDER_APPROVED) ? "✅" : action.includes(ORDER_REJECTED) ? "❌" : "📦";
            const title = action.includes("Submitted") ? "New Purchase Order" : `PO ${action}`;
            const desc = `PO #${orderId} — ${quantity}x ${productName} by ${byUser}`;
            showSignalRToast(icon, title, desc);
            dispatchRealtimeUpdate('moc:purchase-order-updated', { orderId, productName, quantity, action, byUser });
        });

        connection.start()
            .then(() => {
                console.log("SignalR Connected.");
                if (!window._signalrConnectedFired) {
                    window._signalrConnectedFired = true;
                    window.dispatchEvent(new CustomEvent('signalr-connected'));
                }
            })
            .catch(err => console.error("SignalR Error:", err));
    </script>

    @* ── Push Notification Init ── *@
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script src="~/js/fcm-init.js" asp-append-version="true"></script>
    }

    @* ── PWA Service Worker ── *@
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .then(reg => console.log('[PWA] Service Worker registered:', reg.scope))
                .catch(err => console.error('[PWA] SW registration failed:', err));
        }
    </script>
    <!-- Push Notification Permission Banner -->
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div id="push-banner" class="push-banner hidden">
            <div class="flex items-center gap-3">
                <span class="text-xl">🔔</span>
                <div class="flex-1">
                    <p class="text-sm font-semibold text-gray-800 dark:text-white">Enable Push Notifications</p>
                    <p class="text-xs text-gray-500 dark:text-neutral-400">Get notified about leave requests, approvals, and stock alerts even when you're away.</p>
                </div>
                <button onclick="window.enablePushNotifications()" class="btn-moc-primary text-xs">Enable</button>
                <button onclick="window.dismissPushBanner()" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
    }
    <!-- Toast Notification Container -->
    <div id="toast-container" class="fixed top-4 end-4 z-[90] flex flex-col gap-3 pointer-events-none"></div>

    <script>document.body.classList.add('ready');</script>
</body>
</html>
