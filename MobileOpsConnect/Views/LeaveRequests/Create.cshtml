@model MobileOpsConnect.Models.LeaveRequest
@using MobileOpsConnect.Services

@{
    ViewData["Title"] = "File Leave Request";
}

@{
    var holidays = (List<MobileOpsConnect.Services.PublicHoliday>?)ViewBag.Holidays ?? new List<MobileOpsConnect.Services.PublicHoliday>();
    var upcomingHolidays = holidays
        .Where(h => h.Date >= DateOnly.FromDateTime(PhilippineTime.Today))
        .OrderBy(h => h.Date)
        .Take(10)
        .ToList();
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="LeaveRequests" asp-action="Index" asp-route-view="my" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to My Leave History
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span> HR Module Active
        </span>
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
            New Application
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">File Leave Request</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Submit a new leave application for manager approval</p>
</div>

<!-- Leave Info -->
<div class="flex items-center gap-x-2 mb-4">
    <i class="bi bi-bar-chart text-gray-400"></i>
    <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Leave Info</h2>
</div>

<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <!-- Balance Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg"><i class="bi bi-calendar-check text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate dark:text-neutral-400" title="Balance">Balance</p>
            </div>
            <div class="text-right shrink-0">
                <div class="flex items-center gap-x-2 justify-end">
                    <h3 class="text-xl font-medium text-gray-800 dark:text-white">12 <span class="text-[13px] text-gray-500 dark:text-neutral-500">days</span></h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Available</span>
                </div>
            </div>
        </div>
    </div>
    <!-- Total Requests Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-gray-50 text-gray-600 dark:bg-neutral-800 dark:text-neutral-400"><i class="bi bi-list-check"></i></span>
            <div class="overflow-hidden">
                <p class="text-xs uppercase tracking-wide text-gray-500 font-medium mb-0 truncate dark:text-neutral-400">Total Requests</p>
                <h3 class="text-xl font-medium text-gray-800 dark:text-white truncate">@(ViewBag.MyTotalCount ?? 0) <span class="text-[13px] text-gray-500 dark:text-neutral-500">requests</span></h3>
            </div>
        </div>
    </div>
    <!-- Pending Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-amber-100 text-amber-800 rounded-lg"><i class="bi bi-clock-history text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate dark:text-neutral-400" title="Pending">Pending</p>
            </div>
            <div class="text-right shrink-0">
                <div class="flex items-center gap-x-2 justify-end">
                    <h3 class="text-xl font-medium text-gray-800 dark:text-white">@(ViewBag.MyPendingCount ?? 0)</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-hourglass-split"></i> Awaiting</span>
                </div>
            </div>
        </div>
    </div>
    <!-- Approved Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-emerald-100 text-emerald-800 rounded-lg"><i class="bi bi-calendar-heart text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate dark:text-neutral-400" title="Approved">Approved</p>
            </div>
            <div class="text-right shrink-0">
                <div class="flex items-center gap-x-2 justify-end">
                    <h3 class="text-xl font-medium text-gray-800 dark:text-white">@(ViewBag.MyApprovedCount ?? 0)</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check2-all"></i> Approved</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Two-Column Asymmetric Layout -->
<div class="grid lg:grid-cols-12 gap-6 lg:gap-8 items-start relative pb-10">

    <!-- Left Column: Holidays & Info (Span 8) -->
    <div class="lg:col-span-8 order-2 lg:order-none space-y-8 min-w-0">
        <!-- Public Holidays Card -->
        <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-x-3">
                        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-gray-100 text-gray-800 dark:bg-neutral-800 dark:text-neutral-300"><i class="bi bi-calendar-event text-lg"></i></span>
                        <div>
                            <h3 class="text-sm font-semibold text-gray-800 dark:text-white">Philippine Public Holidays @PhilippineTime.Now.Year</h3>
                            <span class="text-xs text-gray-500 dark:text-neutral-400">Upcoming holidays &bull; Data from <strong>Nager.Date API</strong></span>
                        </div>
                    </div>
                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 shadow-sm dark:bg-indigo-900/30 dark:text-indigo-400 border dark:border-indigo-800">Live Data</span>
                </div>
            </div>
            <div class="p-6">
                @if (upcomingHolidays.Any())
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                            <thead>
                                <tr>
                                    <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest">Date</th>
                                    <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest">Holiday</th>
                                    <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest">English Name</th>
                                    <th scope="col" class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                                @foreach (var h in upcomingHolidays)
                                {
                                    var daysUntil = h.Date.DayNumber - DateOnly.FromDateTime(PhilippineTime.Today).DayNumber;
                                    <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-neutral-800/50">
                                        <td class="whitespace-nowrap px-6 py-3">
                                            <div class="flex items-center gap-x-3">
                                                <div class="shrink-0 text-center w-[48px]">
                                                    <span class="text-xs uppercase text-gray-500 block mb-0.5 dark:text-neutral-500">@h.Date.ToString("MMM")</span>
                                                    <span class="text-lg font-bold @(h.Date == DateOnly.FromDateTime(PhilippineTime.Now) ? "text-indigo-600 dark:text-indigo-400" : "text-gray-900 dark:text-white") leading-none">@h.Date.ToString("dd")</span>
                                                </div>
                                                <div>
                                                    <span class="text-sm font-semibold text-gray-800 dark:text-white">@h.Date.ToString("MMM dd, yyyy")</span><br />
                                                    <span class="text-[11px] font-medium px-2 py-0.5 rounded flex items-center gap-1 w-max mt-1
                                                        @(h.Global ? "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400" : "bg-gray-100 text-gray-600 dark:bg-neutral-800 dark:text-neutral-400")">
                                                        @(h.Global ? "National" : "Local")
                                                    </span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="whitespace-nowrap px-6 py-3"><span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">@h.LocalName</span></td>
                                        <td class="whitespace-nowrap px-6 py-3 text-right">
                                            <span class="text-sm text-gray-500 dark:text-neutral-400">@h.Name</span>
                                        </td>
                                        <td class="whitespace-nowrap px-6 py-3 text-center">
                                            @if (daysUntil == 0)
                                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium shadow-sm"><i class="bi bi-star-fill text-amber-500"></i> Today</span> }
                                            else if (daysUntil <= 60)
                                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium">In @daysUntil day@(daysUntil != 1 ? "s" : "")</span> }
                                            else
                                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-blue-50 text-blue-800 text-xs font-medium border border-blue-100">In @daysUntil days</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-xs text-gray-500 mt-4 flex items-center gap-1.5 dark:text-neutral-500">Compare your selected dates with these public holidays.</p>
                }
                else
                {
                    <div class="p-12 text-center bg-gray-50/50 dark:bg-neutral-800/10">
                        <span class="inline-flex justify-center items-center size-[56px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-800 mx-auto mb-3 dark:border-neutral-800 dark:bg-neutral-800 dark:text-neutral-400"><i class="bi bi-calendar-x text-xl"></i></span>
                        <p class="text-sm font-semibold text-gray-800 mb-1 dark:text-neutral-200">Holiday data unavailable</p>
                        <p class="text-xs text-gray-500 dark:text-neutral-500">We could not retrieve the holiday schedule at this time.</p>
                    </div>
                }
            </div>
        </div>
        <!-- Recent Leave History Card -->
        <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
                <div class="flex items-center gap-x-3">
                    <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-50 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400"><i class="bi bi-calendar2-range"></i></span>
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-500 font-medium mb-0 dark:text-neutral-400">Annual Allowance</p>
                        <h3 class="text-xl font-medium text-gray-800 dark:text-white">12 <span class="text-[13px] text-gray-500 dark:text-neutral-500">days</span></h3>
                    </div>
                </div>
            </div>
            <div class="p-6">
                @{
                    var recentLeaves = (List<MobileOpsConnect.Models.LeaveRequest>?)ViewBag.RecentLeaves ?? new List<MobileOpsConnect.Models.LeaveRequest>();
                }
                @if (recentLeaves.Any())
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                            <thead>
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-start text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
                                    <th scope="col" class="px-6 py-3 text-start text-[10px] font-bold text-gray-400 uppercase tracking-widest">Duration</th>
                                    <th scope="col" class="px-6 py-3 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
                                    <th scope="col" class="px-6 py-3 text-end text-[10px] font-bold text-gray-400 uppercase tracking-widest">Filed</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                                @foreach (var l in recentLeaves)
                                {
                                    <tr class="hover:bg-gray-50/50 transition-colors">
                                        <td class="whitespace-nowrap px-6 py-3">
                                            <span class="text-xs font-semibold text-gray-800 dark:text-neutral-300">@l.LeaveType</span>
                                        </td>
                                        <td class="whitespace-nowrap px-6 py-3">
                                            <span class="text-xs text-gray-500">@l.StartDate.ToString("MMM d") &rarr; @l.EndDate.ToString("MMM d")</span>
                                        </td>
                                        <td class="whitespace-nowrap px-6 py-3 text-center">
                                            @if (l.Status == "Pending")
                                            {
                                                <span class="inline-flex items-center py-0.5 px-2 rounded-md bg-amber-50 text-amber-600 text-[10px] font-bold uppercase tracking-wider border border-amber-100">Pending</span>
                                            }
                                            else if (l.Status == "Approved")
                                            {
                                                <span class="inline-flex items-center py-0.5 px-2 rounded-md bg-emerald-50 text-emerald-600 text-[10px] font-bold uppercase tracking-wider border border-emerald-100">Approved</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center py-0.5 px-2 rounded-md bg-red-50 text-red-600 text-[10px] font-bold uppercase tracking-wider border border-red-100">Rejected</span>
                                            }
                                        </td>
                                        <td class="whitespace-nowrap px-6 py-3 text-end">
                                            <span class="text-[10px] text-gray-400 font-medium">@l.DateRequested.ToString("MM/dd/yy")</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-50 dark:border-neutral-800 text-center">
                        <a asp-action="Index" asp-route-view="my" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 transition-colors flex items-center justify-center gap-1">
                            View Full Leave History <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center py-8">
                        <div class="shrink-0 flex justify-center items-center size-[46px] bg-gray-50 text-gray-300 rounded-full mx-auto mb-3 border border-gray-100"><i class="bi bi-folder2-open text-xl"></i></div>
                        <p class="text-xs font-semibold text-gray-600 mb-1">No leave requests filed yet</p>
                        <span class="text-[10px] text-gray-400">Your history will appear here once you submit a request.</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Sticky Application Form (Span 4) -->
    <div class="lg:col-span-4 order-1 lg:order-none lg:sticky lg:top-6 min-w-0">
        <div class="flex items-center gap-x-2 mb-4">
            <i class="bi bi-file-earmark-text text-gray-400"></i>
            <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Application Form</h2>
        </div>

        <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
            <div class="p-6">
                <form asp-action="Create">
                <div class="grid gap-y-5">
                    <!-- Leave Type -->
                    <div>
                        <label asp-for="LeaveType" class="block text-sm font-medium mb-2 dark:text-white">Type of Leave</label>
                        <select asp-for="LeaveType" class="py-3 px-4 block w-full bg-white border appearance-none text-left border-gray-200 rounded-lg text-base sm:text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400">
                            <option>Sick Leave</option>
                            <option>Vacation Leave</option>
                            <option>Emergency Leave</option>
                        </select>
                    </div>

                    <!-- Date Range -->
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="StartDate" class="block text-sm font-medium mb-2 dark:text-white">Start Date</label>
                            <input asp-for="StartDate" type="date" class="py-3 px-4 block w-full bg-white border appearance-none text-left border-gray-200 rounded-lg text-base sm:text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" />
                        </div>
                        <div>
                            <label asp-for="EndDate" class="block text-sm font-medium mb-2 dark:text-white">End Date</label>
                            <input asp-for="EndDate" type="date" class="py-3 px-4 block w-full bg-white border appearance-none text-left border-gray-200 rounded-lg text-base sm:text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" />
                        </div>
                    </div>

                    <!-- Reason -->
                    <div>
                        <label asp-for="Reason" class="block text-sm font-medium mb-2 dark:text-white">Reason for Leave</label>
                        <textarea asp-for="Reason" class="py-3 px-4 block w-full bg-white border appearance-none text-left border-gray-200 rounded-lg text-base sm:text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" rows="4" placeholder="Why do you need this leave?" style="resize:vertical;min-height:120px;"></textarea>
                        <p class="text-xs text-gray-500 mt-1.5">Be clear and concise — this helps your manager process faster.</p>
                    </div>

                    <!-- Policy -->
                    <div class="bg-blue-50/50 border border-blue-100 rounded-lg p-3 flex items-start gap-2.5">
                        <i class="bi bi-shield-check text-blue-600 mt-0.5"></i>
                        <div>
                            <p class="text-[13px] text-gray-600 leading-snug">File at least 3 days in advance (except emergencies). Must be approved prior to leave.</p>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-2 pt-2 border-t border-gray-100 mt-2">
                        <input type="submit" value="Submit Request" class="py-2.5 px-3 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] cursor-pointer transition-colors" />
                        <a asp-controller="Home" asp-action="Index" class="py-2.5 px-3 flex-[0.5] inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-colors dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300">
                            Cancel
                        </a>
                    </div>
                </div>
            </form>
        </div>
        <div class="px-6 py-4 border-t border-gray-100 bg-gray-50/50 text-center rounded-b-xl mb-0">
            <span class="text-xs text-gray-500">Securely submitted to authorized approvers.</span>
        </div>
    </div>
</div>

</div> <!-- End Asymmetric Layout Grid -->

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const startDateInput = document.getElementById('StartDate');
            const endDateInput = document.getElementById('EndDate');

            // Philippine Standard Time (UTC+8)
            const phNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Manila' }));
            const phToday = phNow.getFullYear() + '-' +
                String(phNow.getMonth() + 1).padStart(2, '0') + '-' +
                String(phNow.getDate()).padStart(2, '0');

            // Block past dates on both inputs
            startDateInput.min = phToday;
            endDateInput.min = phToday;

            // Default start date to today
            if (!startDateInput.value) {
                startDateInput.value = phToday;
            }

            if (startDateInput && endDateInput) {
                startDateInput.addEventListener('change', function () {
                    if (this.value) {
                        // Prevent selecting past dates
                        if (this.value < phToday) {
                            this.value = phToday;
                        }
                        endDateInput.min = this.value;
                        if (endDateInput.value && endDateInput.value < this.value) {
                            endDateInput.value = '';
                        }
                        endDateInput.focus();
                        if (typeof endDateInput.showPicker === 'function') {
                            try { endDateInput.showPicker(); } catch (e) { }
                        }
                    }
                });
            }
        });
    </script>
}
