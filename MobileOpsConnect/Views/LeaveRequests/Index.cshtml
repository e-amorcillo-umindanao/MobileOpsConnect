@using Microsoft.AspNetCore.Identity
@using MobileOpsConnect.Models
@inject UserManager<IdentityUser> UserManager
@model PaginatedList<MobileOpsConnect.Models.LeaveRequest>

@{
    ViewData["Title"] = "Leave Request Management";

    var currentUser = await UserManager.GetUserAsync(User);
    var currentUserId = currentUser?.Id;
    var userRoles = (Dictionary<string, string>)ViewBag.UserRoles;

    int myRank = 0;
    if (User.IsInRole("SuperAdmin")) { myRank = 4; }
    else if (User.IsInRole("SystemAdmin")) { myRank = 3; }
    else if (User.IsInRole("DepartmentManager")) { myRank = 2; }
    else { myRank = 1; }

    bool hasPower = myRank > 1;
    bool isMyView = ViewBag.IsMyView == true;
    if (isMyView) { hasPower = false; }

    int totalRequests = ViewBag.TotalCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int rejectedCount = ViewBag.RejectedCount ?? 0;
    int archivedCount = approvedCount + rejectedCount;

    string activeTabValue = ViewBag.ActiveTabValue ?? ListStatusFilters.Active;
    string archivedTabValue = ViewBag.ArchivedTabValue ?? ListStatusFilters.Archived;
    string selectedStatus = ViewBag.SelectedStatus ?? activeTabValue;
}

@functions {
    string RoleIconClass(string role) => role switch {
        "SuperAdmin" => "bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500",
        "SystemAdmin" => "bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500",
        "DepartmentManager" => "bg-purple-100 text-purple-800 dark:bg-purple-800/30 dark:text-purple-500",
        _ => "bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500"
    };
    string RoleIcon(string role) => role switch {
        "SuperAdmin" => "bi-shield-lock-fill",
        "SystemAdmin" => "bi-gear-fill",
        "DepartmentManager" => "bi-briefcase-fill",
        _ => "bi-person-fill"
    };
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    @if (hasPower)
    {
        <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Manage Leave Requests</h1>
        <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">@(User.IsInRole("SuperAdmin") ? "Review, approve & manage System Admin leave applications" : "Review, approve & manage employee leave applications")</p>
    }
    else
    {
        <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">My Leave History</h1>
        <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Track your submitted leave requests &amp; approval status</p>
    }
</div>

<!-- Leave Overview Title -->
<div class="flex items-center gap-x-2 mb-4">
    <i class="bi bi-bar-chart text-gray-400"></i>
    <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Leave Overview</h2>
</div>

<!-- Metrics Grid -->
<div class="grid grid-cols-2 @((User.IsInRole("SuperAdmin") && isMyView) ? "lg:grid-cols-3" : "lg:grid-cols-4") gap-3 sm:gap-4 lg:gap-6 mb-8 mt-2">
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 min-w-0">
        <div class="p-3 sm:p-4 md:p-5 flex items-center justify-between w-full gap-x-3 sm:gap-x-4 min-w-0">
            <div class="flex items-center gap-x-3 sm:gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-10 sm:size-[46px] bg-indigo-100 text-indigo-800 rounded-lg dark:bg-indigo-900/20 dark:text-indigo-400">
                    <i class="bi bi-calendar2-week text-lg sm:text-xl"></i>
                </div>
                <p class="text-[10px] sm:text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500 truncate" title="Total">Total</p>
            </div>
            <h3 class="text-lg sm:text-2xl font-bold text-gray-800 dark:text-neutral-200 truncate text-right shrink-0" title="@totalRequests">@totalRequests</h3>
        </div>
    </div>
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 min-w-0">
        <div class="p-3 sm:p-4 md:p-5 flex items-center justify-between w-full gap-x-3 sm:gap-x-4 min-w-0">
            <div class="flex items-center gap-x-3 sm:gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-10 sm:size-[46px] bg-amber-100 text-amber-800 rounded-lg dark:bg-amber-900/20 dark:text-amber-400">
                    <i class="bi bi-clock-history text-lg sm:text-xl"></i>
                </div>
                <p class="text-[10px] sm:text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500 truncate" title="Pending">Pending</p>
            </div>
            <h3 class="text-lg sm:text-2xl font-bold text-gray-800 dark:text-neutral-200 truncate text-right shrink-0" title="@pendingCount">@pendingCount</h3>
        </div>
    </div>
    <div class="@((User.IsInRole("SuperAdmin") && isMyView) ? "col-span-2 lg:col-span-1" : "") flex flex-col bg-white border border-gray-100 shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 min-w-0">
        <div class="p-3 sm:p-4 md:p-5 flex items-center justify-between w-full gap-x-3 sm:gap-x-4 min-w-0">
            <div class="flex items-center gap-x-3 sm:gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-10 sm:size-[46px] bg-green-100 text-green-800 rounded-lg dark:bg-emerald-900/20 dark:text-emerald-400">
                    <i class="bi bi-calendar-check text-lg sm:text-xl"></i>
                </div>
                <p class="text-[10px] sm:text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500 truncate" title="Approved">Approved</p>
            </div>
            <h3 class="text-lg sm:text-2xl font-bold text-gray-800 dark:text-neutral-200 truncate text-right shrink-0" title="@approvedCount">@approvedCount</h3>
        </div>
    </div>
    @if (!(User.IsInRole("SuperAdmin") && isMyView))
    {
        <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 min-w-0">
            <div class="p-3 sm:p-4 md:p-5 flex items-center justify-between w-full gap-x-3 sm:gap-x-4 min-w-0">
                <div class="flex items-center gap-x-3 sm:gap-x-4 min-w-0">
                    <div class="shrink-0 flex justify-center items-center size-10 sm:size-[46px] bg-red-100 text-red-800 rounded-lg dark:bg-rose-900/20 dark:text-rose-400">
                        <i class="bi bi-calendar-x text-lg sm:text-xl"></i>
                    </div>
                    <p class="text-[10px] sm:text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500 truncate" title="Rejected">Rejected</p>
                </div>
                <h3 class="text-lg sm:text-2xl font-bold text-gray-800 dark:text-neutral-200 truncate text-right shrink-0" title="@rejectedCount">@rejectedCount</h3>
            </div>
        </div>
    }
</div>

<!-- Leave Directory Title -->
<div class="flex items-center gap-x-2 mb-4">
    <i class="bi bi-folder text-gray-400"></i>
    <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Leave Directory</h2>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-4">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-neutral-800 dark:text-neutral-400"><i class="bi bi-funnel-fill text-lg"></i></span>
        <div>
            <p class="font-semibold text-sm text-gray-800 dark:text-white mb-0">@(selectedStatus == "archived" ? "Leave Archive" : "Active Requests")</p>
            <p class="text-gray-500 dark:text-neutral-400 text-xs mb-0">Showing @(selectedStatus == "archived" ? archivedCount : pendingCount) total record@( (selectedStatus == "archived" ? archivedCount : pendingCount) != 1 ? "s" : "")</p>
        </div>
    </div>
    <div class="flex flex-wrap items-center gap-2">
        <!-- Search Form -->
        <form method="get" asp-action="Index" class="relative">
            <input type="hidden" name="view" value="@(isMyView ? "my" : "")" />
            <input type="hidden" name="status" value="@selectedStatus" />
            <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none text-gray-400">
                <i class="bi bi-search text-xs"></i>
            </div>
            <input type="text" name="searchString" value="@ViewBag.SearchString" aria-label="Search leave requests" class="py-2 ps-9 pe-16 block w-full bg-white border-gray-200 rounded-lg text-xs focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="Search requests...">
            <button type="submit" class="absolute inset-y-0 end-0 flex items-center pe-3 text-indigo-600 hover:text-indigo-700 font-semibold text-[10px] uppercase tracking-wider">
                Search
            </button>
        </form>
        @if (!hasPower)
        {
            <a asp-action="Create" class="btn-moc-primary inline-flex items-center gap-x-2">
                Apply for Leave
            </a>
        }
    </div>
</div>

<!-- Tab Header Underline -->
<nav class="flex space-x-6 border-b border-gray-200 dark:border-neutral-700 mb-6" aria-label="Tabs">
    <a asp-action="Index" asp-route-view="@(isMyView ? "my" : "")" asp-route-status="@activeTabValue" asp-route-searchString="@ViewBag.SearchString" 
       class="tab-link py-3 px-1 inline-flex items-center gap-2 border-b-2 text-sm whitespace-nowrap font-bold focus:outline-none focus:ring-0 transition-colors @(selectedStatus == activeTabValue ? "border-gray-800 text-gray-900 dark:border-white dark:text-white active-tab" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-neutral-400 inactive-tab")">
        Active
        <span class="inline-flex items-center py-0.5 px-2 rounded-full text-[10px] font-bold @(selectedStatus == activeTabValue ? "bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-white" : "bg-gray-50 text-gray-500 dark:bg-neutral-800 dark:text-neutral-400")">@pendingCount</span>
    </a>
    <a asp-action="Index" asp-route-view="@(isMyView ? "my" : "")" asp-route-status="@archivedTabValue" asp-route-searchString="@ViewBag.SearchString" 
       class="tab-link py-3 px-1 inline-flex items-center gap-2 border-b-2 text-sm whitespace-nowrap font-bold focus:outline-none focus:ring-0 transition-colors @(selectedStatus == archivedTabValue ? "border-gray-800 text-gray-900 dark:border-white dark:text-white active-tab" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-neutral-400 inactive-tab")">
        Archive
        <span class="inline-flex items-center py-0.5 px-2 rounded-full text-[10px] font-bold @(selectedStatus == archivedTabValue ? "bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-white" : "bg-gray-50 text-gray-500 dark:bg-neutral-800 dark:text-neutral-400")">@archivedCount</span>
    </a>
</nav>

<!-- Leave Table Container (Targeted by AJAX) -->
<div id="table-container">
    <partial name="_LeaveRequestsTable" model="Model" />
</div>



<!-- Tab Toggle & Pagination Script (Native AJAX) -->
<script>
    (function () {
        const TAB_STATUS_ACTIVE = '@activeTabValue';

        function loadContent(url, updateHistory = true) {
            const container = document.getElementById('table-container');
            if (!container) return;

            container.style.opacity = '0.5';

            fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => {
                if (!response.ok) throw new Error();
                return response.text();
            })
            .then(html => {
                container.innerHTML = html;
                container.style.opacity = '1';
                if (updateHistory) history.pushState(null, '', url);
                updateActiveTab(url);
            })
            .catch(() => {
                // Graceful degradation on failure: full page reload
                window.location.href = url;
            });
        }

        function updateActiveTab(url) {
            const params = new URLSearchParams(new URL(url, location.origin).search);
            const status = params.get('status') || TAB_STATUS_ACTIVE;
            
            document.querySelectorAll('.tab-link').forEach(tab => {
                const tabStatus = new URLSearchParams(
                    new URL(tab.href, location.origin).search
                ).get('status') || TAB_STATUS_ACTIVE;
                
                if (tabStatus === status) {
                    tab.classList.remove('border-transparent', 'text-gray-500', 'hover:text-gray-700', 'dark:text-neutral-400', 'inactive-tab');
                    tab.classList.add('border-gray-800', 'text-gray-900', 'dark:border-white', 'dark:text-white', 'active-tab');
                    
                    const badge = tab.querySelector('span');
                    if(badge) {
                        badge.classList.remove('bg-gray-50', 'text-gray-500', 'dark:bg-neutral-800', 'dark:text-neutral-400');
                        badge.classList.add('bg-gray-100', 'text-gray-800', 'dark:bg-neutral-700', 'dark:text-white');
                    }
                } else {
                    tab.classList.remove('border-gray-800', 'text-gray-900', 'dark:border-white', 'dark:text-white', 'active-tab');
                    tab.classList.add('border-transparent', 'text-gray-500', 'hover:text-gray-700', 'dark:text-neutral-400', 'inactive-tab');
                    
                    const badge = tab.querySelector('span');
                    if(badge) {
                        badge.classList.remove('bg-gray-100', 'text-gray-800', 'dark:bg-neutral-700', 'dark:text-white');
                        badge.classList.add('bg-gray-50', 'text-gray-500', 'dark:bg-neutral-800', 'dark:text-neutral-400');
                    }
                }
            });
        }

        // Event delegation - single listener handles tabs AND dynamic pagination links
        document.addEventListener('click', (e) => {
            const link = e.target.closest('.tab-link, #table-container a[href]');
            if (link) {
                e.preventDefault();
                loadContent(link.getAttribute('href'));
            }
        });

        // Browser Back/Forward support
        window.addEventListener('popstate', () => {
            loadContent(window.location.href, false);
        });

        window.addEventListener('moc:leave-status-changed', () => {
            loadContent(window.location.href, false);
        });
    })();
</script>
