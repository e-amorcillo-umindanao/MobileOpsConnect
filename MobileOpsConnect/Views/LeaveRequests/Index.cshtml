@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@model IEnumerable<MobileOpsConnect.Models.LeaveRequest>

@{
    ViewData["Title"] = "Leave Request Management";

    var currentUser = await UserManager.GetUserAsync(User);
    var currentUserId = currentUser?.Id;
    var userRoles = (Dictionary<string, string>)ViewBag.UserRoles;

    int myRank = 0;
    if (User.IsInRole("SuperAdmin")) { myRank = 4; }
    else if (User.IsInRole("SystemAdmin")) { myRank = 3; }
    else if (User.IsInRole("DepartmentManager")) { myRank = 2; }
    else { myRank = 1; }

    bool hasPower = myRank > 1;

    int totalRequests = Model.Count();
    int pendingCount = Model.Count(l => l.Status == "Pending");
    int approvedCount = Model.Count(l => l.Status == "Approved");
    int rejectedCount = Model.Count(l => l.Status == "Rejected");
    int archivedCount = approvedCount + rejectedCount;

    var activeLeaves = Model.Where(l => l.Status == "Pending").ToList();
    var archivedLeaves = Model.Where(l => l.Status == "Approved" || l.Status == "Rejected").ToList();
}

@functions {
    string RoleIconClass(string role) => role switch {
        "SuperAdmin" => "bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500",
        "SystemAdmin" => "bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500",
        "DepartmentManager" => "bg-purple-100 text-purple-800 dark:bg-purple-800/30 dark:text-purple-500",
        _ => "bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500"
    };
    string RoleIcon(string role) => role switch {
        "SuperAdmin" => "bi-shield-lock-fill",
        "SystemAdmin" => "bi-gear-fill",
        "DepartmentManager" => "bi-briefcase-fill",
        _ => "bi-person-fill"
    };
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> HR Module Active
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-calendar2-week"></i> @totalRequests Total Request@(totalRequests != 1 ? "s" : "")
            </span>
            @if (pendingCount > 0)
            {
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-amber-500/30 text-white">
                    <i class="bi bi-exclamation-circle-fill"></i> @pendingCount Pending
                </span>
            }
        </div>
        @if (hasPower)
        {
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Manage Leave Requests</h1>
            <p class="text-blue-100 text-lg">Review, approve &amp; manage employee leave applications</p>
        }
        else
        {
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">My Leave History</h1>
            <p class="text-blue-100 text-lg">Track your submitted leave requests &amp; approval status</p>
        }
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-calendar2-week-fill text-9xl text-white"></i>
    </div>
</div>

<!-- Leave Overview Title -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-bar-chart-line-fill text-indigo-500"></i> Leave Overview
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<!-- Metrics Grid -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg"><i class="bi bi-calendar2-week text-xl"></i></div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500">Total</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@totalRequests</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium"><i class="bi bi-list-check"></i> All</span>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-amber-100 text-amber-800 rounded-lg"><i class="bi bi-clock-history text-xl"></i></div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500">Pending</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@pendingCount</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-hourglass-split"></i> Awaiting</span>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg"><i class="bi bi-calendar-check text-xl"></i></div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500">Approved</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@approvedCount</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Cleared</span>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg"><i class="bi bi-calendar-x text-xl"></i></div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500">Rejected</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@rejectedCount</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-x-circle-fill"></i> Denied</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Leave Directory Title -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-list-columns-reverse text-amber-500"></i> Leave Directory
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-4">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-funnel-fill text-lg"></i></span>
        <div>
            <p class="font-semibold text-sm text-gray-800 mb-0" id="lv-tab-label">Active Requests</p>
            <p class="text-gray-500 text-xs mb-0" id="lv-tab-count">Showing @pendingCount record@(pendingCount != 1 ? "s" : "")</p>
        </div>
    </div>
    <div class="flex gap-2">
        @if (!hasPower)
        {
            <a asp-action="Create" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                <i class="bi bi-plus-circle"></i> Apply for Leave
            </a>
        }
    </div>
</div>

<!-- Tab Pills -->
<div class="flex gap-2 mb-6">
    <button class="py-2 px-4 inline-flex items-center gap-2 text-sm font-medium rounded-lg lv-tab-btn active bg-blue-600 text-white border border-transparent" data-tab="active">
        <i class="bi bi-hourglass-split"></i> Active
        <span class="inline-flex items-center py-0.5 px-2.5 rounded-full text-xs font-semibold bg-white/20 text-white">@pendingCount</span>
    </button>
    <button class="py-2 px-4 inline-flex items-center gap-2 text-sm font-medium rounded-lg lv-tab-btn bg-white text-gray-500 border border-gray-200 shadow-sm hover:text-gray-800 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" data-tab="archived">
        <i class="bi bi-archive"></i> Archive
        <span class="inline-flex items-center py-0.5 px-2.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-neutral-300">@archivedCount</span>
    </button>
</div>

<!-- Leave Table Card -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">

    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-cyan-100 text-cyan-800"><i class="bi bi-table text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800 dark:text-neutral-200" id="lv-card-title">Leave Records</h3>
                    <span class="text-xs text-gray-500" id="lv-card-subtitle">@pendingCount pending application@(pendingCount != 1 ? "s" : "")</span>
                </div>
            </div>
            <div class="flex gap-1 flex-wrap" id="lv-card-badges">
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium">@pendingCount Pending</span>
            </div>
        </div>
    </div>

    <div class="p-6">

        <!-- ACTIVE LEAVES SECTION -->
        <div id="lv-active-section">
            @if (activeLeaves.Count == 0)
            {
                <div class="text-center py-10">
                    <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4">
                        <i class="bi bi-check-circle-fill text-2xl"></i>
                    </span>
                    <h3 class="text-lg font-semibold text-gray-800 mb-1">All Caught Up!</h3>
                    <p class="text-sm text-gray-500">No pending leave requests. Check the Archive tab for resolved applications.</p>
                </div>
            }
            else
            {
                <!-- Desktop Table -->
                <div class="hidden lg:block">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full inline-block align-middle">
                            <div class="border rounded-xl shadow-sm overflow-hidden border-gray-200 dark:border-neutral-700">
                                <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
                                    <thead class="bg-gray-50 dark:bg-neutral-800">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-person me-1"></i> Employee</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-tag me-1"></i> Type</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-calendar-range me-1"></i> Dates</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-chat-text me-1"></i> Reason</th>
                                            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase"><i class="bi bi-flag me-1"></i> Status</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-clock me-1"></i> Filed</th>
                                            @if (hasPower)
                                            {
                                                <th scope="col" class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase">Actions</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                                        @foreach (var item in activeLeaves)
                                        {
                                            bool isMyRequest = (item.UserID == currentUserId);
                                            string rRole = userRoles.ContainsKey(item.UserID) ? userRoles[item.UserID] : "Employee";
                                            int targetRank = rRole == "SuperAdmin" ? 4 : rRole == "SystemAdmin" ? 3 : rRole == "DepartmentManager" ? 2 : 1;
                                            bool canApproveThisRow = (myRank > targetRank);

                                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors @(hasPower && canApproveThisRow ? "border-l-4 border-l-amber-500" : "")">
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <div class="flex items-center gap-x-3">
                                                        <span class="shrink-0 inline-flex justify-center items-center size-[36px] rounded-full @(RoleIconClass(rRole))">
                                                            <i class="bi @(RoleIcon(rRole)) text-sm"></i>
                                                        </span>
                                                        <div>
                                                            <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">
                                                                @(item.User?.UserName ?? "Unknown")
                                                                @if (isMyRequest)
                                                                {
                                                                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium ms-1">YOU</span>
                                                                }
                                                            </p>
                                                            <span class="text-xs text-gray-500">@rRole</span>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800">@item.LeaveType</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">@item.StartDate.ToString("MMM dd") – @item.EndDate.ToString("MMM dd")</p>
                                                    <span class="text-xs text-gray-500">@((item.EndDate - item.StartDate).Days + 1) Day@(((item.EndDate - item.StartDate).Days + 1) != 1 ? "s" : "")</span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span class="text-sm text-gray-500 inline-block max-w-[180px] truncate" title="@item.Reason">@item.Reason</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4 text-center">
                                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800"><i class="bi bi-hourglass-split"></i> Pending</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="text-sm text-gray-500">@item.DateRequested.ToString("MMM dd, yyyy")</span>
                                                </td>
                                                @if (hasPower)
                                                {
                                                    <td class="whitespace-nowrap px-6 py-4 text-end">
                                                        @if (canApproveThisRow)
                                                        {
                                                            <div class="flex justify-end gap-1">
                                                                <form asp-action="Approve" asp-route-id="@item.LeaveID" method="post" class="inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-green-200 bg-green-50 text-green-800 hover:bg-green-100" title="Approve"><i class="bi bi-check-lg"></i></button>
                                                                </form>
                                                                <form asp-action="Reject" asp-route-id="@item.LeaveID" method="post" class="inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100" title="Reject"><i class="bi bi-x-lg"></i></button>
                                                                </form>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-xs text-gray-400 italic"><i class="bi bi-lock me-1"></i>Higher Approval</span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mobile Card List -->
                <div class="lg:hidden space-y-3">
                    @foreach (var item in activeLeaves)
                    {
                        bool isMyRequest = (item.UserID == currentUserId);
                        string rRole = userRoles.ContainsKey(item.UserID) ? userRoles[item.UserID] : "Employee";
                        int targetRank = rRole == "SuperAdmin" ? 4 : rRole == "SystemAdmin" ? 3 : rRole == "DepartmentManager" ? 2 : 1;
                        bool canApproveThisRow = (myRank > targetRank);

                        <div class="flex flex-col bg-white border border-l-4 border-l-amber-500 shadow-sm rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center gap-x-3 min-w-0">
                                    <span class="shrink-0 inline-flex justify-center items-center size-[36px] rounded-full @(RoleIconClass(rRole))">
                                        <i class="bi @(RoleIcon(rRole)) text-sm"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-800 mb-0 truncate">
                                            @(item.User?.UserName ?? "Unknown")
                                            @if (isMyRequest) { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium ms-1">YOU</span> }
                                        </p>
                                        <span class="text-xs text-gray-500">@rRole</span>
                                    </div>
                                </div>
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-hourglass-split"></i> Pending</span>
                            </div>
                            <div class="grid grid-cols-2 gap-2 mb-3">
                                <div class="bg-cyan-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">Type</p><p class="text-sm font-semibold text-gray-800 mb-0">@item.LeaveType</p></div>
                                <div class="bg-indigo-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">Duration</p><p class="text-sm font-semibold text-gray-800 mb-0">@((item.EndDate - item.StartDate).Days + 1) Day@(((item.EndDate - item.StartDate).Days + 1) != 1 ? "s" : "")</p></div>
                                <div class="bg-green-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">From</p><p class="text-sm font-semibold text-gray-800 mb-0">@item.StartDate.ToString("MMM dd")</p></div>
                                <div class="bg-purple-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">To</p><p class="text-sm font-semibold text-gray-800 mb-0">@item.EndDate.ToString("MMM dd")</p></div>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-2 mb-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">Reason</p><p class="text-sm text-gray-800 mb-0">@item.Reason</p></div>
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-gray-500 text-xs"><i class="bi bi-clock me-1"></i>Filed: @item.DateRequested.ToString("MMM dd, yyyy")</span>
                            </div>
                            @if (hasPower)
                            {
                                @if (canApproveThisRow)
                                {
                                    <div class="flex gap-2">
                                        <form asp-action="Approve" asp-route-id="@item.LeaveID" method="post" class="flex-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="w-full py-2 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-green-200 bg-green-50 text-green-800 hover:bg-green-100"><i class="bi bi-check-circle"></i> Approve</button>
                                        </form>
                                        <form asp-action="Reject" asp-route-id="@item.LeaveID" method="post" class="flex-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="w-full py-2 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100"><i class="bi bi-x-circle"></i> Reject</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center bg-gray-50 rounded-lg p-2"><span class="text-gray-400 text-xs italic"><i class="bi bi-lock me-1"></i>Awaiting higher-level approval</span></div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ARCHIVED LEAVES SECTION -->
        <div id="lv-archived-section" style="display:none;">
            @if (archivedLeaves.Count == 0)
            {
                <div class="text-center py-10">
                    <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-amber-50 bg-amber-100 text-amber-800 mx-auto mb-4">
                        <i class="bi bi-hourglass-split text-2xl"></i>
                    </span>
                    <h3 class="text-lg font-semibold text-gray-800 mb-1">No Archived Leaves</h3>
                    <p class="text-sm text-gray-500">No leave requests have been resolved yet. All requests are still pending.</p>
                </div>
            }
            else
            {
                <!-- Desktop Table -->
                <div class="hidden lg:block">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full inline-block align-middle">
                            <div class="border rounded-xl shadow-sm overflow-hidden border-gray-200 dark:border-neutral-700">
                                <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
                                    <thead class="bg-gray-50 dark:bg-neutral-800">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-person me-1"></i> Employee</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-tag me-1"></i> Type</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-calendar-range me-1"></i> Dates</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-chat-text me-1"></i> Reason</th>
                                            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase"><i class="bi bi-flag me-1"></i> Status</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-clock me-1"></i> Filed</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                                        @foreach (var item in archivedLeaves)
                                        {
                                            bool isMyRequest = (item.UserID == currentUserId);
                                            string rRole = userRoles.ContainsKey(item.UserID) ? userRoles[item.UserID] : "Employee";

                                            <tr class="opacity-60 hover:opacity-100 transition-opacity">
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <div class="flex items-center gap-x-3">
                                                        <span class="shrink-0 inline-flex justify-center items-center size-[36px] rounded-full @(RoleIconClass(rRole))"><i class="bi @(RoleIcon(rRole)) text-sm"></i></span>
                                                        <div>
                                                            <p class="text-sm font-semibold text-gray-800 mb-0">@(item.User?.UserName ?? "Unknown") @if (isMyRequest) { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium ms-1">YOU</span> }</p>
                                                            <span class="text-xs text-gray-500">@rRole</span>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4"><span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800">@item.LeaveType</span></td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <p class="text-sm font-semibold text-gray-800 mb-0">@item.StartDate.ToString("MMM dd") – @item.EndDate.ToString("MMM dd")</p>
                                                    <span class="text-xs text-gray-500">@((item.EndDate - item.StartDate).Days + 1) Day@(((item.EndDate - item.StartDate).Days + 1) != 1 ? "s" : "")</span>
                                                </td>
                                                <td class="px-6 py-4"><span class="text-sm text-gray-500 inline-block max-w-[180px] truncate" title="@item.Reason">@item.Reason</span></td>
                                                <td class="whitespace-nowrap px-6 py-4 text-center">
                                                    @if (item.Status == "Approved")
                                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><i class="bi bi-check-circle-fill"></i> Approved</span> }
                                                    else
                                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="bi bi-x-circle-fill"></i> Rejected</span> }
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4"><span class="text-sm text-gray-500">@item.DateRequested.ToString("MMM dd, yyyy")</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mobile Card List -->
                <div class="lg:hidden space-y-3">
                    @foreach (var item in archivedLeaves)
                    {
                        bool isMyRequest = (item.UserID == currentUserId);
                        string rRole = userRoles.ContainsKey(item.UserID) ? userRoles[item.UserID] : "Employee";

                        <div class="flex flex-col bg-white border border-l-4 shadow-sm rounded-xl p-4 opacity-60 dark:bg-neutral-900 dark:border-neutral-800 @(item.Status == "Approved" ? "border-l-green-500" : "border-l-red-500")">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center gap-x-3 min-w-0">
                                    <span class="shrink-0 inline-flex justify-center items-center size-[36px] rounded-full @(RoleIconClass(rRole))"><i class="bi @(RoleIcon(rRole)) text-sm"></i></span>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-800 mb-0 truncate">@(item.User?.UserName ?? "Unknown") @if (isMyRequest) { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium ms-1">YOU</span> }</p>
                                        <span class="text-xs text-gray-500">@rRole</span>
                                    </div>
                                </div>
                                @if (item.Status == "Approved")
                                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Approved</span> }
                                else
                                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-x-circle-fill"></i> Rejected</span> }
                            </div>
                            <div class="grid grid-cols-2 gap-2 mb-3">
                                <div class="bg-cyan-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">Type</p><p class="text-sm font-semibold text-gray-800 mb-0">@item.LeaveType</p></div>
                                <div class="bg-indigo-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">Duration</p><p class="text-sm font-semibold text-gray-800 mb-0">@((item.EndDate - item.StartDate).Days + 1) Day@(((item.EndDate - item.StartDate).Days + 1) != 1 ? "s" : "")</p></div>
                                <div class="bg-green-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">From</p><p class="text-sm font-semibold text-gray-800 mb-0">@item.StartDate.ToString("MMM dd")</p></div>
                                <div class="bg-purple-50 rounded-lg p-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">To</p><p class="text-sm font-semibold text-gray-800 mb-0">@item.EndDate.ToString("MMM dd")</p></div>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-2 mb-2"><p class="text-gray-500 text-xs mb-0 uppercase font-medium">Reason</p><p class="text-sm text-gray-800 mb-0">@item.Reason</p></div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-gray-500 text-xs"><i class="bi bi-clock me-1"></i>Filed: @item.DateRequested.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="text-center bg-gray-50 rounded-lg p-2"><span class="text-gray-400 text-xs"><i class="bi bi-archive me-1"></i>Archived — @item.Status</span></div>
                        </div>
                    }
                </div>
            }
        </div>

    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-gray-200 dark:border-neutral-700">
        <div class="flex flex-wrap justify-between items-center gap-2">
            <span class="text-xs text-gray-500" id="lv-footer-text"><i class="bi bi-info-circle me-1"></i> Showing @pendingCount pending request@(pendingCount != 1 ? "s" : "")</span>
            <div class="flex gap-1 flex-wrap" id="lv-footer-badges">
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium">@pendingCount Pending</span>
            </div>
        </div>
    </div>
</div>

<!-- Back to Dashboard -->
<div class="flex justify-start mb-6">
    <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>

<!-- Tab Toggle Script -->
<script>
(function () {
    const btns = document.querySelectorAll('.lv-tab-btn');
    const activeSection = document.getElementById('lv-active-section');
    const archivedSection = document.getElementById('lv-archived-section');
    const tabLabel = document.getElementById('lv-tab-label');
    const tabCount = document.getElementById('lv-tab-count');
    const cardTitle = document.getElementById('lv-card-title');
    const cardSubtitle = document.getElementById('lv-card-subtitle');
    const cardBadges = document.getElementById('lv-card-badges');
    const footerText = document.getElementById('lv-footer-text');
    const footerBadges = document.getElementById('lv-footer-badges');

    const pendingCount = @pendingCount;
    const archivedCount = @archivedCount;
    const approvedCount = @approvedCount;
    const rejectedCount = @rejectedCount;

    btns.forEach(btn => {
        btn.addEventListener('click', function () {
            const tab = this.dataset.tab;

            btns.forEach(b => {
                b.classList.remove('active');
                b.className = 'py-2 px-4 inline-flex items-center gap-2 text-sm font-medium rounded-lg lv-tab-btn bg-white text-gray-500 border border-gray-200 shadow-sm hover:text-gray-800';
            });
            this.classList.add('active');
            this.className = 'py-2 px-4 inline-flex items-center gap-2 text-sm font-medium rounded-lg lv-tab-btn active bg-blue-600 text-white border border-transparent';

            // Update badge inside the clicked button
            const badges = this.querySelectorAll('span');
            badges.forEach(s => { s.className = 'inline-flex items-center py-0.5 px-2.5 rounded-full text-xs font-semibold bg-white/20 text-white'; });
            // Reset other buttons' badges
            btns.forEach(b => {
                if (!b.classList.contains('active')) {
                    const otherBadges = b.querySelectorAll('span');
                    otherBadges.forEach(s => { s.className = 'inline-flex items-center py-0.5 px-2.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800'; });
                }
            });

            if (tab === 'active') {
                activeSection.style.display = '';
                archivedSection.style.display = 'none';
                tabLabel.textContent = 'Active Requests';
                tabCount.textContent = 'Showing ' + pendingCount + ' record' + (pendingCount !== 1 ? 's' : '');
                cardTitle.textContent = 'Leave Records';
                cardSubtitle.textContent = pendingCount + ' pending application' + (pendingCount !== 1 ? 's' : '');
                cardBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium">' + pendingCount + ' Pending</span>';
                footerText.innerHTML = '<i class="bi bi-info-circle me-1"></i> Showing ' + pendingCount + ' pending request' + (pendingCount !== 1 ? 's' : '');
                footerBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium">' + pendingCount + ' Pending</span>';
            } else {
                activeSection.style.display = 'none';
                archivedSection.style.display = '';
                tabLabel.textContent = 'Archived Requests';
                tabCount.textContent = 'Showing ' + archivedCount + ' record' + (archivedCount !== 1 ? 's' : '');
                cardTitle.textContent = 'Leave Archive';
                cardSubtitle.textContent = archivedCount + ' resolved application' + (archivedCount !== 1 ? 's' : '');
                cardBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium">' + approvedCount + ' Approved</span>' +
                    '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium">' + rejectedCount + ' Rejected</span>';
                footerText.innerHTML = '<i class="bi bi-info-circle me-1"></i> Showing ' + archivedCount + ' archived request' + (archivedCount !== 1 ? 's' : '');
                footerBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium">' + approvedCount + ' Approved</span>' +
                    '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium">' + rejectedCount + ' Rejected</span>';
            }
        });
    });
})();
</script>
