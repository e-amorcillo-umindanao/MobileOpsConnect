@using Microsoft.AspNetCore.Identity
@using MobileOpsConnect.Models
@inject UserManager<IdentityUser> UserManager
@model PaginatedList<MobileOpsConnect.Models.LeaveRequest>

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var currentUserId = currentUser?.Id;
    var userRoles = (Dictionary<string, string>)ViewBag.UserRoles;

    int myRank = 0;
    if (User.IsInRole("SuperAdmin")) { myRank = 4; }
    else if (User.IsInRole("SystemAdmin")) { myRank = 3; }
    else if (User.IsInRole("DepartmentManager")) { myRank = 2; }
    else { myRank = 1; }

    bool hasPower = myRank > 1;
    bool isMyView = ViewBag.IsMyView == true;
    if (isMyView) { hasPower = false; }

    int totalRequests = ViewBag.TotalCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
}

@functions {
    string RoleIconClass(string role) => role switch {
        "SuperAdmin" => "bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500",
        "SystemAdmin" => "bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500",
        "DepartmentManager" => "bg-purple-100 text-purple-800 dark:bg-purple-800/30 dark:text-purple-500",
        _ => "bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500"
    };
    string RoleIcon(string role) => role switch {
        "SuperAdmin" => "bi-shield-lock-fill",
        "SystemAdmin" => "bi-gear-fill",
        "DepartmentManager" => "bi-briefcase-fill",
        _ => "bi-person-fill"
    };
}

<!-- Leave Table Card -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6 relative overflow-hidden">

    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-cyan-100 text-cyan-800 dark:bg-cyan-800/30 dark:text-cyan-500"><i class="bi bi-table text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800 dark:text-neutral-200" id="lv-card-title">Leave Records</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500" id="lv-card-subtitle">@pendingCount pending application@(pendingCount != 1 ? "s" : "")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="p-6">
        @if (!Model.Any())
        {
            <div class="text-center py-20 px-6">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-400 mx-auto mb-4 dark:border-neutral-800 dark:bg-neutral-800/50">
                    <i class="bi bi-inbox text-2xl"></i>
                </span>
                <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-1">No Leave Requests Found</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-500">There are no leave requests to display.</p>
            </div>
        }
        else
        {
                <!-- Desktop Table -->
                <div class="hidden md:block">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full inline-block align-middle">
                            <div class="border rounded-xl shadow-sm overflow-hidden border-gray-200 dark:border-neutral-700">
                                <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                                    <thead class="bg-gray-50 dark:bg-neutral-800/50">
                                        <tr>
                                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Employee</th>
                                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Type</th>
                                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Dates</th>
                                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Reason</th>
                                            <th scope="col" class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Status</th>
                                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Filed</th>
                                            @if (hasPower)
                                            {
                                                <th scope="col" class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Actions</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                                        @foreach (var item in Model)
                                        {
                                            bool isMyRequest = (item.UserID == currentUserId);
                                            string rRole = userRoles.ContainsKey(item.UserID) ? userRoles[item.UserID] : "Employee";
                                            int targetRank = rRole == "SuperAdmin" ? 4 : rRole == "SystemAdmin" ? 3 : rRole == "DepartmentManager" ? 2 : 1;
                                            bool canApproveThisRow = (myRank > targetRank) && item.Status == LeaveRequestStatus.Pending;

                                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors @(canApproveThisRow ? "border-l-4 border-l-amber-500" : "")">
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <div class="flex items-center gap-x-3">
                                                        <span class="shrink-0 inline-flex justify-center items-center size-[36px] rounded-full @(RoleIconClass(rRole))">
                                                            <i class="bi @(RoleIcon(rRole)) text-sm"></i>
                                                        </span>
                                                        <div>
                                                            <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">
                                                                @(item.User?.UserName ?? "Unknown")
                                                                @if (isMyRequest)
                                                                {
                                                                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-400 text-xs font-medium ms-1">YOU</span>
                                                                }
                                                            </p>
                                                            <span class="text-xs text-gray-500 dark:text-neutral-500">@rRole</span>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800 dark:bg-cyan-800/30 dark:text-cyan-400">@item.LeaveType</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">@item.StartDate.ToString("MMM dd") – @item.EndDate.ToString("MMM dd")</p>
                                                    <span class="text-xs text-gray-500 dark:text-neutral-500">@((item.EndDate - item.StartDate).Days + 1) Day@(((item.EndDate - item.StartDate).Days + 1) != 1 ? "s" : "")</span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span class="text-sm text-gray-500 dark:text-neutral-400 inline-block max-w-[180px] truncate" title="@item.Reason">@item.Reason</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4 text-center">
                                                    @if (item.Status == LeaveRequestStatus.Pending)
                                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500">Pending</span> }
                                                    else if (item.Status == LeaveRequestStatus.Approved)
                                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-emerald-800/30 dark:text-emerald-500">Approved</span> }
                                                    else
                                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-rose-800/30 dark:text-rose-500">Rejected</span> }
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="text-sm text-gray-500 dark:text-neutral-400">@item.DateRequested.ToString("MMM dd, yyyy")</span>
                                                </td>
                                                @if (hasPower)
                                                {
                                                    <td class="whitespace-nowrap px-6 py-4 text-end">
                                                        @if (canApproveThisRow)
                                                        {
                                                            <div class="flex justify-end gap-1">
                                                                <form asp-action="Approve" asp-route-id="@item.LeaveID" method="post" class="inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-green-200 bg-green-50 text-green-800 hover:bg-green-100 dark:border-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-500 dark:hover:bg-emerald-800/50" title="Approve" onclick="return confirm('Approve leave request #@item.LeaveID?');"><i class="bi bi-check-lg"></i></button>
                                                                </form>
                                                                <form asp-action="Reject" asp-route-id="@item.LeaveID" method="post" class="inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="decisionReason" value="" />
                                                                    <button type="submit" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100 dark:border-rose-800 dark:bg-rose-900/30 dark:text-rose-500 dark:hover:bg-rose-800/50" title="Reject" onclick="return openLeaveRejectModal(@item.LeaveID, this.form);"><i class="bi bi-x-lg"></i></button>
                                                                </form>
                                                            </div>
                                                        }
                                                        else if (item.Status == LeaveRequestStatus.Pending)
                                                        {
                                                            <span class="text-xs text-gray-400 italic dark:text-neutral-600">Higher Approval</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-xs text-gray-400 dark:text-neutral-600">Processed</span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mobile Card List -->
                <div class="md:hidden space-y-3 mt-4">
                    @foreach (var item in Model)
                    {
                        bool isMyRequest = (item.UserID == currentUserId);
                        string rRole = userRoles.ContainsKey(item.UserID) ? userRoles[item.UserID] : "Employee";
                        int targetRank = rRole == "SuperAdmin" ? 4 : rRole == "SystemAdmin" ? 3 : rRole == "DepartmentManager" ? 2 : 1;
                        bool canApproveThisRow = (myRank > targetRank) && item.Status == LeaveRequestStatus.Pending;

                        <div class="flex flex-col bg-white border border-gray-200 shadow-sm rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800 @(canApproveThisRow ? "border-l-4 border-l-amber-500" : "")">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center gap-x-3 min-w-0">
                                    <span class="shrink-0 inline-flex justify-center items-center size-[36px] rounded-full @(RoleIconClass(rRole))">
                                        <i class="bi @(RoleIcon(rRole)) text-sm"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-800 mb-0 truncate dark:text-neutral-200">
                                            @(item.User?.UserName ?? "Unknown")
                                            @if (isMyRequest) { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-400 text-xs font-medium ms-1">YOU</span> }
                                        </p>
                                        <span class="text-xs text-gray-500 dark:text-neutral-500">@rRole</span>
                                    </div>
                                </div>
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md text-xs font-medium @(item.Status == LeaveRequestStatus.Pending ? "bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500" : item.Status == LeaveRequestStatus.Approved ? "bg-green-100 text-green-800 dark:bg-emerald-800/30 dark:text-emerald-500" : "bg-red-100 text-red-800 dark:bg-rose-800/30 dark:text-rose-500")">@item.Status</span>
                            </div>
                            <div class="grid grid-cols-2 gap-2 mb-3">
                                <div class="bg-cyan-50 dark:bg-cyan-900/20 rounded-lg p-2"><p class="text-gray-500 dark:text-neutral-500 text-xs mb-0 uppercase font-medium">Type</p><p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">@item.LeaveType</p></div>
                                <div class="bg-indigo-50 dark:bg-indigo-900/20 rounded-lg p-2"><p class="text-gray-500 dark:text-neutral-500 text-xs mb-0 uppercase font-medium">Duration</p><p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">@((item.EndDate - item.StartDate).Days + 1) Day@(((item.EndDate - item.StartDate).Days + 1) != 1 ? "s" : "")</p></div>
                                <div class="bg-green-50 dark:bg-emerald-900/20 rounded-lg p-2"><p class="text-gray-500 dark:text-neutral-500 text-xs mb-0 uppercase font-medium">From</p><p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">@item.StartDate.ToString("MMM dd")</p></div>
                                <div class="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-2"><p class="text-gray-500 dark:text-neutral-500 text-xs mb-0 uppercase font-medium">To</p><p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-0">@item.EndDate.ToString("MMM dd")</p></div>
                            </div>
                            <div class="bg-gray-50 dark:bg-neutral-800/50 rounded-lg p-2 mb-2"><p class="text-gray-500 dark:text-neutral-500 text-xs mb-0 uppercase font-medium">Reason</p><p class="text-sm text-gray-800 dark:text-neutral-300 mb-0">@item.Reason</p></div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-500 dark:text-neutral-500 text-xs">Filed: @item.DateRequested.ToString("MMM dd, yyyy")</span>
                            </div>
                            @if (canApproveThisRow)
                            {
                                <div class="flex gap-2 mt-4">
                                    <form asp-action="Approve" asp-route-id="@item.LeaveID" method="post" class="flex-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-full py-2 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-green-200 bg-green-50 text-green-800 hover:bg-green-100 dark:border-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-500 dark:hover:bg-emerald-800/50" onclick="return confirm('Approve leave request #@item.LeaveID?');">Approve</button>
                                    </form>
                                    <form asp-action="Reject" asp-route-id="@item.LeaveID" method="post" class="flex-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="decisionReason" value="" />
                                        <button type="submit" class="w-full py-2 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100 dark:border-rose-800 dark:bg-rose-900/30 dark:text-rose-500 dark:hover:bg-rose-800/50" onclick="return openLeaveRejectModal(@item.LeaveID, this.form);">Reject</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
        }
    </div>

    @if (Model.Any())
    {
        <!-- Pagination Integration -->
        <div class="px-6 py-4 border-t border-gray-100 dark:border-neutral-800">
            <partial name="_Pagination" model="Model" />
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 bg-gray-50/50 dark:bg-neutral-800/50 border-t border-gray-100 dark:border-neutral-800 rounded-b-2xl">
            <div class="flex flex-wrap justify-between items-center gap-2">
                <span class="text-[11px] text-gray-500 dark:text-neutral-500 font-medium tracking-wide">
                    <i class="bi bi-info-circle me-1"></i> 
                    Showing @((Model.PageIndex - 1) * 10 + 1) to @(Math.Min(Model.PageIndex * 10, totalRequests)) of @totalRequests total requests
                </span>
            </div>
        </div>
    }

    <div id="leaveRejectModal" class="hidden fixed inset-0 z-[120] bg-black/40 backdrop-blur-sm items-center justify-center p-4">
        <div class="w-full max-w-md rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200 dark:border-neutral-700 shadow-xl">
            <div class="px-5 py-4 border-b border-gray-100 dark:border-neutral-800 flex items-center justify-between">
                <h3 class="text-sm font-bold text-gray-900 dark:text-white">Reject Leave Request</h3>
                <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" onclick="closeLeaveRejectModal()" aria-label="Close reject reason dialog">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="p-5 space-y-3">
                <p id="leaveRejectLabel" class="text-sm text-gray-600 dark:text-neutral-300"></p>
                <label for="leaveRejectReason" class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-neutral-400">Rejection reason</label>
                <textarea id="leaveRejectReason" rows="4" class="w-full rounded-lg border border-gray-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 px-3 py-2 text-sm" placeholder="Explain why this leave request is rejected..."></textarea>
                <p id="leaveRejectError" class="hidden text-xs text-red-600">Rejection reason is required.</p>
            </div>
            <div class="px-5 py-4 border-t border-gray-100 dark:border-neutral-800 flex justify-end gap-2">
                <button type="button" class="px-3 py-2 text-sm rounded-lg border border-gray-200 dark:border-neutral-700" onclick="closeLeaveRejectModal()">Cancel</button>
                <button type="button" class="px-3 py-2 text-sm rounded-lg bg-red-600 text-white hover:bg-red-700" onclick="submitLeaveRejectModal()">Reject Request</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        if (!window._leaveRejectState) {
            window._leaveRejectState = { form: null, leaveId: null };
        }

        window.openLeaveRejectModal = function (leaveId, form) {
            window._leaveRejectState.form = form;
            window._leaveRejectState.leaveId = leaveId;

            const modal = document.getElementById('leaveRejectModal');
            const label = document.getElementById('leaveRejectLabel');
            const reason = document.getElementById('leaveRejectReason');
            const error = document.getElementById('leaveRejectError');

            if (!modal || !label || !reason || !error) return false;

            label.textContent = `Provide a reason for rejecting leave request #${leaveId}.`;
            reason.value = '';
            error.classList.add('hidden');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            reason.focus();

            return false;
        };

        window.closeLeaveRejectModal = function () {
            const modal = document.getElementById('leaveRejectModal');
            if (!modal) return;
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        };

        window.submitLeaveRejectModal = function () {
            const state = window._leaveRejectState;
            const reason = document.getElementById('leaveRejectReason');
            const error = document.getElementById('leaveRejectError');
            if (!state?.form || !reason || !error) return;

            const value = reason.value.trim();
            if (!value) {
                error.classList.remove('hidden');
                reason.focus();
                return;
            }

            const input = state.form.querySelector('input[name="decisionReason"]');
            if (input) input.value = value;
            closeLeaveRejectModal();
            state.form.submit();
        };
    })();
</script>
