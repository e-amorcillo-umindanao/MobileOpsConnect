@model MobileOpsConnect.Models.Product

@{
    ViewData["Title"] = "Product Details";
    bool isLowStock = Model.StockQuantity <= 10;
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-upc-scan"></i> SKU: @Model.SKU
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-tag-fill"></i> @Model.Category
            </span>
            @if (isLowStock)
            {
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-500/30 text-white">
                    <i class="bi bi-exclamation-triangle-fill"></i> Low Stock
                </span>
            }
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">@Model.Name</h1>
        <p class="text-blue-100 text-lg">Product details &amp; inventory information</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-box-seam-fill text-9xl text-white"></i>
    </div>
</div>

<!-- Quick Overview -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-bar-chart-line-fill text-indigo-500"></i> Quick Overview</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div><p class="text-xs uppercase tracking-wide text-gray-500">Category</p><h3 class="text-xl font-medium text-gray-800 mt-1">@Model.Category</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium"><i class="bi bi-tag-fill"></i> Classification</span></div>
            <span class="shrink-0 flex justify-center items-center size-[46px] bg-cyan-100 text-cyan-800 rounded-lg"><i class="bi bi-bookmark-star-fill text-xl"></i></span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">In Stock</p>
                <h3 class="text-xl font-medium text-gray-800 mt-1">@Model.StockQuantity <span class="text-sm text-gray-500">units</span></h3>
                @if (isLowStock)
                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-exclamation-triangle-fill"></i> Low Stock</span> }
                else
                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Healthy</span> }
            </div>
            <span class="shrink-0 flex justify-center items-center size-[46px] @(isLowStock ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") rounded-lg"><i class="bi @(isLowStock ? "bi-exclamation-octagon-fill" : "bi-box-seam-fill") text-xl"></i></span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div><p class="text-xs uppercase tracking-wide text-gray-500">Unit Price</p><h3 class="text-xl font-medium text-gray-800 mt-1">₱@Model.Price.ToString("N2")</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium"><i class="bi bi-currency-exchange"></i> Per Unit</span></div>
            <span class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg"><i class="bi bi-cash-stack text-xl"></i></span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div><p class="text-xs uppercase tracking-wide text-gray-500">Last Updated</p><h3 class="text-xl font-medium text-gray-800 mt-1">@Model.LastUpdated.ToString("MMM dd")</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-purple-100 text-purple-800 text-xs font-medium"><i class="bi bi-clock-history"></i> @Model.LastUpdated.ToString("yyyy")</span></div>
            <span class="shrink-0 flex justify-center items-center size-[46px] bg-purple-100 text-purple-800 rounded-lg"><i class="bi bi-calendar-check text-xl"></i></span>
        </div>
    </div>
</div>

<!-- Full Details -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-file-earmark-text-fill text-amber-500"></i> Full Details</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
        <div class="p-6">
            <div class="divide-y divide-gray-200">
                <div class="flex items-center py-4 gap-x-3">
                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-upc-scan"></i></span>
                    <div class="grow"><span class="text-xs uppercase text-gray-500 font-medium">SKU Code</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.SKU</p></div>
                    <span class="inline-flex items-center py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium">Barcode</span>
                </div>
                <div class="flex items-center py-4 gap-x-3">
                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-purple-100 text-purple-800"><i class="bi bi-box-seam"></i></span>
                    <div class="grow"><span class="text-xs uppercase text-gray-500 font-medium">Product Name</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.Name</p></div>
                </div>
                <div class="flex items-center py-4 gap-x-3">
                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-cyan-100 text-cyan-800"><i class="bi bi-bookmark-star-fill"></i></span>
                    <div class="grow"><span class="text-xs uppercase text-gray-500 font-medium">Category</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.Category</p></div>
                    <span class="inline-flex items-center py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium"><i class="bi bi-tag-fill me-1"></i>@Model.Category</span>
                </div>
                <div class="flex items-center py-4 gap-x-3">
                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg @(isLowStock ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")"><i class="bi @(isLowStock ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i></span>
                    <div class="grow"><span class="text-xs uppercase text-gray-500 font-medium">Stock Quantity</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.StockQuantity units</p></div>
                    <span class="inline-flex items-center py-1 px-2.5 rounded-full @(isLowStock ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") text-xs font-medium"><i class="bi @(isLowStock ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-1"></i> @Model.StockQuantity</span>
                </div>
                <div class="flex items-center py-4 gap-x-3">
                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-amber-100 text-amber-800"><i class="bi bi-cash-stack"></i></span>
                    <div class="grow"><span class="text-xs uppercase text-gray-500 font-medium">Price</span><p class="text-sm font-semibold text-gray-800 mb-0">₱@Model.Price.ToString("N2")</p></div>
                </div>
                <div class="flex items-center py-4 gap-x-3">
                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-purple-100 text-purple-800"><i class="bi bi-clock-history"></i></span>
                    <div class="grow"><span class="text-xs uppercase text-gray-500 font-medium">Last Updated</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.LastUpdated.ToString("MMMM dd, yyyy — h:mm tt")</p></div>
                </div>
            </div>
        </div>
        <!-- Footer Actions -->
        <div class="px-6 py-4 border-t border-gray-200">
            <div class="flex flex-wrap gap-2 justify-between">
                <a asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                <div class="flex gap-2">
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ProductID" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                    }
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin"))
                    {
                        <a asp-action="Delete" asp-route-id="@Model.ProductID" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100">
                            <i class="bi bi-trash3"></i> Delete
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
