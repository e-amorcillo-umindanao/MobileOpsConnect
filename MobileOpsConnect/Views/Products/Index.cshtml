@model IEnumerable<MobileOpsConnect.Models.Product>

@{
    ViewData["Title"] = "Inventory List";
    int totalProducts = Model.Count();
    int outOfStockCount = Model.Count(p => p.StockQuantity == 0);
    int activeCount = totalProducts - outOfStockCount;
    int lowStockCount = Model.Count(p => p.StockQuantity > 0 && p.StockQuantity <= 10);
    int healthyCount = activeCount - lowStockCount;

    var activeProducts = Model.Where(p => p.StockQuantity > 0).ToList();
    var archivedProducts = Model.Where(p => p.StockQuantity == 0).ToList();
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                    <span class="size-1.5 inline-block bg-green-500 rounded-full"></span>
                    Inventory Online
                </span>
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                    <i class="bi bi-box-seam-fill"></i> @totalProducts Products Tracked
                </span>
                @if (lowStockCount > 0)
                {
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-500/30 text-white">
                        <i class="bi bi-exclamation-triangle-fill"></i> @lowStockCount Low Stock
                    </span>
                }
                @if (outOfStockCount > 0)
                {
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                        <i class="bi bi-archive-fill"></i> @outOfStockCount Archived
                    </span>
                }
            </div>
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Inventory Management</h1>
            <p class="text-blue-100 text-lg">Product catalog, stock levels &amp; valuation</p>
        </div>
        <div class="hidden md:block opacity-20 pointer-events-none">
            <i class="bi bi-box-seam-fill text-9xl text-white"></i>
        </div>
    </div>
</div>

<!-- Stock Overview Title -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-bar-chart-line-fill text-indigo-500"></i> Stock Overview
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<!-- Metrics Grid -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <!-- Total SKUs -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg dark:bg-indigo-800/30 dark:text-indigo-500">
                <i class="bi bi-box-seam-fill text-xl"></i>
            </div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Total SKUs</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@totalProducts</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium dark:bg-indigo-800/20 dark:text-indigo-400">
                        <i class="bi bi-box-seam"></i> Catalog
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Healthy -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg dark:bg-green-800/30 dark:text-green-500">
                <i class="bi bi-check2-all text-xl"></i>
            </div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Healthy</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@healthyCount</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium dark:bg-green-800/20 dark:text-green-400">
                        <i class="bi bi-check-circle-fill"></i> In Stock
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Low Stock -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg dark:bg-red-800/30 dark:text-red-500">
                <i class="bi bi-exclamation-octagon-fill text-xl"></i>
            </div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Low Stock</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@lowStockCount</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium dark:bg-red-800/20 dark:text-red-400">
                        <i class="bi bi-exclamation-triangle-fill"></i> Alert
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Out of Stock -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-gray-100 text-gray-800 rounded-lg dark:bg-neutral-800 dark:text-neutral-400">
                <i class="bi bi-archive-fill text-xl"></i>
            </div>
            <div class="grow">
                <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Out of Stock</p>
                <div class="mt-1 flex items-center gap-x-2">
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@outOfStockCount</h3>
                    <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md text-xs font-medium @(outOfStockCount > 0 ? "bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400" : "bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400")">
                        <i class="bi @(outOfStockCount > 0 ? "bi-archive-fill" : "bi-check-circle-fill")"></i>
                        @(outOfStockCount > 0 ? "Archived" : "None")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Product Directory Title -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-list-columns-reverse text-amber-500"></i> Product Directory
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-4">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500">
            <i class="bi bi-funnel-fill text-lg"></i>
        </span>
        <div>
            <p class="font-semibold text-sm text-gray-800 dark:text-neutral-200 mb-0" id="inv-tab-label">Active Products</p>
            <p class="text-gray-500 text-xs mb-0 dark:text-neutral-500" id="inv-tab-count">Showing @activeCount item@(activeCount != 1 ? "s" : "")</p>
        </div>
    </div>
    <div class="flex flex-wrap gap-2">
        <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 focus:outline-none focus:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
        {
            <a asp-action="Create" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:bg-blue-700">
                <i class="bi bi-plus-circle"></i> New Product
            </a>
        }
    </div>
</div>

<!-- Tab Pills -->
<nav class="flex gap-2 mb-6" aria-label="Tabs" role="tablist">
    <button type="button" class="hs-tab-active:bg-blue-600 hs-tab-active:text-white hs-tab-active:border-transparent py-2 px-4 inline-flex items-center gap-2 bg-white text-sm font-medium text-gray-500 rounded-lg shadow-sm hover:text-gray-800 border border-gray-200 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 active" id="inv-active-tab" data-hs-tab="#inv-active-section" aria-controls="inv-active-section" role="tab">
        <i class="bi bi-box-seam"></i> Active
        <span class="hs-tab-active:bg-white/20 hs-tab-active:text-white inline-flex items-center py-0.5 px-2.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-neutral-300">@activeCount</span>
    </button>
    <button type="button" class="hs-tab-active:bg-blue-600 hs-tab-active:text-white hs-tab-active:border-transparent py-2 px-4 inline-flex items-center gap-2 bg-white text-sm font-medium text-gray-500 rounded-lg shadow-sm hover:text-gray-800 border border-gray-200 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" id="inv-archived-tab" data-hs-tab="#inv-archived-section" aria-controls="inv-archived-section" role="tab">
        <i class="bi bi-archive"></i> Archived
        <span class="hs-tab-active:bg-white/20 hs-tab-active:text-white inline-flex items-center py-0.5 px-2.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-neutral-300">@outOfStockCount</span>
    </button>
</nav>

<!-- Product Table Card -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">

    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500">
                    <i class="bi bi-table text-lg"></i>
                </span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800 dark:text-neutral-200" id="inv-card-title">Inventory Catalog</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500" id="inv-card-subtitle">@activeCount active product@(activeCount != 1 ? "s" : "")</span>
                </div>
            </div>
            <div class="flex gap-1 flex-wrap" id="inv-card-badges">
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium dark:bg-green-800/20 dark:text-green-400">@healthyCount Stocked</span>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium dark:bg-red-800/20 dark:text-red-400">@lowStockCount Low</span>
            </div>
        </div>
    </div>

    <div class="p-6">

        <!-- ACTIVE PRODUCTS SECTION -->
        <div id="inv-active-section" role="tabpanel" aria-labelledby="inv-active-tab">

            @if (activeProducts.Count == 0)
            {
                <div class="text-center py-10">
                    <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4 dark:border-green-900 dark:bg-green-800 dark:text-green-400">
                        <i class="bi bi-box-seam text-2xl"></i>
                    </span>
                    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-1">No Active Products</h3>
                    <p class="text-sm text-gray-500 dark:text-neutral-500">All products are currently out of stock. Check the Archive tab.</p>
                </div>
            }
            else
            {
                <!-- Desktop Table -->
                <div class="hidden md:block">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full inline-block align-middle">
                            <div class="border rounded-xl shadow-sm overflow-hidden border-gray-200 dark:border-neutral-700">
                                <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
                                    <thead class="bg-gray-50 dark:bg-neutral-800">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">
                                                <div class="flex items-center gap-x-2"><i class="bi bi-upc-scan"></i> SKU</div>
                                            </th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">
                                                <div class="flex items-center gap-x-2"><i class="bi bi-box"></i> Product</div>
                                            </th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">
                                                <div class="flex items-center gap-x-2"><i class="bi bi-tag"></i> Category</div>
                                            </th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">
                                                <div class="flex items-center gap-x-2"><i class="bi bi-layers"></i> Stock</div>
                                            </th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">
                                                <div class="flex items-center gap-x-2"><i class="bi bi-currency-exchange"></i> Price</div>
                                            </th>
                                            <th scope="col" class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                                        @foreach (var item in activeProducts)
                                        {
                                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-md text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-800/20 dark:text-indigo-400">
                                                        @item.SKU
                                                    </span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <div class="flex items-center gap-x-3">
                                                        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-purple-100 text-purple-600 dark:bg-purple-800/30 dark:text-purple-400">
                                                            <i class="bi bi-box-seam"></i>
                                                        </span>
                                                        <span class="block text-sm font-semibold text-gray-800 dark:text-neutral-200">@item.Name</span>
                                                    </div>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800 dark:bg-cyan-800/20 dark:text-cyan-400">
                                                        <i class="bi bi-tag-fill"></i> @item.Category
                                                    </span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    @if (item.StockQuantity <= 10)
                                                    {
                                                        <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400">
                                                            <i class="bi bi-exclamation-circle-fill"></i> @item.StockQuantity Low
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400">
                                                            <i class="bi bi-check-circle-fill"></i> @item.StockQuantity
                                                        </span>
                                                    }
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">₱@item.Price</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4 text-end">
                                                    <div class="hs-dropdown [--placement:bottom-right] relative inline-block">
                                                        <button id="hs-dropdown-@item.ProductID" type="button" class="hs-dropdown-toggle py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800" aria-haspopup="menu" aria-expanded="false" aria-label="Dropdown">
                                                            Options
                                                            <i class="bi bi-chevron-down hs-dropdown-open:rotate-180 transition-transform duration-200"></i>
                                                        </button>
                                                        <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden min-w-40 bg-white shadow-md rounded-lg p-2 mt-2 z-10 border border-gray-200 dark:bg-neutral-900 dark:border-neutral-700" role="menu" aria-orientation="vertical" aria-labelledby="hs-dropdown-@item.ProductID">
                                                            <a asp-action="Details" asp-route-id="@item.ProductID" class="flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-gray-800 hover:bg-gray-100 dark:text-neutral-400 dark:hover:bg-neutral-800">
                                                                <i class="bi bi-eye"></i> View Details
                                                            </a>
                                                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
                                                            {
                                                                <a asp-action="Edit" asp-route-id="@item.ProductID" class="flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-gray-800 hover:bg-gray-100 dark:text-neutral-400 dark:hover:bg-neutral-800">
                                                                    <i class="bi bi-pencil-square"></i> Edit Product
                                                                </a>
                                                                <div class="my-1 border-t border-gray-200 dark:border-neutral-700"></div>
                                                                <a asp-action="Delete" asp-route-id="@item.ProductID" class="flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-red-600 hover:bg-gray-100 dark:text-red-400 dark:hover:bg-neutral-800">
                                                                    <i class="bi bi-trash3"></i> Delete
                                                                </a>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mobile Card List -->
                <div class="md:hidden space-y-3">
                    @foreach (var item in activeProducts)
                    {
                        <div class="flex flex-col bg-white border shadow-sm rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800 @(item.StockQuantity <= 10 ? "border-l-4 border-l-red-500" : "")">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center gap-x-3 min-w-0">
                                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg @(item.StockQuantity <= 10 ? "bg-red-100 text-red-800" : "bg-indigo-100 text-indigo-800")">
                                        <i class="bi @(item.StockQuantity <= 10 ? "bi-exclamation-triangle-fill" : "bi-box-seam-fill")"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <p class="font-semibold text-sm text-gray-800 dark:text-neutral-200 truncate mb-0">@item.Name</p>
                                        <span class="text-xs text-gray-500 dark:text-neutral-500">@item.SKU</span>
                                    </div>
                                </div>
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md text-xs font-medium @(item.StockQuantity <= 10 ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">
                                    <i class="bi @(item.StockQuantity <= 10 ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i> @item.StockQuantity
                                </span>
                            </div>
                            <div class="flex items-center justify-between mb-3">
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium">
                                    <i class="bi bi-tag-fill"></i> @item.Category
                                </span>
                                <span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">₱@item.Price</span>
                            </div>
                            <div class="flex gap-2">
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.ProductID" class="py-2 px-3 flex-1 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@item.ProductID" class="py-2 px-3 flex-1 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.ProductID" class="py-2 px-3 flex-1 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100">
                                        <i class="bi bi-trash3"></i> Delete
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

        </div>

        <!-- ARCHIVED PRODUCTS SECTION -->
        <div id="inv-archived-section" class="hidden" role="tabpanel" aria-labelledby="inv-archived-tab">

            @if (archivedProducts.Count == 0)
            {
                <div class="text-center py-10">
                    <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4 dark:border-green-900 dark:bg-green-800 dark:text-green-400">
                        <i class="bi bi-check-circle-fill text-2xl"></i>
                    </span>
                    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-1">No Archived Products</h3>
                    <p class="text-sm text-gray-500 dark:text-neutral-500">All products currently have stock. Nothing to archive.</p>
                </div>
            }
            else
            {
                <!-- Desktop Table -->
                <div class="hidden md:block">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full inline-block align-middle">
                            <div class="border rounded-xl shadow-sm overflow-hidden border-gray-200 dark:border-neutral-700">
                                <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
                                    <thead class="bg-gray-50 dark:bg-neutral-800">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500"><i class="bi bi-upc-scan me-1"></i> SKU</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500"><i class="bi bi-box me-1"></i> Product</th>
                                            <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500"><i class="bi bi-tag me-1"></i> Category</th>
                                            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase dark:text-neutral-500"><i class="bi bi-layers me-1"></i> Stock</th>
                                            <th scope="col" class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase dark:text-neutral-500"><i class="bi bi-currency-exchange me-1"></i> Price</th>
                                            <th scope="col" class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase dark:text-neutral-500">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                                        @foreach (var item in archivedProducts)
                                        {
                                            <tr class="opacity-60 hover:opacity-100 transition-opacity">
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-md text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-800/20 dark:text-indigo-400">@item.SKU</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <div class="flex items-center gap-x-3">
                                                        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-gray-100 text-gray-500 dark:bg-neutral-700 dark:text-neutral-400">
                                                            <i class="bi bi-archive"></i>
                                                        </span>
                                                        <span class="block text-sm font-semibold text-gray-500 dark:text-neutral-400">@item.Name</span>
                                                    </div>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4">
                                                    <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800 dark:bg-cyan-800/20 dark:text-cyan-400">
                                                        <i class="bi bi-tag-fill"></i> @item.Category
                                                    </span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4 text-center">
                                                    <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-md text-xs font-medium bg-gray-100 text-gray-500 dark:bg-neutral-700 dark:text-neutral-400">
                                                        <i class="bi bi-archive-fill"></i> Out of Stock
                                                    </span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4 text-end">
                                                    <span class="text-sm font-semibold text-gray-500 dark:text-neutral-400">₱@item.Price</span>
                                                </td>
                                                <td class="whitespace-nowrap px-6 py-4 text-end">
                                                    <a asp-action="Details" asp-route-id="@item.ProductID" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mobile Card List -->
                <div class="md:hidden space-y-3">
                    @foreach (var item in archivedProducts)
                    {
                        <div class="flex flex-col bg-white border border-l-4 border-l-gray-400 shadow-sm rounded-xl p-4 opacity-60 dark:bg-neutral-900 dark:border-neutral-800">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center gap-x-3 min-w-0">
                                    <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-gray-100 text-gray-500">
                                        <i class="bi bi-archive-fill"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <p class="font-semibold text-sm text-gray-500 truncate mb-0">@item.Name</p>
                                        <span class="text-xs text-gray-400">@item.SKU</span>
                                    </div>
                                </div>
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-gray-100 text-gray-500 text-xs font-medium">
                                    <i class="bi bi-archive-fill"></i> 0
                                </span>
                            </div>
                            <div class="flex items-center justify-between mb-3">
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium">
                                    <i class="bi bi-tag-fill"></i> @item.Category
                                </span>
                                <span class="text-sm font-semibold text-gray-500">₱@item.Price</span>
                            </div>
                            <a asp-action="Details" asp-route-id="@item.ProductID" class="py-2 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                                <i class="bi bi-eye"></i> Details
                            </a>
                        </div>
                    }
                </div>
            }

        </div>

    </div>

    <!-- Table Footer -->
    <div class="px-6 py-4 border-t border-gray-200 dark:border-neutral-700">
        <div class="flex flex-wrap justify-between items-center gap-2">
            <span class="text-xs text-gray-500 dark:text-neutral-500" id="inv-footer-text">
                <i class="bi bi-info-circle me-1"></i>
                Showing @activeCount active product@(activeCount != 1 ? "s" : "")
            </span>
            <div class="flex gap-1" id="inv-footer-badges">
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium">@healthyCount Healthy</span>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium">@lowStockCount Low</span>
            </div>
        </div>
    </div>

</div>

<!-- Dynamic Header Update Script -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const activeTab = document.getElementById('inv-active-tab');
        const archivedTab = document.getElementById('inv-archived-tab');

        const tabLabel = document.getElementById('inv-tab-label');
        const tabCount = document.getElementById('inv-tab-count');
        const cardTitle = document.getElementById('inv-card-title');
        const cardSubtitle = document.getElementById('inv-card-subtitle');
        const cardBadges = document.getElementById('inv-card-badges');
        const footerText = document.getElementById('inv-footer-text');
        const footerBadges = document.getElementById('inv-footer-badges');

        const activeCount = @activeCount;
        const archivedCount = @outOfStockCount;
        const healthyCount = @healthyCount;
        const lowStockCount = @lowStockCount;

        if (activeTab) {
            activeTab.addEventListener('click', () => {
                tabLabel.textContent = 'Active Products';
                tabCount.textContent = 'Showing ' + activeCount + ' item' + (activeCount !== 1 ? 's' : '');
                cardTitle.textContent = 'Inventory Catalog';
                cardSubtitle.textContent = activeCount + ' active product' + (activeCount !== 1 ? 's' : '');
                cardBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium">' + healthyCount + ' Stocked</span>' +
                    '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium">' + lowStockCount + ' Low</span>';
                footerText.innerHTML = '<i class="bi bi-info-circle me-1"></i> Showing ' + activeCount + ' active product' + (activeCount !== 1 ? 's' : '');
                footerBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium">' + healthyCount + ' Healthy</span>' +
                    '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium">' + lowStockCount + ' Low</span>';
            });
        }

        if (archivedTab) {
            archivedTab.addEventListener('click', () => {
                tabLabel.textContent = 'Archived Products';
                tabCount.textContent = 'Showing ' + archivedCount + ' item' + (archivedCount !== 1 ? 's' : '');
                cardTitle.textContent = 'Archived Inventory';
                cardSubtitle.textContent = archivedCount + ' out-of-stock product' + (archivedCount !== 1 ? 's' : '');
                cardBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-gray-100 text-gray-500 text-xs font-medium">' + archivedCount + ' Archived</span>';
                footerText.innerHTML = '<i class="bi bi-info-circle me-1"></i> Showing ' + archivedCount + ' archived product' + (archivedCount !== 1 ? 's' : '');
                footerBadges.innerHTML = '<span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-gray-100 text-gray-500 text-xs font-medium"><i class="bi bi-archive-fill me-1"></i> Out of Stock</span>';
            });
        }
    });
</script>
