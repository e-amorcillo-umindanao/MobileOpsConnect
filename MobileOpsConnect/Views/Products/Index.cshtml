@using MobileOpsConnect.Models
@model PaginatedList<Product>

@{
    ViewData["Title"] = "Inventory List";
    var currentStatus = ViewBag.CurrentStatus as string ?? "active";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Inventory Management</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Product catalog, stock levels & valuation</p>
</div>

<!-- Stock Overview Title -->
<div class="mb-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-[#5e4dcd] flex items-center gap-x-2 dark:text-indigo-400">
        <i class="bi bi-grid-3x3-gap"></i> Stock Overview
    </h2>
</div>

<!-- Metrics Grid -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-12">
    <!-- Total SKUs -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-[#f4f2ff] text-[#5e4dcd] rounded-2xl dark:bg-indigo-900/20 dark:text-indigo-400">
                <i class="bi bi-box-seam-fill text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Total SKUs</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@ViewBag.TotalProducts</h3>
        </div>
    </div>

    <!-- Healthy -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-emerald-50 text-emerald-600 border border-emerald-100 rounded-2xl dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800/30">
                <i class="bi bi-check-circle text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Healthy</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@(ViewBag.ActiveCount - ViewBag.LowStockCount)</h3>
        </div>
    </div>

    <!-- Low Stock -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-rose-50 text-rose-500 border border-rose-100 rounded-2xl dark:bg-rose-900/20 dark:text-rose-400 dark:border-rose-800/30">
                <i class="bi bi-exclamation-circle text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Low Stock</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@ViewBag.LowStockCount</h3>
        </div>
    </div>

    <!-- Out of Stock -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-gray-100 text-gray-500 rounded-2xl dark:bg-neutral-800 dark:text-neutral-400">
                <i class="bi bi-archive text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Out of Stock</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@ViewBag.ArchivedCount</h3>
        </div>
    </div>
</div>

<!-- Product Directory Title & Actions -->
<div class="flex flex-wrap items-center justify-between gap-4 mb-2">
    <h2 class="text-xs font-bold uppercase tracking-widest text-[#f0a623] flex items-center gap-x-2">
        <i class="bi bi-funnel"></i> Product Directory
    </h2>
    <div class="flex gap-2">

        @if (User.IsInRole("SuperAdmin") || User.IsInRole("SystemAdmin") || User.IsInRole("DepartmentManager"))
        {
            <a asp-action="Create" class="py-2.5 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] focus:outline-none focus:bg-[#1a1a1a]">
                <i class="bi bi-plus text-lg leading-none"></i> New Product
            </a>
        }
    </div>
</div>

<!-- Tab Header Underline -->
<nav class="flex space-x-6 border-b border-gray-200 dark:border-neutral-700 mb-6" aria-label="Tabs">
    <a asp-action="Index" asp-route-status="active" 
       class="tab-link @(currentStatus == "active" ? "border-gray-800 text-gray-900 font-bold dark:border-white dark:text-white" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-neutral-400 dark:hover:text-neutral-300") py-3 px-1 inline-flex items-center gap-2 border-b-2 text-sm whitespace-nowrap focus:outline-none focus:ring-0 transition-colors">
        <i class="bi bi-box-seam"></i> Active
        <span class="@(currentStatus == "active" ? "bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-white" : "bg-gray-50 text-gray-500 dark:bg-neutral-800 dark:text-neutral-400") inline-flex items-center py-0.5 px-2 rounded-full text-[10px] font-bold">@ViewBag.ActiveCount</span>
    </a>
    <a asp-action="Index" asp-route-status="archived" 
       class="tab-link @(currentStatus == "archived" ? "border-gray-800 text-gray-900 font-bold dark:border-white dark:text-white" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-neutral-400 dark:hover:text-neutral-300") py-3 px-1 inline-flex items-center gap-2 border-b-2 text-sm whitespace-nowrap focus:outline-none focus:ring-0 transition-colors">
        <i class="bi bi-archive"></i> Archived
        <span class="@(currentStatus == "archived" ? "bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-white" : "bg-gray-50 text-gray-500 dark:bg-neutral-800 dark:text-neutral-400") inline-flex items-center py-0.5 px-2 rounded-full text-[10px] font-bold">@ViewBag.ArchivedCount</span>
    </a>
</nav>

<!-- Product Table Container (Targeted by AJAX) -->
<div id="table-container">
    <partial name="_ProductsTable" model="Model" />
</div>

<!-- Tab Toggle & Pagination Script (Native AJAX) -->
<script>
    (function () {
        function loadContent(url, updateHistory = true) {
            const container = document.getElementById('table-container');
            if (!container) return;

            container.style.opacity = '0.5';

            fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => {
                if (!response.ok) throw new Error();
                return response.text();
            })
            .then(html => {
                container.innerHTML = html;
                container.style.opacity = '1';
                if (updateHistory) history.pushState(null, '', url);
                updateActiveTab(url);
            })
            .catch(() => {
                // Graceful degradation on failure: full page reload
                window.location.href = url;
            });
        }

        function updateActiveTab(url) {
            const params = new URLSearchParams(new URL(url, location.origin).search);
            const status = params.get('status') || 'active'; // Match casing of default status
            
            document.querySelectorAll('.tab-link').forEach(tab => {
                const tabStatus = new URLSearchParams(
                    new URL(tab.href, location.origin).search
                ).get('status') || 'active';
                
                if (tabStatus === status) {
                    // Make Active
                    tab.classList.remove('border-transparent', 'text-gray-500', 'hover:text-gray-700', 'dark:text-neutral-400', 'dark:hover:text-neutral-300');
                    tab.classList.add('border-gray-800', 'text-gray-900', 'font-bold', 'dark:border-white', 'dark:text-white', 'active-tab');
                    
                    const badge = tab.querySelector('span');
                    if(badge) {
                        badge.classList.remove('bg-gray-50', 'text-gray-500', 'dark:bg-neutral-800', 'dark:text-neutral-400');
                        badge.classList.add('bg-gray-100', 'text-gray-800', 'dark:bg-neutral-700', 'dark:text-white');
                    }
                } else {
                    // Make Inactive
                    tab.classList.remove('border-gray-800', 'text-gray-900', 'font-bold', 'dark:border-white', 'dark:text-white', 'active-tab');
                    tab.classList.add('border-transparent', 'text-gray-500', 'hover:text-gray-700', 'dark:text-neutral-400', 'dark:hover:text-neutral-300');
                    
                    const badge = tab.querySelector('span');
                    if(badge) {
                        badge.classList.remove('bg-gray-100', 'text-gray-800', 'dark:bg-neutral-700', 'dark:text-white');
                        badge.classList.add('bg-gray-50', 'text-gray-500', 'dark:bg-neutral-800', 'dark:text-neutral-400');
                    }
                }
            });
        }

        // Event delegation - handles tabs AND dynamic pagination links
        document.addEventListener('click', (e) => {
            const link = e.target.closest('.tab-link, #table-container a[href]');
            if (link) {
                e.preventDefault();
                loadContent(link.getAttribute('href'));
            }
        });

        // Browser Back/Forward support
        window.addEventListener('popstate', () => {
            loadContent(window.location.href, false);
        });
    })();
</script>
