@model MobileOpsConnect.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-circle-fill text-green-500 mr-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                Inventory Module
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-pencil-square mr-1"></i> Edit Product
            </span>
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">Edit Product</h1>
        <p class="lead mb-0 opacity-75">
            Update product details and pricing
        </p>
    </div>
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-pencil-square"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- FORM SECTION                                    -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-section-header mt-2">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-pencil-square text-amber mr-1"></i> Product Information
    </h5>
    <hr />
</div>

<div class="flex flex-wrap -mx-3 justify-center">
    <div class="w-full lg:w-2/3 px-6 w-full xl:w-1/2 px-3">

        <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-1">
            <div class="p-6 p-6 p-md-5">

                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 mb-6"></div>
                    <input type="hidden" asp-for="ProductID" />

                    <!-- ── Identification Section ── -->
                    <div class="flex items-center mb-6">
                        <div class="moc-icon-box bg-indigo-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-upc-scan text-indigo"></i>
                        </div>
                        <div>
                            <h6 class="font-bold mb-0 letter-tight">Identification</h6>
                            <span class="text-moc-text-muted text-xs">Barcode and product name</span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label asp-for="SKU" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                            <i class="bi bi-upc mr-1 text-indigo"></i> SKU / Barcode <span class="text-red-500">*</span>
                        </label>
                        <div class="flex w-full items-stretch">
                            <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0"
                                  style="background:rgba(99,102,241,0.06);">
                                <i class="bi bi-upc-scan text-indigo"></i>
                            </span>
                            <input asp-for="SKU" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                                   placeholder="SCAN or type barcode"
                                   style="padding:0.875rem 1rem;font-size:1rem;" />
                        </div>
                        <span asp-validation-for="SKU" class="text-red-500 text-xs"></span>
                    </div>

                    <div class="mb-6">
                        <label asp-for="Name" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                            <i class="bi bi-box mr-1 text-purple"></i> Product Name <span class="text-red-500">*</span>
                        </label>
                        <div class="flex w-full items-stretch">
                            <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0"
                                  style="background:rgba(139,92,246,0.06);">
                                <i class="bi bi-box-seam text-purple"></i>
                            </span>
                            <input asp-for="Name" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                                   placeholder="Enter product name"
                                   style="padding:0.875rem 1rem;font-size:1rem;" />
                        </div>
                        <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                    </div>

                    <hr class="my-6 opacity-10" />

                    <!-- ── Classification Section ── -->
                    <div class="flex items-center mb-6">
                        <div class="moc-icon-box bg-cyan-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-bookmark-star-fill text-cyan"></i>
                        </div>
                        <div>
                            <h6 class="font-bold mb-0 letter-tight">Classification</h6>
                            <span class="text-moc-text-muted text-xs">Category grouping for inventory</span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label asp-for="Category" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                            <i class="bi bi-tag-fill mr-1 text-cyan"></i> Category <span class="text-red-500">*</span>
                        </label>
                        <div class="flex w-full items-stretch">
                            <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0"
                                  style="background:rgba(6,182,212,0.06);">
                                <i class="bi bi-tag text-cyan"></i>
                            </span>
                            <input asp-for="Category" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                                   placeholder="e.g. Electronics, Accessories, Furniture"
                                   style="padding:0.875rem 1rem;font-size:1rem;" />
                        </div>
                        <span asp-validation-for="Category" class="text-red-500 text-xs"></span>
                    </div>

                    <hr class="my-6 opacity-10" />

                    <!-- ── Stock & Pricing Section ── -->
                    <div class="flex items-center mb-6">
                        <div class="moc-icon-box bg-green-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-cash-stack text-green"></i>
                        </div>
                        <div>
                            <h6 class="font-bold mb-0 letter-tight">Stock &amp; Pricing</h6>
                            <span class="text-moc-text-muted text-xs">Correction of stock and price update</span>
                        </div>
                    </div>

                    <div class="flex flex-wrap -mx-3 gap-6 mb-6">
                        <div class="w-full sm:w-1/2 px-3">
                            <label asp-for="StockQuantity" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                                <i class="bi bi-layers mr-1 text-green"></i> Stock Quantity <span class="text-red-500">*</span>
                            </label>
                            <div class="flex w-full items-stretch">
                                <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0"
                                      style="background:rgba(34,197,94,0.06);">
                                    <i class="bi bi-plus-slash-minus text-green"></i>
                                </span>
                                <input asp-for="StockQuantity" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                                       type="number" min="0" placeholder="0"
                                       style="padding:0.875rem 1rem;font-size:1rem;" />
                            </div>
                            <span asp-validation-for="StockQuantity" class="text-red-500 text-xs"></span>
                        </div>

                        <div class="w-full sm:w-1/2 px-3">
                            <label asp-for="Price" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                                <i class="bi bi-cash mr-1 text-amber"></i> Unit Price (₱) <span class="text-red-500">*</span>
                            </label>
                            <div class="flex w-full items-stretch">
                                <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0"
                                      style="background:rgba(245,158,11,0.06);">
                                    <i class="bi bi-currency-exchange text-amber"></i>
                                </span>
                                <input asp-for="Price" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                                       type="number" step="0.01" min="0" placeholder="0.00"
                                       style="padding:0.875rem 1rem;font-size:1rem;" />
                            </div>
                            <span asp-validation-for="Price" class="text-red-500 text-xs"></span>
                        </div>
                    </div>

                    <hr class="my-6 opacity-10" />

                     <!-- ── Action Buttons ── -->
                    <div class="grid gap-2">
                        <input type="submit" value="Save Changes" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-4 py-2 text-base py-6" />
                        <a asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-4 py-2 text-base py-6">
                            <i class="bi bi-arrow-left mr-1"></i> Cancel &amp; Back to List
                        </a>
                    </div>

                </form>

            </div>
             <!-- Card Footer -->
            <div class="px-6 py-4 border-t border-moc-border bg-gray-50 bg-transparent border-0 px-6 py-6 text-center"
                 style="border-top:1px solid var(--moc-border);border-radius:0 0 0.875rem 0.875rem;">
                <span class="text-moc-text-muted text-xs">
                    <i class="bi bi-lock-fill mr-1"></i>
                    Price and stock changes are logged for audit purposes.
                </span>
            </div>
        </div>

    </div>
</div>

