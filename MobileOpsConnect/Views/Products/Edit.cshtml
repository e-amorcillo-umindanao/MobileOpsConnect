@model MobileOpsConnect.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Inventory
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            Inventory Module
        </span>
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
            <i class="bi bi-upc-scan"></i> @Model.SKU
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Edit Product</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Update product details for @Model.Name</p>
</div>

<!-- Form Card -->
<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-50 text-amber-500 dark:bg-amber-900/20 dark:text-amber-400">
                    <i class="bi bi-pencil-square text-lg"></i>
                </span>
                <div>
                    <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Product Information</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500">Modify the product details below</span>
                </div>
            </div>
        </div>

        <div class="p-6">
            <form asp-action="Edit">
                <input type="hidden" asp-for="ProductID" />
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mt-2 mb-4 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

                <div class="grid gap-y-4">
                    <!-- Product Name -->
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-box me-1 text-indigo-500"></i> Product Name
                        </label>
                        <input asp-for="Name" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="Enter product name" />
                        <span asp-validation-for="Name" class="text-xs text-red-600 mt-2 block"></span>
                    </div>

                    <!-- SKU -->
                    <div>
                        <label asp-for="SKU" class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-upc-scan me-1 text-purple-500"></i> SKU
                        </label>
                        <input asp-for="SKU" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="e.g., PRD-001" />
                        <span asp-validation-for="SKU" class="text-xs text-red-600 mt-2 block"></span>
                    </div>

                    <!-- Category -->
                    <div>
                        <label asp-for="Category" class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-tag-fill me-1 text-cyan-500"></i> Category
                        </label>
                        <select asp-for="Category" asp-items="ViewBag.Categories" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400">
                            <option value="">— Select Category —</option>
                        </select>
                        <span asp-validation-for="Category" class="text-xs text-red-600 mt-2 block"></span>
                    </div>

                    <div class="grid sm:grid-cols-2 gap-4">
                        <!-- Price -->
                        <div>
                            <label asp-for="Price" class="block text-sm font-medium mb-2 dark:text-white">
                                <i class="bi bi-currency-exchange me-1 text-green-500"></i> Price (₱)
                            </label>
                            <input type="text" id="priceDisplay" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" inputmode="decimal" placeholder="0.00" value="@Model.Price.ToString("N2")" />
                            <input type="hidden" asp-for="Price" id="priceHidden" />
                            <span asp-validation-for="Price" class="text-xs text-red-600 mt-2 block"></span>
                        </div>

                        <!-- Stock Quantity -->
                        <div>
                            <label asp-for="StockQuantity" class="block text-sm font-medium mb-2 dark:text-white">
                                <i class="bi bi-layers me-1 text-amber-500"></i> Stock Quantity
                            </label>
                            <input type="text" id="qtyDisplay" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" inputmode="numeric" placeholder="0" value="@Model.StockQuantity.ToString("N0")" />
                            <input type="hidden" asp-for="StockQuantity" id="qtyHidden" />
                            <span asp-validation-for="StockQuantity" class="text-xs text-red-600 mt-2 block"></span>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="py-3 px-4 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                            <i class="bi bi-check2-circle"></i> Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function() {
        const pDisp = document.getElementById('priceDisplay');
        const pHid = document.getElementById('priceHidden');
        const qDisp = document.getElementById('qtyDisplay');
        const qHid = document.getElementById('qtyHidden');

        function formatNumber(val, decimals = 0) {
            let parts = val.toString().split(".");
            parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            return parts.join(".");
        }

        function handleInput(display, hidden, isDecimal) {
            display.addEventListener('input', function(e) {
                let val = this.value.replace(/,/g, '');
                if (isDecimal) {
                    val = val.replace(/[^0-9.]/g, '');
                    const dots = val.split('.');
                    if (dots.length > 2) val = dots[0] + '.' + dots.slice(1).join('');
                } else {
                    val = val.replace(/[^0-9]/g, '');
                }
                
                hidden.value = val || 0;
                
                let cursorPos = this.selectionStart;
                let oldLen = this.value.length;
                this.value = formatNumber(val, isDecimal ? 2 : 0);
                let newLen = this.value.length;
                this.setSelectionRange(cursorPos + (newLen - oldLen), cursorPos + (newLen - oldLen));
            });
        }

        if (pDisp && pHid) {
            pHid.value = "@Model.Price";
            handleInput(pDisp, pHid, true);
        }
        if (qDisp && qHid) {
            qHid.value = "@Model.StockQuantity";
            handleInput(qDisp, qHid, false);
        }
    })();
    </script>
}
