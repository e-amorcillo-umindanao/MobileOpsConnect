@model MobileOpsConnect.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
        <i class="bi bi-arrow-left"></i> Back to Inventory
    </a>
</div>

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span>
                Inventory Module
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-upc-scan"></i> @Model.SKU
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Edit Product</h1>
        <p class="text-blue-100 text-lg">Update product details for @Model.Name</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-pencil-square text-9xl text-white"></i>
    </div>
</div>

<!-- Form Card -->
<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500">
                    <i class="bi bi-pencil-square text-lg"></i>
                </span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800 dark:text-neutral-200">Product Information</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500">Modify the product details below</span>
                </div>
            </div>
        </div>

        <div class="p-6">
            <form asp-action="Edit">
                <input type="hidden" asp-for="ProductID" />
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mt-2 mb-4 bg-red-50 p-3 rounded-lg dark:bg-red-500/10 dark:text-red-400" role="alert"></div>

                <div class="grid gap-y-4">
                    <!-- Product Name -->
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-box me-1 text-indigo-500"></i> Product Name
                        </label>
                        <input asp-for="Name" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="Enter product name" />
                        <span asp-validation-for="Name" class="text-xs text-red-600 mt-2 block"></span>
                    </div>

                    <!-- SKU -->
                    <div>
                        <label asp-for="SKU" class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-upc-scan me-1 text-purple-500"></i> SKU
                        </label>
                        <input asp-for="SKU" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="e.g., PRD-001" />
                        <span asp-validation-for="SKU" class="text-xs text-red-600 mt-2 block"></span>
                    </div>

                    <!-- Category -->
                    <div>
                        <label asp-for="Category" class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-tag-fill me-1 text-cyan-500"></i> Category
                        </label>
                        <input asp-for="Category" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="e.g., Electronics" />
                        <span asp-validation-for="Category" class="text-xs text-red-600 mt-2 block"></span>
                    </div>

                    <div class="grid sm:grid-cols-2 gap-4">
                        <!-- Price -->
                        <div>
                            <label asp-for="Price" class="block text-sm font-medium mb-2 dark:text-white">
                                <i class="bi bi-currency-exchange me-1 text-green-500"></i> Price (₱)
                            </label>
                            <input asp-for="Price" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" type="number" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="Price" class="text-xs text-red-600 mt-2 block"></span>
                        </div>

                        <!-- Stock Quantity -->
                        <div>
                            <label asp-for="StockQuantity" class="block text-sm font-medium mb-2 dark:text-white">
                                <i class="bi bi-layers me-1 text-amber-500"></i> Stock Quantity
                            </label>
                            <input asp-for="StockQuantity" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" type="number" placeholder="0" />
                            <span asp-validation-for="StockQuantity" class="text-xs text-red-600 mt-2 block"></span>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="py-3 px-4 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:bg-blue-700">
                            <i class="bi bi-check2-circle"></i> Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
