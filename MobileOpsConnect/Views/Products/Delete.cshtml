@model MobileOpsConnect.Models.Product

@{
    ViewData["Title"] = "Archive Product";
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(239,68,68,0.25);">
                <i class="bi bi-exclamation-triangle-fill mr-1"></i> Archive Confirmation
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-box-seam-fill mr-1"></i> SKU: @Model.SKU
            </span>
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">Archive Product</h1>
        <p class="lead mb-0 opacity-75">
            Review the product details below before archiving
        </p>
    </div>
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-archive-fill"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- WARNING ALERT                                   -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-metric p-6 p-md-4 mb-6 anim-fade-in anim-delay-1" style="border-left:4px solid #f59e0b !important;">
    <div class="flex items-start gap-6">
        <div class="moc-icon-box bg-amber-50 rounded-3" style="min-width:44px;">
            <i class="bi bi-exclamation-triangle-fill text-amber fs-5"></i>
        </div>
        <div>
            <h6 class="font-bold mb-1 letter-tight">Are you sure you want to archive this product?</h6>
            <p class="text-moc-text-muted text-sm mb-0">
                This product will be moved to the <strong>Archived</strong> section with stock set to zero.
                It will remain visible in your inventory archive for reference but will no longer appear in the active product list.
            </p>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- PRODUCT DETAILS                                 -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-section-header mt-6">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-info-circle-fill text-indigo mr-1"></i> Product Details
    </h5>
    <hr />
</div>

<div class="flex flex-wrap -mx-3 g-3 mb-6 anim-fade-in anim-delay-2">
    <div class="col-6 w-full lg:w-1/3 px-6">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">SKU Code</p>
                    <h4 class="font-bold mb-1 letter-tight">@Model.SKU</h4>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-cyan-50 text-cyan text-xs font-semibold">
                        <i class="bi bi-upc-scan mr-1"></i> Barcode
                    </span>
                </div>
                <div class="moc-icon-box bg-cyan-50 rounded-3">
                    <i class="bi bi-upc-scan text-cyan fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 w-full lg:w-1/3 px-6">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Product Name</p>
                    <h4 class="font-bold mb-1 letter-tight">@Model.Name</h4>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo text-xs font-semibold">
                        <i class="bi bi-box-seam mr-1"></i> Item
                    </span>
                </div>
                <div class="moc-icon-box bg-indigo-50 rounded-3">
                    <i class="bi bi-box-seam text-indigo fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 w-full lg:w-1/3 px-6">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Category</p>
                    <h4 class="font-bold mb-1 letter-tight">
                        @(string.IsNullOrEmpty(Model.Category) ? "Uncategorized" : Model.Category)
                    </h4>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple text-xs font-semibold">
                        <i class="bi bi-tag-fill mr-1"></i> Group
                    </span>
                </div>
                <div class="moc-icon-box bg-purple-50 rounded-3">
                    <i class="bi bi-tag-fill text-purple fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 w-full lg:w-1/3 px-6">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Current Stock</p>
                    <h4 class="font-bold mb-1 letter-tight">@Model.StockQuantity</h4>
                    @if (Model.StockQuantity == 0)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red text-xs font-semibold">
                            <i class="bi bi-x-circle-fill mr-1"></i> Out of Stock
                        </span>
                    }
                    else if (Model.StockQuantity <= 10)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber text-xs font-semibold">
                            <i class="bi bi-exclamation-triangle-fill mr-1"></i> Low Stock
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green text-xs font-semibold">
                            <i class="bi bi-check-circle-fill mr-1"></i> In Stock
                        </span>
                    }
                </div>
                <div class="moc-icon-box bg-amber-50 rounded-3">
                    <i class="bi bi-stack text-amber fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 w-full lg:w-1/3 px-6">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Unit Price</p>
                    <h4 class="font-bold mb-1 letter-tight">₱@Model.Price.ToString("N2")</h4>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green text-xs font-semibold">
                        <i class="bi bi-currency-exchange mr-1"></i> PHP
                    </span>
                </div>
                <div class="moc-icon-box bg-green-50 rounded-3">
                    <i class="bi bi-currency-exchange text-green fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 w-full lg:w-1/3 px-6">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Last Updated</p>
                    <h4 class="font-bold mb-1 letter-tight">@Model.LastUpdated.ToString("MMM dd")</h4>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-50 text-moc-text-muted text-xs font-semibold">
                        <i class="bi bi-clock-history mr-1"></i> @Model.LastUpdated.ToString("yyyy")
                    </span>
                </div>
                <div class="moc-icon-box rounded-3" style="background:rgba(100,116,139,0.08);">
                    <i class="bi bi-clock-history fs-5" style="color:#64748b;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- ACTION BUTTONS                                  -->
<!-- ═══════════════════════════════════════════════ -->
<div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-3">
    <div class="p-6 p-6">
        <div class="flex flex-col flex-sm-row align-items-stretch align-items-sm-center justify-between gap-6">
            <div class="flex items-center gap-2">
                <div class="moc-icon-box bg-red-50 rounded-3">
                    <i class="bi bi-archive-fill text-red fs-5"></i>
                </div>
                <div>
                    <h6 class="font-bold mb-0 letter-tight">Confirm Archive</h6>
                    <span class="text-moc-text-muted text-xs">This action will move the product to the archived section</span>
                </div>
            </div>
            <div class="flex gap-2">
                <a asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-6 py-2">
                    <i class="bi bi-arrow-left mr-1"></i> Cancel
                </a>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="ProductID" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 px-6 py-2 font-semibold"
                            style="background:rgba(239,68,68,0.08);color:#ef4444;border:1.5px solid rgba(239,68,68,0.2);">
                        <i class="bi bi-archive mr-1"></i> Archive Product
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Back -->
<div class="flex justify-content-start mb-6 anim-fade-in">
    <a asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-6 py-2">
        <i class="bi bi-arrow-left mr-1"></i> Back to Inventory
    </a>
</div>
