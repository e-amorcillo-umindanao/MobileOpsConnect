@model PaginatedList<MobileOpsConnect.Models.PurchaseOrder>
@{
    ViewData["Title"] = "Purchase Orders";
    string currentStatus = ViewBag.CurrentStatus ?? "active";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            Procurement Module
        </span>
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
            <i class="bi bi-clipboard2-data"></i> @ViewBag.TotalCount Order@(ViewBag.TotalCount != 1 ? "s" : "")
        </span>
        @if (ViewBag.PendingCount > 0)
        {
            <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-amber-50 text-amber-600 border border-amber-100 dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-400 tracking-wide uppercase">
                <i class="bi bi-hourglass-split"></i> @ViewBag.PendingCount Pending
            </span>
        }
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Purchase Orders</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Restock requests, approval tracking & order history</p>
</div>

<!-- Metrics Grid -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg dark:bg-indigo-800/30 dark:text-indigo-500">
                <i class="bi bi-clipboard2-data-fill text-xl"></i>
            </div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Total POs</p>
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-800 dark:text-neutral-200">@ViewBag.TotalCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-amber-100 text-amber-800 rounded-lg dark:bg-amber-800/30 dark:text-amber-500">
                <i class="bi bi-clock-history text-xl"></i>
            </div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Pending</p>
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-800 dark:text-neutral-200">@ViewBag.PendingCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg dark:bg-green-800/30 dark:text-green-500">
                <i class="bi bi-check2-all text-xl"></i>
            </div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Approved</p>
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-800 dark:text-neutral-200">@ViewBag.ApprovedCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] rounded-lg @(ViewBag.RejectedCount > 0 ? "bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500" : "bg-green-100 text-green-800 dark:bg-green-800/30 dark:text-green-500")">
                <i class="bi @(ViewBag.RejectedCount > 0 ? "bi-x-octagon-fill" : "bi-check2-all") text-xl"></i>
            </div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Rejected</p>
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-800 dark:text-neutral-200">@ViewBag.RejectedCount</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tab Interface -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-6">
    <div class="flex flex-wrap items-center gap-2">
        <nav class="flex space-x-2 bg-gray-100 p-1 rounded-xl dark:bg-neutral-800" aria-label="Tabs">
            <a asp-action="Index" asp-route-status="active" 
               class="py-2 px-4 inline-flex items-center gap-x-2 text-xs font-bold rounded-lg transition-all @(currentStatus == "active" ? "bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-white" : "text-gray-500 hover:text-gray-700 dark:text-neutral-400")">
                <i class="bi bi-hourglass-split"></i> Active
                <span class="py-0.5 px-1.5 rounded-full text-[10px] font-bold @(currentStatus == "active" ? "bg-indigo-50 text-indigo-600 dark:bg-indigo-900/40" : "bg-gray-200 text-gray-600 dark:bg-neutral-700 dark:text-neutral-400")">@ViewBag.PendingCount</span>
            </a>
            <a asp-action="Index" asp-route-status="archived" 
               class="py-2 px-4 inline-flex items-center gap-x-2 text-xs font-bold rounded-lg transition-all @(currentStatus == "archived" ? "bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-white" : "text-gray-500 hover:text-gray-700 dark:text-neutral-400")">
                <i class="bi bi-archive"></i> Archive
                <span class="py-0.5 px-1.5 rounded-full text-[10px] font-bold @(currentStatus == "archived" ? "bg-indigo-50 text-indigo-600 dark:bg-indigo-900/40" : "bg-gray-200 text-gray-600 dark:bg-neutral-700 dark:text-neutral-400")">@(ViewBag.ApprovedCount + ViewBag.RejectedCount)</span>
            </a>
        </nav>

        @if (User.IsInRole("DepartmentManager") || User.IsInRole("WarehouseStaff") || User.IsInRole("SuperAdmin"))
        {
            <a asp-action="Create" class="py-2 px-4 inline-flex items-center gap-x-2 text-xs font-bold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                <i class="bi bi-plus-circle"></i> Submit New PO
            </a>
        }
    </div>
</div>

<!-- Order Table Card -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6 relative overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex items-center gap-x-3">
             <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500">
                <i class="bi @(currentStatus == "active" ? "bi-hourglass-split" : "bi-archive") text-lg"></i>
            </span>
            <div>
                <p class="font-bold text-sm text-gray-900 dark:text-neutral-200 mb-0">@(currentStatus == "active" ? "Awaiting Approval" : "Processed Orders")</p>
                <p class="text-gray-500 text-xs mb-0 dark:text-neutral-500">Page @Model.PageIndex of @Model.TotalPages</p>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-20 px-6">
            <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-400 mx-auto mb-4">
                <i class="bi bi-inbox text-2xl"></i>
            </span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">No Orders Found</h3>
            <p class="text-sm text-gray-500 dark:text-neutral-500">There are no @currentStatus purchase orders to display.</p>
        </div>
    }
    else
    {
        <!-- Desktop Table -->
        <div class="hidden md:block overflow-x-auto p-2">
            <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                <thead>
                    <tr>
                        <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">PO #</th>
                        <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Product</th>
                        <th scope="col" class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Qty</th>
                        <th scope="col" class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Cost</th>
                        <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Requester</th>
                        <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Date</th>
                        <th scope="col" class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Status</th>
                        @if ((bool)ViewBag.CanApprove)
                        {
                            <th scope="col" class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Action</th>
                        }
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                    @foreach (var po in Model)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                            <td class="whitespace-nowrap px-6 py-4 text-xs font-bold text-gray-900 dark:text-white">PO-@po.Id.ToString("D4")</td>
                            <td class="whitespace-nowrap px-6 py-4">
                                <div class="flex items-center gap-x-2">
                                    <span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">@(po.Product?.Name ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="whitespace-nowrap px-6 py-4 text-center text-sm">@po.Quantity</td>
                            <td class="whitespace-nowrap px-6 py-4 text-end text-sm font-semibold">₱@po.EstimatedCost.ToString("N2")</td>
                            <td class="whitespace-nowrap px-6 py-4 text-xs text-gray-500">@(po.RequestedBy?.Email ?? "N/A")</td>
                            <td class="whitespace-nowrap px-6 py-4 text-xs text-gray-500">@po.DateRequested.ToString("MMM dd, yyyy")</td>
                            <td class="whitespace-nowrap px-6 py-4 text-center">
                                @if (po.Status == "Pending") { <span class="py-1 px-2.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-800 uppercase tracking-wide">Pending</span> }
                                else if (po.Status == "Approved") { <span class="py-1 px-2.5 rounded-full text-[10px] font-bold bg-green-100 text-green-800 uppercase tracking-wide">Approved</span> }
                                else { <span class="py-1 px-2.5 rounded-full text-[10px] font-bold bg-red-100 text-red-800 uppercase tracking-wide">Rejected</span> }
                            </td>
                            @if ((bool)ViewBag.CanApprove)
                            {
                                <td class="whitespace-nowrap px-6 py-4 text-end">
                                    @if (po.Status == "Pending")
                                    {
                                        <div class="flex justify-end gap-1">
                                            <form asp-action="ProcessOrder" method="post" class="inline">
                                                <input type="hidden" name="id" value="@po.Id" />
                                                <input type="hidden" name="actionType" value="Approve" />
                                                <button type="submit" class="p-1.5 rounded-lg border border-green-200 bg-green-50 text-green-800 hover:bg-green-100"><i class="bi bi-check-lg"></i></button>
                                            </form>
                                            <form asp-action="ProcessOrder" method="post" class="inline">
                                                <input type="hidden" name="id" value="@po.Id" />
                                                <input type="hidden" name="actionType" value="Reject" />
                                                <button type="submit" class="p-1.5 rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100"><i class="bi bi-x-lg"></i></button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] text-gray-400 font-bold uppercase tracking-tight">Processed</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile View -->
        <div class="md:hidden p-4 space-y-3">
            @foreach (var po in Model)
            {
                <div class="bg-white border shadow-sm rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800 border-l-4 @(po.Status == "Pending" ? "border-l-amber-500" : (po.Status == "Approved" ? "border-l-green-500" : "border-l-red-500"))">
                    <div class="flex justify-between items-start mb-2">
                         <p class="font-bold text-sm text-gray-900 dark:text-white">PO-@po.Id.ToString("D4")</p>
                         <span class="text-[10px] font-bold uppercase tracking-wide @(po.Status == "Pending" ? "text-amber-600" : (po.Status == "Approved" ? "text-green-600" : "text-red-600"))">@po.Status</span>
                    </div>
                    <p class="text-sm font-semibold mb-1 text-gray-800 dark:text-neutral-200">@(po.Product?.Name ?? "N/A")</p>
                    <div class="flex justify-between text-xs text-gray-500 mb-3">
                        <span>@po.Quantity units</span>
                        <span>₱@po.EstimatedCost.ToString("N2")</span>
                    </div>
                    @if ((bool)ViewBag.CanApprove && po.Status == "Pending")
                    {
                        <div class="flex gap-2">
                             <form asp-action="ProcessOrder" method="post" class="flex-1">
                                <input type="hidden" name="id" value="@po.Id" />
                                <input type="hidden" name="actionType" value="Approve" />
                                <button type="submit" class="w-full py-2 bg-green-600 text-white rounded-lg text-xs font-bold">Approve</button>
                            </form>
                            <form asp-action="ProcessOrder" method="post" class="flex-1">
                                <input type="hidden" name="id" value="@po.Id" />
                                <input type="hidden" name="actionType" value="Reject" />
                                <button type="submit" class="w-full py-2 bg-red-600 text-white rounded-lg text-xs font-bold">Reject</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- Pagination -->
    <partial name="_Pagination" model="Model" />
</div>
