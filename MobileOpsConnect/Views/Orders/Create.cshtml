@{
    ViewData["Title"] = "Submit Purchase Order";
}

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            Procurement Module
        </span>
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
            <i class="bi bi-pencil-square"></i> New Request
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Submit Purchase Order</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Request inventory restocking &mdash; managers will review and approve</p>
</div>

<!-- Section Title -->
<div class="flex items-center gap-x-2 mb-4">
    <i class="bi bi-cart-plus text-gray-400"></i>
    <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Order Details</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 text-sm text-red-800 rounded-lg p-4 mb-4 flex items-center gap-2 dark:bg-red-800/10 dark:border-red-900 dark:text-red-400" role="alert">
        <i class="bi bi-x-circle-fill"></i> @TempData["Error"]
    </div>
}

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="p-6">

            <form asp-action="Create" method="post">

                <div class="grid gap-y-5">
                    <!-- Product Selection -->
                    <div>
                        <label class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-box me-1 text-indigo-500"></i> Product <span class="text-red-500">*</span>
                        </label>
                        <select name="ProductId" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" required>
                            <option value="">-- Select Product --</option>
                            @foreach (var item in (SelectList)ViewBag.Products)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Quantity -->
                    <div>
                        <label class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-layers me-1 text-green-500"></i> Quantity <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="QuantityDisplay" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="0" value="1" required inputmode="numeric" />
                        <input type="hidden" name="Quantity" id="QuantityRaw" value="1" />
                    </div>

                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            const display = document.getElementById('QuantityDisplay');
                            const raw = document.getElementById('QuantityRaw');

                            function formatNumber(val) {
                                if (!val) return '';
                                return parseFloat(val.replace(/,/g, '')).toLocaleString('en-US');
                            }

                            display.addEventListener('input', function (e) {
                                let cursorPosition = e.target.selectionStart;
                                let originalLength = e.target.value.length;
                                
                                // Remove non-numeric characters except for leading zero protection
                                let numericValue = e.target.value.replace(/[^0-9]/g, '');
                                if (numericValue === '') numericValue = '0';
                                
                                raw.value = numericValue;
                                e.target.value = formatNumber(numericValue);

                                // Adjust cursor position after comma insertion
                                let newLength = e.target.value.length;
                                cursorPosition = cursorPosition + (newLength - originalLength);
                                e.target.setSelectionRange(cursorPosition, cursorPosition);
                            });

                            // Initial format
                            display.value = formatNumber(raw.value);
                        });
                    </script>

                    <!-- Notes -->
                    <div>
                        <label class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-chat-dots me-1 text-amber-500"></i> Notes <span class="text-xs text-gray-400">(optional)</span>
                        </label>
                        <textarea name="Notes" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" rows="4" placeholder="Reason for restocking, supplier preference, etc." style="resize:vertical;min-height:120px;"></textarea>
                        <p class="text-xs text-gray-500 mt-1.5 dark:text-neutral-500">
                            <i class="bi bi-info-circle me-1 text-blue-500"></i>
                            Include any urgency details or preferred supplier information.
                        </p>
                    </div>

                    <!-- Policy Notice -->
                    <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 flex items-start gap-3 dark:bg-blue-800/10 dark:border-blue-900">
                        <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500">
                            <i class="bi bi-shield-check"></i>
                        </span>
                        <div>
                            <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-1">Procurement Policy</p>
                            <p class="text-xs text-gray-500 dark:text-neutral-500 mb-0">
                                Purchase orders require management approval before processing. You will be notified once
                                your request has been reviewed. Orders are processed during business hours.
                            </p>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="py-3 px-4 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                            <i class="bi bi-send"></i> Submit Purchase Order
                        </button>
                        <a asp-action="Index" class="py-3 px-4 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-colors dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-300">
                            <i class="bi bi-arrow-left"></i> Cancel &amp; Go Back
                        </a>
                    </div>
                </div>

            </form>

        </div>

        <!-- Card Footer -->
        <div class="px-6 py-4 border-t border-gray-100 dark:border-neutral-800 text-center">
            <span class="text-xs text-gray-500 dark:text-neutral-500">
                <i class="bi bi-lock-fill me-1"></i>
                Your order is submitted securely and routed to authorized approvers.
            </span>
        </div>
    </div>
</div>
