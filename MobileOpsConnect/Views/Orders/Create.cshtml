@{
    ViewData["Title"] = "Submit Purchase Order";
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-circle-fill text-green-500 mr-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                Procurement Module
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-pencil-square mr-1"></i> New Request
            </span>
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">Submit Purchase Order</h1>
        <p class="lead mb-0 opacity-75">
            Request inventory restocking &mdash; managers will review and approve
        </p>
    </div>
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-truck"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- FORM SECTION                                    -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-section-header mt-2">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-cart-plus-fill text-indigo mr-1"></i> Order Details
    </h5>
    <hr />
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 flex items-center gap-2 mb-6 anim-fade-in" role="alert">
        <i class="bi bi-x-circle-fill fs-5"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="flex flex-wrap -mx-3 justify-center">
    <div class="w-full lg:w-2/3 px-6 w-full xl:w-1/2 px-3">

        <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-1">
            <div class="p-6 p-6 p-md-5">

                <form asp-action="Create" method="post">

                    <!-- Product Selection -->
                    <div class="flex items-center mb-6">
                        <div class="moc-icon-box bg-indigo-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-box-seam-fill text-indigo"></i>
                        </div>
                        <div>
                            <h6 class="font-bold mb-0 letter-tight">Product</h6>
                            <span class="text-moc-text-muted text-xs">Select the item to restock</span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                            <i class="bi bi-box mr-1 text-indigo"></i> Product <span class="text-red-500">*</span>
                        </label>
                        <select name="ProductId" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 form-select-lg rounded-3"
                                style="padding:0.875rem 1rem;font-size:1rem;" required>
                            <option value="">-- Select Product --</option>
                            @foreach (var item in (SelectList)ViewBag.Products)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <hr class="my-6 opacity-10" />

                    <!-- Quantity -->
                    <div class="flex items-center mb-6">
                        <div class="moc-icon-box bg-green-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-hash text-green"></i>
                        </div>
                        <div>
                            <h6 class="font-bold mb-0 letter-tight">Quantity</h6>
                            <span class="text-moc-text-muted text-xs">How many units to order</span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                            <i class="bi bi-layers mr-1 text-green"></i> Quantity <span class="text-red-500">*</span>
                        </label>
                        <div class="flex w-full items-stretch">
                            <span class="flex items-center px-4 py-2 bg-gray-50 border border-gray-300 text-gray-500 text-sm font-medium rounded-start-3 border-end-0"
                                  style="background:rgba(34,197,94,0.06);">
                                <i class="bi bi-plus-slash-minus text-green"></i>
                            </span>
                            <input type="number" name="Quantity" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0"
                                   min="1" value="1" required
                                   style="padding:0.875rem 1rem;font-size:1rem;" />
                        </div>
                    </div>

                    <hr class="my-6 opacity-10" />

                    <!-- Notes -->
                    <div class="flex items-center mb-6">
                        <div class="moc-icon-box bg-amber-50 rounded-3 mr-4" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-chat-left-text-fill text-amber"></i>
                        </div>
                        <div>
                            <h6 class="font-bold mb-0 letter-tight">Notes</h6>
                            <span class="text-moc-text-muted text-xs">Optional details for the approver</span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                            <i class="bi bi-chat-dots mr-1 text-amber"></i> Notes <span class="text-moc-text-muted">(optional)</span>
                        </label>
                        <textarea name="Notes" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-3" rows="4"
                                  placeholder="Reason for restocking, supplier preference, etc."
                                  style="padding:0.875rem 1rem;font-size:1rem;resize:vertical;min-height:120px;"></textarea>
                        <small class="text-moc-text-muted text-xs mt-1 flex items-center">
                            <i class="bi bi-info-circle mr-1 text-indigo"></i>
                            Include any urgency details or preferred supplier information.
                        </small>
                    </div>

                    <hr class="my-6 opacity-10" />

                    <!-- Policy Notice -->
                    <div class="rounded-3 p-6 mb-6 flex items-start gap-6"
                         style="background:rgba(99,102,241,0.04);border:1px solid rgba(99,102,241,0.1);">
                        <div class="moc-icon-box bg-indigo-50 rounded-3" style="width:40px;height:40px;min-width:40px;">
                            <i class="bi bi-shield-check text-indigo"></i>
                        </div>
                        <div>
                            <p class="font-semibold text-sm mb-1 letter-tight">Procurement Policy</p>
                            <p class="text-moc-text-muted text-xs mb-0">
                                Purchase orders require management approval before processing. You will be notified once
                                your request has been reviewed. Orders are processed during business hours.
                            </p>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="grid gap-2">
                        <button type="submit" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-4 py-2 text-base py-6">
                            <i class="bi bi-send-fill mr-1"></i> Submit Purchase Order
                        </button>
                        <a asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-4 py-2 text-base py-6">
                            <i class="bi bi-arrow-left mr-1"></i> Cancel &amp; Go Back
                        </a>
                    </div>

                </form>

            </div>

            <!-- Card Footer -->
            <div class="px-6 py-4 border-t border-moc-border bg-gray-50 bg-transparent border-0 px-6 py-6 text-center"
                 style="border-top:1px solid var(--moc-border);border-radius:0 0 0.875rem 0.875rem;">
                <span class="text-moc-text-muted text-xs">
                    <i class="bi bi-lock-fill mr-1"></i>
                    Your order is submitted securely and routed to authorized approvers.
                </span>
            </div>
        </div>

    </div>
</div>


