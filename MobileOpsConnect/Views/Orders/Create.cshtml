@{
    ViewData["Title"] = "Submit Purchase Order";
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span>
                Procurement Module
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-pencil-square"></i> New Request
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Submit Purchase Order</h1>
        <p class="text-blue-100 text-lg">Request inventory restocking &mdash; managers will review and approve</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-truck text-9xl text-white"></i>
    </div>
</div>

<!-- Section Title -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-cart-plus-fill text-indigo-500"></i> Order Details
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 text-sm text-red-800 rounded-lg p-4 mb-4 flex items-center gap-2 dark:bg-red-800/10 dark:border-red-900 dark:text-red-400" role="alert">
        <i class="bi bi-x-circle-fill"></i> @TempData["Error"]
    </div>
}

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="p-6">

            <form asp-action="Create" method="post">

                <div class="grid gap-y-5">
                    <!-- Product Selection -->
                    <div>
                        <label class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-box me-1 text-indigo-500"></i> Product <span class="text-red-500">*</span>
                        </label>
                        <select name="ProductId" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" required>
                            <option value="">-- Select Product --</option>
                            @foreach (var item in (SelectList)ViewBag.Products)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Quantity -->
                    <div>
                        <label class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-layers me-1 text-green-500"></i> Quantity <span class="text-red-500">*</span>
                        </label>
                        <input type="number" name="Quantity" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" min="1" value="1" required />
                    </div>

                    <!-- Notes -->
                    <div>
                        <label class="block text-sm font-medium mb-2 dark:text-white">
                            <i class="bi bi-chat-dots me-1 text-amber-500"></i> Notes <span class="text-xs text-gray-400">(optional)</span>
                        </label>
                        <textarea name="Notes" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" rows="4" placeholder="Reason for restocking, supplier preference, etc." style="resize:vertical;min-height:120px;"></textarea>
                        <p class="text-xs text-gray-500 mt-1.5 dark:text-neutral-500">
                            <i class="bi bi-info-circle me-1 text-blue-500"></i>
                            Include any urgency details or preferred supplier information.
                        </p>
                    </div>

                    <!-- Policy Notice -->
                    <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 flex items-start gap-3 dark:bg-blue-800/10 dark:border-blue-900">
                        <span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500">
                            <i class="bi bi-shield-check"></i>
                        </span>
                        <div>
                            <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mb-1">Procurement Policy</p>
                            <p class="text-xs text-gray-500 dark:text-neutral-500 mb-0">
                                Purchase orders require management approval before processing. You will be notified once
                                your request has been reviewed. Orders are processed during business hours.
                            </p>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="py-3 px-4 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:bg-blue-700">
                            <i class="bi bi-send-fill"></i> Submit Purchase Order
                        </button>
                        <a asp-action="Index" class="py-3 px-4 flex-1 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                            <i class="bi bi-arrow-left"></i> Cancel &amp; Go Back
                        </a>
                    </div>
                </div>

            </form>

        </div>

        <!-- Card Footer -->
        <div class="px-6 py-4 border-t border-gray-200 dark:border-neutral-700 text-center">
            <span class="text-xs text-gray-500 dark:text-neutral-500">
                <i class="bi bi-lock-fill me-1"></i>
                Your order is submitted securely and routed to authorized approvers.
            </span>
        </div>
    </div>
</div>
