@model PaginatedList<MobileOpsConnect.Models.InAppNotification>
@{
    ViewData["Title"] = "Notifications";
    int totalCount = ViewBag.TotalCount ?? 0;
    int unreadCount = ViewBag.UnreadCount ?? 0;
    int readCount = ViewBag.ReadCount ?? 0;
    string topType = ViewBag.TopType ?? "None";
    string currentStatus = ViewBag.CurrentStatus ?? "unread";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Activity History</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Track your personal activity history and system updates.</p>
</div>

<!-- Metrics Grid -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4 min-w-0">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg"><i class="bi bi-bell text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate" title="Total">Total</p>
            </div>
            <div class="text-right shrink-0">
                <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@totalCount</h3>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4 min-w-0">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-amber-100 text-amber-800 rounded-lg"><i class="bi bi-envelope text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate" title="Unread">Unread</p>
            </div>
            <div class="text-right shrink-0">
                <h3 id="unread-metric-count" class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@unreadCount</h3>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4 min-w-0">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-emerald-100 text-emerald-800 rounded-lg"><i class="bi bi-check2-all text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate" title="Read">Read</p>
            </div>
            <div class="text-right shrink-0">
                <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@readCount</h3>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex items-center justify-between w-full gap-x-4 min-w-0">
            <div class="flex items-center gap-x-4 min-w-0">
                <div class="shrink-0 flex justify-center items-center size-[46px] bg-purple-100 text-purple-800 rounded-lg"><i class="bi bi-tags text-xl"></i></div>
                <p class="text-xs uppercase tracking-wide text-gray-500 truncate" title="Top Category">Top Category</p>
            </div>
            <div class="text-right shrink-0 min-w-0">
                <h3 class="text-lg sm:text-xl font-medium text-gray-800 dark:text-neutral-200 truncate" title="@topType">@topType</h3>
            </div>
        </div>
    </div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-4">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800 dark:bg-indigo-800/30 dark:text-indigo-500">
            <i class="bi @(currentStatus == "unread" ? "bi-envelope" : "bi-bell") text-lg"></i>
        </span>
        <div>
            <p class="font-semibold text-sm text-gray-800 mb-0 dark:text-white">@(currentStatus == "unread" ? "Unread Activity" : "All Activity")</p>
            <p class="text-gray-500 text-xs mb-0 dark:text-neutral-400">Page @Model.PageIndex of @Model.TotalPages</p>
        </div>
    </div>
    <div class="flex flex-wrap items-center gap-2">
        <button onclick="markAllNotificationsAsRead(this)" class="py-2 px-3 inline-flex items-center gap-x-2 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
            Mark all read
        </button>
        <button onclick="clearAllNotifications(this)" class="py-2 px-3 inline-flex items-center gap-x-2 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-800 hover:bg-red-100 transition-colors">
             <i class="bi bi-trash3"></i> Clear all
        </button>
    </div>
</div>

<!-- Tab Header -->
<nav class="flex space-x-6 border-b border-gray-200 dark:border-neutral-700 mb-6" aria-label="Tabs">
    <a asp-action="Index" asp-route-status="unread" 
       class="py-3 px-1 inline-flex items-center gap-2 border-b-2 @(currentStatus == "unread" ? "border-gray-800 text-gray-900 font-bold dark:border-white dark:text-white" : "border-transparent text-gray-500 hover:text-gray-700 font-medium dark:text-neutral-400 dark:hover:text-neutral-300") focus:outline-none transition-all">
        Unread
        <span id="tab-unread-count" class="inline-flex items-center py-0.5 px-2 rounded-full text-[10px] font-bold @(currentStatus == "unread" ? "bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-white" : "bg-gray-50 text-gray-500 dark:bg-neutral-800 dark:text-neutral-400")">@unreadCount</span>
    </a>
    <a asp-action="Index" asp-route-status="all" 
       class="py-3 px-1 inline-flex items-center gap-2 border-b-2 @(currentStatus == "all" ? "border-gray-800 text-gray-900 font-bold dark:border-white dark:text-white" : "border-transparent text-gray-500 hover:text-gray-700 font-medium dark:text-neutral-400 dark:hover:text-neutral-300") focus:outline-none transition-all">
        All History
        <span class="inline-flex items-center py-0.5 px-2 rounded-full text-[10px] font-bold @(currentStatus == "all" ? "bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-white" : "bg-gray-50 text-gray-500 dark:bg-neutral-800 dark:text-neutral-400")">@totalCount</span>
    </a>
</nav>

<!-- Notifications Table Card -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6 overflow-hidden">
    <div class="p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-16 px-6">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-800 mx-auto mb-4 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">
                    <i class="bi bi-bell-slash text-2xl"></i>
                </span>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">No activity @(currentStatus == "unread" ? "unread" : "yet")</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-400 max-w-xs mx-auto">Notifications and system updates will appear here once they arrive.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto p-2">
                <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                    <thead>
                        <tr class="bg-gray-50/50 dark:bg-neutral-800/50">
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest">Type</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest">Notification</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest">Received</th>
                            <th scope="col" class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800" id="notif-table-body">
                        @foreach (var item in Model)
                        {
                            <tr class="notif-row transition-all duration-200 @(item.IsRead ? "opacity-60 grayscale-[0.3]" : "bg-blue-50/10 active-row")" 
                                data-id="@item.Id" 
                                data-unread="@(!item.IsRead)">
                                <td class="whitespace-nowrap px-6 py-4">
                                    <div class="flex items-center gap-x-3">
                                        <span class="inline-flex items-center justify-center size-8 rounded-lg @(GetIconBg(item.Type)) text-white shadow-sm">
                                            <i class="bi @(item.Icon ?? "bi-info-circle")"></i>
                                        </span>
                                        <span class="text-xs font-semibold text-gray-800 dark:text-neutral-300">@item.Type</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="relative ps-3">
                                        @if (!item.IsRead)
                                        {
                                            <div class="indicator-dot absolute left-0 top-1.5 size-1.5 bg-blue-500 rounded-full"></div>
                                        }
                                        <p class="text-sm font-bold text-gray-900 dark:text-white mb-0.5">@item.Title</p>
                                        <p class="text-xs text-gray-500 dark:text-neutral-400 line-clamp-1">@item.Message</p>
                                    </div>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    <span class="text-[11px] font-medium text-gray-500 dark:text-neutral-500 uppercase">@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-end">
                                    <div class="flex justify-end gap-x-2">
                                        @if (!string.IsNullOrEmpty(item.Url) && item.Url != "#")
                                        {
                                            <a href="@item.Url" class="p-1 text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" title="View Source">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        }
                                        @if (!item.IsRead)
                                        {
                                            <button onclick="markSingleRead(this, @item.Id)" class="p-1 text-gray-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors" title="Mark as read">
                                                <i class="bi bi-check-lg text-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Card List -->
            <div class="md:hidden divide-y divide-gray-100 dark:divide-neutral-800" id="notif-mobile-body">
                @foreach (var item in Model)
                {
                    <div class="notif-card p-4 transition-all @(item.IsRead ? "opacity-60" : "bg-blue-50/10 active-row")" 
                         data-id="@item.Id" 
                         data-unread="@(!item.IsRead)">
                        <div class="flex gap-x-3 mb-3">
                            <span class="shrink-0 inline-flex items-center justify-center size-9 rounded-xl @(GetIconBg(item.Type)) text-white">
                                <i class="bi @(item.Icon ?? "bi-info-circle") text-lg"></i>
                            </span>
                            <div class="flex-grow min-w-0">
                                <div class="flex justify-between items-start gap-2 mb-1">
                                    <h4 class="text-sm font-bold text-gray-900 dark:text-white truncate">@item.Title</h4>
                                    <span class="text-[10px] text-gray-500 uppercase whitespace-nowrap">@item.CreatedAt.ToString("MMM dd")</span>
                                </div>
                                <p class="text-xs text-gray-600 dark:text-neutral-400 line-clamp-2 mb-2">@item.Message</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full @(GetIconBg(item.Type)) bg-opacity-10 dark:bg-opacity-20 uppercase tracking-tighter" style="color:inherit">@item.Type</span>
                                    <div class="flex gap-x-3">
                                        @if (!string.IsNullOrEmpty(item.Url) && item.Url != "#")
                                        {
                                            <a href="@item.Url" class="text-xs text-indigo-600 font-bold dark:text-indigo-400">View Details</a>
                                        }
                                        @if (!item.IsRead)
                                        {
                                            <button onclick="markSingleRead(this, @item.Id)" class="text-xs text-emerald-600 font-bold dark:text-emerald-400">Mark read</button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Pagination -->
    <partial name="_Pagination" model="Model" />
</div>

@functions {
    string GetIconBg(string type) => type switch {
        "Leave" => "bg-purple-500",
        "Stock" => "bg-blue-500",
        "Order" => "bg-amber-500",
        "User" => "bg-emerald-500",
        "Accounting" => "bg-rose-500",
        _ => "bg-gray-500"
    };
}

<script>
// OPTIMISTIC ACTIONS
async function markSingleRead(btn, id) {
    // Optimistic UI
    const targets = document.querySelectorAll(`[data-id="${id}"]`);
    targets.forEach(el => {
        el.dataset.unread = 'false';
        el.classList.add('opacity-60', 'grayscale-[0.3]');
        el.classList.remove('bg-blue-50/10', 'active-row');
        const dot = el.querySelector('.indicator-dot');
        if (dot) dot.remove();
        
        // Remove individual mark read buttons
        const readBtns = el.querySelectorAll('button[title="Mark as read"], button.text-emerald-600');
        readBtns.forEach(b => b.remove());

        // If in Unread tab, hide after a short delay
        if ("@currentStatus" === "unread") {
            setTimeout(() => {
                el.classList.add('scale-y-0', 'opacity-0');
                setTimeout(() => el.remove(), 300);
            }, 500);
        }
    });

    // Update metrics
    const unreadMetric = document.getElementById('unread-metric-count');
    const currentUnread = parseInt(unreadMetric.textContent);
    if (currentUnread > 0) {
        unreadMetric.textContent = currentUnread - 1;
        const tabBadge = document.getElementById('tab-unread-count');
        if (tabBadge) tabBadge.textContent = currentUnread - 1;
    }

    try {
        await fetch(`/InAppNotification/MarkRead?id=${id}`, { method: 'POST' });
    } catch (e) {
        console.error('Failed to mark read', e);
    }
}

async function markAllNotificationsAsRead(btn) {
    const originalText = btn.innerHTML;
    
    // Optimistic UI for visible items
    document.querySelectorAll('.active-row').forEach(div => {
        const id = div.dataset.id;
        markSingleRead(null, id);
    });

    btn.innerHTML = 'All Read ✓';
    btn.classList.add('text-emerald-600');
    setTimeout(() => {
        btn.innerHTML = originalText;
        btn.classList.remove('text-emerald-600');
    }, 2000);

    try {
        await fetch('/InAppNotification/MarkAllAsRead', { method: 'POST' });
    } catch (e) {
        console.error('Failed to mark all as read', e);
        location.reload();
    }
}

async function clearAllNotifications(btn) {
    if (!confirm('Are you sure you want to permanently delete all notifications in this view?')) return;
    
    // Optimistic UI
    const tableBody = document.getElementById('notif-table-body');
    const mobileBody = document.getElementById('notif-mobile-body');
    const card = document.querySelector('.overflow-hidden.bg-white');

    if (tableBody) tableBody.innerHTML = '';
    if (mobileBody) mobileBody.innerHTML = '';
    
    btn.innerHTML = 'Cleared ✓';
    setTimeout(() => location.reload(), 1000); // Reload to show empty state correctly

    try {
        await fetch('/InAppNotification/ClearAll', { method: 'POST' });
    } catch (e) {
        console.error('Failed to clear all', e);
        location.reload();
    }
}
</script>
