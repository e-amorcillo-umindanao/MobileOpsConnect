@{
    ViewData["Title"] = "Command Center";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    bool isSystemAdmin = User.IsInRole("SystemAdmin");
}

<!-- Hero Header -->
<div class="mb-10 pt-4">
    <div class="flex flex-wrap items-center gap-2 mb-6">
        <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 border border-gray-100 shadow-sm dark:bg-neutral-900 dark:border-neutral-800 dark:text-neutral-200">
            <span class="size-1.5 inline-block bg-green-500 rounded-full"></span>
            All Systems Operational
        </span>
        @if (isSuperAdmin)
        {
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 border border-gray-100 shadow-sm dark:bg-neutral-900 dark:border-neutral-800 dark:text-neutral-200">
                <i class="bi bi-shield-lock text-gray-400"></i> Super Admin
            </span>
        }
        else if (isSystemAdmin)
        {
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 border border-gray-100 shadow-sm dark:bg-neutral-900 dark:border-neutral-800 dark:text-neutral-200">
                <i class="bi bi-gear text-gray-400"></i> System Admin
            </span>
        }
    </div>
    
    @if (isSuperAdmin)
    {
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Super Admin Command Center</h1>
        <p class="text-gray-500 text-lg dark:text-neutral-400">Super Admin Overview &amp; Control Panel</p>
    }
    else if (isSystemAdmin)
    {
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-2 tracking-tight">System Admin Dashboard</h1>
        <p class="text-gray-500 text-lg dark:text-neutral-400">System Admin Overview &amp; Control Panel</p>
    }
</div>

<!-- System Health -->
<div class="mb-8">
    <div class="flex items-center gap-x-2 mb-4">
        <i class="bi bi-activity text-gray-400"></i>
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">System Health</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-6">
        <!-- Card: Registered Users -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="p-4 sm:p-5">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 mb-4 truncate" title="Registered Users">Registered Users</p>
                <div class="flex flex-col-reverse sm:flex-row sm:justify-between sm:items-end gap-2 min-w-0">
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-green-50 text-green-700 text-[10px] font-bold border border-green-100 dark:bg-green-900/10 dark:text-green-400 dark:border-green-900/30 self-start sm:self-auto truncate max-w-full">
                        <span class="size-1.5 bg-green-500 rounded-full shrink-0"></span> Total
                    </span>
                    <h3 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none truncate w-full sm:w-auto text-left sm:text-right" title="@ViewBag.ActiveUsers">@ViewBag.ActiveUsers</h3>
                </div>
            </div>
        </div>

        <!-- Card: Pending Leaves -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="p-4 sm:p-5">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 mb-4 truncate" title="Pending Leaves">Pending Leaves</p>
                <div class="flex flex-col-reverse sm:flex-row sm:justify-between sm:items-end gap-2 min-w-0">
                    @if (ViewBag.PendingLeaves > 0)
                    {
                        <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-amber-50 text-amber-700 text-[10px] font-bold border border-amber-100 dark:bg-amber-900/10 dark:text-amber-400 dark:border-amber-900/30 self-start sm:self-auto truncate max-w-full">
                            <span class="size-1.5 bg-amber-500 rounded-full shrink-0"></span> Needs Review
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-green-50 text-green-700 text-[10px] font-bold border border-green-100 dark:bg-green-900/10 dark:text-green-400 dark:border-green-900/30 self-start sm:self-auto truncate max-w-full">
                            <span class="size-1.5 bg-green-500 rounded-full shrink-0"></span> All Clear
                        </span>
                    }
                    <h3 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none truncate w-full sm:w-auto text-left sm:text-right" title="@ViewBag.PendingLeaves">@ViewBag.PendingLeaves</h3>
                </div>
            </div>
        </div>

        <!-- Card: DB Size -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="p-4 sm:p-5">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 mb-4 truncate" title="DB Size">DB Size</p>
                <div class="flex flex-col-reverse sm:flex-row sm:justify-between sm:items-end gap-2 min-w-0">
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-green-50 text-green-700 text-[10px] font-bold border border-green-100 dark:bg-green-900/10 dark:text-green-400 dark:border-green-900/30 self-start sm:self-auto truncate max-w-full">
                        <span class="size-1.5 bg-green-500 rounded-full shrink-0"></span> Online
                    </span>
                    @if (ViewBag.DbSizeMB != null)
                    {
                        var dbMb = (decimal)ViewBag.DbSizeMB;
                        <h3 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none truncate w-full sm:w-auto text-left sm:text-right" title="@((dbMb >= 1024) ? (dbMb / 1024).ToString("F1") : dbMb.ToString("F0"))">
                            @((dbMb >= 1024) ? (dbMb / 1024).ToString("F1") : dbMb.ToString("F0"))
                            <span class="text-base text-gray-400 font-medium">@((dbMb >= 1024) ? "GB" : "MB")</span>
                        </h3>
                    }
                    else
                    {
                        <h3 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none truncate w-full sm:w-auto text-left sm:text-right" title="N/A">N/A</h3>
                    }
                </div>
            </div>
        </div>

        <!-- Card: Uptime -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="p-4 sm:p-5">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 mb-4 truncate" title="Uptime">Uptime</p>
                <div class="flex flex-col-reverse sm:flex-row sm:justify-between sm:items-end gap-2 min-w-0">
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-green-50 text-green-700 text-[10px] font-bold border border-green-100 dark:bg-green-900/10 dark:text-green-400 dark:border-green-900/30 self-start sm:self-auto truncate max-w-full">
                        <span class="size-1.5 bg-green-500 rounded-full shrink-0"></span> Healthy
                    </span>
                    <h3 id="uptimeCounter" class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none w-full sm:w-auto text-left sm:text-right truncate" data-start-utc="@ViewBag.AppStartTimeUtc" data-server-now-utc="@ViewBag.ServerNowUtc" title="@ViewBag.UptimeDisplay">
                        @ViewBag.UptimeDisplay
                    </h3>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!isSystemAdmin)
{
<!-- Business Overview -->
<div class="mb-12">
    <div class="flex items-center gap-x-2 mb-4">
        <i class="bi bi-bar-chart text-gray-400"></i>
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Business Overview</h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-6">
        <!-- Card: Products -->
        <div class="bg-white border border-gray-100 rounded-xl p-3 sm:p-5 dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="flex items-center justify-between gap-x-2">
                <div class="flex items-center gap-x-2 sm:gap-x-4 min-w-0">
                    <div class="shrink-0 flex justify-center items-center size-8 sm:size-12 bg-white text-gray-600 rounded-xl dark:bg-neutral-800 dark:text-neutral-400 border border-gray-100 dark:border-neutral-700">
                        <i class="bi bi-box-seam text-base sm:text-xl"></i>
                    </div>
                    <p class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 truncate" title="Products">Products</p>
                </div>
                <h3 class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-neutral-200 truncate" title="@ViewBag.TotalProducts">@ViewBag.TotalProducts</h3>
            </div>
        </div>

        <!-- Card: Alerts -->
        <div class="bg-white border border-gray-100 rounded-xl p-3 sm:p-5 dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="flex items-center justify-between gap-x-2">
                <div class="flex items-center gap-x-2 sm:gap-x-4 min-w-0">
                    <div class="shrink-0 flex justify-center items-center size-8 sm:size-12 bg-white text-gray-600 rounded-xl dark:bg-neutral-800 dark:text-neutral-400 border border-gray-100 dark:border-neutral-700">
                        <i class="bi bi-exclamation-circle text-base sm:text-xl"></i>
                    </div>
                    <p class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 truncate" title="Alerts">Alerts</p>
                </div>
                <h3 class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-neutral-200 truncate" title="@ViewBag.LowStockCount">@ViewBag.LowStockCount</h3>
            </div>
        </div>

        <!-- Card: Value -->
        <div class="bg-white border border-gray-100 rounded-xl p-3 sm:p-5 dark:bg-neutral-900 dark:border-neutral-800 shadow-sm min-w-0">
            <div class="flex items-center justify-between gap-x-2">
                <div class="flex items-center gap-x-2 sm:gap-x-4 min-w-0">
                    <div class="shrink-0 flex justify-center items-center size-8 sm:size-12 bg-white text-gray-600 rounded-xl dark:bg-neutral-800 dark:text-neutral-400 border border-gray-100 dark:border-neutral-700">
                        <i class="bi bi-wallet2 text-base sm:text-xl"></i>
                    </div>
                    <p class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 truncate" title="Value">Value</p>
                </div>
                <h3 class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-neutral-200 truncate" title="₱@Convert.ToDecimal(ViewBag.TotalValue).ToString("N2")">₱@Convert.ToDecimal(ViewBag.TotalValue).ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>
}

<!-- Quick Access -->
<div class="mb-12">
    <div class="flex items-center gap-x-2 mb-6">
        <i class="bi bi-lightning text-gray-400"></i>
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Quick Access</h2>
    </div>

    <div class="grid @(isSystemAdmin ? "grid-cols-1" : "sm:grid-cols-2") gap-6">
