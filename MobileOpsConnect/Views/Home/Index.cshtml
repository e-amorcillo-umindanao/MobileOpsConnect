                    <i class="bi bi-file-earmark-diff text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">View My Payslip</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">Access compensation details</p>
                </div>
