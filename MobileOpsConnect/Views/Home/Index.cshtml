            }
        </h2>
        <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
      <!-- Card -->
      <a class="group flex flex-col bg-white border shadow-sm rounded-xl hover:shadow-md transition dark:bg-neutral-900 dark:border-neutral-800" asp-controller="Settings" asp-action="AuditLogs">
        <div class="p-4 md:p-5">
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-x-3">
              <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500">
                <i class="bi bi-journal-text text-lg"></i>
              </span>
              <div>
                  <h3 class="group-hover:text-blue-600 font-semibold text-gray-800 dark:group-hover:text-blue-400 dark:text-neutral-200">
                    Audit Logs
                  </h3>
                  <p class="text-sm text-gray-500 dark:text-neutral-500">Global Activity</p>
              </div>
            </div>
            <div class="ps-3">
              <svg class="shrink-0 size-5 text-gray-800 dark:text-neutral-200" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          </div>
        </div>
      </a>
      <!-- End Card -->
    </div>
}

<script>
(function () {
    const el = document.getElementById('uptimeCounter');
    if (!el) return;
    const startUtc = new Date(el.dataset.startUtc).getTime();
    if (isNaN(startUtc)) return;

    function tick() {
        const diff = Date.now() - startUtc;
        const totalSec = Math.floor(diff / 1000);
        const days = Math.floor(totalSec / 86400);
        const hrs  = Math.floor((totalSec % 86400) / 3600);
        const mins = Math.floor((totalSec % 3600) / 60);
        const secs = totalSec % 60;

        if (days >= 1)      el.textContent = days + 'd ' + hrs + 'h';
        else if (hrs >= 1)  el.textContent = hrs + 'h ' + mins + 'm';
        else                el.textContent = mins + 'm ' + secs + 's';
    }

    tick();
    setInterval(tick, 1000);
})();
</script>
