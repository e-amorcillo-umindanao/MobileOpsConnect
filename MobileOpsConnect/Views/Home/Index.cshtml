@{
    ViewData["Title"] = "Command Center";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    bool isSystemAdmin = User.IsInRole("SystemAdmin");
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                    <span class="size-1.5 inline-block bg-green-500 rounded-full"></span>
                    All Systems Operational
                </span>
                @if (isSuperAdmin)
                {
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                        <i class="bi bi-shield-lock-fill text-blue-600"></i> Super Admin &bull; Alpha
                    </span>
                }
                else if (isSystemAdmin)
                {
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                        <i class="bi bi-gear-fill text-blue-600"></i> System Admin &bull; Beta
                    </span>
                }
            </div>
            @if (isSuperAdmin)
            {
                <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Alpha's Command Center</h1>
                <p class="text-blue-100 text-lg sm:text-xl">Super Admin Overview &amp; Control Panel</p>
            }
            else if (isSystemAdmin)
            {
                <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Beta's Dashboard</h1>
                <p class="text-blue-100 text-lg sm:text-xl">System Admin Overview &amp; Control Panel</p>
            }
        </div>
        <div class="hidden md:block opacity-20 pointer-events-none">
            <i class="bi bi-shield-lock-fill text-9xl text-white"></i>
        </div>
    </div>
</div>

<!-- System Health Title -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-heart-pulse-fill text-red-500"></i> System Health
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<!-- System Health Grid -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5">
        <div class="flex items-center gap-x-2">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">
            Registered Users
          </p>
        </div>
        <div class="mt-1 flex items-center gap-x-2">
          <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">
            @ViewBag.ActiveUsers
          </h3>
          <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium dark:bg-green-800/20 dark:text-green-400">
            <i class="bi bi-check-circle-fill"></i> Total
          </span>
        </div>
      </div>
    </div>
    <!-- End Card -->

    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5">
        <div class="flex items-center gap-x-2">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">
            Pending Leaves
          </p>
        </div>
        <div class="mt-1 flex items-center gap-x-2">
          <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">
            @ViewBag.PendingLeaves
          </h3>
          <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md text-xs font-medium @(ViewBag.PendingLeaves > 0 ? "bg-amber-100 text-amber-800 dark:bg-amber-800/20 dark:text-amber-400" : "bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400")">
            <i class="bi @(ViewBag.PendingLeaves > 0 ? "bi-hourglass-split" : "bi-check-circle-fill")"></i>
            @(ViewBag.PendingLeaves > 0 ? "Needs Review" : "All Clear")
          </span>
        </div>
      </div>
    </div>
    <!-- End Card -->

    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5">
        <div class="flex items-center gap-x-2">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">
            DB Size
          </p>
        </div>
        <div class="mt-1 flex items-center gap-x-2">
            @if (ViewBag.DbSizeMB != null)
            {
                var dbMb = (decimal)ViewBag.DbSizeMB;
                if (dbMb >= 1024)
                {
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">
                        @((dbMb / 1024).ToString("F1")) <span class="text-sm font-medium text-gray-500">GB</span>
                    </h3>
                }
                else
                {
                    <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">
                        @dbMb.ToString("F0") <span class="text-sm font-medium text-gray-500">MB</span>
                    </h3>
                }
            }
            else
            {
                <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">N/A</h3>
            }
            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium dark:bg-green-800/20 dark:text-green-400">
                <i class="bi bi-check-circle-fill"></i> Online
            </span>
        </div>
      </div>
    </div>
    <!-- End Card -->

    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5">
        <div class="flex items-center gap-x-2">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">
            Uptime
          </p>
        </div>
        <div class="mt-1 flex items-center gap-x-2">
          <h3 id="uptimeCounter" class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200" data-start-utc="@ViewBag.AppStartTimeUtc">
            @ViewBag.UptimeDisplay
          </h3>
          <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium dark:bg-green-800/20 dark:text-green-400">
            <i class="bi bi-check-circle-fill"></i> Healthy
          </span>
        </div>
      </div>
    </div>
    <!-- End Card -->
</div>

<!-- Business Metrics Title -->
<div class="flex items-center gap-x-3 mb-4 mt-8">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-bar-chart-line-fill text-indigo-500"></i> Business Overview
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<!-- Business Metrics Grid -->
<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5 flex gap-x-4">
        <div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg dark:bg-indigo-800/30 dark:text-indigo-500">
          <i class="bi bi-box-seam-fill text-xl"></i>
        </div>
        <div class="grow">
          <div class="flex items-center gap-x-2">
            <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Products</p>
          </div>
          <div class="mt-1 flex items-center gap-x-2">
            <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@ViewBag.TotalProducts</h3>
          </div>
        </div>
      </div>
    </div>
    <!-- End Card -->

    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5 flex gap-x-4">
        <div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg dark:bg-red-800/30 dark:text-red-500">
          <i class="bi bi-exclamation-octagon-fill text-xl"></i>
        </div>
        <div class="grow">
          <div class="flex items-center gap-x-2">
            <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Alerts</p>
          </div>
          <div class="mt-1 flex items-center gap-x-2">
            <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">@ViewBag.LowStockCount</h3>
          </div>
        </div>
      </div>
    </div>
    <!-- End Card -->

    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5 flex gap-x-4">
        <div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg dark:bg-green-800/30 dark:text-green-500">
          <i class="bi bi-currency-exchange text-xl"></i>
        </div>
        <div class="grow">
          <div class="flex items-center gap-x-2">
            <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Value</p>
          </div>
          <div class="mt-1 flex items-center gap-x-2">
            <h3 class="text-xl sm:text-2xl font-medium text-gray-800 dark:text-neutral-200">₱@Convert.ToDecimal(ViewBag.TotalValue).ToString("N2")</h3>
          </div>
        </div>
      </div>
    </div>
    <!-- End Card -->
</div>

<!-- Quick Access Title -->
<div class="flex items-center gap-x-3 mb-4 mt-8">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-neutral-200 flex items-center gap-x-2">
        <i class="bi bi-lightning-charge-fill text-amber-500"></i> Quick Access
    </h2>
    <div class="grow border-t border-gray-200 dark:border-neutral-700"></div>
</div>

<div class="grid @(isSystemAdmin ? "" : "sm:grid-cols-2") gap-4 sm:gap-6 mb-8">
    @if (!isSystemAdmin)
    {
    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl hover:shadow-md transition dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5">
        <div class="flex items-center gap-x-4 mb-4">
            <div class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-indigo-50 bg-indigo-100 text-indigo-800 dark:border-indigo-900 dark:bg-indigo-800 dark:text-indigo-400">
                <i class="bi bi-box-seam-fill text-2xl"></i>
            </div>
            <div>
                <h3 class="text-lg font-bold text-gray-800 dark:text-white">Inventory Management</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-500">Products &amp; Stock Control</p>
            </div>
        </div>
        <p class="text-gray-600 dark:text-neutral-400 mb-4">View stock levels, adjust prices, and manage product details across all warehouses.</p>
        <a asp-controller="Products" asp-action="Index" class="py-2 px-3 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:bg-blue-700 disabled:opacity-50 disabled:pointer-events-none w-full border-gray-200 shadow-sm">
            <i class="bi bi-arrow-right-circle"></i> Go to Inventory
        </a>
      </div>
    </div>
    <!-- End Card -->
    }

    <!-- Card -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl hover:shadow-md transition dark:bg-neutral-900 dark:border-neutral-800">
      <div class="p-4 md:p-5">
        <div class="flex items-center gap-x-4 mb-4">
            @if (isSuperAdmin)
            {
                <div class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-red-50 bg-red-100 text-red-800 dark:border-red-900 dark:bg-red-800 dark:text-red-400">
                    <i class="bi bi-shield-lock-fill text-2xl"></i>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white">Manage System Admins</h3>
                    <p class="text-sm text-gray-500 dark:text-neutral-500">Beta-Level Accounts</p>
                </div>
            }
            else
            {
                <div class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-cyan-50 bg-cyan-100 text-cyan-800 dark:border-cyan-900 dark:bg-cyan-800 dark:text-cyan-400">
                    <i class="bi bi-people-fill text-2xl"></i>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white">Manage User Accounts</h3>
                    <p class="text-sm text-gray-500 dark:text-neutral-500">Staff &amp; Employees</p>
                </div>
            }
        </div>
        @if (isSuperAdmin)
        {
            <p class="text-gray-600 dark:text-neutral-400 mb-4">Create and manage System Administrator accounts (Beta) with elevated privileges.</p>
        }
        else
        {
            <p class="text-gray-600 dark:text-neutral-400 mb-4">Manage Managers, Warehouse Staff, and Employee accounts and their permissions.</p>
        }
        <a asp-controller="Users" asp-action="Index" class="py-2 px-3 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 focus:outline-none focus:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 dark:focus:bg-neutral-800 w-full">
            <i class="bi bi-arrow-right-circle"></i> Manage Users
        </a>
      </div>
    </div>
    <!-- End Card -->
</div>

<!-- Admin Tools -->
@if (isSuperAdmin || isSystemAdmin)
{
    <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
        <!-- Card -->
        <div class="flex flex-col bg-white border shadow-sm rounded-xl hover:shadow-md transition dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-4 md:p-5 flex flex-col h-full">
            <div class="flex items-center gap-x-4 mb-4">
                <div class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400">
                    <i class="bi bi-gear-wide-connected text-2xl"></i>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white">System Configuration</h3>
