@{
    ViewData["Title"] = "Command Center";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    bool isSystemAdmin = User.IsInRole("SystemAdmin");
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="bg-white border border-moc-border rounded-lg shadow-sm p-6 md:p-10 mb-6 relative overflow-hidden">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-6 py-1.5 rounded-full text-sm font-medium border border-moc-border bg-moc-secondary text-moc-text">
                <i class="bi bi-circle-fill text-green-500 mr-1.5 text-[0.4rem]"></i>
                All Systems Operational
            </span>
            @if (isSuperAdmin)
            {
                <span class="inline-flex items-center px-6 py-1.5 rounded-full text-sm font-medium border border-moc-border bg-moc-secondary text-moc-text">
                    <i class="bi bi-shield-lock-fill mr-1.5"></i> Super Admin &bull; Alpha
                </span>
            }
            else if (isSystemAdmin)
            {
                <span class="inline-flex items-center px-6 py-1.5 rounded-full text-sm font-medium border border-moc-border bg-moc-secondary text-moc-text">
                    <i class="bi bi-gear-fill mr-1.5"></i> System Admin &bull; Beta
                </span>
            }
        </div>
        @if (isSuperAdmin)
        {
            <h1 class="text-3xl md:text-4xl font-bold mb-2 tracking-tight">Alpha's Command Center</h1>
            <p class="text-lg text-moc-text-muted mb-0">Super Admin Overview &amp; Control Panel &mdash; MobileOps Connect ERP</p>
        }
        else if (isSystemAdmin)
        {
            <h1 class="text-3xl md:text-4xl font-bold mb-2 tracking-tight">Beta's Dashboard</h1>
            <p class="text-lg text-moc-text-muted mb-0">System Admin Overview &amp; Control Panel &mdash; MobileOps Connect ERP</p>
        }
    </div>
    <!-- Decorative watermark -->
    <div class="absolute top-1/2 right-0 -translate-y-1/2 hidden lg:block pointer-events-none text-moc-text opacity-5 text-9xl pr-6">
        <i class="bi bi-shield-lock-fill"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- SYSTEM HEALTH METRICS  (Placeholders)           -->
<!-- ═══════════════════════════════════════════════ -->
<div class="flex items-center gap-6 mb-6 mt-2">
    <h5 class="m-0 text-lg font-semibold text-moc-text tracking-tight">
        <i class="bi bi-heart-pulse-fill text-red-500 mr-1.5"></i> System Health
    </h5>
    <hr class="flex-grow border-t border-moc-border opacity-100 m-0" />
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Active Users -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg p-6 md:p-6 shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted uppercase text-xs font-semibold mb-2 flex items-center gap-1">
                        Registered Users
                    </p>
                    <h3 class="text-2xl font-bold mb-2 tracking-tight">@ViewBag.ActiveUsers</h3>
                    <span class="inline-flex items-center text-xs font-semibold text-green-700 bg-green-50 px-2 py-1 rounded-md">
                        <i class="bi bi-check-circle-fill mr-1.5"></i> Total
                    </span>
                </div>
                <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-indigo-50 text-indigo-600 shrink-0">
                    <i class="bi bi-people-fill text-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Leaves -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg p-6 md:p-6 shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted uppercase text-xs font-semibold mb-2">Pending <span class="hidden md:inline">Leaves</span></p>
                    <h3 class="text-2xl font-bold mb-2 tracking-tight">@ViewBag.PendingLeaves</h3>
                    <span class="inline-flex items-center text-xs font-semibold px-2 py-1 rounded-md @(ViewBag.PendingLeaves > 0 ?"bg-amber-50 text-amber-700" : "bg-green-50 text-green-700")">
                        <i class="bi @(ViewBag.PendingLeaves > 0 ?"bi-hourglass-split" : "bi-check-circle-fill") mr-1.5"></i>
                        @(ViewBag.PendingLeaves > 0 ? "Needs Review" : "All Clear")
                    </span>
                </div>
                <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-amber-50 text-amber-600 shrink-0">
                    <i class="bi bi-calendar-event text-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Database Size -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg p-6 md:p-6 shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted uppercase text-xs font-semibold mb-2">DB Size</p>
                    @if (ViewBag.DbSizeMB != null)
                    {
                        var dbMb = (decimal)ViewBag.DbSizeMB;
                        if (dbMb >= 1024)
                        {
                            <h3 class="text-2xl font-bold mb-2 tracking-tight">@((dbMb / 1024).ToString("F1")) <span class="text-base font-semibold text-moc-text-muted">GB</span></h3>
                        }
                        else
                        {
                            <h3 class="text-2xl font-bold mb-2 tracking-tight">@dbMb.ToString("F0") <span class="text-base font-semibold text-moc-text-muted">MB</span></h3>
                        }
                    }
                    else
                    {
                        <h3 class="text-2xl font-bold mb-2 tracking-tight">N/A</h3>
                    }
                    <span class="inline-flex items-center text-xs font-semibold text-green-700 bg-green-50 px-2 py-1 rounded-md">
                        <i class="bi bi-check-circle-fill mr-1.5"></i> Online
                    </span>
                </div>
                <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-purple-50 text-purple-600 shrink-0">
                    <i class="bi bi-database-fill text-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- System Uptime -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg p-6 md:p-6 shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted uppercase text-xs font-semibold mb-2">Uptime</p>
                    <h3 id="uptimeCounter" class="text-2xl font-bold mb-2 tracking-tight"
                        data-start-utc="@ViewBag.AppStartTimeUtc">@ViewBag.UptimeDisplay</h3>
                    <span class="inline-flex items-center text-xs font-semibold text-green-700 bg-green-50 px-2 py-1 rounded-md">
                        <i class="bi bi-check-circle-fill mr-1.5"></i> Healthy
                    </span>
                </div>
                <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-green-50 text-green-600 shrink-0">
                    <i class="bi bi-activity text-lg"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- BUSINESS METRICS  (from backend ViewBag)        -->
<!-- ═══════════════════════════════════════════════ -->
<div class="flex items-center gap-6 mb-6 mt-12">
    <h5 class="m-0 text-lg font-semibold text-moc-text tracking-tight">
        <i class="bi bi-bar-chart-line-fill text-indigo-500 mr-1.5"></i> Business Overview
    </h5>
    <hr class="flex-grow border-t border-moc-border opacity-100 m-0" />
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Total Products -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
                        <i class="bi bi-box-seam-fill text-lg"></i>
                    </div>
                    <span class="inline-flex items-center px-6 py-1 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700">Products</span>
                </div>
                <h2 class="text-3xl font-bold mb-1 tracking-tight">@ViewBag.TotalProducts</h2>
                <p class="text-moc-text-muted text-sm mb-0">Total items in inventory</p>
            </div>
        </div>
    </div>

    <!-- Low Stock Alerts -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-red-50 text-red-600">
                        <i class="bi bi-exclamation-octagon-fill text-lg"></i>
                    </div>
                    <span class="inline-flex items-center px-6 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700">Alerts</span>
                </div>
                <h2 class="text-3xl font-bold mb-1 tracking-tight">@ViewBag.LowStockCount</h2>
                <p class="text-moc-text-muted text-sm mb-0">Low stock — reorder needed</p>
            </div>
        </div>
    </div>

    <!-- Inventory Value -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-green-50 text-green-600">
                        <i class="bi bi-currency-exchange text-lg"></i>
                    </div>
                    <span class="inline-flex items-center px-6 py-1 rounded-full text-xs font-semibold bg-green-50 text-green-700">Value</span>
                </div>
                <h2 class="text-3xl font-bold mb-1 tracking-tight">₱@Convert.ToDecimal(ViewBag.TotalValue).ToString("N2")</h2>
                <p class="text-moc-text-muted text-sm mb-0">Total inventory asset value</p>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- QUICK ACCESS — CORE OPERATIONS                  -->
<!-- ═══════════════════════════════════════════════ -->
<div class="flex items-center gap-6 mb-6 mt-12">
    <h5 class="m-0 text-lg font-semibold text-moc-text tracking-tight">
        <i class="bi bi-lightning-charge-fill text-amber-500 mr-1.5"></i> Quick Access
    </h5>
    <hr class="flex-grow border-t border-moc-border opacity-100 m-0" />
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <!-- Inventory Management -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="p-6 flex flex-col h-full">
                <div class="flex items-center mb-6">
                    <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-indigo-50 text-indigo-600 mr-4 shrink-0">
                        <i class="bi bi-box-seam-fill text-xl"></i>
                    </div>
                    <div>
                        <h5 class="font-bold mb-0 text-lg tracking-tight">Inventory Management</h5>
                        <span class="text-moc-text-muted text-sm">Products &amp; Stock Control</span>
                    </div>
                </div>
                <p class="text-moc-text-muted text-sm grow mb-6">
                    View stock levels, adjust prices, and manage product details across all warehouses.
                </p>
                <a asp-controller="Products" asp-action="Index" class="inline-flex justify-center items-center w-full px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-moc-primary hover:bg-moc-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-moc-primary transition-colors">
                    <i class="bi bi-arrow-right-circle mr-2"></i> Go to Inventory
                </a>
            </div>
        </div>
    </div>

    <!-- User / Admin Management (conditional) -->
    <div>
        <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
            <div class="p-6 flex flex-col h-full">
                <div class="flex items-center mb-6">
                    @if (isSuperAdmin)
                    {
                        <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-red-50 text-red-600 mr-4 shrink-0">
                            <i class="bi bi-shield-lock-fill text-xl"></i>
                        </div>
                        <div>
                            <h5 class="font-bold mb-0 text-lg text-red-600 tracking-tight">Manage System Admins</h5>
                            <span class="text-moc-text-muted text-sm">Beta-Level Accounts</span>
                        </div>
                    }
                    else
                    {
                        <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-cyan-50 text-cyan-600 mr-4 shrink-0">
                            <i class="bi bi-people-fill text-xl"></i>
                        </div>
                        <div>
                            <h5 class="font-bold mb-0 text-lg tracking-tight">Manage User Accounts</h5>
                            <span class="text-moc-text-muted text-sm">Staff &amp; Employees</span>
                        </div>
                    }
                </div>
                @if (isSuperAdmin)
                {
                    <p class="text-moc-text-muted text-sm grow mb-6">
                        Create and manage System Administrator accounts (Beta) with elevated privileges.
                    </p>
                }
                else
                {
                    <p class="text-moc-text-muted text-sm grow mb-6">
                        Manage Managers, Warehouse Staff, and Employee accounts and their permissions.
                    </p>
                }
                <a asp-controller="Users" asp-action="Index" class="inline-flex justify-center items-center w-full px-6 py-2 border border-moc-border text-sm font-medium rounded-md shadow-sm text-moc-text bg-white hover:bg-moc-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-moc-primary transition-colors">
                    <i class="bi bi-arrow-right-circle mr-2"></i> Manage Users
                </a>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- ADMIN TOOLS  (SuperAdmin OR SystemAdmin)        -->
<!-- ═══════════════════════════════════════════════ -->
@if (isSuperAdmin || isSystemAdmin)
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- System Configuration -->
        <div>
            <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
                <div class="p-6 flex flex-col h-full">
                    <div class="flex items-center mb-6">
                        <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-gray-100 text-gray-700 mr-4 shrink-0">
                            <i class="bi bi-gear-wide-connected text-xl"></i>
                        </div>
                        <div>
                            <h5 class="font-bold mb-0 text-lg tracking-tight">System Configuration</h5>
                            <span class="text-moc-text-muted text-sm">Settings &amp; Thresholds</span>
                        </div>
                    </div>
                    <p class="text-moc-text-muted text-sm grow mb-6">
                        Manage global settings, tax rates, low stock thresholds, and company information.
                    </p>
                    <a asp-controller="Settings" asp-action="Index" class="inline-flex justify-center items-center w-full px-6 py-2 border border-moc-border text-sm font-medium rounded-md shadow-sm text-moc-text bg-white hover:bg-moc-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-moc-primary transition-colors">
                        <i class="bi bi-sliders mr-2"></i> Open Settings
                    </a>
                </div>
            </div>
        </div>

        <!-- HR & Self Service -->
        <div>
            <div class="bg-white border border-moc-border rounded-lg shadow-sm hover:shadow-md transition-shadow h-full">
                <div class="p-6 flex flex-col h-full">
                    <div class="flex items-center mb-6">
                        <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-gray-100 text-gray-700 mr-4 shrink-0">
                            <i class="bi bi-calendar2-week-fill text-xl"></i>
                        </div>
                        <div>
                            <h5 class="font-bold mb-0 text-lg tracking-tight">HR &amp; Self Service</h5>
                            <span class="text-moc-text-muted text-sm">Leave &amp; Payroll</span>
                        </div>
                    </div>
                    <p class="text-moc-text-muted text-sm grow mb-6">
                        Manage staff leaves, file your own leave requests, and view payroll information.
                    </p>
                    <div class="flex flex-col gap-2">
                        <a asp-controller="LeaveRequests" asp-action="Index" class="inline-flex justify-center items-center w-full px-6 py-2 border border-moc-border text-sm font-medium rounded-md shadow-sm text-moc-text bg-white hover:bg-moc-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-moc-primary transition-colors">
                            <i class="bi bi-calendar-check mr-2"></i> Manage Staff Leaves
                        </a>
                        <div class="grid grid-cols-2 gap-2">
                            <a asp-controller="LeaveRequests" asp-action="Create" class="inline-flex justify-center items-center px-2 py-2 border border-moc-border text-sm font-medium rounded-md shadow-sm text-moc-text bg-white hover:bg-moc-secondary focus:outline-none transition-colors">
                                <i class="bi bi-plus-circle mr-1.5"></i> File Leave
                            </a>
                            <a asp-controller="Payroll" asp-action="MyPayslip" class="inline-flex justify-center items-center px-2 py-2 border border-moc-border text-sm font-medium rounded-md shadow-sm text-moc-text bg-white hover:bg-moc-secondary focus:outline-none transition-colors">
                                <i class="bi bi-file-earmark-text mr-1.5"></i> Payslip
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════ -->
<!-- SUPER ADMIN ZONE  (SuperAdmin only)             -->
<!-- ═══════════════════════════════════════════════ -->
