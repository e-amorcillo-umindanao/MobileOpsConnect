                <div class="bg-white border border-moc-border rounded-lg p-6 shadow-sm hover:border-gray-300 transition-colors h-full flex flex-col">
                    <div class="flex items-center mb-6">
                        <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gray-100 text-gray-700 mr-3">
                            <i class="bi bi-journal-text text-lg"></i>
                        </div>
                        <div>
                            <h6 class="font-semibold text-sm mb-0 text-moc-text">Audit Logs</h6>
                            <span class="text-moc-text-muted text-xs">Global Activity</span>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <a asp-controller="Settings" asp-action="AuditLogs"
                           class="inline-flex justify-center items-center w-full px-6 py-1.5 border border-moc-border text-sm font-medium rounded-md text-moc-text bg-white hover:bg-moc-secondary transition-colors">
                            <i class="bi bi-arrow-right-circle mr-1.5"></i> View Logs
                        </a>
                    </div>
                </div>
            </div>


            <!-- System Maintenance (placeholder) -->
            <div>
                <div class="bg-white border border-moc-border rounded-lg p-6 shadow-sm hover:border-gray-300 transition-colors h-full flex flex-col">
                    <div class="flex items-center mb-6">
                        <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gray-100 text-gray-700 mr-3">
                            <i class="bi bi-wrench-adjustable-circle-fill text-lg"></i>
                        </div>
                        <div>
                            <h6 class="font-semibold text-sm mb-0 text-moc-text">Maintenance</h6>
                            <span class="text-moc-text-muted text-xs">System Health</span>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <button class="inline-flex justify-center items-center w-full px-6 py-1.5 border border-moc-border text-sm font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed" disabled>
                            <i class="bi bi-clock mr-1.5"></i> Coming Soon
                        </button>
                    </div>
                </div>
            </div>

            <!-- Database Backups (placeholder) -->
            <div>
                <div class="bg-white border border-moc-border rounded-lg p-6 shadow-sm hover:border-gray-300 transition-colors h-full flex flex-col">
                    <div class="flex items-center mb-6">
                        <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gray-100 text-gray-700 mr-3">
                            <i class="bi bi-database-fill-down text-lg"></i>
                        </div>
                        <div>
                            <h6 class="font-semibold text-sm mb-0 text-moc-text">DB Backups</h6>
                            <span class="text-moc-text-muted text-xs">Data Safety</span>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <button class="inline-flex justify-center items-center w-full px-6 py-1.5 border border-moc-border text-sm font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed" disabled>
                            <i class="bi bi-clock mr-1.5"></i> Coming Soon
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
}

<!-- Live Uptime Ticker -->
<script>
(function () {
    const el = document.getElementById('uptimeCounter');
    if (!el) return;
    const startUtc = new Date(el.dataset.startUtc).getTime();
    if (isNaN(startUtc)) return;

    function tick() {
        const diff = Date.now() - startUtc;
        const totalSec = Math.floor(diff / 1000);
        const days = Math.floor(totalSec / 86400);
        const hrs  = Math.floor((totalSec % 86400) / 3600);
        const mins = Math.floor((totalSec % 3600) / 60);
        const secs = totalSec % 60;

        if (days >= 1)      el.textContent = days + 'd ' + hrs + 'h';
        else if (hrs >= 1)  el.textContent = hrs + 'h ' + mins + 'm';
        else                el.textContent = mins + 'm ' + secs + 's';
    }

    tick();
    setInterval(tick, 1000);
})();
</script>
