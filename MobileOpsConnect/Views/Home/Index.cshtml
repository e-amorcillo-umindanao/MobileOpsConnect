        </div>
        
        <a asp-controller="Settings" asp-action="AuditLogs" class="group p-5 flex items-center gap-x-4 bg-white border border-gray-100 rounded-2xl hover:border-blue-200 hover:shadow-sm transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:hover:border-blue-900/30 shadow-sm">
            <div class="size-12 flex justify-center items-center bg-blue-50 text-blue-600 rounded-xl dark:bg-blue-900/20 dark:text-blue-400 border border-blue-100 dark:border-blue-900/30">
                <i class="bi bi-list-columns-reverse text-xl"></i>
            </div>
            <div class="grow">
                <h3 class="font-bold text-gray-800 dark:text-white transition-colors group-hover:text-blue-600">Audit Logs</h3>
                <p class="text-xs text-gray-400 dark:text-neutral-500">Global Activity</p>
            </div>
            <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
        </a>
    </div>
    }
</div>

<script>
(function () {
    const el = document.getElementById('uptimeCounter');
    if (!el) return;
    const startUtc = new Date(el.dataset.startUtc).getTime();
    const serverNow = new Date(el.dataset.serverNowUtc).getTime();
    if (isNaN(startUtc) || isNaN(serverNow)) return;

    // Clock offset: how far the client clock is from the server clock
    const clockOffset = Date.now() - serverNow;

    function tick() {
        // Subtract offset to align with server time, clamp to 0
        const diff = Math.max(0, (Date.now() - clockOffset) - startUtc);
        const totalSec = Math.floor(diff / 1000);
        const days = Math.floor(totalSec / 86400);
        const hrs  = Math.floor((totalSec % 86400) / 3600);
        const mins = Math.floor((totalSec % 3600) / 60);
        const secs = totalSec % 60;

        if (days >= 1)      el.textContent = days + 'd ' + hrs + 'h';
        else if (hrs >= 1)  el.textContent = hrs + 'h ' + mins + 'm';
        else                el.textContent = mins + 'm ' + secs + 's';
    }

    tick();
    setInterval(tick, 1000);
})();
</script>
