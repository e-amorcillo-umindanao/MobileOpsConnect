@{
    ViewData["Title"] = "Staff Portal";
    bool isWarehouse = User.IsInRole("WarehouseStaff");
}

<!-- Hero Banner -->
<div class="mb-8">
    
    @if (isWarehouse)
    {
        <h1 class="text-2xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Delta's Operations Hub</h1>
        <p class="text-gray-500 dark:text-neutral-400 text-base">Warehouse Operations &amp; Self-Service Portal &mdash; Welcome, @User.Identity?.Name</p>
    }
    else
    {
        <h1 class="text-2xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Echo's Portal</h1>
        <p class="text-gray-500 dark:text-neutral-400 text-base">Employee Self-Service Portal &mdash; Welcome, @User.Identity?.Name</p>
    }
</div>

<!-- Snapshot Title -->
<div class="mb-4">
    <h2 class="text-sm font-bold text-gray-900 dark:text-white flex items-center gap-x-2">
        @(isWarehouse ? "Warehouse Snapshot" : "My Snapshot")
    </h2>
</div>

<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-10">
    @if (isWarehouse)
    {
        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-indigo-50/50 text-indigo-500 rounded-xl dark:bg-indigo-900/20 dark:text-indigo-400">
              <i class="bi bi-arrow-left-right text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Movements</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">0</h3>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-cyan-50/50 text-cyan-500 rounded-xl dark:bg-cyan-900/20 dark:text-cyan-400">
              <i class="bi bi-box-seam text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">In Stock</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.TotalProducts</h3>
              </div>
            </div>
          </div>
        </div>

        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-red-50/50 text-red-500 rounded-xl dark:bg-red-900/20 dark:text-red-400">
              <i class="bi bi-exclamation-octagon text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Low Stock</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.LowStockCount</h3>
              </div>
            </div>
          </div>
        </div>

        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-emerald-50/50 text-emerald-500 rounded-xl dark:bg-emerald-900/20 dark:text-emerald-400">
              <i class="bi bi-calendar-check text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Leave Bal.</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.LeaveBalance <span class="text-lg font-medium text-gray-400 dark:text-neutral-500 ml-1">days</span></h3>
              </div>
            </div>
          </div>
        </div>
    }
    else
    {
        <!-- Leave Balance -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-emerald-50/50 text-emerald-500 rounded-xl dark:bg-emerald-900/20 dark:text-emerald-400">
              <i class="bi bi-calendar-check text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Leave Bal.</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.LeaveBalance <span class="text-lg font-medium text-gray-400 ml-1">days</span></h3>
              </div>
            </div>
          </div>
        </div>

        <!-- Leaves Used -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-indigo-50/50 text-indigo-500 rounded-xl dark:bg-indigo-900/20 dark:text-indigo-400">
              <i class="bi bi-calendar-minus text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Used</p>
              <div class="mt-1 flex flex-col gap-y-2">
                <div class="flex items-baseline justify-end">
                  <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.LeavesUsed <span class="text-lg font-medium text-gray-400 ml-1">days</span></h3>
                </div>
                <div class="flex flex-col gap-y-1">
                  <div class="flex w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-neutral-800" role="progressbar" aria-valuenow="@ViewBag.LeaveUsedPercent" aria-valuemin="0" aria-valuemax="100">
                    <div class="flex flex-col justify-center rounded-full overflow-hidden bg-gray-900 text-xs text-white text-center whitespace-nowrap transition duration-500 dark:bg-white" style="width: @ViewBag.LeaveUsedPercent%"></div>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-[9px] text-gray-400 uppercase font-bold tracking-tight">Utilization</span>
                    <span class="text-xs text-gray-400 whitespace-nowrap font-medium">of @ViewBag.LeaveAllowance total</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Pending Requests -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-amber-50/50 text-amber-500 rounded-xl dark:bg-amber-900/20 dark:text-amber-400">
              <i class="bi bi-clock-history text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Pending</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.UserPending</h3>
              </div>
            </div>
          </div>
        </div>

        <!-- Next Payslip -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
          <div class="p-5 flex items-center gap-x-5">
            <div class="shrink-0 flex justify-center items-center size-[48px] bg-cyan-50/50 text-cyan-500 rounded-xl dark:bg-cyan-900/20 dark:text-cyan-400">
              <i class="bi bi-wallet2 text-xl"></i>
            </div>
            <div class="grow flex flex-col justify-center">
              <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400 dark:text-neutral-500 mb-1">Next Pay</p>
              <div class="flex items-baseline justify-between">
                <h3 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-none">@ViewBag.NextPayDate</h3>
              </div>
            </div>
          </div>
        </div>
    }
</div>

@if (isWarehouse)
{
    <!-- Warehouse Operations Title -->
    <div class="mb-4 mt-8">
        <h2 class="text-sm font-bold text-gray-900 dark:text-white flex items-center gap-x-2">
            Warehouse Operations
        </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-10">
        <!-- Purchase Order Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-3xl dark:bg-neutral-900 dark:border-neutral-800">
            <div class="p-6 md:p-8 flex flex-col text-center h-full">
                <div class="inline-flex justify-center items-center size-[64px] rounded-full mx-auto mb-6 bg-amber-50 text-amber-500 dark:bg-amber-900/20 dark:text-amber-400">
                    <i class="bi bi-cart3 text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Purchase Order</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-400 grow mb-8 leading-relaxed">Submit restock requests for manager approval</p>
                <a asp-controller="Orders" asp-action="Create" class="mt-auto py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-xl border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 focus:outline-none focus:bg-gray-50 transition-all w-full dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                    <i class="bi bi-plus-lg"></i> New Order
                </a>
            </div>
        </div>
        
        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-3xl dark:bg-neutral-900 dark:border-neutral-800">
            <div class="p-6 md:p-8 flex flex-col text-center h-full">
                <div class="inline-flex justify-center items-center size-[64px] rounded-full mx-auto mb-6 bg-indigo-50 text-indigo-500 dark:bg-indigo-900/20 dark:text-indigo-400">
                    <i class="bi bi-arrow-left-right text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Stock In / Out</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-400 grow mb-8 leading-relaxed">Process incoming and outgoing stock movements</p>
                <a asp-controller="Warehouse" asp-action="Index" class="mt-auto py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-xl border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 focus:outline-none focus:bg-gray-50 transition-all w-full dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                    <i class="bi bi-arrow-right"></i> Open
                </a>
            </div>
        </div>
        
        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-3xl dark:bg-neutral-900 dark:border-neutral-800">
            <div class="p-6 md:p-8 flex flex-col text-center h-full">
                <div class="inline-flex justify-center items-center size-[64px] rounded-full mx-auto mb-6 bg-cyan-50 text-cyan-500 dark:bg-cyan-900/20 dark:text-cyan-400">
                    <i class="bi bi-search text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Inventory List</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-400 grow mb-8 leading-relaxed">Search and browse all products in the system</p>
                <a asp-controller="Products" asp-action="Index" class="mt-auto py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-xl border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 focus:outline-none focus:bg-gray-50 transition-all w-full dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                    <i class="bi bi-arrow-right"></i> Browse
                </a>
            </div>
        </div>

        <!-- Card -->
        <div class="flex flex-col bg-white border border-gray-100 border-l-4 @(ViewBag.LowStockCount > 0 ? "border-l-red-500" : "border-l-emerald-500") rounded-3xl dark:bg-neutral-900 dark:border-t-neutral-800 dark:border-r-neutral-800 dark:border-b-neutral-800">
            <div class="p-6 md:p-8 flex flex-col text-center h-full">
                <div class="relative inline-flex justify-center items-center size-[64px] rounded-full mx-auto mb-6 @(ViewBag.LowStockCount > 0 ? "bg-red-50 text-red-500 dark:bg-red-900/20 dark:text-red-400" : "bg-emerald-50 text-emerald-500 dark:bg-emerald-900/20 dark:text-emerald-400")">
                    <i class="bi @(ViewBag.LowStockCount > 0 ? "bi-bell text-2xl" : "bi-check-circle text-2xl")"></i>
                    @if (ViewBag.LowStockCount > 0)
                    {
                        <span class="absolute top-[2px] right-[2px] size-3.5 bg-red-500 border-2 border-white rounded-full dark:border-neutral-900"></span>
                    }
                </div>
                <h3 class="text-xl font-bold @(ViewBag.LowStockCount > 0 ? "text-red-600 dark:text-red-500" : "text-emerald-600 dark:text-emerald-500") mb-2">Low Stock Alerts</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-400 grow mb-8 leading-relaxed">@(ViewBag.LowStockCount > 0 ? "Items below threshold — reorder needed" : "Inventory levels are healthy")</p>
                
                @if (ViewBag.LowStockCount > 0)
                {
                    <a asp-controller="Warehouse" asp-action="LowStock" class="mt-auto py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-xl border border-transparent bg-red-600 text-white hover:bg-red-700 focus:outline-none transition-all w-full">
                        <i class="bi bi-exclamation-octagon"></i> View Alerts (@ViewBag.LowStockCount)
                    </a>
                }
                else
                {
                    <a asp-controller="Warehouse" asp-action="LowStock" class="mt-auto py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-xl border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 focus:outline-none transition-all w-full dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                        <i class="bi bi-shield-check"></i> Check Levels
                    </a>
                }
            </div>
        </div>
    </div>
}

<!-- Self-Service Title -->
<div class="mb-4 mt-8">
    <h2 class="text-sm font-bold text-gray-900 dark:text-white flex items-center gap-x-2">
        My Self-Service
    </h2>
</div>

<div class="grid lg:grid-cols-2 gap-12 mb-10">
    <!-- Self Service -->
    <div>
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 overflow-hidden shadow-sm divide-y divide-gray-100 dark:divide-neutral-800">
            <!-- File Leave -->
            <a asp-controller="LeaveRequests" asp-action="Create" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-indigo-50 text-indigo-600 rounded-lg dark:bg-indigo-900/20 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/30">
                    <i class="bi bi-calendar-event text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">File Leave Request</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">Submit a new leave application</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>

            <!-- My Leave History -->
            <a asp-controller="LeaveRequests" asp-action="Index" asp-route-view="my" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-amber-50 text-amber-500 rounded-lg dark:bg-amber-900/20 dark:text-amber-400 border border-amber-100 dark:border-amber-900/30">
                    <i class="bi bi-folder2-open text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">My Leave History</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">View submitted leaves & approval status</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>

            <!-- My Payslip -->
            <a asp-controller="Payroll" asp-action="MyPayslip" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-cyan-50 text-cyan-600 rounded-lg dark:bg-cyan-900/20 dark:text-cyan-400 border border-cyan-100 dark:border-cyan-900/30">
                    <i class="bi bi-file-earmark-diff text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">View My Payslip</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">Access compensation details</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>
        </div>
    </div>
</div>

