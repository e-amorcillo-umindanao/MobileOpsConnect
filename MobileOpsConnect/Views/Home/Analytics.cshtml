@{
    ViewData["Title"] = "Analytics Dashboard";
    decimal totalValue = (decimal)ViewBag.TotalValue;
    int totalProducts = (int)ViewBag.TotalProducts;
    int lowStockCount = (int)ViewBag.LowStockCount;
    int onLeaveCount = (int)ViewBag.OnLeaveCount;
    int leaveUtilPercent = (int)ViewBag.LeaveUtilPercent;
    int pendingLeaves = (int)ViewBag.PendingLeaves;
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-x-2 text-sm font-medium text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            Analytics Module
        </span>
        @if (lowStockCount > 0)
        { <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-rose-50 text-rose-600 border border-rose-100 dark:bg-rose-900/30 dark:border-rose-800 dark:text-rose-400 tracking-wide uppercase"><i class="bi bi-exclamation-triangle"></i> @lowStockCount Low Stock Alert@(lowStockCount != 1 ? "s" : "")</span> }
        @if (pendingLeaves > 0)
        { <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-amber-50 text-amber-600 border border-amber-100 dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-400 tracking-wide uppercase"><i class="bi bi-hourglass-split"></i> @pendingLeaves Pending Leave@(pendingLeaves != 1 ? "s" : "")</span> }
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Performance & Analytics</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Real-time overview of inventory, staffing & operational alerts</p>
</div>

<!-- Key Metrics -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-10">
    <!-- Inventory Value -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-[#f4f2ff] text-[#5e4dcd] rounded-2xl dark:bg-indigo-900/20 dark:text-indigo-400">
                <i class="bi bi-cash-stack text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Inventory Value</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">₱@totalValue.ToString("N0")</h3>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-[#f4f2ff] text-[#5e4dcd] text-[10px] font-bold uppercase tracking-wide dark:bg-indigo-900/20 dark:text-indigo-400 mb-1">
                <i class="bi bi-box-seam"></i> @totalProducts Products
            </span>
        </div>
    </div>

    <!-- Total Products -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-purple-50 text-purple-500 rounded-2xl dark:bg-purple-900/20 dark:text-purple-400">
                <i class="bi bi-box-seam text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Total Products</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@totalProducts</h3>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-purple-50 text-purple-600 text-[10px] font-bold uppercase tracking-wide dark:bg-purple-900/20 dark:text-purple-400 mb-1">
                <i class="bi bi-grid"></i> Catalog
            </span>
        </div>
    </div>

    <!-- Low Stock -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] @(lowStockCount > 0 ? "bg-rose-50 text-rose-500 dark:bg-rose-900/20 dark:text-rose-400" : "bg-emerald-50 text-emerald-500 dark:bg-emerald-900/20 dark:text-emerald-400") rounded-2xl">
                <i class="bi @(lowStockCount > 0 ? "bi-exclamation-octagon" : "bi-check2-all") text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Low Stock</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@lowStockCount</h3>
            @if (lowStockCount > 0)
            { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-rose-50 text-rose-600 text-[10px] font-bold uppercase tracking-wide dark:bg-rose-900/20 dark:text-rose-400 mb-1"><i class="bi bi-exclamation-triangle"></i> Reorder Needed</span> }
            else
            { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-emerald-50 text-emerald-600 text-[10px] font-bold uppercase tracking-wide dark:bg-emerald-900/20 dark:text-emerald-400 mb-1"><i class="bi bi-check-circle"></i> Healthy</span> }
        </div>
    </div>

    <!-- Staff On Leave -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-amber-50 text-amber-500 rounded-2xl dark:bg-amber-900/20 dark:text-amber-400">
                <i class="bi bi-people text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Staff On Leave</p>
        <div class="flex items-end justify-between mt-auto">
            <h3 class="text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@onLeaveCount</h3>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-amber-50 text-amber-600 text-[10px] font-bold uppercase tracking-wide dark:bg-amber-900/20 dark:text-amber-400 mb-1">
                @leaveUtilPercent% Workforce
            </span>
        </div>
    </div>
</div>

<!-- Charts & Alerts Row -->
<div class="grid lg:grid-cols-2 gap-6 gap-y-14 mb-8">
    <!-- Inventory Distribution -->
    <div>
        <div class="flex items-center gap-x-2 mb-4">
            <i class="bi bi-pie-chart text-gray-400"></i>
            <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Inventory Distribution</h2>
        </div>
        <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl h-full dark:bg-neutral-900 dark:border-neutral-800">
            <div class="p-6">
                @if (ViewBag.TopCategories != null)
                {
                    var categories = (IEnumerable<dynamic>)ViewBag.TopCategories;
                    var colors = new[] { "#6366f1", "#0ea5e9", "#818cf8", "#38bdf8", "#a5b4fc", "#7dd3fc" };
                    var bgColors = new[] { "rgba(99,102,241,0.12)", "rgba(14,165,233,0.12)", "rgba(99,102,241,0.08)", "rgba(14,165,233,0.08)", "rgba(99,102,241,0.06)", "rgba(14,165,233,0.06)" };
                    
                    // Calculate conic gradient segments
                    var gradientParts = new List<string>();
                    double currentPercent = 0;
                    int i = 0;
                    foreach (var cat in categories)
                    {
                        var color = colors[i % colors.Length];
                        gradientParts.Add($"{color} {currentPercent}% {currentPercent + cat.Percent}%");
                        currentPercent += cat.Percent;
                        i++;
                    }
                    var gradientStr = string.Join(", ", gradientParts);

                    <!-- Donut Chart -->
                    <div class="relative size-48 mx-auto mb-8">
                        <div class="size-full rounded-full" style="background: conic-gradient(@gradientStr);"></div>
                        <div class="absolute inset-4 bg-white dark:bg-neutral-900 rounded-full flex flex-col items-center justify-center border-4 border-gray-50 dark:border-neutral-800">
                            <span class="text-2xl font-bold text-gray-900 dark:text-white">@totalProducts</span>
                            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total Items</span>
                        </div>
                    </div>

                    int ci = 0;
                    foreach (var cat in categories)
                    {
                        var color = colors[ci % colors.Length];
                        var bgColor = bgColors[ci % bgColors.Length]; ci++;
                        <div class="mb-4">
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="inline-flex justify-center items-center size-[32px] rounded-md" style="background:@bgColor;"><i class="bi bi-tag-fill" style="color:@color; font-size:0.8rem;"></i></span>
                                    <span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">@(string.IsNullOrEmpty(cat.Category) ? "Uncategorized" : cat.Category)</span>
                                </div>
                                <div class="text-right"><span class="text-sm font-bold text-gray-800 dark:text-neutral-200">@cat.Count</span> <span class="text-xs text-gray-500">(@cat.Percent%)</span></div>
                            </div>
                            <div class="progress rounded-pill" style="height:6px;background:#f3f4f6;">
                                <div class="progress-bar rounded-pill" style="width:@cat.Percent%;background:@color;transition:width 1s ease;" role="progressbar"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-8">
                        <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-indigo-50 bg-indigo-100 text-indigo-800 mx-auto mb-4"><i class="bi bi-inbox text-2xl"></i></span>
                        <h3 class="text-sm font-semibold text-gray-800 mb-1">No Data Available</h3>
                        <p class="text-xs text-gray-500 mb-0">Inventory distribution data will appear here once products are added.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Actions Required -->
    <div>
        <div class="flex items-center gap-x-2 mb-4">
            <i class="bi bi-bell text-gray-400"></i>
            <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Actions Required</h2>
        </div>
        <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
            <div class="p-0">
                @{ bool hasAlerts = pendingLeaves > 0 || (ViewBag.LowStockAlerts != null && ((IEnumerable<dynamic>)ViewBag.LowStockAlerts).Any()); }
                @if (!hasAlerts)
                {
                    <div class="text-center py-8 px-6">
                        <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4"><i class="bi bi-check-circle-fill text-2xl"></i></span>
                        <h3 class="text-sm font-semibold text-gray-800 mb-1">All Clear</h3>
                        <p class="text-xs text-gray-500 mb-0">No critical alerts at this time. Everything is running smoothly.</p>
                    </div>
                }
                else
                {
                    <div class="p-6 space-y-4">
                        @if (pendingLeaves > 0)
                        {
                            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <span class="inline-flex justify-center items-center size-[44px] rounded-lg bg-amber-100 text-amber-800"><i class="bi bi-calendar-event-fill text-lg"></i></span>
                                    <div><p class="text-sm font-bold text-gray-800 mb-0">Leave Requests Pending</p><span class="text-xs text-gray-500"><strong>@pendingLeaves</strong> request@(pendingLeaves != 1 ? "s" : "") awaiting approval</span></div>
                                </div>
                                <a asp-controller="LeaveRequests" asp-action="Index" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100"><i class="bi bi-arrow-right"></i> Review</a>
                            </div>
                        }
                        @if (ViewBag.LowStockAlerts != null)
                        {
                            foreach (var item in ViewBag.LowStockAlerts)
                            {
                                bool isOutOfStock = item.StockQuantity == 0;
                                <div class="rounded-lg p-4 flex items-center justify-between @(isOutOfStock ? "bg-red-50 border border-red-200" : "bg-amber-50 border border-amber-200")">
                                    <div class="flex items-center gap-3">
                                        <span class="inline-flex justify-center items-center size-[44px] rounded-lg @(isOutOfStock ? "bg-red-100 text-red-800" : "bg-amber-100 text-amber-800")"><i class="bi @(isOutOfStock ? "bi-x-circle-fill" : "bi-exclamation-triangle-fill") text-lg"></i></span>
                                        <div><p class="text-sm font-bold text-gray-800 mb-0">@item.Name</p><span class="text-xs text-gray-500">Only <strong>@item.StockQuantity</strong> remaining</span></div>
                                    </div>
                                    <span class="inline-flex items-center py-1 px-2.5 rounded-full text-xs font-semibold @(isOutOfStock ? "bg-red-100 text-red-800" : "bg-amber-100 text-amber-800")">@(isOutOfStock ? "OUT OF STOCK" : "CRITICAL")</span>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>


