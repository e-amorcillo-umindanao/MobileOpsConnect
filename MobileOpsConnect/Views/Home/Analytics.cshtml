@{
    ViewData["Title"] = "Analytics Dashboard";
    decimal totalValue = (decimal)ViewBag.TotalValue;
    int totalProducts = (int)ViewBag.TotalProducts;
    int lowStockCount = (int)ViewBag.LowStockCount;
    int onLeaveCount = (int)ViewBag.OnLeaveCount;
    int leaveUtilPercent = (int)ViewBag.LeaveUtilPercent;
    int pendingLeaves = (int)ViewBag.PendingLeaves;
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> Analytics Module
            </span>
            @if (lowStockCount > 0)
            { <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-500/30 text-white"><i class="bi bi-exclamation-triangle-fill"></i> @lowStockCount Low Stock Alert@(lowStockCount != 1 ? "s" : "")</span> }
            @if (pendingLeaves > 0)
            { <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-amber-500/30 text-white"><i class="bi bi-hourglass-split"></i> @pendingLeaves Pending Leave@(pendingLeaves != 1 ? "s" : "")</span> }
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Performance &amp; Analytics</h1>
        <p class="text-blue-100 text-lg">Real-time overview of inventory, staffing &amp; operational alerts</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-graph-up-arrow text-9xl text-white"></i>
    </div>
</div>

<!-- Key Metrics -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div><p class="text-xs uppercase tracking-wide text-gray-500">Inventory Value</p><h3 class="text-xl font-medium text-gray-800 mt-1">₱@totalValue.ToString("N0")</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium"><i class="bi bi-box-seam"></i> @totalProducts Products</span></div>
            <span class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg"><i class="bi bi-cash-stack text-xl"></i></span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div><p class="text-xs uppercase tracking-wide text-gray-500">Total Products</p><h3 class="text-xl font-medium text-gray-800 mt-1">@totalProducts</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-purple-100 text-purple-800 text-xs font-medium"><i class="bi bi-grid-fill"></i> Catalog</span></div>
            <span class="shrink-0 flex justify-center items-center size-[46px] bg-purple-100 text-purple-800 rounded-lg"><i class="bi bi-box-seam-fill text-xl"></i></span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Low Stock</p><h3 class="text-xl font-medium text-gray-800 mt-1">@lowStockCount</h3>
                @if (lowStockCount > 0)
                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-exclamation-triangle-fill"></i> Reorder Needed</span> }
                else
                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Healthy</span> }
            </div>
            <span class="shrink-0 flex justify-center items-center size-[46px] @(lowStockCount > 0 ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") rounded-lg"><i class="bi @(lowStockCount > 0 ? "bi-exclamation-octagon-fill" : "bi-check2-all") text-xl"></i></span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex justify-between">
            <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Staff On Leave</p><h3 class="text-xl font-medium text-gray-800 mt-1">@onLeaveCount</h3>
                <div class="progress mt-1" style="height:4px;width:72px;">
                    <div class="progress-bar rounded-pill" role="progressbar" style="width:@leaveUtilPercent%;background:#6366f1;" aria-valuenow="@leaveUtilPercent" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <span class="text-xs text-gray-500">@leaveUtilPercent% of workforce</span>
            </div>
            <span class="shrink-0 flex justify-center items-center size-[46px] bg-amber-100 text-amber-800 rounded-lg"><i class="bi bi-people-fill text-xl"></i></span>
        </div>
    </div>
</div>

<!-- Charts & Alerts Row -->
<div class="grid lg:grid-cols-2 gap-6 mb-8">
    <!-- Inventory Distribution -->
    <div>
        <div class="flex items-center gap-x-3 mb-4">
            <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-pie-chart-fill text-indigo-500"></i> Inventory Distribution</h2>
            <div class="grow border-t border-gray-200"></div>
        </div>
        <div class="flex flex-col bg-white border shadow-sm rounded-xl h-full">
            <div class="p-6">
                @if (ViewBag.TopCategories != null)
                {
                    var colors = new[] {
                        new { bg = "rgba(99,102,241,0.12)", bar = "#6366f1", text = "text-indigo-600" },
                        new { bg = "rgba(14,165,233,0.12)", bar = "#0ea5e9", text = "text-cyan-600" },
                        new { bg = "rgba(99,102,241,0.08)", bar = "#818cf8", text = "text-indigo-400" },
                        new { bg = "rgba(14,165,233,0.08)", bar = "#38bdf8", text = "text-cyan-400" },
                        new { bg = "rgba(99,102,241,0.06)", bar = "#a5b4fc", text = "text-indigo-300" },
                        new { bg = "rgba(14,165,233,0.06)", bar = "#7dd3fc", text = "text-cyan-300" }
                    };
                    int ci = 0;
                    foreach (var cat in ViewBag.TopCategories)
                    {
                        var c = colors[ci % colors.Length]; ci++;
                        <div class="mb-4">
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="inline-flex justify-center items-center size-[32px] rounded-md" style="background:@c.bg;"><i class="bi bi-tag-fill @c.text" style="font-size:0.8rem;"></i></span>
                                    <span class="text-sm font-semibold text-gray-800">@(string.IsNullOrEmpty(cat.Category) ? "Uncategorized" : cat.Category)</span>
                                </div>
                                <div class="text-right"><span class="text-sm font-bold text-gray-800">@cat.Count</span> <span class="text-xs text-gray-500">(@cat.Percent%)</span></div>
                            </div>
                            <div class="progress rounded-pill" style="height:8px;background:#e5e7eb;">
                                <div class="progress-bar rounded-pill" style="width:@cat.Percent%;background:@c.bar;transition:width 1s ease;" role="progressbar"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-8">
                        <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-indigo-50 bg-indigo-100 text-indigo-800 mx-auto mb-4"><i class="bi bi-inbox text-2xl"></i></span>
                        <h3 class="text-sm font-semibold text-gray-800 mb-1">No Data Available</h3>
                        <p class="text-xs text-gray-500 mb-0">Inventory distribution data will appear here once products are added.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Actions Required -->
    <div>
        <div class="flex items-center gap-x-3 mb-4">
            <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-bell-fill text-indigo-500"></i> Actions Required</h2>
            <div class="grow border-t border-gray-200"></div>
        </div>
        <div class="flex flex-col bg-white border shadow-sm rounded-xl h-full">
            <div class="p-0">
                @{ bool hasAlerts = pendingLeaves > 0 || (ViewBag.LowStockAlerts != null && ((IEnumerable<dynamic>)ViewBag.LowStockAlerts).Any()); }
                @if (!hasAlerts)
                {
                    <div class="text-center py-8 px-6">
                        <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4"><i class="bi bi-check-circle-fill text-2xl"></i></span>
                        <h3 class="text-sm font-semibold text-gray-800 mb-1">All Clear</h3>
                        <p class="text-xs text-gray-500 mb-0">No critical alerts at this time. Everything is running smoothly.</p>
                    </div>
                }
                else
                {
                    <div class="p-6 space-y-4">
                        @if (pendingLeaves > 0)
                        {
                            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <span class="inline-flex justify-center items-center size-[44px] rounded-lg bg-amber-100 text-amber-800"><i class="bi bi-calendar-event-fill text-lg"></i></span>
                                    <div><p class="text-sm font-bold text-gray-800 mb-0">Leave Requests Pending</p><span class="text-xs text-gray-500"><strong>@pendingLeaves</strong> request@(pendingLeaves != 1 ? "s" : "") awaiting approval</span></div>
                                </div>
                                <a asp-controller="LeaveRequests" asp-action="Index" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100"><i class="bi bi-arrow-right"></i> Review</a>
                            </div>
                        }
                        @if (ViewBag.LowStockAlerts != null)
                        {
                            foreach (var item in ViewBag.LowStockAlerts)
                            {
                                bool isOutOfStock = item.StockQuantity == 0;
                                <div class="rounded-lg p-4 flex items-center justify-between @(isOutOfStock ? "bg-red-50 border border-red-200" : "bg-amber-50 border border-amber-200")">
                                    <div class="flex items-center gap-3">
                                        <span class="inline-flex justify-center items-center size-[44px] rounded-lg @(isOutOfStock ? "bg-red-100 text-red-800" : "bg-amber-100 text-amber-800")"><i class="bi @(isOutOfStock ? "bi-x-circle-fill" : "bi-exclamation-triangle-fill") text-lg"></i></span>
                                        <div><p class="text-sm font-bold text-gray-800 mb-0">@item.Name</p><span class="text-xs text-gray-500">Only <strong>@item.StockQuantity</strong> remaining</span></div>
                                    </div>
                                    <span class="inline-flex items-center py-1 px-2.5 rounded-full text-xs font-semibold @(isOutOfStock ? "bg-red-100 text-red-800" : "bg-amber-100 text-amber-800")">@(isOutOfStock ? "OUT OF STOCK" : "CRITICAL")</span>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="text-center mb-6">
    <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>
