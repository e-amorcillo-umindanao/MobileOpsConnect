@{
    ViewData["Title"] = "Analytics Dashboard";

    decimal totalValue = (decimal)ViewBag.TotalValue;
    int totalProducts = (int)ViewBag.TotalProducts;
    int lowStockCount = (int)ViewBag.LowStockCount;
    int onLeaveCount = (int)ViewBag.OnLeaveCount;
    int leaveUtilPercent = (int)ViewBag.LeaveUtilPercent;
    int pendingLeaves = (int)ViewBag.PendingLeaves;
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-circle-fill text-green-500 mr-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                Analytics Module
            </span>
            @if (lowStockCount > 0)
            {
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(239,68,68,0.25);">
                    <i class="bi bi-exclamation-triangle-fill mr-1"></i> @lowStockCount Low Stock Alert@(lowStockCount != 1 ? "s" : "")
                </span>
            }
            @if (pendingLeaves > 0)
            {
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(245,158,11,0.25);">
                    <i class="bi bi-hourglass-split mr-1"></i> @pendingLeaves Pending Leave@(pendingLeaves != 1 ? "s" : "")
                </span>
            }
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">Performance &amp; Analytics</h1>
        <p class="lead mb-0 opacity-75">
            Real-time overview of inventory, staffing &amp; operational alerts
        </p>
    </div>
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-graph-up-arrow"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- KEY METRICS                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-section-header mt-2">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-speedometer2 text-indigo mr-1"></i> Key Metrics
    </h5>
    <hr />
</div>

<div class="flex flex-wrap -mx-3 g-3 mb-6">
    <!-- Total Inventory Value -->
    <div class="col-6 col-lg-3 anim-fade-in anim-delay-1">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Inventory Value</p>
                    <h3 class="font-bold mb-1 letter-tight">₱@totalValue.ToString("N0")</h3>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo text-xs font-semibold">
                        <i class="bi bi-box-seam mr-1"></i> @totalProducts Products
                    </span>
                </div>
                <div class="moc-icon-box bg-indigo-50 rounded-3">
                    <i class="bi bi-cash-stack text-indigo fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Products -->
    <div class="col-6 col-lg-3 anim-fade-in anim-delay-2">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Total Products</p>
                    <h3 class="font-bold mb-1 letter-tight">@totalProducts</h3>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple text-xs font-semibold">
                        <i class="bi bi-grid-fill mr-1"></i> Catalog
                    </span>
                </div>
                <div class="moc-icon-box bg-purple-50 rounded-3">
                    <i class="bi bi-box-seam-fill text-purple fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Low Stock Items -->
    <div class="col-6 col-lg-3 anim-fade-in anim-delay-3">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Low Stock</p>
                    <h3 class="font-bold mb-1 letter-tight">@lowStockCount</h3>
                    @if (lowStockCount > 0)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red text-xs font-semibold">
                            <i class="bi bi-exclamation-triangle-fill mr-1"></i> Reorder Needed
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green text-xs font-semibold">
                            <i class="bi bi-check-circle-fill mr-1"></i> Healthy
                        </span>
                    }
                </div>
                <div class="moc-icon-box @(lowStockCount > 0 ?"bg-red-50" : "bg-green-50") rounded-3">
                    <i class="bi @(lowStockCount > 0 ?"bi-exclamation-octagon-fill text-red" : "bi-check2-all text-green") fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Staff On Leave -->
    <div class="col-6 col-lg-3 anim-fade-in anim-delay-4">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Staff On Leave</p>
                    <h3 class="font-bold mb-1 letter-tight">@onLeaveCount</h3>
                    <div class="progress mt-1" style="height:4px;width:72px;">
                        <div class="progress-bar rounded-pill" role="progressbar"
                             style="width:@leaveUtilPercent%;background:var(--moc-primary);"
                             aria-valuenow="@leaveUtilPercent" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <span class="text-moc-text-muted text-xs">@leaveUtilPercent% of workforce</span>
                </div>
                <div class="moc-icon-box bg-amber-50 rounded-3">
                    <i class="bi bi-people-fill text-amber fs-5"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- CHARTS & ALERTS ROW                             -->
<!-- ═══════════════════════════════════════════════ -->
<div class="flex flex-wrap -mx-3 g-4 mb-6">

    <!-- Inventory Distribution Chart -->
    <div class="w-full lg:w-1/2 px-6 anim-fade-in anim-delay-1">
        <div class="moc-section-header mt-6">
            <h5 class="font-bold letter-tight">
                <i class="bi bi-pie-chart-fill text-indigo mr-1"></i> Inventory Distribution
            </h5>
            <hr />
        </div>

        <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm h-100">
            <div class="p-6 p-6">
                @if (ViewBag.TopCategories != null)
                {
                    var colors = new[] {
                        new { bg = "rgba(99,102,241,0.12)", bar = "var(--moc-primary)", text = "text-indigo" },
                        new { bg = "rgba(14,165,233,0.12)", bar = "#0ea5e9", text = "text-secondary-color" },
                        new { bg = "rgba(99,102,241,0.08)", bar = "#818cf8", text = "text-indigo" },
                        new { bg = "rgba(14,165,233,0.08)", bar = "#38bdf8", text = "text-secondary-color" },
                        new { bg = "rgba(99,102,241,0.06)", bar = "#a5b4fc", text = "text-indigo" },
                        new { bg = "rgba(14,165,233,0.06)", bar = "#7dd3fc", text = "text-secondary-color" }
                    };
                    int ci = 0;

                    foreach (var cat in ViewBag.TopCategories)
                    {
                        var c = colors[ci % colors.Length];
                        ci++;

                        <div class="mb-6">
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <div class="rounded-2 flex items-center justify-center"
                                         style="width:32px;height:32px;min-width:32px;background:@c.bg;">
                                        <i class="bi bi-tag-fill @c.text" style="font-size:0.8rem;"></i>
                                    </div>
                                    <span class="font-semibold text-sm letter-tight">
                                        @(string.IsNullOrEmpty(cat.Category) ? "Uncategorized" : cat.Category)
                                    </span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-sm">@cat.Count</span>
                                    <span class="text-moc-text-muted text-xs ml-1">(@cat.Percent%)</span>
                                </div>
                            </div>
                            <div class="progress rounded-pill" style="height:8px;background:var(--moc-border);">
                                <div class="progress-bar rounded-pill"
                                     style="width:@cat.Percent%;background:@c.bar;transition:width 1s ease;"
                                     role="progressbar"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-8">
                        <div class="moc-icon-box-lg bg-indigo-50 rounded-3 mx-auto mb-6">
                            <i class="bi bi-inbox text-indigo fs-3"></i>
                        </div>
                        <h6 class="font-bold mb-1 letter-tight">No Data Available</h6>
                        <p class="text-moc-text-muted text-sm mb-0">Inventory distribution data will appear here once products are added.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- System Actions Required -->
    <div class="w-full lg:w-1/2 px-6 anim-fade-in anim-delay-2">
        <div class="moc-section-header mt-6">
            <h5 class="font-bold letter-tight">
                <i class="bi bi-bell-fill text-indigo mr-1"></i> Actions Required
            </h5>
            <hr />
        </div>

        <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm h-100">
            <div class="p-6 p-0">

                @{
                    bool hasAlerts = pendingLeaves > 0 || (ViewBag.LowStockAlerts != null && ((IEnumerable<dynamic>)ViewBag.LowStockAlerts).Any());
                }

                @if (!hasAlerts)
                {
                    <div class="text-center p-8">
                        <div class="moc-icon-box-lg bg-green-50 rounded-3 mx-auto mb-6">
                            <i class="bi bi-check-circle-fill text-green fs-3"></i>
                        </div>
                        <h6 class="font-bold mb-1 letter-tight">All Clear</h6>
                        <p class="text-moc-text-muted text-sm mb-0">No critical alerts at this time. Everything is running smoothly.</p>
                    </div>
                }
                else
                {
                    <div class="p-6">
                        <!-- Pending Leave Requests -->
                        @if (pendingLeaves > 0)
                        {
                            <div class="moc-metric p-6 mb-6" style="border-left:4px solid #f59e0b !important;">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-6">
                                        <div class="moc-icon-box bg-amber-50 rounded-3" style="width:44px;height:44px;min-width:44px;">
                                            <i class="bi bi-calendar-event-fill text-amber fs-5"></i>
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm mb-0 letter-tight">Leave Requests Pending</p>
                                            <span class="text-moc-text-muted text-xs">
                                                <strong>@pendingLeaves</strong> request@(pendingLeaves != 1 ? "s" : "") awaiting approval
                                            </span>
                                        </div>
                                    </div>
                                    <a asp-controller="LeaveRequests" asp-action="Index"
                                       class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 px-2 py-1 text-xs px-6 py-1 font-semibold"
                                       style="background:rgba(245,158,11,0.08);color:#f59e0b;border:1.5px solid rgba(245,158,11,0.2);">
                                        <i class="bi bi-arrow-right mr-1"></i> Review
                                    </a>
                                </div>
                            </div>
                        }

                        <!-- Low Stock Alerts -->
                        @if (ViewBag.LowStockAlerts != null)
                        {
                            foreach (var item in ViewBag.LowStockAlerts)
                            {
                                bool isOutOfStock = item.StockQuantity == 0;
                                <div class="moc-metric p-6 mb-6" style="border-left:4px solid @(isOutOfStock ? "#ef4444" : "#f59e0b") !important;">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-6">
                                            <div class="moc-icon-box @(isOutOfStock ?"bg-red-50" : "bg-amber-50") rounded-3"
                                                 style="width:44px;height:44px;min-width:44px;">
                                                <i class="bi @(isOutOfStock ?"bi-x-circle-fill text-red" : "bi-exclamation-triangle-fill text-amber") fs-5"></i>
                                            </div>
                                            <div>
                                                <p class="font-bold text-sm mb-0 letter-tight">@item.Name</p>
                                                <span class="text-moc-text-muted text-xs">
                                                    Only <strong>@item.StockQuantity</strong> remaining
                                                </span>
                                            </div>
                                        </div>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill @(isOutOfStock ?"bg-red-50 text-red" : "bg-amber-50 text-amber") px-3 py-2 fw-semibold text-xs">
                                            @(isOutOfStock ? "OUT OF STOCK" : "CRITICAL")
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<div class="text-center mb-6 anim-fade-in">
    <a asp-controller="Home" asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-6 py-2">
        <i class="bi bi-arrow-left mr-1"></i> Back to Dashboard
    </a>
</div>

