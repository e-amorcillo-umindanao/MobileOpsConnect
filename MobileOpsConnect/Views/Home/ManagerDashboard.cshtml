@{
    ViewData["Title"] = "Manager Overview";
}

<!-- Header -->
<div class="mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-green-50 text-green-700 text-[10px] font-bold border border-green-100 dark:bg-green-900/10 dark:text-green-400 dark:border-green-900/30">
            <span class="size-1.5 bg-green-500 rounded-full"></span> All Systems Operational
        </span>
        <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-gray-50 text-gray-600 text-[10px] font-bold border border-gray-100 dark:bg-neutral-800 dark:text-neutral-400 dark:border-neutral-700">
            <i class="bi bi-shield-check"></i> Department Manager • Charlie
        </span>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">Charlie's Dashboard</h1>
    <p class="text-gray-500 dark:text-neutral-400 text-lg">Approvals, Analytics &amp; Self-Service &mdash; MobileOps Connect ERP</p>
</div>

<!-- Department Overview -->
<div class="mb-12">
    <div class="flex items-center gap-x-2 mb-6">
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Department Overview</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        <!-- Card: Pending -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm">
            <div class="p-5">
                <div class="flex justify-between items-start mb-4">
                    <div class="size-10 flex justify-center items-center bg-amber-50 text-amber-600 rounded-lg dark:bg-amber-900/20 dark:text-amber-400 border border-amber-100 dark:border-amber-900/30">
                        <i class="bi bi-hourglass-split text-lg"></i>
                    </div>
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2 rounded-full @(ViewBag.PendingLeaves > 0 ? "bg-amber-50 text-amber-700 border-amber-100 dark:bg-amber-900/10 dark:text-amber-400" : "bg-green-50 text-green-700 border-green-100 dark:bg-green-900/10 dark:text-green-400") text-[10px] font-bold border">
                        @(ViewBag.PendingLeaves > 0 ? "Action" : "Clear")
                    </span>
                </div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Pending</p>
                <h3 class="text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none mt-1">@ViewBag.PendingLeaves</h3>
            </div>
        </div>

        <!-- Card: Team -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm">
            <div class="p-5">
                <div class="flex justify-between items-start mb-4">
                    <div class="size-10 flex justify-center items-center bg-indigo-50 text-indigo-600 rounded-lg dark:bg-indigo-900/20 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/30">
                        <i class="bi bi-people text-lg"></i>
                    </div>
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2 rounded-full bg-indigo-50 text-indigo-700 text-[10px] font-bold border border-indigo-100 dark:bg-indigo-900/10 dark:text-indigo-400">
                        Active
                    </span>
                </div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Team</p>
                <h3 class="text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none mt-1">@ViewBag.TeamCount</h3>
            </div>
        </div>

        <!-- Card: On Leave -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm">
            <div class="p-5">
                <div class="flex justify-between items-start mb-4">
                    <div class="size-10 flex justify-center items-center bg-cyan-50 text-cyan-600 rounded-lg dark:bg-cyan-900/20 dark:text-cyan-400 border border-cyan-100 dark:border-cyan-900/30">
                        <i class="bi bi-calendar-check text-lg"></i>
                    </div>
                </div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">On Leave</p>
                <h3 class="text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none mt-1">@ViewBag.OnLeaveToday</h3>
                <div class="mt-4 flex flex-col gap-y-1">
                    <div class="w-full h-1 bg-gray-100 rounded-full dark:bg-neutral-800 overflow-hidden">
                        <div class="h-full bg-blue-600 rounded-full dark:bg-blue-500 transition-all duration-500" style="width: @ViewBag.OnLeavePercent%"></div>
                    </div>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500 font-medium tracking-tight">of @ViewBag.TeamCount staff</p>
                </div>
            </div>
        </div>

        <!-- Card: Inventory -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm">
            <div class="p-5">
                <div class="flex justify-between items-start mb-4">
                    <div class="size-10 flex justify-center items-center bg-green-50 text-green-600 rounded-lg dark:bg-green-900/20 dark:text-green-400 border border-green-100 dark:border-green-900/30">
                        <i class="bi bi-box-seam text-lg"></i>
                    </div>
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2 rounded-full @(ViewBag.LowStockCount > 0 ? "bg-amber-50 text-amber-700 border-amber-100 dark:bg-amber-900/10 dark:text-amber-400" : "bg-green-50 text-green-700 border-green-100 dark:bg-green-900/10 dark:text-green-400") text-[10px] font-bold border">
                        @(ViewBag.LowStockCount > 0 ? $"{ViewBag.LowStockCount} Low Stock" : "Healthy")
                    </span>
                </div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Inventory</p>
                <h3 class="text-4xl font-bold text-gray-900 dark:text-neutral-200 leading-none mt-1">@ViewBag.TotalProducts</h3>
            </div>
        </div>
    </div>
</div>

<!-- Operational Approvals -->
<div class="mb-12">
    <div class="flex items-center gap-x-2 mb-6">
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Operational Approvals</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
        <!-- Pending Leaves Approvals -->
        <div class="flex flex-col bg-white border border-gray-100 border-l-4 border-l-amber-500 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-x-4">
                        <div class="size-12 flex justify-center items-center bg-amber-50 text-amber-600 rounded-xl dark:bg-amber-900/20 dark:text-amber-400 border border-amber-100 dark:border-amber-900/30">
                            <i class="bi bi-calendar-event text-xl"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Pending Leaves</h3>
                            <p class="text-xs text-gray-400 dark:text-neutral-500">Employee Requests</p>
                        </div>
                    </div>
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full @(ViewBag.PendingLeaves > 0 ? "bg-amber-50 text-amber-700 border-amber-100 dark:bg-amber-900/10 dark:text-amber-400" : "bg-green-50 text-green-700 border-green-100 dark:bg-green-900/10 dark:text-green-400") text-[10px] font-bold border">
                         @(ViewBag.PendingLeaves > 0 ? "Needs Review" : "All Clear")
                    </span>
                </div>
                <p class="text-gray-500 dark:text-neutral-400 text-sm leading-relaxed mb-6">Review and approve employee leave applications. Pending requests require your attention for timely processing.</p>
                
                <div class="bg-amber-50/50 border border-amber-100 rounded-xl p-4 mb-6 dark:bg-amber-900/10 dark:border-amber-900/30">
                    <div class="flex items-center gap-x-3">
                        <i class="bi bi-clock text-amber-600 dark:text-amber-400"></i>
                        <div>
                            <p class="text-xs font-bold text-amber-900 dark:text-amber-300">@ViewBag.PendingLeaves request(s) awaiting review</p>
                            <p class="text-[10px] text-amber-600/80 dark:text-amber-400/80">Oldest pending: @ViewBag.OldestPendingDays</p>
                        </div>
                    </div>
                </div>

                <a asp-controller="LeaveRequests" asp-action="Index" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-all dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                    Review Requests
                </a>
            </div>
        </div>

        <!-- Purchase Orders Approvals -->
        <div class="flex flex-col bg-white border border-gray-100 border-l-4 border-l-blue-600 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-x-4">
                        <div class="size-12 flex justify-center items-center bg-blue-50 text-blue-600 rounded-xl dark:bg-blue-900/20 dark:text-blue-400 border border-blue-100 dark:border-blue-900/30">
                            <i class="bi bi-truck text-xl"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Purchase Orders</h3>
                            <p class="text-xs text-gray-400 dark:text-neutral-500">Restock Requests</p>
                        </div>
                    </div>
                    <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full bg-green-50 text-green-700 text-[10px] font-bold border border-green-100 dark:bg-green-900/10 dark:text-green-400">
                        Live
                    </span>
                </div>
                <p class="text-gray-500 dark:text-neutral-400 text-sm leading-relaxed mb-6">Approve or reject purchase orders submitted by warehouse staff for inventory restocking.</p>

                <div class="bg-amber-50/50 border border-amber-100 rounded-xl p-4 mb-6 dark:bg-amber-900/10 dark:border-amber-900/30">
                    <div class="flex items-center gap-x-3">
                        <i class="bi bi-inbox text-amber-600 dark:text-amber-400"></i>
                        <div>
                            <p class="text-xs font-bold text-amber-900 dark:text-amber-300">@(ViewBag.PendingOrders ?? 0) Pending Orders</p>
                            <p class="text-[10px] text-amber-600/80 dark:text-amber-400/80">Awaiting your approval</p>
                        </div>
                    </div>
                </div>

                <a asp-controller="Orders" asp-action="Index" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-all dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                    Approve Orders
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Reports & Analytics -->
<div class="mb-12">
    <div class="flex items-center gap-x-2 mb-6">
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200">Reports &amp; Analytics</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
        <!-- Analytics Dashboard -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm">
            <div class="p-6">
                <div class="flex items-center gap-x-4 mb-6">
                    <div class="size-12 flex justify-center items-center bg-indigo-50 text-indigo-600 rounded-xl dark:bg-indigo-900/20 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/30">
                        <i class="bi bi-speedometer2 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Analytics Dashboard</h3>
                        <p class="text-xs text-gray-400 dark:text-neutral-500">Trends &amp; Metrics</p>
                    </div>
                </div>
                <p class="text-gray-500 dark:text-neutral-400 text-sm leading-relaxed mb-6">Sales trends, leave utilization, and performance metrics in one comprehensive view.</p>
                
                <div class="flex items-end justify-between gap-1.5 h-16 mb-8 px-2">
                    <div class="w-full bg-indigo-100 rounded-t-sm dark:bg-indigo-900/20" style="height: 30%"></div>
                    <div class="w-full bg-indigo-200 rounded-t-sm dark:bg-indigo-800/40" style="height: 45%"></div>
                    <div class="w-full bg-indigo-100 rounded-t-sm dark:bg-indigo-900/20" style="height: 35%"></div>
                    <div class="w-full bg-indigo-300 rounded-t-sm dark:bg-indigo-700/40" style="height: 60%"></div>
                    <div class="w-full bg-indigo-200 rounded-t-sm dark:bg-indigo-800/40" style="height: 50%"></div>
                    <div class="w-full bg-indigo-500 rounded-t-sm dark:bg-indigo-500/80" style="height: 85%"></div>
                    <div class="w-full bg-indigo-600 rounded-t-sm dark:bg-indigo-600" style="height: 75%"></div>
                </div>

                <a asp-controller="Home" asp-action="Analytics" class="group w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-gray-200 bg-white text-gray-900 hover:bg-gray-50 transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:text-white dark:hover:bg-neutral-800">
                    <i class="bi bi-arrow-right text-xs transition-transform group-hover:translate-x-1"></i> Open Dashboard
                </a>
            </div>
        </div>

        <!-- Inventory Reports -->
        <div class="flex flex-col bg-white border border-gray-100 rounded-xl dark:bg-neutral-900 dark:border-neutral-800 shadow-sm">
            <div class="p-6">
                <div class="flex items-center gap-x-4 mb-6">
                    <div class="size-12 flex justify-center items-center bg-gray-50 text-gray-600 rounded-xl dark:bg-neutral-800 dark:text-neutral-400 border border-gray-100 dark:border-neutral-700">
                        <i class="bi bi-box-seam text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Inventory Reports</h3>
                        <p class="text-xs text-gray-400 dark:text-neutral-500">Stock &amp; Valuation</p>
                    </div>
                </div>
                <p class="text-gray-500 dark:text-neutral-400 text-sm leading-relaxed mb-6">Detailed breakdown of stock levels, product categories, and overall inventory valuation.</p>

                <div class="grid grid-cols-3 gap-3 mb-8">
                    <div class="p-3 bg-gray-50 rounded-xl border border-gray-100 dark:bg-neutral-800/50 dark:border-neutral-700">
                        <p class="text-lg font-bold text-gray-900 dark:text-white leading-none">@ViewBag.TotalProducts</p>
                        <span class="text-[9px] font-bold text-gray-400 uppercase tracking-tight">Products</span>
                    </div>
                    <div class="p-3 bg-red-50 rounded-xl border border-red-100 dark:bg-red-900/10 dark:border-red-900/30">
                        <p class="text-lg font-bold text-red-600 dark:text-red-400 leading-none">@ViewBag.LowStockCount</p>
                        <span class="text-[9px] font-bold text-red-400 uppercase tracking-tight">Low Stock</span>
                    </div>
                    <div class="p-3 bg-green-50 rounded-xl border border-green-100 dark:bg-green-900/10 dark:border-green-900/30">
                        <p class="text-lg font-bold text-green-600 dark:text-green-400 leading-none">@(ViewBag.InStockPercent)%</p>
                        <span class="text-[9px] font-bold text-green-400 uppercase tracking-tight">In Stock</span>
                    </div>
                </div>

                <a asp-controller="Products" asp-action="Index" class="group w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-gray-200 bg-white text-gray-900 hover:bg-gray-50 transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:text-white dark:hover:bg-neutral-800">
                    <i class="bi bi-arrow-right text-xs transition-transform group-hover:translate-x-1"></i> View Inventory Report
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Self-Service & Team Management -->
<div class="grid lg:grid-cols-2 gap-12 mb-12">
    <!-- Self Service -->
    <div>
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200 mb-6">My Self-Service</h2>
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 overflow-hidden shadow-sm divide-y divide-gray-100 dark:divide-neutral-800">
            <!-- File Leave -->
            <a asp-controller="LeaveRequests" asp-action="Create" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-indigo-50 text-indigo-600 rounded-lg dark:bg-indigo-900/20 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/30">
                    <i class="bi bi-calendar-event text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">File Leave Request</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">Submit a new leave application</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>

            <!-- My Leave History -->
            <a asp-controller="LeaveRequests" asp-action="Index" asp-route-view="my" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-amber-50 text-amber-500 rounded-lg dark:bg-amber-900/20 dark:text-amber-400 border border-amber-100 dark:border-amber-900/30">
                    <i class="bi bi-folder2-open text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">My Leave History</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">View submitted leaves & approval status</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>

            <!-- My Payslip -->
            <a asp-controller="Payroll" asp-action="MyPayslip" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-cyan-50 text-cyan-600 rounded-lg dark:bg-cyan-900/20 dark:text-cyan-400 border border-cyan-100 dark:border-cyan-900/30">
                    <i class="bi bi-file-earmark-diff text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">View My Payslip</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">Access compensation details</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>

            <!-- Account Security -->
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="group p-5 flex items-center gap-x-4 hover:bg-gray-50/50 transition-all dark:hover:bg-neutral-800">
                <div class="size-10 flex justify-center items-center bg-purple-50 text-purple-600 rounded-lg dark:bg-purple-900/20 dark:text-purple-400 border border-purple-100 dark:border-purple-900/30">
                    <i class="bi bi-shield-lock text-lg"></i>
                </div>
                <div class="grow">
                    <h3 class="font-bold text-gray-800 dark:text-white text-sm">Account Security</h3>
                    <p class="text-[10px] text-gray-400 dark:text-neutral-500">Update password &amp; profile</p>
                </div>
                <i class="bi bi-chevron-right text-gray-300 dark:text-neutral-600 transition-transform group-hover:translate-x-0.5"></i>
            </a>
        </div>
    </div>

    <!-- Team Management -->
    <div>
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest dark:text-neutral-200 mb-6">Team Management</h2>
        <div class="flex flex-col bg-white border border-gray-100 rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 overflow-hidden shadow-sm">
            <div class="p-6 flex-grow">
                <div class="flex items-center gap-x-4 mb-6">
                    <div class="size-12 flex justify-center items-center bg-gray-50 text-gray-600 rounded-xl dark:bg-neutral-800 dark:text-neutral-400 border border-gray-100 dark:border-neutral-700">
                        <i class="bi bi-person-badge text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Employee Records</h3>
                        <p class="text-xs text-gray-400 dark:text-neutral-500">Staff directory &amp; stats</p>
                    </div>
                </div>
                <p class="text-gray-500 dark:text-neutral-400 text-sm leading-relaxed mb-6">View your team's employee information, roles, and leave activity. Read-only access.</p>
                
                <a asp-controller="Users" asp-action="EmployeeRecords" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 transition-all dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                    <i class="bi bi-people text-xs"></i> View Employee Records
                </a>
            </div>
        </div>
    </div>
</div>
