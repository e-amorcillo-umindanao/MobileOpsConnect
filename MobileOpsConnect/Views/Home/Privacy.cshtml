@{
    ViewData["Title"] = "Privacy Policy";
}
<div class="max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 mx-auto">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-10 lg:mb-14">
        <h2 class="text-3xl font-bold md:text-5xl md:leading-tight text-gray-900 dark:text-white mb-4 tracking-tight">Privacy Policy</h2>
        <p class="text-lg text-gray-500 dark:text-neutral-400">Our commitment to protecting your data and account transparency.</p>
        <p class="mt-8 text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Last Updated: February 27, 2026</p>
    </div>
    <!-- End Header -->

    <div class="max-w-4xl mx-auto">
        <!-- Grid -->
        <div class="grid gap-12 sm:gap-16">
            <!-- Section: Information Collection -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-8">
                <div class="flex-shrink-0 pt-1">
                    <span class="flex justify-center items-center size-12 bg-blue-50/80 text-blue-600 rounded-2xl border border-blue-100 dark:bg-blue-900/20 dark:border-blue-800 dark:text-blue-400">
                        <i class="bi bi-person-badge text-xl"></i>
                    </span>
                </div>
                <div class="grow">
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">1. Information We Collect</h3>
                    <p class="text-gray-600 dark:text-neutral-400 leading-relaxed mb-4">To provide a secure and functional ERP experience, MobileOpsConnect collects the following types of data:</p>
                    <ul class="space-y-4 text-gray-600 dark:text-neutral-400 text-sm">
                        <li class="flex gap-x-3">
                            <span class="mt-2 size-1.5 flex justify-center items-center rounded-full bg-gray-400 dark:bg-neutral-600"></span>
                            <span><strong class="font-semibold text-gray-800 dark:text-neutral-200">Identity Data:</strong> Email addresses, usernames, and role assignments for secure access control.</span>
                        </li>
                        <li class="flex gap-x-3">
                            <span class="mt-2 size-1.5 flex justify-center items-center rounded-full bg-gray-400 dark:bg-neutral-600"></span>
                            <span><strong class="font-semibold text-gray-800 dark:text-neutral-200">Operational Data:</strong> Detailed records of Leave Requests (type, dates, reasons) and their approval workflows.</span>
                        </li>
                        <li class="flex gap-x-3">
                            <span class="mt-2 size-1.5 flex justify-center items-center rounded-full bg-gray-400 dark:bg-neutral-600"></span>
                            <span><strong class="font-semibold text-gray-800 dark:text-neutral-200">Financial Data:</strong> Accounting entries including transaction amounts, descriptions, and reference numbers.</span>
                        </li>
                        <li class="flex gap-x-3">
                            <span class="mt-2 size-1.5 flex justify-center items-center rounded-full bg-gray-400 dark:bg-neutral-600"></span>
                            <span><strong class="font-semibold text-gray-800 dark:text-neutral-200">Security Log Data:</strong> Timestamps and IP addresses associated with administrative actions to ensure traceability.</span>
                        </li>
                    </ul>
                </div>
            </div>
            <!-- End Section -->

            <!-- Section: Usage -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-8">
                <div class="flex-shrink-0 pt-1">
                    <span class="flex justify-center items-center size-12 bg-emerald-50/80 text-emerald-600 rounded-2xl border border-emerald-100 dark:bg-emerald-900/20 dark:border-emerald-800 dark:text-emerald-400">
                        <i class="bi bi-box text-xl"></i>
                    </span>
                </div>
                <div class="grow">
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">2. How We Use Your Information</h3>
                    <p class="text-gray-600 dark:text-neutral-400 leading-relaxed mb-6">The data collected is utilized solely for the enhancement of your operational workflows:</p>
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div class="p-5 border border-gray-200 rounded-2xl shadow-sm transition-all duration-300 hover:shadow-md hover:border-gray-300 hover:-translate-y-0.5 dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-neutral-700 dark:hover:bg-neutral-800/80">
                            <span class="block text-sm font-bold text-gray-800 dark:text-white mb-1">Core Functionality</span>
                            <span class="block text-sm text-gray-500 dark:text-neutral-400 leading-relaxed">Processing leave requests and managing financial accounting records.</span>
                        </div>
                        <div class="p-5 border border-gray-200 rounded-2xl shadow-sm transition-all duration-300 hover:shadow-md hover:border-gray-300 hover:-translate-y-0.5 dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-neutral-700 dark:hover:bg-neutral-800/80">
                            <span class="block text-sm font-bold text-gray-800 dark:text-white mb-1">Accountability</span>
                            <span class="block text-sm text-gray-500 dark:text-neutral-400 leading-relaxed">Generating audit logs for security oversight and transaction history.</span>
                        </div>
                        <div class="p-5 border border-gray-200 rounded-2xl shadow-sm transition-all duration-300 hover:shadow-md hover:border-gray-300 hover:-translate-y-0.5 dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-neutral-700 dark:hover:bg-neutral-800/80">
                            <span class="block text-sm font-bold text-gray-800 dark:text-white mb-1">Communication</span>
                            <span class="block text-sm text-gray-500 dark:text-neutral-400 leading-relaxed">Sending real-time stock and status alerts via push notifications.</span>
                        </div>
                        <div class="p-5 border border-gray-200 rounded-2xl shadow-sm transition-all duration-300 hover:shadow-md hover:border-gray-300 hover:-translate-y-0.5 dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-neutral-700 dark:hover:bg-neutral-800/80">
                            <span class="block text-sm font-bold text-gray-800 dark:text-white mb-1">Security</span>
                            <span class="block text-sm text-gray-500 dark:text-neutral-400 leading-relaxed">Verifying authorization levels and preventing unauthorized access.</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- End Section -->

            <!-- Section: Data Protection -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-8">
                <div class="flex-shrink-0 pt-1">
                    <span class="flex justify-center items-center size-12 bg-purple-50/80 text-purple-600 rounded-2xl border border-purple-100 dark:bg-purple-900/20 dark:border-purple-800 dark:text-purple-400">
                        <i class="bi bi-shield-check text-xl"></i>
                    </span>
                </div>
                <div class="grow">
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">3. Security & Retention</h3>
                    <p class="text-gray-600 dark:text-neutral-400 leading-relaxed mb-6">We employ high-grade security protocols to safeguard your enterprise data. Credentials are never stored in plain text, and all communications are encrypted via SSL/TLS.</p>
                    <div class="border-l-2 border-blue-600 pl-4 py-1 dark:border-blue-500">
                        <p class="text-sm text-gray-500 dark:text-neutral-400 italic">"Personal data is retained only for the duration of its operational relevance and can be managed directly via the account management portal."</p>
                    </div>
                </div>
            </div>
            <!-- End Section -->
        </div>
        <!-- End Grid -->
    </div>
</div>
