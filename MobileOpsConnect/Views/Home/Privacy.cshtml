@{
    ViewData["Title"] = "Privacy Policy";
}
<div class="max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 mx-auto">
    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-10 lg:mb-14">
        <h2 class="text-2xl font-bold md:text-4xl md:leading-tight dark:text-white">Privacy Policy</h2>
        <p class="mt-1 text-gray-600 dark:text-neutral-400">Our commitment to protecting your data and account transparency.</p>
        <p class="mt-4 text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-500">Last Updated: February 27, 2026</p>
    </div>
    <!-- End Header -->

    <div class="max-w-3xl mx-auto">
        <!-- Grid -->
        <div class="grid gap-12">
            <!-- Section: Information Collection -->
            <div>
                <div class="flex gap-x-5">
                    <div class="flex-shrink-0">
                        <span class="flex justify-center items-center size-10 bg-blue-100 text-blue-600 rounded-lg dark:bg-blue-900/30 dark:text-blue-400">
                            <i class="bi bi-person-badge text-xl"></i>
                        </span>
                    </div>
                    <div class="grow">
                        <h3 class="text-lg font-semibold text-gray-800 dark:text-white">1. Information We Collect</h3>
                        <p class="mt-1 text-gray-600 dark:text-neutral-400">To provide a secure and functional ERP experience, MobileOpsConnect collects the following types of data:</p>
                        <ul class="mt-3 space-y-2 list-disc list-inside text-gray-600 dark:text-neutral-400 text-sm">
                            <li><strong>Identity Data</strong>: Email addresses, usernames, and role assignments for secure access control.</li>
                            <li><strong>Operational Data</strong>: Detailed records of Leave Requests (type, dates, reasons) and their approval workflows.</li>
                            <li><strong>Financial Data</strong>: Accounting entries including transaction amounts, descriptions, and reference numbers.</li>
                            <li><strong>Security Log Data</strong>: Timestamps and IP addresses associated with administrative actions to ensure traceability.</li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- End Section -->

            <!-- Section: Usage -->
            <div>
                <div class="flex gap-x-5">
                    <div class="flex-shrink-0">
                        <span class="flex justify-center items-center size-10 bg-green-100 text-green-600 rounded-lg dark:bg-green-900/30 dark:text-green-400">
                            <i class="bi bi-gear-wide-connected text-xl"></i>
                        </span>
                    </div>
                    <div class="grow">
                        <h3 class="text-lg font-semibold text-gray-800 dark:text-white">2. How We Use Your Information</h3>
                        <p class="mt-1 text-gray-600 dark:text-neutral-400">The data collected is utilized solely for the enhancement of your operational workflows:</p>
                        <div class="mt-4 grid sm:grid-cols-2 gap-4">
                            <div class="p-4 border border-gray-200 rounded-xl dark:border-neutral-700">
                                <span class="block text-sm font-bold text-gray-800 dark:text-white">Core Functionality</span>
                                <span class="block text-xs text-gray-500 dark:text-neutral-500">Processing leave requests and managing financial accounting records.</span>
                            </div>
                            <div class="p-4 border border-gray-200 rounded-xl dark:border-neutral-700">
                                <span class="block text-sm font-bold text-gray-800 dark:text-white">Accountability</span>
                                <span class="block text-xs text-gray-500 dark:text-neutral-500">Generating audit logs for security oversight and transaction history.</span>
                            </div>
                            <div class="p-4 border border-gray-200 rounded-xl dark:border-neutral-700">
                                <span class="block text-sm font-bold text-gray-800 dark:text-white">Communication</span>
                                <span class="block text-xs text-gray-500 dark:text-neutral-500">Sending real-time stock and status alerts via push notifications.</span>
                            </div>
                            <div class="p-4 border border-gray-200 rounded-xl dark:border-neutral-700">
                                <span class="block text-sm font-bold text-gray-800 dark:text-white">Security</span>
                                <span class="block text-xs text-gray-500 dark:text-neutral-500">Verifying authorization levels and preventing unauthorized access.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- End Section -->

            <!-- Section: Data Protection -->
            <div>
                <div class="flex gap-x-5">
                    <div class="flex-shrink-0">
                        <span class="flex justify-center items-center size-10 bg-purple-100 text-purple-600 rounded-lg dark:bg-purple-900/30 dark:text-purple-400">
                            <i class="bi bi-shield-lock text-xl"></i>
                        </span>
                    </div>
                    <div class="grow">
                        <h3 class="text-lg font-semibold text-gray-800 dark:text-white">3. Security & Retention</h3>
                        <p class="mt-1 text-gray-600 dark:text-neutral-400">We employ high-grade security protocols to safeguard your enterprise data. Credentials are never stored in plain text, and all communications are encrypted via SSL/TLS.</p>
                        <div class="mt-2 bg-gray-50 border-l-4 border-blue-500 p-4 dark:bg-black/20">
                            <p class="text-sm text-gray-800 dark:text-neutral-300 italic">"Personal data is retained only for the duration of its operational relevance and can be managed directly via the account management portal."</p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- End Section -->
        </div>
        <!-- End Grid -->
    </div>
</div>
