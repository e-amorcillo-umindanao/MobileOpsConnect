@{
    ViewData["Title"] = "My Payslip";
    var currentUser = User.Identity?.Name;

    string department = "General Staff";
    string jobTitle = "Employee";
    decimal basicSalary = 22000m;
    decimal overtime = 0m;
    decimal allowance = 2000m;
    decimal tax = 1500m;

    if (User.IsInRole("SuperAdmin"))
    {
        department = "Executive Board"; jobTitle = "Chief Executive Officer";
        basicSalary = 150000m; allowance = 20000m; tax = 35000m;
    }
    else if (User.IsInRole("SystemAdmin"))
    {
        department = "IT Infrastructure"; jobTitle = "System Administrator";
        basicSalary = 75000m; allowance = 5000m; tax = 12000m;
    }
    else if (User.IsInRole("DepartmentManager"))
    {
        department = "Management"; jobTitle = "Operations Manager";
        basicSalary = 55000m; allowance = 4000m; tax = 6500m;
    }
    else if (User.IsInRole("WarehouseStaff"))
    {
        department = "Warehouse Logistics"; jobTitle = "Warehouse Operator";
        basicSalary = 26000m; overtime = 4500m; allowance = 1500m; tax = 2200m;
    }

    decimal sss = 1350m;
    decimal philhealth = 1125m;
    decimal pagibig = 100m;

    decimal totalEarnings = basicSalary + overtime + allowance;
    decimal totalDeductions = sss + philhealth + pagibig + tax;
    decimal netPay = totalEarnings - totalDeductions;
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> Payroll Module Active
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-green-500/30 text-white">
                <i class="bi bi-check-circle-fill"></i> PAID
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-calendar3"></i> @DateTime.Now.ToString("MMMM yyyy")
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">My Payslip</h1>
        <p class="text-blue-100 text-lg mb-4">Compensation breakdown &amp; digital receipt &mdash; MobileOps Connect ERP</p>
        <a asp-action="DownloadPayslip" class="py-2.5 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg bg-white text-gray-800 shadow-sm hover:bg-gray-50">
            <i class="bi bi-file-earmark-pdf-fill text-red-500"></i> Download PDF Payslip
        </a>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-wallet2 text-9xl text-white"></i>
    </div>
</div>

<!-- Pay Summary -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-cash-stack text-green-500"></i> Pay Summary</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg"><i class="bi bi-cash-coin text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Gross Pay</p><h3 class="text-lg font-medium text-gray-800 mt-1">₱@totalEarnings.ToString("N2")</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-arrow-up-short"></i> Earnings</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg"><i class="bi bi-dash-circle text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Deductions</p><h3 class="text-lg font-medium text-gray-800 mt-1">₱@totalDeductions.ToString("N2")</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-arrow-down-short"></i> Withheld</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg"><i class="bi bi-wallet2 text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Net Pay</p><h3 class="text-lg font-medium text-green-600 mt-1">₱@netPay.ToString("N2")</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Final</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-cyan-100 text-cyan-800 rounded-lg"><i class="bi bi-patch-check-fill text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Status</p><h3 class="text-lg font-medium text-gray-800 mt-1">Paid</h3><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-patch-check-fill"></i> Processed</span></div></div></div>
</div>

<!-- Digital Payslip -->
<div class="flex items-center gap-x-3 mb-4">
    <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-receipt-cutoff text-indigo-500"></i> Digital Payslip</h2>
    <div class="grow border-t border-gray-200"></div>
</div>

<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">

        <!-- Receipt Header -->
        <div class="p-6 text-center">
            <span class="inline-flex justify-center items-center size-[64px] rounded-xl bg-blue-600 text-white mx-auto mb-4"><i class="bi bi-shield-lock-fill text-2xl"></i></span>
            <h4 class="text-lg font-bold text-gray-800 mb-1">MobileOps Connect Inc.</h4>
            <p class="text-sm text-gray-500 mb-2">Official Compensation Statement</p>
            <span class="inline-flex items-center gap-x-1 py-1 px-3 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"><i class="bi bi-calendar3"></i> Pay Period: @DateTime.Now.ToString("MMMM yyyy")</span>
        </div>

        <div class="px-6 pb-6">
            <!-- Back Button & Actions -->
            <div class="flex justify-between items-center mb-6">
                <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-x-2 text-sm font-semibold text-gray-500 hover:text-blue-600 transition-colors">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            </div>

            <!-- Employee Info & Net Pay -->
            <div class="grid lg:grid-cols-12 gap-6 mb-8">
                <div class="lg:col-span-7 grid sm:grid-cols-2 gap-4">
                    <div class="bg-indigo-50 rounded-xl p-4 border border-indigo-100">
                        <div class="flex items-center gap-x-2 mb-2">
                            <span class="inline-flex justify-center items-center size-[32px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-person-fill text-sm"></i></span>
                            <span class="text-xs text-gray-500 uppercase font-medium">Employee Details</span>
                        </div>
                        <p class="text-sm font-semibold text-gray-800 mb-0.5">@currentUser</p>
                        <p class="text-xs text-gray-500 mb-0.5">@jobTitle</p>
                        <p class="text-xs text-gray-500">@department</p>
                    </div>
                    <div class="bg-green-50 rounded-xl p-4 border border-green-100">
                        <div class="flex items-center gap-x-2 mb-2">
                            <span class="inline-flex justify-center items-center size-[32px] rounded-lg bg-green-100 text-green-800"><i class="bi bi-receipt text-sm"></i></span>
                            <span class="text-xs text-gray-500 uppercase font-medium">Payment Info</span>
                        </div>
                        <div class="flex items-center gap-x-2 mb-1">
                            <span class="text-sm font-semibold text-gray-800">Status:</span>
                            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> PAID</span>
                        </div>
                        <p class="text-xs text-gray-500 mb-0.5">Issue Date: @DateTime.Now.ToString("dd MMM yyyy")</p>
                        <p class="text-xs text-gray-500">Ref: MOC-@DateTime.Now.ToString("yyyyMM")-001</p>
                    </div>
                </div>

                <!-- Elevated Net Pay Hero -->
                <div class="lg:col-span-5 rounded-xl p-5 text-center bg-blue-600 flex flex-col justify-center">
                    <p class="text-blue-200 uppercase text-xs font-semibold mb-1"><i class="bi bi-wallet2 me-1"></i> Net Take-Home Pay</p>
                    <h1 class="text-white font-bold mb-2 text-3xl sm:text-4xl">₱@netPay.ToString("N2")</h1>
                    <div class="flex justify-center gap-2 flex-wrap">
                        <span class="inline-flex items-center gap-1 py-1 px-2.5 rounded-full text-[10px] font-medium bg-white/20 text-white"><i class="bi bi-check-circle-fill"></i> Processed &amp; Paid</span>
                    </div>
                </div>
            </div>

            <!-- Side-by-Side Breakdown -->
            <div class="grid md:grid-cols-2 gap-6 lg:gap-8 mb-6">
                <!-- Earnings -->
                <div>
                    <div class="flex items-center gap-x-3 mb-3">
                        <span class="inline-flex justify-center items-center size-[32px] rounded-lg bg-green-100 text-green-800"><i class="bi bi-plus-circle-fill text-sm"></i></span>
                        <h3 class="text-sm font-semibold text-gray-800">Earnings</h3>
                    </div>
                    <div class="border rounded-xl overflow-hidden shadow-sm">
                        <div class="flex justify-between items-center px-4 py-3 bg-green-50"><div class="flex items-center gap-x-2"><i class="bi bi-briefcase text-green-600 text-sm"></i><span class="text-sm font-medium text-gray-800">Basic Salary</span></div><span class="text-sm font-semibold text-gray-800">₱@basicSalary.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3"><div class="flex items-center gap-x-2"><i class="bi bi-clock-history text-amber-500 text-sm"></i><span class="text-sm font-medium text-gray-800">Overtime Pay</span></div><span class="text-sm font-semibold text-gray-800">₱@overtime.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3 bg-green-50"><div class="flex items-center gap-x-2"><i class="bi bi-gift text-purple-500 text-sm"></i><span class="text-sm font-medium text-gray-800">Allowances</span></div><span class="text-sm font-semibold text-gray-800">₱@allowance.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3 bg-green-100"><div class="flex items-center gap-x-2"><span class="inline-flex justify-center items-center size-[24px] rounded-md bg-green-200 text-green-800"><i class="bi bi-check-lg" style="font-size:0.75rem;"></i></span><span class="text-sm font-bold text-gray-800">Total Earnings</span></div><span class="text-sm font-bold text-green-700">₱@totalEarnings.ToString("N2")</span></div>
                    </div>
                </div>

                <!-- Deductions -->
                <div>
                    <div class="flex items-center gap-x-3 mb-3">
                        <span class="inline-flex justify-center items-center size-[32px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-dash-circle-fill text-sm"></i></span>
                        <h3 class="text-sm font-semibold text-gray-800">Deductions</h3>
                    </div>
                    <div class="border rounded-xl overflow-hidden shadow-sm">
                        <div class="flex justify-between items-center px-4 py-3 bg-red-50/50"><div class="flex items-center gap-x-2"><i class="bi bi-shield-check text-indigo-500 text-sm"></i><span class="text-sm font-medium text-gray-800">SSS Contribution</span></div><span class="text-sm font-semibold text-red-600">−₱@sss.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3"><div class="flex items-center gap-x-2"><i class="bi bi-heart-pulse text-cyan-500 text-sm"></i><span class="text-sm font-medium text-gray-800">PhilHealth</span></div><span class="text-sm font-semibold text-red-600">−₱@philhealth.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3 bg-red-50/50"><div class="flex items-center gap-x-2"><i class="bi bi-house-heart text-amber-500 text-sm"></i><span class="text-sm font-medium text-gray-800">Pag-IBIG</span></div><span class="text-sm font-semibold text-red-600">−₱@pagibig.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3"><div class="flex items-center gap-x-2"><i class="bi bi-bank text-purple-500 text-sm"></i><span class="text-sm font-medium text-gray-800">Withholding Tax</span></div><span class="text-sm font-semibold text-red-600">−₱@tax.ToString("N2")</span></div>
                        <div class="border-t"></div>
                        <div class="flex justify-between items-center px-4 py-3 bg-red-100"><div class="flex items-center gap-x-2"><span class="inline-flex justify-center items-center size-[24px] rounded-md bg-red-200 text-red-800"><i class="bi bi-dash-lg" style="font-size:0.75rem;"></i></span><span class="text-sm font-bold text-gray-800">Total Deductions</span></div><span class="text-sm font-bold text-red-700">−₱@totalDeductions.ToString("N2")</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Receipt Footer -->
        <div class="px-6 py-4 border-t border-gray-200 text-center">
            <div class="flex flex-col sm:flex-row justify-between items-center gap-2">
                <span class="text-xs text-gray-500"><i class="bi bi-lock-fill me-1"></i> This is a system-generated document. No signature required.</span>
                <span class="text-xs text-gray-500"><i class="bi bi-shield-check me-1"></i> Ref: MOC-@DateTime.Now.ToString("yyyyMM")-001</span>
            </div>
        </div>
    </div>
</div>
