@model MobileOpsConnect.Models.SystemSetting

@{
    ViewData["Title"] = "System Configuration";
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> Configuration Active
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-clock-history"></i> Last saved: @Model.LastUpdated.ToString("g")
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">System Configuration</h1>
        <p class="text-blue-100 text-lg">Manage global settings, thresholds &amp; company parameters</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-gear-wide-connected text-9xl text-white"></i>
    </div>
</div>

<!-- Success Alert -->
@if (ViewBag.Message != null)
{
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6" role="alert">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-green-100 text-green-800"><i class="bi bi-check-circle-fill text-lg"></i></span>
                <div><span class="font-semibold text-green-800">Success!</span> <span class="text-sm text-green-800 ms-1">@ViewBag.Message</span></div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<!-- Current Settings Overview -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5">
            <p class="text-xs uppercase tracking-wide text-gray-500">Company</p>
            <h3 class="text-lg font-medium text-gray-800 mt-1 truncate" title="@Model.CompanyName">@Model.CompanyName</h3>
            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-green-100 text-green-800 text-xs font-medium"><i class="bi bi-check-circle-fill"></i> Active</span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5">
            <p class="text-xs uppercase tracking-wide text-gray-500">Tax Rate</p>
            <h3 class="text-lg font-medium text-gray-800 mt-1">@Model.TaxRate<span class="text-sm text-gray-500">%</span></h3>
            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-amber-100 text-amber-800 text-xs font-medium"><i class="bi bi-receipt"></i> Applied</span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5">
            <p class="text-xs uppercase tracking-wide text-gray-500">Low Stock</p>
            <h3 class="text-lg font-medium text-gray-800 mt-1">@Model.LowStockThreshold <span class="text-sm text-gray-500">units</span></h3>
            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-red-100 text-red-800 text-xs font-medium"><i class="bi bi-exclamation-triangle-fill"></i> Threshold</span>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5">
            <p class="text-xs uppercase tracking-wide text-gray-500">Support</p>
            <h3 class="text-sm font-medium text-gray-800 mt-1 truncate" title="@Model.SupportEmail">@Model.SupportEmail</h3>
            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium"><i class="bi bi-headset"></i> Linked</span>
        </div>
    </div>
</div>

<!-- Configuration Form -->
<div class="max-w-6xl mx-auto">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <!-- 1. General Information Section -->
        <div class="grid lg:grid-cols-12 gap-6 lg:gap-8 mb-8 pb-8 border-b border-gray-200">
            <!-- Left Header -->
            <div class="lg:col-span-4">
                <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-shop-window text-indigo-500"></i> General Information</h2>
                <p class="text-sm text-gray-500 mt-1">Update your primary company identity and primary support contact details displayed across the platform.</p>
            </div>
            
            <!-- Right Form Card -->
            <div class="lg:col-span-8 flex flex-col bg-white border shadow-sm rounded-xl">
                <div class="p-6">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="CompanyName" class="block text-sm font-medium mb-2"><i class="bi bi-shop-window me-1 text-indigo-500"></i> Company Name</label>
                            <input asp-for="CompanyName" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500 bg-gray-50 focus:bg-white transition-colors" placeholder="Enter company name" />
                            <span asp-validation-for="CompanyName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="SupportEmail" class="block text-sm font-medium mb-2"><i class="bi bi-envelope me-1 text-cyan-500"></i> Support Email</label>
                            <div class="flex">
                                <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-gray-200 bg-gray-50 text-sm text-gray-500"><i class="bi bi-at text-cyan-500"></i></span>
                                <input asp-for="SupportEmail" class="py-3 px-4 block w-full border-gray-200 rounded-e-lg text-sm focus:border-blue-500 focus:ring-blue-500 bg-gray-50 focus:bg-white transition-colors" placeholder="support@company.com" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Inventory Logic Section -->
        <div class="grid lg:grid-cols-12 gap-6 lg:gap-8 mb-8">
            <!-- Left Header -->
            <div class="lg:col-span-4">
                <h2 class="text-lg font-semibold text-gray-800 flex items-center gap-x-2"><i class="bi bi-box-seam-fill text-amber-500"></i> Inventory Logic</h2>
                <p class="text-sm text-gray-500 mt-1">Configure automated stock warnings and the default active tax calculation rate across your inventory.</p>
            </div>
            
            <!-- Right Form Card -->
            <div class="lg:col-span-8 flex flex-col bg-white border shadow-sm rounded-xl">
                <div class="p-6">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="LowStockThreshold" class="block text-sm font-medium mb-2"><i class="bi bi-exclamation-triangle me-1 text-red-500"></i> Low Stock Threshold</label>
                            <div class="flex">
                                <input asp-for="LowStockThreshold" class="py-3 px-4 block w-full border-gray-200 rounded-s-lg text-sm focus:border-blue-500 focus:ring-blue-500 bg-gray-50 focus:bg-white transition-colors" type="number" placeholder="e.g., 10" />
                                <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-e-lg border border-s-0 border-gray-200 bg-red-50 text-sm font-semibold text-red-600"><i class="bi bi-box me-1"></i> Units</span>
                            </div>
                            <p class="text-xs text-gray-500 mt-2 flex items-center gap-1"><i class="bi bi-info-circle text-indigo-500"></i> Products below this count trigger reorder alerts.</p>
                        </div>
                        <div>
                            <label asp-for="TaxRate" class="block text-sm font-medium mb-2"><i class="bi bi-receipt me-1 text-amber-500"></i> Tax Rate</label>
                            <div class="flex">
                                <input asp-for="TaxRate" class="py-3 px-4 block w-full border-gray-200 rounded-s-lg text-sm focus:border-blue-500 focus:ring-blue-500 bg-gray-50 focus:bg-white transition-colors" type="number" step="0.01" placeholder="e.g., 12.00" />
                                <span class="py-3 px-4 inline-flex items-center min-w-fit rounded-e-lg border border-s-0 border-gray-200 bg-amber-50 text-sm font-semibold text-amber-600"><i class="bi bi-percent me-1"></i> Rate</span>
                            </div>
                            <p class="text-xs text-gray-500 mt-2 flex items-center gap-1"><i class="bi bi-info-circle text-indigo-500"></i> Applied to all taxable transactions.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="grid lg:grid-cols-12 gap-6 lg:gap-8">
            <div class="lg:col-span-4"></div> <!-- Spacer for alignment -->
            <div class="lg:col-span-8 flex flex-col bg-white border shadow-sm rounded-xl overflow-hidden">
                <div class="p-6 bg-gray-50/50">
                    <div class="grid sm:grid-cols-3 gap-4">
                        <div class="sm:col-span-2">
                            <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 shadow-sm shadow-blue-500/30 transition-all">
                                <i class="bi bi-check2-circle text-lg"></i> Save Configuration
                            </button>
                        </div>
                        <div>
                            <a asp-controller="Home" asp-action="Index" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 transition-colors">
                                <i class="bi bi-arrow-left"></i> Dashboard
                            </a>
                        </div>
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <div class="sm:col-span-3 mt-4 pt-4 border-t border-gray-200 dark:border-neutral-700">
                                <a asp-action="Maintenance" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg border border-red-200 bg-red-50 text-red-700 shadow-sm hover:bg-red-100 transition-colors">
                                    <i class="bi bi-shield-lock-fill"></i> Access Super Admin Maintenance &amp; Database Backups
                                </a>
                            </div>
                        }
                    </div>
                    <div class="text-center mt-4">
                        <span class="text-xs text-gray-500"><i class="bi bi-clock-history me-1"></i> Configuration last modified: @Model.LastUpdated.ToString("g")</span>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
