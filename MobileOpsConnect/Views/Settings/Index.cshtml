@model MobileOpsConnect.Models.SystemSetting

@{
    ViewData["Title"] = "System Configuration";
}

<!-- ═══════════════════════════════════════════════ -->
<!-- PAGE HEADER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-circle-fill text-green-500 mr-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                Configuration Active
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-clock-history mr-1"></i> Last saved: @Model.LastUpdated.ToString("g")
            </span>
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">System Configuration</h1>
        <p class="lead mb-0 opacity-75">
            Manage global settings, thresholds &amp; company parameters
        </p>
    </div>
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-gear-wide-connected"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- SUCCESS ALERT                                   -->
<!-- ═══════════════════════════════════════════════ -->
@if (ViewBag.Message != null)
{
    <div class="alert border-0 shadow-sm rounded-3 mb-6 anim-fade-in"
         role="alert"
         style="background: rgba(34,197,94,0.08); color: #16a34a; border-left: 4px solid #22c55e !important;">
        <div class="flex items-center justify-between">
            <div class="flex items-center">
                <div class="moc-icon-box bg-green-50 rounded-3 mr-4">
                    <i class="bi bi-check-circle-fill text-green fs-5"></i>
                </div>
                <div>
                    <span class="font-semibold">Success!</span>
                    <span class="text-sm ml-1">@ViewBag.Message</span>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════ -->
<!-- CURRENT SETTINGS OVERVIEW                       -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-section-header mt-2">
    <h5 class="font-bold letter-tight">
        <i class="bi bi-sliders text-indigo mr-1"></i> Current Settings
    </h5>
    <hr />
</div>

<div class="flex flex-wrap -mx-3 g-3 mb-6">
    <div class="col-6 col-lg-3 anim-fade-in anim-delay-1">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div>
                <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Company</p>
                <h5 class="font-bold mb-1 letter-tight text-truncate" style="max-width: 140px;" title="@Model.CompanyName">
                    @Model.CompanyName
                </h5>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green text-xs font-semibold">
                    <i class="bi bi-check-circle-fill mr-1"></i> Active
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3 anim-fade-in anim-delay-2">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div>
                <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Tax Rate</p>
                <h3 class="font-bold mb-1 letter-tight">@Model.TaxRate<span class="fs-6 font-semibold text-moc-text-muted">%</span></h3>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber text-xs font-semibold">
                    <i class="bi bi-receipt mr-1"></i> Applied
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3 anim-fade-in anim-delay-3">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div>
                <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Low Stock</p>
                <h3 class="font-bold mb-1 letter-tight">@Model.LowStockThreshold <span class="fs-6 font-semibold text-moc-text-muted">units</span></h3>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red text-xs font-semibold">
                    <i class="bi bi-exclamation-triangle-fill mr-1"></i> Threshold
                </span>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3 anim-fade-in anim-delay-4">
        <div class="moc-metric p-6 p-md-4 h-100">
            <div>
                <p class="text-moc-text-muted text-uppercase text-xs font-semibold mb-1">Support</p>
                <h6 class="font-bold mb-1 letter-tight text-truncate" style="max-width: 140px;" title="@Model.SupportEmail">
                    @Model.SupportEmail
                </h6>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-cyan-50 text-cyan text-xs font-semibold">
                    <i class="bi bi-headset mr-1"></i> Linked
                </span>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- CONFIGURATION FORM                              -->
<!-- ═══════════════════════════════════════════════ -->
<div class="flex flex-wrap -mx-3 justify-center">
    <div class="col-lg-10 col-xl-8">

        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <!-- ── General Information Card ── -->
            <div class="moc-section-header mt-6">
                <h5 class="font-bold letter-tight">
                    <i class="bi bi-shop-window text-indigo mr-1"></i> General Information
                </h5>
                <hr />
            </div>

            <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-1">
                <div class="p-6 p-6">
                    <div class="flex flex-wrap -mx-3 g-3">
                        <!-- Company Name -->
                        <div class="w-full md:w-1/2 px-6">
                            <label asp-for="CompanyName" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                                <i class="bi bi-shop-window mr-1 text-indigo"></i> Company Name
                            </label>
                            <input asp-for="CompanyName" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 form-control-lg rounded-3" placeholder="Enter company name" />
                            <span asp-validation-for="CompanyName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <!-- Support Email -->
                        <div class="w-full md:w-1/2 px-6">
                            <label asp-for="SupportEmail" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                                <i class="bi bi-envelope mr-1 text-cyan"></i> Support Email
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text rounded-start-3 border-end-0"
                                      style="background: rgba(6,182,212,0.06);">
                                    <i class="bi bi-at text-cyan"></i>
                                </span>
                                <input asp-for="SupportEmail" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-end-3 border-start-0" placeholder="support@company.com" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Inventory Logic Card ── -->
            <div class="moc-section-header mt-8">
                <h5 class="font-bold letter-tight">
                    <i class="bi bi-box-seam-fill text-amber mr-1"></i> Inventory Logic
                </h5>
                <hr />
            </div>

            <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-2">
                <div class="p-6 p-6">
                    <div class="flex flex-wrap -mx-3 g-3">
                        <!-- Low Stock Threshold -->
                        <div class="w-full md:w-1/2 px-6">
                            <label asp-for="LowStockThreshold" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                                <i class="bi bi-exclamation-triangle mr-1 text-red"></i> Low Stock Threshold
                            </label>
                            <div class="input-group input-group-lg">
                                <input asp-for="LowStockThreshold" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-start-3" type="number" placeholder="e.g., 10" />
                                <span class="input-group-text rounded-end-3 font-semibold text-sm"
                                      style="background: rgba(239,68,68,0.06); color: #ef4444; border-color: #e2e8f0;">
                                    <i class="bi bi-box mr-1"></i> Units
                                </span>
                            </div>
                            <small class="text-moc-text-muted text-xs mt-2 flex items-center">
                                <i class="bi bi-info-circle mr-1 text-indigo"></i>
                                Products below this count trigger reorder alerts.
                            </small>
                        </div>

                        <!-- Tax Rate -->
                        <div class="w-full md:w-1/2 px-6">
                            <label asp-for="TaxRate" class="block text-sm font-medium leading-6 text-gray-900 font-semibold text-sm mb-2">
                                <i class="bi bi-receipt mr-1 text-amber"></i> Tax Rate
                            </label>
                            <div class="input-group input-group-lg">
                                <input asp-for="TaxRate" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 rounded-start-3" type="number" step="0.01" placeholder="e.g., 12.00" />
                                <span class="input-group-text rounded-end-3 font-semibold text-sm"
                                      style="background: rgba(245,158,11,0.06); color: #f59e0b; border-color: #e2e8f0;">
                                    <i class="bi bi-percent mr-1"></i> Rate
                                </span>
                            </div>
                            <small class="text-moc-text-muted text-xs mt-2 flex items-center">
                                <i class="bi bi-info-circle mr-1 text-indigo"></i>
                                Applied to all taxable transactions.
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Action Buttons ── -->
            <div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-3">
                <div class="p-6 p-6">
                    <div class="flex flex-wrap -mx-3 g-3 items-center">
                        <div class="w-full md:w-2/3 px-6">
                            <button type="submit" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-4 py-2 text-base w-100 py-6">
                                <i class="bi bi-check2-circle mr-2"></i> Save Configuration
                            </button>
                        </div>
                        <div class="w-full md:w-1/3 px-6">
                            <a asp-controller="Home" asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-4 py-2 text-base w-100 py-6">
                                <i class="bi bi-arrow-left mr-1"></i> Dashboard
                            </a>
                        </div>
                    </div>
                    <div class="text-center mt-6">
                        <small class="text-moc-text-muted text-xs">
                            <i class="bi bi-clock-history mr-1"></i>
                            Configuration last modified: @Model.LastUpdated.ToString("g")
                        </small>
                    </div>
                </div>
            </div>

        </form>

    </div>
</div>
