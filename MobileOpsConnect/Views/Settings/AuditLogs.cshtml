@using Microsoft.AspNetCore.Mvc.Rendering
@model List<MobileOpsConnect.Models.AuditLog>
@{
    bool isSuperAdmin = (bool)ViewBag.IsSuperAdmin;
    ViewData["Title"] = isSuperAdmin ? "Global Audit Logs" : "Standard Audit Logs";
    int totalEvents = ViewBag.TotalEvents;
    int loginCount = ViewBag.LoginCount;
    int dataCount = ViewBag.CreateCount;
    int stockCount = ViewBag.StockCount;
    int securityCount = ViewBag.SecurityCount;
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-[#f4f2ff] text-[#5e4dcd] border border-[#e6e1fc] dark:bg-indigo-900/30 dark:border-indigo-800 dark:text-indigo-400 tracking-wide uppercase">
            <i class="bi bi-shield-lock"></i> @(isSuperAdmin ? "Global Access" : "Standard View")
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">@(isSuperAdmin ? "Global Audit Logs" : "Standard Audit Logs")</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">@(isSuperAdmin ? "Complete system activity — including security events" : "General system activity log")</p>
</div>

<!-- Metrics -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl" style="border-left: 3px solid #6366f1;">
        <div class="p-4"><p class="text-xs uppercase tracking-wide text-gray-500">Total Events</p><h3 class="text-xl font-bold text-indigo-600 mt-1">@totalEvents</h3></div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl" style="border-left: 3px solid #06b6d4;">
        <div class="p-4"><p class="text-xs uppercase tracking-wide text-gray-500">Data Changes</p><h3 class="text-xl font-bold text-cyan-600 mt-1">@dataCount</h3></div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl" style="border-left: 3px solid #22c55e;">
        <div class="p-4"><p class="text-xs uppercase tracking-wide text-gray-500">Stock Moves</p><h3 class="text-xl font-bold text-green-600 mt-1">@stockCount</h3></div>
    </div>
    @if (isSuperAdmin)
    {
        <div class="flex flex-col bg-white border shadow-sm rounded-xl" style="border-left: 3px solid #ef4444;">
            <div class="p-4"><p class="text-xs uppercase tracking-wide text-gray-500">Security Events</p><h3 class="text-xl font-bold text-red-600 mt-1">@securityCount</h3></div>
        </div>
    }
    else
    {
        <div class="flex flex-col bg-white border shadow-sm rounded-xl" style="border-left: 3px solid #f59e0b;">
            <div class="p-4"><p class="text-xs uppercase tracking-wide text-gray-500">Login Events</p><h3 class="text-xl font-bold text-amber-600 mt-1">@loginCount</h3></div>
        </div>
    }
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-100 rounded-2xl p-5 mb-8 shadow-sm dark:bg-neutral-900 dark:border-neutral-800">
    <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400">
                <i class="bi bi-funnel-fill"></i>
            </span>
            <div>
                <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider">Search Filters</h4>
                <p class="text-[11px] text-gray-400 dark:text-neutral-500 font-medium">Refine audit entries by role or specific user</p>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(ViewBag.SelectedRole) || !string.IsNullOrEmpty(ViewBag.SelectedUserId))
        {
            <a asp-action="AuditLogs" class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-lg text-xs font-semibold bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors dark:bg-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-700">
                <i class="bi bi-x-circle-fill"></i> Reset
            </a>
        }
    </div>

    <div class="grid md:grid-cols-2 gap-4">
        <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest px-1 ml-1 cursor-default">Roles</label>
            <div class="relative">
                <div class="absolute inset-y-0 start-0 flex items-center ps-3.5 pointer-events-none text-gray-400">
                    <i class="bi bi-person-badge"></i>
                </div>
                <select id="roleFilter" class="py-2.5 ps-10 pe-9 block w-full bg-gray-50 border-gray-200 rounded-xl text-sm focus:border-indigo-500 focus:ring-indigo-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:focus:ring-neutral-600 transition-all font-medium">
                    <option value="">All Roles</option>
                    @foreach (string roleName in ViewBag.AllRoles)
                    {
                        string displayName = ((Dictionary<string, string>)ViewBag.RoleDisplayNames).GetValueOrDefault(roleName, roleName);
                        <option value="@roleName" selected="@(ViewBag.SelectedRole == roleName)">@displayName</option>
                    }
                </select>
            </div>
        </div>

        <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest px-1 ml-1 cursor-default">Individual Users</label>
            <div class="relative">
                <div class="absolute inset-y-0 start-0 flex items-center ps-3.5 pointer-events-none text-gray-400">
                    <i class="bi bi-search"></i>
                </div>
                <select id="userFilter" class="py-2.5 ps-10 pe-9 block w-full bg-gray-50 border-gray-200 rounded-xl text-sm focus:border-indigo-500 focus:ring-indigo-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:focus:ring-neutral-600 transition-all font-medium">
                    <option value="">All Users</option>
                    @foreach (var entry in (Dictionary<string, List<SelectListItem>>)ViewBag.UsersByRole)
                    {
                        string groupName = ((Dictionary<string, string>)ViewBag.RoleDisplayNames).GetValueOrDefault(entry.Key, entry.Key);
                        <optgroup label="@groupName">
                            @foreach (var user in entry.Value)
                            {
                                <option value="@user.Value" data-role="@entry.Key" selected="@(ViewBag.SelectedUserId == user.Value)">@user.Text</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Log Table -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800">
    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <i class="bi bi-journal-text text-gray-400 text-lg"></i>
                <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">@(isSuperAdmin ? "All Activity" : "Activity Log")</h3>
            </div>
            @if (isSuperAdmin)
            { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="bi bi-shield-fill-exclamation"></i> Global Access</span> }
            else
            { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"><i class="bi bi-eye-fill"></i> Standard View</span> }
        </div>
    </div>
    <div class="p-0">
        @if (Model.Count == 0)
        {
            <div class="text-center py-10">
                <i class="bi bi-shield-check text-gray-400" style="font-size: 3rem;"></i>
                <p class="text-gray-500 mt-2">No audit events recorded yet. Events will appear here as users interact with the system.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="overflow-x-auto hidden md:block">
                <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                    <thead><tr>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Timestamp</th>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">User</th>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Action</th>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Details</th>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">IP</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                        @foreach (var log in Model)
                        {
                            var actionBadge = log.Action switch { "LOGIN" => "bg-green-100 text-green-800", "CREATE" => "bg-cyan-100 text-cyan-800", "UPDATE" => "bg-indigo-100 text-indigo-800", "DELETE" => "bg-red-100 text-red-800", "STOCK_IN" => "bg-green-100 text-green-800", "STOCK_OUT" => "bg-amber-100 text-amber-800", "APPROVE" => "bg-green-100 text-green-800", "REJECT" => "bg-red-100 text-red-800", "SECURITY" => "bg-red-100 text-red-800", _ => "bg-purple-100 text-purple-800" };
                            var actionIcon = log.Action switch { "LOGIN" => "bi-box-arrow-in-right", "CREATE" => "bi-plus-circle-fill", "UPDATE" => "bi-pencil-fill", "DELETE" => "bi-trash-fill", "STOCK_IN" => "bi-arrow-down-circle-fill", "STOCK_OUT" => "bi-arrow-up-circle-fill", "APPROVE" => "bi-check-circle-fill", "REJECT" => "bi-x-circle-fill", "SECURITY" => "bi-shield-fill-exclamation", _ => "bi-activity" };
                            <tr class="hover:bg-gray-50 transition-colors" style="@(log.IsCritical ? "background: rgba(239,68,68,0.03);" : "")">
                                <td class="px-6 py-4"><span class="text-sm text-gray-800">@log.Timestamp.ToString("MMM dd, yyyy")</span><br/><span class="text-xs text-gray-500">@log.Timestamp.ToString("hh:mm:ss tt")</span></td>
                                <td class="px-6 py-4"><span class="text-sm font-semibold text-gray-800">@log.UserEmail</span>@if (!string.IsNullOrEmpty(log.UserRole)){<br/><span class="text-xs text-gray-500">@log.UserRole</span>}</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium @actionBadge"><i class="bi @actionIcon"></i> @log.Action.Replace("_", " ")</span>
                                    @if (log.IsCritical){ <i class="bi bi-exclamation-triangle-fill text-red-500 ms-1" title="Security Event"></i> }
                                </td>
                                <td class="px-6 py-4"><span class="text-sm text-gray-500" style="max-width:300px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@log.Details">@log.Details</span></td>
                                <td class="px-6 py-4"><span class="text-xs text-gray-500 font-mono">@log.IpAddress</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden p-4 space-y-4">
                @foreach (var log in Model)
                {
                    var actionBadge = log.Action switch { "LOGIN" => "bg-green-100 text-green-800", "CREATE" => "bg-cyan-100 text-cyan-800", "UPDATE" => "bg-indigo-100 text-indigo-800", "DELETE" => "bg-red-100 text-red-800", "STOCK_IN" => "bg-green-100 text-green-800", "STOCK_OUT" => "bg-amber-100 text-amber-800", "APPROVE" => "bg-green-100 text-green-800", "REJECT" => "bg-red-100 text-red-800", "SECURITY" => "bg-red-100 text-red-800", _ => "bg-purple-100 text-purple-800" };
                    var actionIcon = log.Action switch { "LOGIN" => "bi-box-arrow-in-right", "CREATE" => "bi-plus-circle-fill", "UPDATE" => "bi-pencil-fill", "DELETE" => "bi-trash-fill", "STOCK_IN" => "bi-arrow-down-circle-fill", "STOCK_OUT" => "bi-arrow-up-circle-fill", "APPROVE" => "bi-check-circle-fill", "REJECT" => "bi-x-circle-fill", "SECURITY" => "bi-shield-fill-exclamation", _ => "bi-activity" };
                    <div class="p-4 rounded-xl bg-gray-50 border" style="border-left: 3px solid @(log.IsCritical ? "#ef4444" : "#6366f1") !important;">
                        <div class="flex items-start justify-between mb-2">
                            <div class="min-w-0 flex-1"><span class="text-sm font-semibold text-gray-800 block break-all">@log.UserEmail</span>@if (!string.IsNullOrEmpty(log.UserRole)){<span class="text-xs text-gray-500">@log.UserRole</span>}</div>
                            <div class="ms-2 shrink-0">
                                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full text-xs font-medium @actionBadge"><i class="bi @actionIcon"></i> @log.Action.Replace("_", " ")</span>
                                @if (log.IsCritical){ <i class="bi bi-exclamation-triangle-fill text-red-500 ms-1" title="Security Event"></i> }
                            </div>
                        </div>
                        <p class="text-sm text-gray-600 mb-2" style="word-break:break-word;">@log.Details</p>
                        <div class="flex items-center justify-between text-gray-500">
                            <span class="text-xs"><i class="bi bi-clock me-1"></i>@log.Timestamp.ToString("MMM dd, yyyy hh:mm tt")</span>
                            <span class="text-xs font-mono">@log.IpAddress</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const roleFilter = document.getElementById('roleFilter');
        const userFilter = document.getElementById('userFilter');
        const userOptions = Array.from(userFilter.querySelectorAll('option[data-role]'));
        const optGroups = Array.from(userFilter.querySelectorAll('optgroup'));

        function applyFilters() {
            const role = roleFilter.value;
            const userId = userFilter.value;
            let url = '@Url.Action("AuditLogs", "Settings")';
            const params = [];
            if (role) params.push(`role=${encodeURIComponent(role)}`);
            if (userId) params.push(`userId=${encodeURIComponent(userId)}`);
            
            if (params.length > 0) {
                url += '?' + params.join('&');
            }
            window.location.href = url;
        }

        function syncDropdowns() {
            const selectedRole = roleFilter.value;
            
            if (!selectedRole) {
                // Show all optgroups and options
                optGroups.forEach(og => og.style.display = '');
                userOptions.forEach(o => o.style.display = '');
            } else {
                // Hide optgroups that don't match, show the one that does
                optGroups.forEach(og => {
                    if (og.label === selectedRole) {
                        og.style.display = '';
                        Array.from(og.querySelectorAll('option')).forEach(o => o.style.display = '');
                    } else {
                        og.style.display = 'none';
                    }
                });
            }
        }

        roleFilter.addEventListener('change', function() {
            // When role changes, if the current selected user is NOT in that role, reset user filter
            const selectedRole = roleFilter.value;
            const selectedUserOption = userFilter.options[userFilter.selectedIndex];
            
            if (selectedRole && selectedUserOption.dataset.role && selectedUserOption.dataset.role !== selectedRole) {
                userFilter.value = "";
            }
            
            applyFilters();
        });

        userFilter.addEventListener('change', applyFilters);

        // Initial sync on load
        syncDropdowns();
    });
</script>
}
