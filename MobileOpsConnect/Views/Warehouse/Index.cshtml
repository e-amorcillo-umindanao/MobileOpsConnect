@model IEnumerable<MobileOpsConnect.Models.Product>

@{
    ViewData["Title"] = "Warehouse Operations";
    int totalProducts = Model.Count();
    int lowStockCount = Model.Count(p => p.StockQuantity <= 10);
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm dark:bg-neutral-900 dark:text-neutral-200">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span>
                Warehouse Floor
            </span>
            @if (lowStockCount > 0)
            {
                <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-500/30 text-white">
                    @lowStockCount Items Low
                </span>
            }
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Warehouse Operations</h1>
        <p class="text-blue-100 text-lg">Scan products, manage stock levels, and verify inventory in real-time.</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-upc-scan text-9xl text-white"></i>
    </div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-6">
    <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>

    <form asp-action="Index" method="get" id="scanForm" class="flex gap-2 flex-grow justify-end" style="max-width: 600px;">
        <div class="flex w-full">
            <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-s-lg border border-gray-200 bg-gray-800 text-white hover:bg-gray-900 dark:bg-neutral-700 dark:border-neutral-600" data-bs-toggle="modal" data-bs-target="#scannerModal">
                <i class="bi bi-camera-fill"></i> Scan
            </button>
            <input type="text" name="searchString" id="barcodeInput" class="py-2 px-4 block w-full border-gray-200 text-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="Scan SKU or Search Product..." value="@ViewData["CurrentFilter"]">
            <button class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-e-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>
</div>

<!-- Product Table Card -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-purple-100 text-purple-800 dark:bg-purple-800/30 dark:text-purple-500">
                <i class="bi bi-box-seam text-lg"></i>
            </span>
            <div>
                <h3 class="text-sm font-semibold text-gray-800 dark:text-neutral-200">Product List</h3>
                <span class="text-xs text-gray-500 dark:text-neutral-500">@totalProducts item@(totalProducts != 1 ? "s" : "") found</span>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
            <thead class="bg-gray-50 dark:bg-neutral-800">
                <tr>
                    <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500" style="width:15%">SKU</th>
                    <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500" style="width:30%">Product Name</th>
                    <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase dark:text-neutral-500" style="width:15%">Category</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase dark:text-neutral-500" style="width:15%">Stock</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase dark:text-neutral-500" style="width:25%">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                        <td class="whitespace-nowrap px-6 py-4">
                            <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-md text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-800/20 dark:text-indigo-400">
                                @item.SKU
                            </span>
                        </td>
                        <td class="whitespace-nowrap px-6 py-4">
                            <span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">@item.Name</span>
                        </td>
                        <td class="whitespace-nowrap px-6 py-4">
                            <span class="inline-flex items-center gap-x-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800 dark:bg-cyan-800/20 dark:text-cyan-400">
                                @item.Category
                            </span>
                        </td>
                        <td class="whitespace-nowrap px-6 py-4 text-center">
                            @if (item.StockQuantity <= 10)
                            {
                                <span class="inline-flex items-center gap-x-1 py-1.5 px-3 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400">
                                    @item.StockQuantity
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-x-1 py-1.5 px-3 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400">
                                    @item.StockQuantity
                                </span>
                            }
                        </td>
                        <td class="whitespace-nowrap px-6 py-4 text-center">
                            <a asp-action="Adjust" asp-route-id="@item.ProductID" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                                Manage
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Scanner Modal -->
<div class="modal fade" id="scannerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
            <div class="modal-header bg-gray-800 text-white border-0" style="border-radius: 1rem 1rem 0 0;">
                <h5 class="modal-title text-sm font-bold"><i class="bi bi-qr-code-scan me-2"></i>Barcode Scanner</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-6">
                <div id="reader" class="overflow-hidden rounded-lg shadow-sm bg-gray-50 mb-4"></div>
                <p class="text-gray-500 text-sm mb-0" id="scanStatus">
                    <i class="bi bi-camera-fill me-1"></i> Point your camera at a product barcode.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        let html5QrcodeScanner = null;

        document.getElementById('scannerModal').addEventListener('shown.bs.modal', function () {
            if (html5QrcodeScanner) return;

            html5QrcodeScanner = new Html5Qrcode("reader");

            html5QrcodeScanner.start(
                { facingMode: "environment" },
                {
                    fps: 10,
                    qrbox: { width: 250, height: 150 },
                    aspectRatio: 1.5
                },
                (decodedText) => {
                    document.getElementById('scanStatus').innerHTML =
                        '<span class="text-green-600 font-bold"><i class="bi bi-check-circle-fill me-1"></i> Scanned: ' + decodedText + '</span>';

                    html5QrcodeScanner.stop().then(() => {
                        html5QrcodeScanner = null;

                        var modalEl = document.getElementById('scannerModal');
                        var modal = bootstrap.Modal.getInstance(modalEl);
                        modal.hide();

                        document.getElementById('barcodeInput').value = decodedText;
                        document.getElementById('scanForm').submit();
                    });
                },
                (errorMessage) => { }
            ).catch((err) => {
                document.getElementById('scanStatus').innerHTML =
                    '<span class="text-red-600"><i class="bi bi-exclamation-triangle-fill me-1"></i> Camera access denied.</span>';
                console.error("html5-qrcode start error:", err);
            });
        });

        document.getElementById('scannerModal').addEventListener('hidden.bs.modal', function () {
            if (html5QrcodeScanner) {
                html5QrcodeScanner.stop().then(() => {
                    html5QrcodeScanner = null;
                    document.getElementById('scanStatus').innerHTML =
                        '<i class="bi bi-camera-fill me-1"></i> Point your camera at a product barcode.';
                }).catch(() => { html5QrcodeScanner = null; });
            }
        });
    </script>
}
