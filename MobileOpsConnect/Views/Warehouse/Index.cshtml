@model IEnumerable<MobileOpsConnect.Models.Product>

@{
    ViewData["Title"] = "Warehouse Operations";
    int totalProducts = Model.Count();
    int lowStockCount = Model.Count(p => p.StockQuantity <= 10);
}

<!-- ═══════════════════════════════════════════════ -->
<!-- HERO BANNER                                     -->
<!-- ═══════════════════════════════════════════════ -->
<div class="moc-hero p-6 p-md-5 mb-6 text-white anim-fade-in">
    <div class="position-relative" style="z-index: 2;">
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(255,255,255,0.14);">
                <i class="bi bi-shop text-green-500 mr-1" style="font-size:0.8rem;vertical-align:text-top;"></i>
                Warehouse Floor
            </span>
             @if (lowStockCount > 0)
            {
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill px-6 py-2 text-sm" style="background:rgba(239,68,68,0.25);">
                    <i class="bi bi-exclamation-triangle-fill mr-1"></i> @lowStockCount Items Low
                </span>
            }
        </div>
        <h1 class="display-5 font-bold mb-2 letter-tight">Warehouse Operations</h1>
        <p class="lead mb-0 opacity-75">
            Scan products, manage stock levels, and verify inventory in real-time.
        </p>
    </div>
    <!-- Decorative Icon -->
    <div class="position-absolute top-50 end-0 translate-middle-y hidden lg:block pe-none"
         style="z-index:1;opacity:0.05;font-size:15rem;line-height:1;margin-right:1.5rem;">
        <i class="bi bi-upc-scan"></i>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- ACTION BAR                                      -->
<!-- ═══════════════════════════════════════════════ -->
<div class="flex flex-wrap justify-between items-center gap-6 mb-6 anim-fade-in anim-delay-1">
    <div class="flex items-center gap-2">
        <a asp-controller="Home" asp-action="Index" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-6">
            <i class="bi bi-arrow-left mr-1"></i> Dashboard
        </a>
    </div>
    
    <form asp-action="Index" method="get" id="scanForm" class="flex gap-2 flex-grow justify-end" style="max-width: 600px;">
        <div class="flex w-full items-stretch shadow-sm" style="border-radius: 0.625rem; overflow: hidden;">
            <button type="button" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-dark px-6" data-bs-toggle="modal" data-bs-target="#scannerModal">
                <i class="bi bi-camera-fill mr-1"></i> Scan
            </button>
            <input type="text" name="searchString" id="barcodeInput" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 border-0 bg-white" placeholder="Scan SKU or Search Product..." value="@ViewData["CurrentFilter"]" style="padding: 0.6rem 1rem;">
             <button class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-primary px-6" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- PRODUCT TABLE                                   -->
<!-- ═══════════════════════════════════════════════ -->
<div class="bg-white shadow-sm rounded-xl border border-moc-border overflow-hidden moc-card border-0 shadow-sm mb-6 anim-fade-in anim-delay-2">
    <div class="px-6 py-4 border-b border-moc-border bg-gray-50 bg-transparent border-0 p-6 pb-0">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-2">
                <div class="moc-icon-box bg-purple-50 rounded-3">
                    <i class="bi bi-box-seam text-purple fs-5"></i>
                </div>
                <div>
                    <h6 class="font-bold mb-0 letter-tight">Product List</h6>
                    <span class="text-moc-text-muted text-xs">@totalProducts item@(totalProducts != 1 ? "s" : "") found</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="p-6 p-0">
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse align-middle mb-0" style="border-collapse:separate;border-spacing:0 0.5rem;">
                <thead class="bg-light">
                    <tr>
                        <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 ps-4 py-6" style="width: 15%; letter-spacing:0.05em;">SKU</th>
                        <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 py-6" style="width: 30%; letter-spacing:0.05em;">Product Name</th>
                        <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 py-6" style="width: 15%; letter-spacing:0.05em;">Category</th>
                        <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 py-6 text-center" style="width: 15%; letter-spacing:0.05em;">Stock</th>
                        <th class="uppercase text-xs font-semibold text-moc-text-muted border-0 pe-4 py-6 text-center" style="width: 25%; letter-spacing:0.05em;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="transition: transform 0.2s;">
                            <td class="border-0 ps-4 py-6">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill bg-indigo-50 text-indigo px-2 py-1 font-semibold text-xs">
                                    @item.SKU
                                </span>
                            </td>
                            <td class="border-0 py-6">
                                <div class="flex items-center gap-2">
                                    <div class="moc-icon-box bg-light rounded-2" style="width:32px;height:32px;min-width:32px;">
                                        <i class="bi bi-box text-moc-text-muted" style="font-size:0.8rem;"></i>
                                    </div>
                                    <span class="font-bold text-sm text-dark">@item.Name</span>
                                </div>
                            </td>
                            <td class="border-0 py-6">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill bg-cyan-50 text-cyan px-2 py-1 font-semibold text-xs">
                                    @item.Category
                                </span>
                            </td>
                            <td class="text-center border-0 py-6">
                                @if (item.StockQuantity <= 10)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill bg-red-50 text-red px-6 py-2 font-semibold text-xs">
                                         <i class="bi bi-exclamation-triangle-fill mr-1"></i> @item.StockQuantity
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium rounded-pill bg-green-50 text-green px-6 py-2 font-semibold text-xs">
                                         <i class="bi bi-check-circle-fill mr-1"></i> @item.StockQuantity
                                    </span>
                                }
                            </td>
                            <td class="text-center border-0 pe-4 py-6">
                                <a asp-action="Adjust" asp-route-id="@item.ProductID" class="inline-flex justify-center rounded-md px-3 py-2 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 btn-moc-outline px-2 py-1 text-xs px-6 py-1">
                                    <i class="bi bi-sliders mr-1"></i> Manage
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════ -->
<!-- SCANNER MODAL                                   -->
<!-- ═══════════════════════════════════════════════ -->
<div class="modal fade" id="scannerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
            <div class="modal-header bg-dark text-white border-0" style="border-radius: 1rem 1rem 0 0;">
                <h5 class="modal-title fs-6 font-bold"><i class="bi bi-qr-code-scan mr-2"></i>Barcode Scanner</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-6">
                <div id="reader" class="overflow-hidden rounded-3 shadow-sm bg-light mb-6"></div>
                <p class="text-moc-text-muted small mb-0" id="scanStatus">
                    <i class="bi bi-camera-fill mr-1"></i> Point your camera at a product barcode.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        let html5QrcodeScanner = null;

        // Start scanner when modal opens
        document.getElementById('scannerModal').addEventListener('shown.bs.modal', function () {
            if (html5QrcodeScanner) return; // Already running

            html5QrcodeScanner = new Html5Qrcode("reader");

            html5QrcodeScanner.start(
                { facingMode: "environment" }, // Use back camera
                {
                    fps: 10,
                    qrbox: { width: 250, height: 150 },
                    aspectRatio: 1.5
                },
                (decodedText) => {
                    // SUCCESS
                    document.getElementById('scanStatus').innerHTML =
                        '<span class="text-green-500 font-bold"><i class="bi bi-check-circle-fill mr-1"></i> Scanned: ' + decodedText + '</span>';

                    // Stop the scanner
                    html5QrcodeScanner.stop().then(() => {
                        html5QrcodeScanner = null;

                        // Close modal, populate search, submit
                        var modalEl = document.getElementById('scannerModal');
                        var modal = bootstrap.Modal.getInstance(modalEl);
                        modal.hide();

                        document.getElementById('barcodeInput').value = decodedText;
                        document.getElementById('scanForm').submit();
                    });
                },
                (errorMessage) => {
                    // Ignore scan errors
                }
            ).catch((err) => {
                document.getElementById('scanStatus').innerHTML =
                    '<span class="text-red-500"><i class="bi bi-exclamation-triangle-fill mr-1"></i> Camera access denied.</span>';
                console.error("html5-qrcode start error:", err);
            });
        });

        // Stop scanner when modal closes
        document.getElementById('scannerModal').addEventListener('hidden.bs.modal', function () {
            if (html5QrcodeScanner) {
                html5QrcodeScanner.stop().then(() => {
                    html5QrcodeScanner = null;
                    document.getElementById('scanStatus').innerHTML =
                        '<i class="bi bi-camera-fill mr-1"></i> Point your camera at a product barcode.';
                }).catch(() => { html5QrcodeScanner = null; });
            }
        });
    </script>
}

