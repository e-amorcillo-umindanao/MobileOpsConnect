@model PaginatedList<MobileOpsConnect.Models.Product>
@{
    ViewData["Title"] = "Low Stock Alerts";
    int totalLow = ViewBag.TotalLow ?? 0;
    int outOfStock = ViewBag.OutOfStock ?? 0;
    int criticalCount = ViewBag.CriticalCount ?? 0;
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Warehouse" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Warehouse
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-rose-50 text-rose-600 border border-rose-100 dark:bg-rose-900/30 dark:border-rose-800 dark:text-rose-400 tracking-wide uppercase">Inventory Alert</span>
        @if (totalLow > 0)
        { <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-rose-50 text-rose-600 border border-rose-100 dark:bg-rose-900/30 dark:border-rose-800 dark:text-rose-400 tracking-wide uppercase">@totalLow Item@(totalLow != 1 ? "s" : "") Below Threshold</span> }
        else
        { <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">All Stocked</span> }
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Low Stock Alerts</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Items below the minimum safety threshold requiring attention</p>
</div>

<!-- Alert Summary -->
<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg dark:bg-red-800/30 dark:text-red-500"><i class="bi bi-exclamation-octagon-fill text-xl"></i></div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Total Alerts</p>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md @(totalLow > 0 ? "bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400" : "bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400") text-xs font-medium mt-1">@(totalLow > 0 ? "Needs Action" : "All Clear")</span>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-neutral-200">@totalLow</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] @(outOfStock > 0 ? "bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500" : "bg-green-100 text-green-800 dark:bg-green-800/30 dark:text-green-500") rounded-lg"><i class="bi @(outOfStock > 0 ? "bi-bag-x-fill" : "bi-bag-check-fill") text-xl"></i></div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Out of Stock</p>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md @(outOfStock > 0 ? "bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400" : "bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400") text-xs font-medium mt-1">@(outOfStock > 0 ? "Critical" : "None")</span>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-neutral-200">@outOfStock</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] @(criticalCount > 0 ? "bg-amber-100 text-amber-800 dark:bg-amber-800/30 dark:text-amber-500" : "bg-green-100 text-green-800 dark:bg-green-800/30 dark:text-green-500") rounded-lg"><i class="bi @(criticalCount > 0 ? "bi-exclamation-diamond-fill" : "bi-check2-all") text-xl"></i></div>
            <div class="grow">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-neutral-500">Running Low</p>
                        <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md @(criticalCount > 0 ? "bg-amber-100 text-amber-800 dark:bg-amber-800/20 dark:text-amber-400" : "bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400") text-xs font-medium mt-1">@(criticalCount > 0 ? "Reorder Soon" : "None")</span>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-neutral-200">@criticalCount</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Header -->
<div class="px-6 py-4 border-b border-gray-100 dark:border-neutral-800 bg-white border shadow-sm rounded-t-2xl dark:bg-neutral-900">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500">
            <i class="bi bi-funnel-fill text-lg"></i>
        </span>
        <div>
            <p class="font-bold text-sm text-gray-900 dark:text-neutral-200 mb-0">Low Stock Items</p>
            <p class="text-gray-500 text-xs mb-0 dark:text-neutral-500">Page @Model.PageIndex of @Model.TotalPages</p>
        </div>
    </div>
</div>

<!-- Alert Table Card -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-b-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6 relative overflow-hidden">
    <div class="p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-10">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4 dark:border-green-900 dark:bg-green-800 dark:text-green-400"><i class="bi bi-check-circle-fill text-2xl"></i></span>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">All Stock Levels Healthy</h3>
                <p class="text-sm text-gray-500 mb-0 dark:text-neutral-500">No items are currently below the safety threshold.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="overflow-x-auto hidden md:block p-2">
                <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                    <thead><tr>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">SKU</th>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Product</th>
                        <th class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Category</th>
                        <th class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Stock</th>
                        <th class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Status</th>
                        <th class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Action</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                                <td class="px-6 py-4 text-xs font-bold text-gray-900 dark:text-white">@item.SKU</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-x-2">
                                        <span class="inline-flex justify-center items-center size-[36px] rounded-lg bg-red-100 text-red-800 dark:bg-red-800/30 dark:text-red-500"><i class="bi bi-exclamation-triangle-fill text-sm"></i></span>
                                        <span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">@item.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-xs font-medium text-gray-500 dark:text-neutral-500">@item.Category</td>
                                <td class="px-6 py-4 text-center">
                                    @if (item.StockQuantity == 0)
                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-bold bg-red-100 text-red-800 uppercase tracking-wide">0</span> }
                                    else
                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-bold bg-amber-100 text-amber-800 uppercase tracking-wide">@item.StockQuantity</span> }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (item.StockQuantity == 0)
                                    { <span class="py-1 px-2.5 rounded-full text-[10px] font-bold bg-red-100 text-red-800 uppercase tracking-wide">OUT OF STOCK</span> }
                                    else
                                    { <span class="py-1 px-2.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-800 uppercase tracking-wide">CRITICAL</span> }
                                </td>
                                <td class="px-6 py-4 text-end">
                                    <a asp-controller="Warehouse" asp-action="Adjust" asp-route-id="@item.ProductID" class="py-1.5 px-3 inline-flex items-center gap-x-2 text-xs font-bold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                                        Adjust
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden p-4 space-y-4">
                @foreach (var item in Model)
                {
                    <div class="bg-white border rounded-xl p-4 dark:bg-neutral-900 dark:border-neutral-800" style="border-left: 4px solid @(item.StockQuantity == 0 ? "#ef4444" : "#f59e0b") !important;">
                        <div class="flex items-start justify-between mb-2">
                            <div class="flex items-center gap-2 min-w-0">
                                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800 shrink-0 dark:bg-red-800/30 dark:text-red-500"><i class="bi bi-exclamation-triangle-fill"></i></span>
                                <div class="min-w-0"><p class="text-sm font-bold text-gray-900 dark:text-white mb-0 truncate">@item.Name</p><span class="text-xs text-gray-500">@item.SKU</span></div>
                            </div>
                            @if (item.StockQuantity == 0)
                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-red-100 text-red-800 text-xs font-medium ms-2"><i class="bi bi-x-circle-fill"></i> 0</span> }
                            else
                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-amber-100 text-amber-800 text-xs font-medium ms-2"><i class="bi bi-exclamation-circle-fill"></i> @item.StockQuantity</span> }
                        </div>
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs font-medium text-gray-500 dark:text-neutral-500">@item.Category</span>
                            @if (item.StockQuantity == 0)
                            { <span class="py-0.5 px-2 rounded-full text-[10px] font-bold bg-red-100 text-red-800 uppercase">OUT OF STOCK</span> }
                            else
                            { <span class="py-0.5 px-2 rounded-full text-[10px] font-bold bg-amber-100 text-amber-800 uppercase">CRITICAL</span> }
                        </div>
                        <a asp-controller="Warehouse" asp-action="Adjust" asp-route-id="@item.ProductID" class="w-full py-2.5 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-bold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                            Adjust Stock
                        </a>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Pagination -->
    <partial name="_Pagination" model="Model" />
</div>
