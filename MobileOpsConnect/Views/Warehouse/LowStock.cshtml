@model IEnumerable<MobileOpsConnect.Models.Product>

@{
    ViewData["Title"] = "Low Stock Alerts";
    int totalLow = Model.Count();
    int outOfStock = Model.Count(p => p.StockQuantity == 0);
    int criticalCount = totalLow - outOfStock;
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white"><i class="bi bi-shield-exclamation"></i> Inventory Alert</span>
            @if (totalLow > 0)
            { <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-500/30 text-white"><i class="bi bi-exclamation-triangle-fill"></i> @totalLow Item@(totalLow != 1 ? "s" : "") Below Threshold</span> }
            else
            { <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-green-500/30 text-white"><i class="bi bi-check-circle-fill"></i> All Stocked</span> }
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Low Stock Alerts</h1>
        <p class="text-blue-100 text-lg">Items below the minimum safety threshold requiring attention</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-exclamation-octagon-fill text-9xl text-white"></i>
    </div>
</div>

<!-- Alert Summary -->
<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg"><i class="bi bi-exclamation-octagon-fill text-xl"></i></div>
            <div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Total Alerts</p><h3 class="text-xl font-medium text-gray-800 mt-1">@totalLow</h3>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md @(totalLow > 0 ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") text-xs font-medium"><i class="bi @(totalLow > 0 ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i> @(totalLow > 0 ? "Needs Action" : "All Clear")</span>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] @(outOfStock > 0 ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") rounded-lg"><i class="bi @(outOfStock > 0 ? "bi-bag-x-fill" : "bi-bag-check-fill") text-xl"></i></div>
            <div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Out of Stock</p><h3 class="text-xl font-medium text-gray-800 mt-1">@outOfStock</h3>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md @(outOfStock > 0 ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") text-xs font-medium"><i class="bi @(outOfStock > 0 ? "bi-x-circle-fill" : "bi-check-circle-fill")"></i> @(outOfStock > 0 ? "Critical" : "None")</span>
            </div>
        </div>
    </div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl">
        <div class="p-4 md:p-5 flex gap-x-4">
            <div class="shrink-0 flex justify-center items-center size-[46px] @(criticalCount > 0 ? "bg-amber-100 text-amber-800" : "bg-green-100 text-green-800") rounded-lg"><i class="bi @(criticalCount > 0 ? "bi-exclamation-diamond-fill" : "bi-check2-all") text-xl"></i></div>
            <div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Running Low</p><h3 class="text-xl font-medium text-gray-800 mt-1">@criticalCount</h3>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md @(criticalCount > 0 ? "bg-amber-100 text-amber-800" : "bg-green-100 text-green-800") text-xs font-medium"><i class="bi @(criticalCount > 0 ? "bi-exclamation-circle-fill" : "bi-check-circle-fill")"></i> @(criticalCount > 0 ? "Reorder Soon" : "None")</span>
            </div>
        </div>
    </div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-3 mb-6">
    <div class="flex items-center gap-x-3">
        <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-funnel-fill text-lg"></i></span>
        <div><p class="text-sm font-semibold text-gray-800 mb-0">Low Stock Items</p><span class="text-xs text-gray-500">Showing @totalLow item@(totalLow != 1 ? "s" : "") below threshold</span></div>
    </div>
    <div class="flex gap-2">
        <a asp-controller="Warehouse" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50"><i class="bi bi-arrow-left"></i> Warehouse</a>
        <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50"><i class="bi bi-house"></i> Dashboard</a>
    </div>
</div>

<!-- Alert Table -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl mb-6">
    <div class="p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-10">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-green-50 bg-green-100 text-green-800 mx-auto mb-4"><i class="bi bi-check-circle-fill text-2xl"></i></span>
                <h3 class="text-lg font-semibold text-gray-800 mb-1">All Stock Levels Healthy</h3>
                <p class="text-sm text-gray-500 mb-0">No items are currently below the safety threshold.</p>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="overflow-x-auto hidden md:block">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50"><tr>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-upc-scan me-1"></i> SKU</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-box me-1"></i> Product</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase"><i class="bi bi-tag me-1"></i> Category</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase"><i class="bi bi-layers me-1"></i> Stock</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase"><i class="bi bi-flag me-1"></i> Status</th>
                        <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase"><i class="bi bi-lightning me-1"></i> Action</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-200">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4"><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-indigo-100 text-indigo-800 text-xs font-medium">@item.SKU</span></td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-x-2">
                                        <span class="inline-flex justify-center items-center size-[36px] rounded-lg bg-red-100 text-red-800"><i class="bi bi-exclamation-triangle-fill text-sm"></i></span>
                                        <span class="text-sm font-semibold text-gray-800">@item.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4"><span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium"><i class="bi bi-tag-fill"></i> @item.Category</span></td>
                                <td class="px-6 py-4 text-center">
                                    @if (item.StockQuantity == 0)
                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="bi bi-x-circle-fill"></i> 0</span> }
                                    else
                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800"><i class="bi bi-exclamation-circle-fill"></i> @item.StockQuantity</span> }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (item.StockQuantity == 0)
                                    { <span class="inline-flex items-center py-1 px-2.5 rounded-full text-xs font-bold bg-red-100 text-red-800">OUT OF STOCK</span> }
                                    else
                                    { <span class="inline-flex items-center py-1 px-2.5 rounded-full text-xs font-bold bg-amber-100 text-amber-800">CRITICAL</span> }
                                </td>
                                <td class="px-6 py-4 text-end">
                                    <a asp-controller="Warehouse" asp-action="Adjust" asp-route-id="@item.ProductID" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                                        <i class="bi bi-sliders"></i> Adjust Stock
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden p-4 space-y-4">
                @foreach (var item in Model)
                {
                    <div class="bg-gray-50 rounded-xl p-4 border" style="border-left: 4px solid @(item.StockQuantity == 0 ? "#ef4444" : "#f59e0b") !important;">
                        <div class="flex items-start justify-between mb-2">
                            <div class="flex items-center gap-2 min-w-0">
                                <span class="inline-flex justify-center items-center size-[40px] rounded-lg bg-red-100 text-red-800 shrink-0"><i class="bi bi-exclamation-triangle-fill"></i></span>
                                <div class="min-w-0"><p class="text-sm font-bold text-gray-800 mb-0 truncate">@item.Name</p><span class="text-xs text-gray-500">@item.SKU</span></div>
                            </div>
                            @if (item.StockQuantity == 0)
                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-red-100 text-red-800 text-xs font-medium ms-2"><i class="bi bi-x-circle-fill"></i> 0</span> }
                            else
                            { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-amber-100 text-amber-800 text-xs font-medium ms-2"><i class="bi bi-exclamation-circle-fill"></i> @item.StockQuantity</span> }
                        </div>
                        <div class="flex items-center justify-between mb-3">
                            <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-md bg-cyan-100 text-cyan-800 text-xs font-medium"><i class="bi bi-tag-fill"></i> @item.Category</span>
                            @if (item.StockQuantity == 0)
                            { <span class="inline-flex items-center py-0.5 px-2 rounded-full text-xs font-bold bg-red-100 text-red-800">OUT OF STOCK</span> }
                            else
                            { <span class="inline-flex items-center py-0.5 px-2 rounded-full text-xs font-bold bg-amber-100 text-amber-800">CRITICAL</span> }
                        </div>
                        <a asp-controller="Warehouse" asp-action="Adjust" asp-route-id="@item.ProductID" class="w-full py-2 px-3 inline-flex justify-center items-center gap-x-2 text-xs font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                            <i class="bi bi-sliders"></i> Adjust Stock
                        </a>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-gray-200">
        <div class="flex flex-wrap justify-between items-center gap-2">
            <span class="text-xs text-gray-500"><i class="bi bi-info-circle me-1"></i> Showing all @totalLow item@(totalLow != 1 ? "s" : "") below safety threshold</span>
            <div class="flex gap-1">
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-red-100 text-red-800 text-xs">@outOfStock Out of Stock</span>
                <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full bg-amber-100 text-amber-800 text-xs">@criticalCount Critical</span>
            </div>
        </div>
    </div>
</div>
