@model MobileOpsConnect.Models.Product

@{
    ViewData["Title"] = "Adjust Stock";
}

<div class="max-w-2xl mx-auto py-6">
    <div class="flex justify-between items-center mb-6">
        <a asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
            Back to Warehouse
        </a>
        <span class="text-xs text-gray-500 dark:text-neutral-500">SKU: <span class="font-semibold">@Model.SKU</span></span>
    </div>

    <div class="flex flex-col bg-white border shadow-sm rounded-xl overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-6 text-center border-b border-gray-200">
            <span class="inline-flex justify-center items-center size-[80px] rounded-full bg-indigo-100 text-indigo-800 mx-auto mb-4">
                <i class="bi bi-box-seam" style="font-size: 2.5rem;"></i>
            </span>
            <h3 class="text-xl font-bold text-gray-800 mb-1">@Model.Name</h3>
            <p class="text-sm text-gray-500 mb-0">Adjust inventory levels</p>
        </div>

        <div class="p-6">
            <!-- Current Stock Display -->
            <div class="text-center mb-6 p-6 rounded-xl bg-gray-50 border border-gray-100">
                <span class="block uppercase text-xs font-bold text-gray-500 mb-1">Current Quantity</span>
                <h1 class="text-5xl font-bold mb-0 @(Model.StockQuantity <= 10 ? "text-red-600" : "text-blue-600")" style="letter-spacing: -2px;">
                    @Model.StockQuantity
                </h1>
                @if (Model.StockQuantity <= 10)
                {
                    <div class="mt-2">
                        <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            Low Stock Warning
                        </span>
                    </div>
                }
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex items-center gap-2 mb-6">
                    <i class="bi bi-x-circle-fill text-red-600 text-lg"></i>
                    <span class="text-sm text-red-800">@TempData["Error"]</span>
                </div>
            }

            <div class="space-y-4">
                <!-- Stock In -->
                <div class="p-4 border rounded-xl bg-white shadow-sm" style="border-left: 5px solid #16a34a !important;">
                    <h6 class="text-green-600 font-bold mb-3 flex items-center gap-2">
                        Stock In
                    </h6>
                    <form asp-action="StockIn">
                        <input type="hidden" name="id" value="@Model.ProductID" />
                        <div class="grid sm:grid-cols-3 gap-3">
                            <div>
                                <div class="form-floating">
                                    <input type="number" name="quantity" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" id="qtyIn" placeholder="0" required min="1">
                                    <label for="qtyIn">Quantity</label>
                                </div>
                            </div>
                            <div class="sm:col-span-2">
                                <div class="flex">
                                    <div class="form-floating flex-grow">
                                        <input type="text" name="notes" class="py-3 px-4 block w-full border-gray-200 rounded-lg rounded-e-none text-sm focus:border-blue-500 focus:ring-blue-500" id="noteIn" placeholder="Reason" required>
                                        <label for="noteIn">Reason / Notes</label>
                                    </div>
                                    <button type="submit" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-e-lg border border-transparent bg-green-600 text-white hover:bg-green-700">
                                        Submit In
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Stock Out -->
                <div class="p-4 border rounded-xl bg-white shadow-sm" style="border-left: 5px solid #dc2626 !important;">
                    <h6 class="text-red-600 font-bold mb-3 flex items-center gap-2">
                        Stock Out
                    </h6>
                    <form asp-action="StockOut">
                        <input type="hidden" name="id" value="@Model.ProductID" />
                        <div class="grid sm:grid-cols-3 gap-3">
                            <div>
                                <div class="form-floating">
                                    <input type="number" name="quantity" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" id="qtyOut" placeholder="0" required min="1">
                                    <label for="qtyOut">Quantity</label>
                                </div>
                            </div>
                            <div class="sm:col-span-2">
                                <div class="flex">
                                    <div class="form-floating flex-grow">
                                        <input type="text" name="notes" class="py-3 px-4 block w-full border-gray-200 rounded-lg rounded-e-none text-sm focus:border-blue-500 focus:ring-blue-500" id="noteOut" placeholder="Reason" required>
                                        <label for="noteOut">Reason / Notes</label>
                                    </div>
                                    <button type="submit" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-e-lg border border-transparent bg-red-600 text-white hover:bg-red-700">
                                        Submit Out
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
