@model MobileOpsConnect.Models.Product

@{
    ViewData["Title"] = "Adjust Stock";
}

<div class="max-w-2xl mx-auto py-6">
    <div class="flex justify-between items-center mb-6">
        <a asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
            ← Back to Warehouse
        </a>
        <span class="text-xs text-gray-500 dark:text-neutral-500">SKU: <span class="font-semibold">@Model.SKU</span></span>
    </div>

    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
        <!-- Header -->
        <div class="px-6 py-6 text-center border-b border-gray-100 dark:border-neutral-800">
            <span class="inline-flex justify-center items-center size-[80px] rounded-full bg-indigo-100 text-indigo-800 mx-auto mb-4">
                <i class="bi bi-box-seam" style="font-size: 2.5rem;"></i>
            </span>
            <h3 class="text-xl font-bold text-gray-800 mb-1">@Model.Name</h3>
            <p class="text-sm text-gray-500 mb-0">Adjust inventory levels</p>
        </div>

        <div class="p-6">
            <!-- Current Stock Display -->
            <div class="text-center mb-6 p-6 rounded-xl bg-gray-50 border border-gray-100">
                <span class="block uppercase text-xs font-bold text-gray-500 mb-1">Current Quantity</span>
                <h1 class="text-5xl font-bold mb-0 @(Model.StockQuantity <= 10 ? "text-red-600" : "text-gray-900 dark:text-white")" style="letter-spacing: -2px;">
                    @Model.StockQuantity
                </h1>
                @if (Model.StockQuantity <= 10)
                {
                    <div class="mt-2">
                        <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            Low Stock Warning
                        </span>
                    </div>
                }
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex items-center gap-2 mb-6">
                    <i class="bi bi-x-circle-fill text-red-600 text-lg"></i>
                    <span class="text-sm text-red-800">@TempData["Error"]</span>
                </div>
            }

            <div class="space-y-6">
                <!-- Stock In -->
                <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800" style="border-left: 5px solid #16a34a !important;">
                    <div class="px-6 py-4 border-b border-gray-100 dark:border-neutral-800">
                        <div class="flex items-center gap-x-3">
                            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-emerald-50 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                                <i class="bi bi-plus-circle text-lg"></i>
                            </span>
                            <div>
                                <h4 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Stock In</h4>
                                <span class="text-xs text-gray-500 dark:text-neutral-500">Increase inventory count</span>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <form asp-action="StockIn">
                            <input type="hidden" name="id" value="@Model.ProductID" />
                            <div class="grid gap-y-5">
                                <div class="grid sm:grid-cols-2 gap-4">
                                    <div>
                                        <label for="qtyIn" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-layers me-1 text-emerald-500"></i> Quantity</label>
                                        <input type="number" name="quantity" id="qtyIn" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="0" required min="1">
                                    </div>
                                    <div>
                                        <label for="noteIn" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-sticky me-1 text-indigo-500"></i> Reason / Notes</label>
                                        <input type="text" name="notes" id="noteIn" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Enter reason" required>
                                    </div>
                                </div>
                                <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                                    <i class="bi bi-plus-lg"></i> Submit Stock In
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Stock Out -->
                <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800" style="border-left: 5px solid #dc2626 !important;">
                    <div class="px-6 py-4 border-b border-gray-100 dark:border-neutral-800">
                        <div class="flex items-center gap-x-3">
                            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-rose-50 text-rose-600 dark:bg-rose-900/30 dark:text-rose-400">
                                <i class="bi bi-dash-circle text-lg"></i>
                            </span>
                            <div>
                                <h4 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Stock Out</h4>
                                <span class="text-xs text-gray-500 dark:text-neutral-500">Decrease inventory count</span>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <form asp-action="StockOut">
                            <input type="hidden" name="id" value="@Model.ProductID" />
                            <div class="grid gap-y-5">
                                <div class="grid sm:grid-cols-2 gap-4">
                                    <div>
                                        <label for="qtyOut" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-layers me-1 text-rose-500"></i> Quantity</label>
                                        <input type="number" name="quantity" id="qtyOut" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="0" required min="1">
                                    </div>
                                    <div>
                                        <label for="noteOut" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-sticky me-1 text-indigo-500"></i> Reason / Notes</label>
                                        <input type="text" name="notes" id="noteOut" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Enter reason" required>
                                    </div>
                                </div>
                                <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700 transition-colors">
                                    <i class="bi bi-dash-lg"></i> Submit Stock Out
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
