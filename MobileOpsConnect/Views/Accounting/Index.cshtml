@model IEnumerable<MobileOpsConnect.Models.AccountingEntry>

@{
    ViewData["Title"] = "Accounting Ledger";
    int totalEntries = Model.Count();
    int incomeCount = Model.Count(e => e.Type == "Income");
    int expenseCount = Model.Count(e => e.Type == "Expense");
}

@{
    var exchangeRates = (MobileOpsConnect.Services.ExchangeRateResult?)ViewBag.ExchangeRates;
    var targetCurrencies = new[] { "USD", "EUR", "GBP", "JPY", "SGD", "AUD" };
    var currencyIcons = new Dictionary<string, string>
    {
        { "USD", "bi-currency-dollar" }, { "EUR", "bi-currency-euro" },
        { "GBP", "bi-currency-pound" }, { "JPY", "bi-currency-yen" },
        { "SGD", "bi-currency-dollar" }, { "AUD", "bi-currency-dollar" }
    };
    var currencyNames = new Dictionary<string, string>
    {
        { "USD", "US Dollar" }, { "EUR", "Euro" }, { "GBP", "British Pound" },
        { "JPY", "Japanese Yen" }, { "SGD", "Singapore Dollar" }, { "AUD", "Australian Dollar" }
    };
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <span class="size-1.5 inline-block bg-green-500 rounded-full"></span> Financial Records
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white/20 text-white">
                <i class="bi bi-receipt"></i> @totalEntries Entries
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Accounting Ledger</h1>
        <p class="text-blue-100 text-lg">Track all financial transactions, income, and expenses.</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-calculator text-9xl text-white"></i>
    </div>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-3 mb-6">
    <a asp-controller="Home" asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
    <a asp-action="Create" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
        <i class="bi bi-plus-lg"></i> New Entry
    </a>
</div>

<!-- Summary Cards -->
<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
    @{
        decimal netResult = (decimal)ViewBag.NetResult;
        bool isPositive = netResult >= 0;
    }
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-green-100 text-green-800 rounded-lg"><i class="bi bi-arrow-up-circle-fill text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Total Income</p><h3 class="text-xl font-medium text-gray-800 mt-1">@(((decimal)ViewBag.TotalIncome).ToString("C"))</h3><span class="text-xs text-gray-500"><i class="bi bi-receipt me-1"></i>@incomeCount transactions</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-red-100 text-red-800 rounded-lg"><i class="bi bi-arrow-down-circle-fill text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Total Expenses</p><h3 class="text-xl font-medium text-gray-800 mt-1">@(((decimal)ViewBag.TotalExpense).ToString("C"))</h3><span class="text-xs text-gray-500"><i class="bi bi-receipt me-1"></i>@expenseCount transactions</span></div></div></div>
    <div class="flex flex-col bg-white border shadow-sm rounded-xl"><div class="p-4 md:p-5 flex gap-x-4"><div class="shrink-0 flex justify-center items-center size-[46px] bg-indigo-100 text-indigo-800 rounded-lg"><i class="bi bi-wallet2 text-xl"></i></div><div class="grow"><p class="text-xs uppercase tracking-wide text-gray-500">Net Result</p><h3 class="text-xl font-medium mt-1" style="color:@(isPositive ? "#16a34a" : "#dc2626");">@netResult.ToString("C")</h3><span class="text-xs text-gray-500"><i class="bi bi-@(isPositive ? "graph-up-arrow" : "graph-down-arrow") me-1"></i>@(isPositive ? "Profit" : "Loss")</span></div></div></div>
</div>

<!-- Live Exchange Rates -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-gray-100 text-gray-800"><i class="bi bi-globe2 text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800"><i class="bi bi-broadcast me-1"></i> Live Exchange Rates</h3>
                    <span class="text-xs text-gray-500">Base: PHP &bull;
                        @if (exchangeRates != null && exchangeRates.IsSuccess)
                        { <span>Updated: @exchangeRates.LastUpdated</span> }
                        else
                        { <span class="text-red-500">API unavailable</span> }
                    </span>
                </div>
            </div>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"><i class="bi bi-lightning-charge-fill"></i> ExchangeRate-API</span>
        </div>
    </div>
    <div class="p-6">
        @if (exchangeRates != null && exchangeRates.IsSuccess && exchangeRates.Rates.Any())
        {
            <div class="flex overflow-x-auto snap-x gap-4 pb-2 sm:grid sm:grid-cols-3 lg:grid-cols-6 custom-scrollbar">
                @foreach (var code in targetCurrencies)
                {
                    if (exchangeRates.Rates.TryGetValue(code, out var rate))
                    {
                        var icon = currencyIcons.GetValueOrDefault(code, "bi-currency-exchange");
                        var name = currencyNames.GetValueOrDefault(code, code);
                        <div class="min-w-[140px] snap-center sm:min-w-0 bg-gray-50 rounded-xl p-4 text-center border border-gray-100">
                            <span class="inline-flex justify-center items-center size-[36px] rounded-lg bg-blue-100 text-blue-800 mx-auto mb-2"><i class="bi @icon text-sm"></i></span>
                            <p class="text-sm font-bold text-gray-800 mb-0">@rate.ToString("F4")</p>
                            <span class="text-xs font-semibold text-gray-500">@code</span><br />
                            <span class="text-xs text-gray-400">@name</span>
                        </div>
                    }
                }
            </div>
            <p class="text-xs text-gray-500 mt-3 text-center"><i class="bi bi-info-circle me-1"></i> 1 PHP = displayed rate &bull; Data from <strong>open.er-api.com</strong></p>
        }
        else
        {
            <div class="text-center py-6">
                <span class="inline-flex justify-center items-center size-[56px] rounded-full border-4 border-red-50 bg-red-100 text-red-800 mx-auto mb-3"><i class="bi bi-wifi-off text-xl"></i></span>
                <p class="text-sm font-semibold text-gray-800 mb-1">Exchange rates unavailable</p>
                <span class="text-xs text-gray-500">Unable to fetch data. Check your connection.</span>
            </div>
        }
    </div>
</div>

<!-- Filter Panel -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-100 text-amber-800"><i class="bi bi-funnel text-lg"></i></span>
            <div>
                <h3 class="text-sm font-semibold text-gray-800">Filter Transactions</h3>
                <span class="text-xs text-gray-500">Narrow down results by type, category, or date range</span>
            </div>
        </div>
    </div>
    <div class="p-6">
        <form method="get" class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">Type</label>
                <select name="filterType" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500">
                    <option value="">All Types</option>
                    <option value="Income">Income</option>
                    <option value="Expense">Expense</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">Category</label>
                <input type="text" name="filterCategory" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Search category..." />
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">Start Date</label>
                <input type="date" name="startDate" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" />
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">End Date</label>
                <input type="date" name="endDate" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" />
            </div>
            <div>
                <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Transactions Table -->
<div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
        <div class="flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-list-ul text-lg"></i></span>
            <div>
                <h3 class="text-sm font-semibold text-gray-800">Transaction History</h3>
                <span class="text-xs text-gray-500">@totalEntries record@(totalEntries != 1 ? "s" : "") found</span>
            </div>
        </div>
    </div>
    <div class="p-6">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-neutral-700">
                <thead class="bg-gray-50 dark:bg-neutral-800">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase">Date</th>
                        <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase">Type</th>
                        <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase">Category</th>
                        <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase">Description</th>
                        <th scope="col" class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase">Amount</th>
                        <th scope="col" class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase">Ref #</th>
                        <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-neutral-700">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800 transition-colors">
                            <td class="whitespace-nowrap px-6 py-4"><span class="text-sm font-semibold text-gray-800">@item.TransactionDate.ToString("MMM dd, yyyy")</span></td>
                            <td class="whitespace-nowrap px-6 py-4">
                                @if (item.Type == "Income")
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><i class="bi bi-arrow-up-short"></i> Income</span> }
                                else
                                { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="bi bi-arrow-down-short"></i> Expense</span> }
                            </td>
                            <td class="whitespace-nowrap px-6 py-4"><span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">@item.Category</span></td>
                            <td class="px-6 py-4"><span class="text-sm text-gray-500">@item.Description</span></td>
                            <td class="whitespace-nowrap px-6 py-4 text-end">
                                <span class="text-sm font-bold" style="color:@(item.Type == "Income" ? "#16a34a" : "#dc2626");">
                                    @(item.Type == "Income" ? "+" : "−")@item.Amount.ToString("C")
                                </span>
                            </td>
                            <td class="whitespace-nowrap px-6 py-4"><span class="text-xs text-gray-500">@(item.ReferenceNumber ?? "—")</span></td>
                            <td class="whitespace-nowrap px-6 py-4 text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-10">
                                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-500 mx-auto mb-4"><i class="bi bi-journal-x text-2xl"></i></span>
                                <h3 class="text-lg font-semibold text-gray-800 mb-1">No Transactions Found</h3>
                                <p class="text-sm text-gray-500 mb-4">Start by recording your first transaction.</p>
                                <a asp-action="Create" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700">
                                    <i class="bi bi-plus-lg"></i> New Entry
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
