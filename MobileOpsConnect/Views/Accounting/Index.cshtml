@model PaginatedList<MobileOpsConnect.Models.AccountingEntry>

@{
    ViewData["Title"] = "Accounting Ledger";
    int totalEntries = ViewBag.TotalCount ?? 0;
    int incomeCount = ViewBag.IncomeCount ?? 0;
    int expenseCount = ViewBag.ExpenseCount ?? 0;
    
    var filterType = ViewData["FilterType"] as string;
    var filterCategory = ViewData["FilterCategory"] as string;
    var startDate = ViewData["StartDate"] as string;
    var endDate = ViewData["EndDate"] as string;
}

@{
    var exchangeRates = (MobileOpsConnect.Services.ExchangeRateResult?)ViewBag.ExchangeRates;
    var targetCurrencies = new[] { "USD", "EUR", "GBP", "JPY", "SGD", "AUD" };
    var currencyIcons = new Dictionary<string, string>
    {
        { "USD", "bi-currency-dollar" }, { "EUR", "bi-currency-euro" },
        { "GBP", "bi-currency-pound" }, { "JPY", "bi-currency-yen" },
        { "SGD", "bi-currency-dollar" }, { "AUD", "bi-currency-dollar" }
    };
    var currencyNames = new Dictionary<string, string>
    {
        { "USD", "US Dollar" }, { "EUR", "Euro" }, { "GBP", "British Pound" },
        { "JPY", "Japanese Yen" }, { "SGD", "Singapore Dollar" }, { "AUD", "Australian Dollar" }
    };
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Dashboard
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            Financial Records
        </span>
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-gray-50 text-gray-500 border border-gray-200 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 tracking-wide uppercase">
            <i class="bi bi-receipt"></i> @totalEntries Entries
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Accounting Ledger</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Track all financial transactions, income, and expenses.</p>
</div>

<!-- Action Bar -->
<div class="flex flex-wrap justify-between items-center gap-3 mb-8">
    <div class="flex flex-wrap items-center gap-3">
        @if (!string.IsNullOrEmpty(filterType) || !string.IsNullOrEmpty(filterCategory) || !string.IsNullOrEmpty(startDate) || !string.IsNullOrEmpty(endDate))
        {
            <a asp-action="Index" class="py-2.5 px-4 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
                <i class="bi bi-x-circle"></i> Clear Filters
            </a>
        }
        <a asp-action="Create" class="py-2.5 px-5 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
            <i class="bi bi-plus-lg"></i> New Entry
        </a>
    </div>
</div>

<!-- Summary Cards -->
<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-10">
    @{
        decimal netResult = (decimal)(ViewBag.NetResult ?? 0m);
        bool isPositive = netResult >= 0;
    }
    <!-- Total Income -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-emerald-50 text-emerald-500 rounded-2xl dark:bg-emerald-900/20 dark:text-emerald-400">
                <i class="bi bi-arrow-up-circle text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Total Income</p>
        <div class="flex items-end justify-between mt-auto">
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-emerald-50 text-emerald-600 text-[10px] font-bold uppercase tracking-wide dark:bg-emerald-900/20 dark:text-emerald-400 mb-1">
                <i class="bi bi-receipt"></i> @incomeCount Txns
            </span>
            <h3 class="text-2xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@(((decimal)(ViewBag.TotalIncome ?? 0m)).ToString("C"))</h3>
        </div>
    </div>
    <!-- Total Expenses -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-rose-50 text-rose-500 rounded-2xl dark:bg-rose-900/20 dark:text-rose-400">
                <i class="bi bi-arrow-down-circle text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Total Expenses</p>
        <div class="flex items-end justify-between mt-auto">
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-rose-50 text-rose-600 text-[10px] font-bold uppercase tracking-wide dark:bg-rose-900/20 dark:text-rose-400 mb-1">
                <i class="bi bi-receipt"></i> @expenseCount Txns
            </span>
            <h3 class="text-2xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white leading-none">@(((decimal)(ViewBag.TotalExpense ?? 0m)).ToString("C"))</h3>
        </div>
    </div>
    <!-- Net Result -->
    <div class="p-6 flex flex-col bg-white border border-gray-100 shadow-sm rounded-[1.25rem] dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex justify-between items-center mb-6">
            <div class="flex justify-center items-center size-[46px] bg-[#f4f2ff] text-[#5e4dcd] rounded-2xl dark:bg-indigo-900/20 dark:text-indigo-400">
                <i class="bi bi-wallet2 text-xl"></i>
            </div>
        </div>
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-neutral-500 mb-1">Net Result</p>
        <div class="flex items-end justify-between mt-auto">
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full bg-@(isPositive ? "emerald" : "rose")-50 text-@(isPositive ? "emerald" : "rose")-600 text-[10px] font-bold uppercase tracking-wide mb-1">
                <i class="bi bi-@(isPositive ? "graph-up-arrow" : "graph-down-arrow")"></i> @(isPositive ? "Profit" : "Loss")
            </span>
            <h3 class="text-2xl sm:text-[2.5rem] font-bold leading-none" style="color:@(isPositive ? "#16a34a" : "#dc2626");">@netResult.ToString("C")</h3>
        </div>
    </div>
</div>

<!-- Live Exchange Rates -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-gray-50 text-gray-600 dark:bg-neutral-800 dark:text-neutral-400">
                    <i class="bi bi-globe2 text-lg"></i>
                </span>
                <div>
                    <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Live Exchange Rates</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500">Base: PHP &bull;
                        @if (exchangeRates != null && exchangeRates.IsSuccess)
                        { <span>Updated: @exchangeRates.LastUpdated</span> }
                        else
                        { <span class="text-red-500">API unavailable</span> }
                    </span>
                </div>
            </div>
            <span class="inline-flex items-center gap-x-1 py-1.5 px-3 rounded-md text-xs font-bold uppercase tracking-wide bg-[#f4f2ff] text-[#5e4dcd] dark:bg-indigo-900/20 dark:text-indigo-400"><i class="bi bi-lightning-charge"></i> ExchangeRate-API</span>
        </div>
    </div>
    <div class="p-6">
        @if (exchangeRates != null && exchangeRates.IsSuccess && exchangeRates.Rates.Any())
        {
            <div class="flex overflow-x-auto snap-x gap-4 pb-2 sm:grid sm:grid-cols-3 lg:grid-cols-6 custom-scrollbar">
                @foreach (var code in targetCurrencies)
                {
                    if (exchangeRates.Rates.TryGetValue(code, out var rate))
                    {
                        var icon = currencyIcons.GetValueOrDefault(code, "bi-currency-exchange");
                        var name = currencyNames.GetValueOrDefault(code, code);
                        <div class="min-w-[140px] snap-center sm:min-w-0 bg-gray-50 rounded-xl p-4 text-center border border-gray-100 dark:bg-neutral-800 dark:border-neutral-700">
                            <span class="inline-flex justify-center items-center size-[36px] rounded-lg bg-blue-100 text-blue-800 mx-auto mb-2 dark:bg-blue-900/30 dark:text-blue-400"><i class="bi @icon text-sm"></i></span>
                            <p class="text-sm font-bold text-gray-800 mb-0 dark:text-white">@rate.ToString("F4")</p>
                            <span class="text-xs font-semibold text-gray-500 dark:text-neutral-500">@code</span><br />
                            <span class="text-xs text-gray-400 dark:text-neutral-600">@name</span>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="text-center py-6">
                <span class="inline-flex justify-center items-center size-[56px] rounded-full border-4 border-red-50 bg-red-100 text-red-800 mx-auto mb-3"><i class="bi bi-wifi-off text-xl"></i></span>
                <p class="text-sm font-semibold text-gray-800 mb-1 dark:text-white">Exchange rates unavailable</p>
                <span class="text-xs text-gray-500 dark:text-neutral-500">Unable to fetch data. Check your connection.</span>
            </div>
        }
    </div>
</div>

<!-- Filter Panel -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-8">
    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-amber-50 text-amber-500 dark:bg-amber-900/20 dark:text-amber-400"><i class="bi bi-funnel text-lg"></i></span>
            <div>
                <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Filter Transactions</h3>
                <span class="text-xs text-gray-500 dark:text-neutral-500">Narrow down results by type, category, or date range</span>
            </div>
        </div>
    </div>
    <div class="p-6">
        <form method="get" class="grid grid-cols-2 lg:grid-cols-5 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">Type</label>
                <select name="filterType" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400">
                    <option value="">All Types</option>
                    <option value="Income" selected="@(filterType == "Income")">Income</option>
                    <option value="Expense" selected="@(filterType == "Expense")">Expense</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">Category</label>
                <input type="text" name="filterCategory" value="@filterCategory" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" placeholder="Search category..." />
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">Start Date</label>
                <input type="date" name="startDate" value="@startDate" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" />
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 dark:text-white">End Date</label>
                <input type="date" name="endDate" value="@endDate" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400" />
            </div>
            <div class="col-span-2 lg:col-span-1">
                <button type="submit" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Transactions Table -->
<div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6 relative overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-[#f4f2ff] text-[#5e4dcd] dark:bg-indigo-900/30 dark:text-indigo-400"><i class="bi bi-list-ul text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Transaction History</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500">Page @Model.PageIndex of @Model.TotalPages (@totalEntries total)</span>
                </div>
            </div>
        </div>
    </div>
    <div class="p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-20 px-6">
                <span class="inline-flex justify-center items-center size-[62px] rounded-full border-4 border-gray-50 bg-gray-100 text-gray-500 mx-auto mb-4 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">
                    <i class="bi bi-journal-x text-2xl"></i>
                </span>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">No Transactions Found</h3>
                <p class="text-sm text-gray-500 dark:text-neutral-400 mb-4">No records match your current filters.</p>
                <a asp-action="Create" class="py-2.5 px-5 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
                    <i class="bi bi-plus-lg"></i> Record Entry
                </a>
            </div>
        }
        else
        {
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100 dark:divide-neutral-800">
                    <thead>
                        <tr>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Date</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Type</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Category</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Description</th>
                            <th scope="col" class="px-6 py-4 text-end text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Amount</th>
                            <th scope="col" class="px-6 py-4 text-start text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Ref #</th>
                            <th scope="col" class="px-6 py-4 text-center text-[11px] font-bold text-gray-500 uppercase tracking-widest dark:text-neutral-500">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-neutral-800/50 transition-colors">
                                <td class="whitespace-nowrap px-6 py-4"><span class="text-sm font-semibold text-gray-800 dark:text-neutral-200">@item.TransactionDate.ToString("MMM dd, yyyy")</span></td>
                                <td class="whitespace-nowrap px-6 py-4">
                                    @if (item.Type == "Income")
                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400"><i class="bi bi-arrow-up-short"></i> Income</span> }
                                    else
                                    { <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400"><i class="bi bi-arrow-down-short"></i> Expense</span> }
                                </td>
                                <td class="whitespace-nowrap px-6 py-4"><span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400">@item.Category</span></td>
                                <td class="px-6 py-4"><span class="text-sm text-gray-500 dark:text-neutral-400">@item.Description</span></td>
                                <td class="whitespace-nowrap px-6 py-4 text-end">
                                    <span class="text-sm font-bold" style="color:@(item.Type == "Income" ? "#16a34a" : "#dc2626");">
                                        @(item.Type == "Income" ? "+" : "−")@item.Amount.ToString("C")
                                    </span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4"><span class="text-xs text-gray-500 dark:text-neutral-500 font-mono">@(item.ReferenceNumber ?? "—")</span></td>
                                <td class="whitespace-nowrap px-6 py-4 text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="py-1.5 px-2.5 inline-flex items-center gap-x-1 text-xs font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden p-4 space-y-4">
                @foreach (var item in Model)
                {
                    <div class="p-4 rounded-xl bg-gray-50 border border-gray-100 dark:bg-neutral-800 dark:border-neutral-700">
                        <div class="flex items-start justify-between mb-3">
                            <div class="min-w-0">
                                <span class="text-xs font-semibold text-gray-400 block mb-1">@item.TransactionDate.ToString("MMM dd, yyyy")</span>
                                <span class="text-sm font-bold text-gray-800 dark:text-white block truncate">@item.Description</span>
                            </div>
                            <div class="shrink-0 ms-2 text-end">
                                <span class="text-sm font-bold block" style="color:@(item.Type == "Income" ? "#16a34a" : "#dc2626");">
                                    @(item.Type == "Income" ? "+" : "−")@item.Amount.ToString("C")
                                </span>
                                @if (item.Type == "Income")
                                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full text-[10px] font-bold bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-400 uppercase tracking-wider">Income</span> }
                                else
                                { <span class="inline-flex items-center gap-x-1 py-0.5 px-2 rounded-full text-[10px] font-bold bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-400 uppercase tracking-wider">Expense</span> }
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between mb-4">
                            <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full text-[10px] font-bold bg-indigo-100 text-indigo-800 dark:bg-indigo-900/40 dark:text-indigo-400 uppercase tracking-wider">@item.Category</span>
                            <span class="text-[10px] font-mono text-gray-500 dark:text-neutral-500">Ref: @(item.ReferenceNumber ?? "—")</span>
                        </div>

                        <a asp-action="Details" asp-route-id="@item.Id" class="w-full py-2 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-bold rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white transition-colors">
                            <i class="bi bi-eye"></i> View Details
                        </a>
                    </div>
                }
            </div>
        }
    </div>
    
    <!-- Pagination -->
    <partial name="_Pagination" model="Model" />
</div>
