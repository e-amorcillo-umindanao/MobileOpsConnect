@model MobileOpsConnect.Models.AccountingEntry

@{
    ViewData["Title"] = "Transaction Details";
    bool isIncome = Model.Type == "Income";
}

<!-- Hero Banner -->
<div class="bg-blue-600 rounded-xl shadow-sm p-6 sm:p-10 mb-6 relative overflow-hidden dark:bg-blue-800">
    <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-white text-gray-800 shadow-sm">
                <i class="bi bi-receipt"></i> Transaction #@Model.Id
            </span>
            <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium @(isIncome ? "bg-green-500/30" : "bg-red-500/30") text-white">
                <i class="bi bi-@(isIncome ? "arrow-up-short" : "arrow-down-short")"></i> @Model.Type
            </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Transaction Details</h1>
        <p class="text-blue-100 text-lg">@Model.Category — @Model.TransactionDate.ToString("MMMM dd, yyyy")</p>
    </div>
    <div class="hidden md:block absolute top-1/2 right-6 -translate-y-1/2 opacity-20 pointer-events-none">
        <i class="bi bi-receipt text-9xl text-white"></i>
    </div>
</div>

<!-- Action Bar -->
<div class="flex justify-start mb-6">
    <a asp-action="Index" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50">
        <i class="bi bi-arrow-left"></i> Back to Ledger
    </a>
</div>

<div class="max-w-2xl mx-auto">
    <!-- Amount Hero -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="p-6 text-center">
            <span class="inline-flex justify-center items-center size-[64px] rounded-xl @(isIncome ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800") mx-auto mb-4">
                <i class="bi bi-@(isIncome ? "arrow-up-circle-fill" : "arrow-down-circle-fill") text-2xl"></i>
            </span>
            <h2 class="text-4xl font-bold mb-2" style="color:@(isIncome ? "#16a34a" : "#dc2626");">
                @(isIncome ? "+" : "−")@Model.Amount.ToString("C")
            </h2>
            <span class="inline-flex items-center gap-x-1 py-1 px-2.5 rounded-full text-xs font-medium @(isIncome ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@Model.Type</span>
        </div>
    </div>

    <!-- Detail Fields -->
    <div class="flex flex-col bg-white border shadow-sm rounded-xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-neutral-700">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-info-circle text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-semibold text-gray-800">Record Information</h3>
                    <span class="text-xs text-gray-500">Full details about this transaction</span>
                </div>
            </div>
        </div>
        <div class="p-6">
            <div class="divide-y divide-gray-200">
                <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-calendar3"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Transaction Date</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.TransactionDate.ToString("MMMM dd, yyyy")</p></div></div>
                <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-tag"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Category</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.Category</p></div></div>
                <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-card-text"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Description</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.Description</p></div></div>
                <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-hash"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Reference #</span><p class="text-sm font-semibold text-gray-800 mb-0">@(Model.ReferenceNumber ?? "N/A")</p></div></div>
                <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-person"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Recorded By</span><p class="text-sm font-semibold text-gray-800 mb-0">@(Model.RecordedBy?.Email ?? "Unknown")</p></div></div>
                <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-clock"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Recorded On</span><p class="text-sm font-semibold text-gray-800 mb-0">@Model.CreatedAt.ToString("MMMM dd, yyyy h:mm tt")</p></div></div>
                @if (Model.PurchaseOrderId != null)
                {
                    <div class="flex items-center py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-link-45deg"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Linked Purchase Order</span><p class="mb-0"><a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.PurchaseOrderId" class="text-sm font-semibold text-blue-600 hover:text-blue-800"><i class="bi bi-box-arrow-up-right me-1"></i> View PO #@Model.PurchaseOrderId</a></p></div></div>
                }
                <div class="flex items-start py-4 gap-x-3"><span class="shrink-0 inline-flex justify-center items-center size-[40px] rounded-lg bg-indigo-100 text-indigo-800"><i class="bi bi-sticky"></i></span><div><span class="text-xs uppercase text-gray-500 font-medium">Notes</span><p class="text-sm text-gray-500 mb-0">@(Model.Notes ?? "No notes provided.")</p></div></div>
            </div>
        </div>
    </div>
</div>
