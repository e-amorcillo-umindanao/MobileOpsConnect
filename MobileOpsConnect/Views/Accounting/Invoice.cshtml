@model MobileOpsConnect.Models.AccountingEntry
@using MobileOpsConnect.Services

@{
    ViewData["Title"] = "Invoice";
    bool isIncome = Model.Type == "Income";
    var invoiceNumber = $"INV-{Model.Id:D6}";
}

<!-- Print-only styles -->
<style>
    @@media print {
        nav, .navbar, .sidebar, footer, .no-print, .breadcrumb-nav { display: none !important; }
        body { background: white !important; }
        .invoice-card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    }
</style>

<!-- Breadcrumb Navigation -->
<div class="mb-6 no-print breadcrumb-nav">
    <a asp-action="Index" class="inline-flex items-center gap-x-2 text-sm font-medium text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors">
        <i class="bi bi-arrow-left"></i> Back to Ledger
    </a>
</div>

<!-- Success Banner -->
@if (TempData["Message"] != null)
{
<div class="mb-6 no-print">
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-xl p-4 dark:bg-emerald-900/20 dark:border-emerald-800 dark:text-emerald-400">
        <div class="flex items-center gap-x-3">
            <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-400">
                <i class="bi bi-check-circle-fill text-lg"></i>
            </span>
            <p class="text-sm font-semibold">@TempData["Message"]</p>
        </div>
    </div>
</div>
}

<!-- Invoice Card -->
<div class="max-w-2xl mx-auto">
    <div class="invoice-card flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6 overflow-hidden">

        <!-- Invoice Header -->
        <div class="px-8 py-6 border-b border-gray-100 dark:border-neutral-800 bg-gradient-to-r from-gray-50 to-white dark:from-neutral-900 dark:to-neutral-900">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">INVOICE</h1>
                    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 mt-1">MobileOps Connect Inc.</p>
                </div>
                <div class="text-right">
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-bold @(isIncome ? "bg-emerald-50 text-emerald-700 border border-emerald-100 dark:bg-emerald-900/30 dark:text-emerald-400" : "bg-rose-50 text-rose-700 border border-rose-100 dark:bg-rose-900/30 dark:text-rose-400") tracking-wide uppercase">
                        <i class="bi bi-@(isIncome ? "arrow-up-short" : "arrow-down-short")"></i> @Model.Type
                    </span>
                    <p class="text-sm font-bold text-gray-900 dark:text-neutral-200 mt-2">@invoiceNumber</p>
                </div>
            </div>
        </div>

        <!-- Invoice Meta -->
        <div class="px-8 py-5 border-b border-gray-100 dark:border-neutral-800">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Date</span>
                    <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mt-0.5">@Model.TransactionDate.ToString("MMM dd, yyyy")</p>
                </div>
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Category</span>
                    <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mt-0.5">@Model.Category</p>
                </div>
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Reference #</span>
                    <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mt-0.5">@(Model.ReferenceNumber ?? "N/A")</p>
                </div>
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Recorded By</span>
                    <p class="text-sm font-semibold text-gray-800 dark:text-neutral-200 mt-0.5">@(Model.RecordedBy?.Email ?? "System")</p>
                </div>
            </div>
        </div>

        <!-- Line Item Table -->
        <div class="px-8 py-5">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 dark:border-neutral-700">
                        <th class="text-left py-3 text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Description</th>
                        <th class="text-right py-3 text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-b border-gray-100 dark:border-neutral-800">
                        <td class="py-4">
                            <p class="font-semibold text-gray-800 dark:text-neutral-200">@Model.Description</p>
                            <p class="text-xs text-gray-400 dark:text-neutral-500 mt-0.5">@Model.Category · @Model.Type</p>
                        </td>
                        <td class="py-4 text-right">
                            <span class="font-bold text-lg @(isIncome ? "text-emerald-600" : "text-rose-600")">
                                ₱@Model.Amount.ToString("N2")
                            </span>
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr>
                        <td class="py-4 text-right font-bold text-gray-900 dark:text-neutral-200 uppercase text-xs tracking-widest">Total</td>
                        <td class="py-4 text-right">
                            <span class="font-bold text-xl @(isIncome ? "text-emerald-600" : "text-rose-600")">
                                ₱@Model.Amount.ToString("N2")
                            </span>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Notes -->
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
        <div class="px-8 py-4 border-t border-gray-100 dark:border-neutral-800 bg-gray-50/50 dark:bg-neutral-800/30">
            <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500">Notes</span>
            <p class="text-sm text-gray-600 dark:text-neutral-400 mt-1">@Model.Notes</p>
        </div>
        }

        <!-- Footer -->
        <div class="px-8 py-4 border-t border-gray-100 dark:border-neutral-800 text-center">
            <div class="flex flex-col sm:flex-row justify-between items-center gap-2">
                <span class="text-xs text-gray-400 dark:text-neutral-500">
                    <i class="bi bi-lock-fill me-1"></i> System-generated document. No signature required.
                </span>
                <span class="text-xs text-gray-400 dark:text-neutral-500">
                    <i class="bi bi-clock me-1"></i> Issued: @Model.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                </span>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-3 no-print">
        <button onclick="window.print();" class="flex-1 py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-[#0d0d0d] bg-[#0d0d0d] text-white hover:bg-[#1a1a1a] transition-colors">
            <i class="bi bi-printer"></i> Print Invoice
        </button>
        <a asp-action="Index" class="flex-1 py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-gray-200 bg-white text-gray-800 hover:bg-gray-50 dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800 transition-colors">
            <i class="bi bi-arrow-left"></i> Back to Ledger
        </a>
    </div>
</div>
