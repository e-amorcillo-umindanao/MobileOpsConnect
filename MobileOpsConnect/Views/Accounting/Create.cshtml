@model MobileOpsConnect.Models.AccountingEntry
@using MobileOpsConnect.Services

@{
    ViewData["Title"] = "New Transaction";
}

<!-- Breadcrumb Navigation -->
<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-gray-400 hover:text-gray-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors">
        ← Back to Ledger
    </a>
</div>

<!-- Hero Banner -->
<div class="mb-8 mt-2 sm:mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-400 tracking-wide uppercase">
            <span class="size-1.5 inline-block bg-emerald-500 rounded-full"></span>
            New Record
        </span>
    </div>
    <h1 class="text-3xl sm:text-[2.5rem] font-bold text-gray-900 dark:text-white mb-2 tracking-tight">Record Transaction</h1>
    <p class="text-gray-500 text-[15px] dark:text-neutral-400 font-medium">Add a new income or expense entry to the accounting ledger.</p>
</div>

<!-- Form Card -->
<div class="max-w-2xl mx-auto">
    <div class="flex flex-col bg-white border border-gray-100 shadow-sm rounded-2xl dark:bg-neutral-900 dark:border-neutral-800 mb-6">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-neutral-800">
            <div class="flex items-center gap-x-3">
                <span class="inline-flex justify-center items-center size-[38px] rounded-lg bg-[#f4f2ff] text-[#5e4dcd] dark:bg-indigo-900/30 dark:text-indigo-400"><i class="bi bi-pencil-square text-lg"></i></span>
                <div>
                    <h3 class="text-sm font-bold text-gray-900 dark:text-neutral-200">Transaction Details</h3>
                    <span class="text-xs text-gray-500 dark:text-neutral-500">Fill in all required fields below</span>
                </div>
            </div>
        </div>
        <div class="p-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
                <div class="grid gap-y-5">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="TransactionDate" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-calendar3 me-1 text-indigo-500"></i> Date</label>
                            <input asp-for="TransactionDate" type="date" value="@PhilippineTime.Now.ToString("yyyy-MM-dd")" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" />
                            <span asp-validation-for="TransactionDate" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="Type" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-tag me-1 text-cyan-500"></i> Type</label>
                            <select asp-for="Type" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500">
                                <option value="Expense">Expense</option>
                                <option value="Income">Income</option>
                            </select>
                            <span asp-validation-for="Type" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="Category" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-bookmark me-1 text-purple-500"></i> Category</label>
                        <input asp-for="Category" list="categoryList" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Select or type a category..." />
                        <datalist id="categoryList">
                            <option value="Purchase Order"></option>
                            <option value="Payroll"></option>
                            <option value="Sales Revenue"></option>
                            <option value="Utilities"></option>
                            <option value="Maintenance"></option>
                            <option value="Office Supplies"></option>
                        </datalist>
                        <span asp-validation-for="Category" class="text-red-500 text-xs"></span>
                    </div>
                    <div>
                        <label asp-for="Description" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-card-text me-1 text-amber-500"></i> Description</label>
                        <input asp-for="Description" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Short description of the transaction" />
                        <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
                    </div>
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Amount" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-cash me-1 text-green-500"></i> Amount</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 start-0 flex items-center pointer-events-none z-20 ps-4"><span class="text-sm text-gray-500 font-semibold">₱</span></div>
                                <input id="amountDisplay" type="text" inputmode="numeric" class="py-3 px-4 ps-8 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="0" autocomplete="off" />
                                <input type="hidden" name="Amount" id="amountValue" value="0" />
                            </div>
                            <span asp-validation-for="Amount" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="ReferenceNumber" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-hash me-1 text-gray-500"></i> Reference #</label>
                            <input asp-for="ReferenceNumber" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Invoice #, Receipt #, etc." />
                            <span asp-validation-for="ReferenceNumber" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="Notes" class="block text-sm font-medium mb-2 dark:text-white"><i class="bi bi-sticky me-1 text-amber-500"></i> Notes</label>
                        <textarea asp-for="Notes" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-blue-500 focus:ring-blue-500" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-red-500 text-xs"></span>
                    </div>
                    <button type="submit" class="btn-moc-primary w-full inline-flex justify-center items-center gap-x-2 text-sm font-semibold">
                        <i class="bi bi-save"></i> Save Transaction
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    (function () {
        const display = document.getElementById('amountDisplay');
        const hidden  = document.getElementById('amountValue');
        if (!display || !hidden) return;

        display.addEventListener('input', function () {
            // Strip everything except digits
            const raw = this.value.replace(/\D/g, '');
            const num = parseInt(raw, 10) || 0;

            // Update hidden field with raw integer
            hidden.value = num;

            // Format display with commas
            this.value = num > 0 ? num.toLocaleString('en-PH') : '';
        });

        // Prevent paste of non-numeric content
        display.addEventListener('paste', function (e) {
            e.preventDefault();
            const text = (e.clipboardData || window.clipboardData).getData('text');
            const raw = text.replace(/\D/g, '');
            const num = parseInt(raw, 10) || 0;
            hidden.value = num;
            this.value = num > 0 ? num.toLocaleString('en-PH') : '';
        });
    })();
    </script>
}
